+      assert.equal(rows[0]!.deferReason, 'other');
+      assert.equal(rows[0]!.deferNote, reason);
+    });
+  });
+
+  // ── 11: pre-seal tick fail-loud (D8) ────────────────────────────────
+
+  describe('pre-seal tick fail-loud', () => {
