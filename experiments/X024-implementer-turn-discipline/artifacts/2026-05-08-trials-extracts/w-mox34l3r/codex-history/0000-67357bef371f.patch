+/**
+ * `reckoner.tick` — periodic-tick relay for the Reckoner.
+ *
+ * Replaces the per-writ-update CDC observer with a global candidate-set
+ * evaluation surface. The relay fires from a Clockworks standing order
+ * (`@every 60s` shipped from this apparatus's `supportKit.standingOrders`)
+ * and walks every currently-held petition through the configured
+ * scheduler in one batch:
+ *
+ *   1. Resolve the active scheduler. Pre-seal — `phase:started` has not
+ *      fired and the active scheduler reference is undefined — fail-loud
+ *      throws (D8). Production never trips this; tests get a deterministic
+ *      loud signal.
+ *   2. Re-read and validate `reckoner.schedulerConfig` (D17/D18). On
+ *      `validateConfig` throw, log fail-loud and skip the entire tick.
+ *   3. Query the held-writ candidate set (writs in the literal `'new'`
+ *      phase carrying `ext.reckoner`).
+ *   4. Apply source/disabled gates inline. Each writ failing a gate
+ *      produces a Reckonings decline row plus a transition to the
+ *      cancelled target. The unregistered-strict path uses the existing
+ *      `'source_unregistered'` reason; the disabled-source path uses
+ *      `'source_banned'` (D2).
+ *   5. Filter the remaining candidates against the
+ *      `(writId, writUpdatedAt)` dedupe lookup *before* building
+ *      `SchedulerInput` (D7). Already-considered writs never reach the
+ *      scheduler.
+ *   6. Empty candidate set → early-return (D10). No row, no error, no
+ *      scheduler call.
+ *   7. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 capacity stub. Call `evaluate` inside a try/catch.
+ *      On throw, log fail-loud and skip the entire tick (no rows).
+ *   8. Decision validation: filter-and-warn on stranger writIds (apply
+ *      only in-scope decisions). Fail-loud-skip the entire tick on any
+ *      writId carrying more than one decision (D9).
+ *   9. Apply each decision: approve → transition to active target via
+ *      `resolveActiveTargetPhase`, decline → transition to cancelled
+ *      target, defer → no transition. Append one Reckonings row per
+ *      writ considered. Defer rows use `deferReason: 'other'` with the
+ *      decision's reason in `deferNote` (D3).
+ *  10. Stamp `tickEventId` from the triggering Clockworks event id when
+ *      present; omit when absent (e.g. the test path drives the helper
+ *      directly with `null`) (D6).
+ *
+ * The relay file pattern follows `summon-relay.ts` and `decline-relay.ts`:
+ * a sibling-file factory `createTickRelay()` builds the
+ * `RelayDefinition`, and a pure handler-body helper (`runTickHandler`)
+ * accepts a dependency context object so unit tests can drive the body
+ * without booting Clockworks.
+ *
+ * See: docs/architecture/apparatus/reckoner.md, the brief at
+ * `commission/x024-rig-moj12h4o`, and the originating registry-side
+ * commission `w-moiy7bmo` for the overall periodic-tick contract.
+ */
+
+import type {
+  GuildEvent,
+  RelayDefinition,
+} from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+import type {
+  Book,
+  ReadOnlyBook,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/**
+ * Plugin id that scopes `writ.ext['reckoner']` reads. Hardcoded literal
+ * — the Reckoner's `RECKONER_PLUGIN_ID` constant. Duplicated here so
+ * the tick module does not pull a private symbol out of `reckoner.ts`.
+ */
+const RECKONER_EXT_KEY = 'reckoner';
+
+/**
+ * Public canonical name of the tick relay. Operators reference this
+ * value from the kit-contributed standing order; tests assert against
+ * it. Hardcoded constant — the literal *is* the contract.
+ */
+export const TICK_RELAY_NAME = 'reckoner.tick';
+
+// ── Dependency-injection context ─────────────────────────────────────
+
+/**
+ * Aggregated dependency-gate outcome for one held petition. Mirrors the
+ * shape produced by `evaluateDependencyGate` in `reckoner.ts`.
+ */
+export type DependencyOutcome =
+  | { kind: 'proceed' }
+  | { kind: 'defer-pending'; gatingIds: string[] }
+  | { kind: 'defer-failed'; failedIds: string[] };
+
+/**
+ * Closure-supplied dependencies the tick handler needs. The Reckoner
+ * builds this once during `start()` and passes it into both the relay
+ * factory and the test-only `runTick` hook. Keeping the context shape
+ * narrow makes the unit tests in `reckoner-tick.test.ts` straightforward
+ * — they assemble the same shape from stubs and call `runTickHandler`
+ * directly.
+ */
+export interface TickHandlerContext {
+  /** Live Clerk handle. Used for transitions and writ-type config. */
+  clerk: ClerkApi;
+  /** Live Stacks handle. Used to read the writs book. */
+  stacks: StacksApi;
+  /** Live writeable Reckonings book handle. */
+  reckoningsBook: Book<ReckoningDoc>;
+  /**
+   * Accessor for the resolved active scheduler. Returns `undefined`
+   * pre-seal so the handler can fail-loud (D8).
+   */
+  getActiveScheduler(): Scheduler | undefined;
+  /**
+   * Accessor for the live `reckoner` block read off `guild.json` —
+   * applies validation and defaults. Throws fail-loud on type
+   * mismatches.
+   */
+  resolveConfig(): { enforceRegistration: boolean; disabledSources: string[] };
+  /**
+   * Accessor for the live `reckoner.schedulerConfig` slot. Returns
+   * `undefined` when the slot is absent. The handler runs the active
+   * scheduler's `validateConfig` against this value before passing it
+   * into `evaluate`.
+   */
+  resolveSchedulerConfig(): unknown;
+  /**
+   * Whether `source` is currently in the kit-static petitioner registry.
+   * The closure version of `ReckonerApi.isSourceRegistered`.
+   */
+  isSourceRegistered(source: string): boolean;
+  /**
+   * Compute the type-aware target active phase for a writ at transition
+   * time. Throws fail-loud on missing config, ambiguity, or no outbound
+   * active candidate.
+   */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /**
+   * Per-writ dedupe lookup: returns `true` when a non-deferred row
+   * already exists for the `(writId, writUpdatedAt)` pair.
+   */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /**
+   * Walk a held writ's outbound `depends-on` links and aggregate the
+   * per-target classifications. Returns a `DependencyOutcome` describing
+   * whether the writ may proceed, must defer pending an unresolved
+   * dependency, or must defer because at least one dependency is
+   * terminally failed. Throws fail-loud when a target's writ-type
+   * config is missing.
+   */
+  evaluateDependencyGate(writId: string): Promise<DependencyOutcome>;
+  /**
+   * Format the `deferNote` text for a dependency-defer row.
+   */
+  buildDependencyDeferNote(
+    kind: 'defer-pending' | 'defer-failed',
+    ids: readonly string[],
+  ): string;
+  /**
+   * Look up the most-recent deferred Reckonings row for `writId` so
+   * the tick can suppress no-op row writes when the dep-gate outcome
+   * shape is unchanged.
+   */
+  findLastDeferredRow(
+    book: Book<ReckoningDoc>,
+    writId: string,
+  ): Promise<ReckoningDoc | undefined>;
+  /**
+   * Build one Reckonings row from in-flight consideration state.
+   * Mirrors the `buildReckoningRow` helper in `reckoner.ts` byte-for-
+   * byte; passing it through the context object lets the tick handler
+   * stay independent of the apparatus closure's private signatures.
+   */
+  buildReckoningRow(params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    outcome: 'accepted' | 'declined' | 'deferred';
+    declineReason?: ReckoningDoc['declineReason'];
+    remediationHint?: string;
+    deferReason?: ReckoningDoc['deferReason'];
+    deferNote?: string;
+    weight?: number;
+    tickEventId?: string;
+  }): ReckoningDoc;
+}
+
+// ── Pure handler body ────────────────────────────────────────────────
+
+/**
+ * The tick handler's pure body, exported so unit tests can drive it
+ * directly without standing up Clockworks. The relay factory wraps
+ * this function and supplies the closure-bound `TickHandlerContext`.
+ *
+ * @param event   The triggering Clockworks event, or `null` when a
+ *                test drives the handler directly. Used only to stamp
+ *                `tickEventId` onto the resulting Reckonings rows
+ *                (D6 — present-when-event-id-present, otherwise omitted).
+ * @param context Closure-supplied dependencies (see `TickHandlerContext`).
+ */
+export async function runTickHandler(
+  event: GuildEvent | null,
+  context: TickHandlerContext,
+): Promise<void> {
+  // 1. Pre-seal guard — D8 patron override. Fail-loud on a tick fired
+  //    before `phase:started` resolved the active scheduler. Production
+  //    never trips this; tests get a deterministic signal.
+  const activeScheduler = context.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  const tickEventId = event?.id;
+  const now = new Date();
+
+  // 2. Re-read and validate `reckoner.schedulerConfig` (D17/D18). On
+  //    `validateConfig` throw, log fail-loud and skip the entire tick.
+  let validatedConfig: unknown = context.resolveSchedulerConfig();
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(validatedConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // 3. Query the held-writ candidate set: a direct read of
+  //    `clerk/writs` filtered to the literal `'new'` phase. The
+  //    brief explicitly carries this shape forward — the type-
+  //    agnostic generalization (iterating Clerk's writ-type registry
+  //    for non-`'new'` initial phases) is observed and lifted as a
+  //    separate concern.
+  const writsBook: ReadOnlyBook<WritDoc> = context.stacks.readBook<WritDoc>(
+    'clerk',
+    'writs',
+  );
+  const allHeld = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+
+  // Cheap pre-filter for writs lacking a Reckoner ext slot.
+  const withExt: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const writ of allHeld) {
+    const ext = writ.ext?.[RECKONER_EXT_KEY] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    withExt.push({ writ, ext });
+  }
+
+  // 4. Apply source/disabled gates inline. Each writ failing a gate
+  //    produces a Reckonings decline row plus a transition to its
+  //    cancelled target. The disabled-source row uses `'source_banned'`
+  //    + the source name in `remediationHint` (D2); the unregistered-
+  //    strict row preserves the existing `'source_unregistered'`
+  //    reason and resolution-string format.
+  const config = context.resolveConfig();
+  const survivors: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const candidate of withExt) {
+    const { writ, ext } = candidate;
+
+    // Disabled-source gate.
+    if (config.disabledSources.includes(ext.source)) {
+      await applyDisabledSourceDecline({
+        clerk: context.clerk,
+        reckoningsBook: context.reckoningsBook,
+        buildReckoningRow: context.buildReckoningRow,
+        alreadyConsidered: context.alreadyConsidered,
+        writ,
+        ext,
+        now,
+        tickEventId,
+      });
+      continue;
+    }
+
+    // Unregistered-strict gate.
+    const isRegistered = context.isSourceRegistered(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      await applyUnregisteredStrictDecline({
+        clerk: context.clerk,
+        reckoningsBook: context.reckoningsBook,
+        buildReckoningRow: context.buildReckoningRow,
+        alreadyConsidered: context.alreadyConsidered,
+        writ,
+        ext,
+        now,
+        tickEventId,
+      });
+      continue;
+    }
+
+    survivors.push(candidate);
+  }
+
+  // 4b. Dependency-aware defer gate. The brief carries forward the
+  //     existing rule sequence: every held petition with one or more
+  //     outbound `depends-on` links whose targets are not all cleared
+  //     defers. The dep gate runs every tick (the no-op-row
+  //     suppression below keeps the deferred row out of the heartbeat
+  //     duplicate path).
+  const proceed: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const candidate of survivors) {
+    const { writ, ext } = candidate;
+    let depOutcome: DependencyOutcome;
+    try {
+      depOutcome = await context.evaluateDependencyGate(writ.id);
+    } catch (err) {
+      // The classifier fail-loud throws on missing/unknown writ-type
+      // config. Surface but do not crash the entire tick — leave the
+      // writ in `new` and continue with the rest of the candidate set.
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: dependency gate threw for writ "${writ.id}" — leaving in new without a row. ${msg}`,
+      );
+      continue;
+    }
+    if (depOutcome.kind === 'proceed') {
+      proceed.push(candidate);
+      continue;
+    }
+    const reason: ReckoningDoc['deferReason'] =
+      depOutcome.kind === 'defer-failed' ? 'dependency_failed' : 'dependency_pending';
+    const ids =
+      depOutcome.kind === 'defer-failed'
+        ? depOutcome.failedIds
+        : depOutcome.gatingIds;
+    const deferNote = context.buildDependencyDeferNote(depOutcome.kind, ids);
+
+    // No-op-row suppression: re-evaluation at the same outcome shape
+    // produces no row. A new row appears only when a dep cleared, a
+    // new dep failed, or the dep set's classification mix changed.
+    const last = await context.findLastDeferredRow(context.reckoningsBook, writ.id);
+    if (last && last.deferReason === reason && last.deferNote === deferNote) {
+      continue;
+    }
