+  // 5. Dedupe before building SchedulerInput (D7). Already-considered
+  //    writs never reach the scheduler.
+  const candidates: WritDoc[] = [];
+  const candidateExtById = new Map<string, ReckonerExt>();
+  for (const { writ, ext } of proceed) {
+    const seen = await context.alreadyConsidered(
+      context.reckoningsBook,
+      writ.id,
+      writ.updatedAt,
+    );
+    if (seen) continue;
+    candidates.push(writ);
+    candidateExtById.set(writ.id, ext);
+  }
+
+  // 6. Empty candidate set → early-return (D10). No row, no error, no
+  //    scheduler call.
+  if (candidates.length === 0) return;
+
+  // 7. Build one SchedulerInput and call evaluate inside a try/catch.
+  //    On throw, log fail-loud and skip the entire tick (no rows).
+  let decisions: readonly SchedulerDecision[];
+  try {
+    decisions = await activeScheduler.evaluate({
+      candidates,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 8. Decision validation: filter-and-warn on stranger writIds; fail-
+  //    loud-skip the entire tick on multi-decision-per-writ (D9).
+  const candidateIds = new Set<string>(candidates.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate; skipping the entire tick.`,
+      );
+      return;
+    }
+  }
+
+  // 9. Apply each decision and append rows. Per-writ try/catch so a
+  //    single transition failure does not poison the rest of the
+  //    candidate set's processing.
+  for (const writ of candidates) {
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) {
+      // No decision for this candidate — defer-equivalent. No row, no
+      // transition. The brief leaves "no decision" silent: only an
+      // explicit `defer` outcome writes a row.
+      continue;
+    }
+    const ext = candidateExtById.get(writ.id);
+    if (!ext) continue; // unreachable; populated alongside candidates.
+
+    if (decision.outcome === 'defer') {
+      // D3: write a deferred row carrying `'other'` + the decision's
+      // reason in `deferNote`. No transition.
+      const row = context.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await context.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await context.clerk.transition(writ.id, 'cancelled' as WritPhase, {
+          resolution,
+        });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = context.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await context.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'approve') {
+      let target: string;
+      try {
+        target = context.resolveActiveTargetPhase(writ);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+        );
+        continue;
+      }
+      try {
+        await context.clerk.transition(writ.id, target as WritPhase, {});
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+        );
+        continue;
+      }
+      const row = context.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'accepted',
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await context.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unknown outcome — defensive. The scheduler interface declares an
+    // exhaustive enum; reaching this branch indicates a misbehaving
+    // scheduler implementation (the type system would have prevented
+    // this in well-typed callers).
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+  }
+}
+
+// ── Gate-decline helpers ─────────────────────────────────────────────
+
+/**
+ * Apply the unregistered-strict decline path: transition the writ to
+ * its cancelled target and append a `source_unregistered` Reckonings
+ * row carrying the source name in `remediationHint`. The resolution
+ * string format mirrors the pre-existing per-call shape byte-for-byte
+ * so operator log-greps remain stable.
+ */
+async function applyUnregisteredStrictDecline(args: {
+  clerk: ClerkApi;
+  reckoningsBook: Book<ReckoningDoc>;
+  buildReckoningRow: TickHandlerContext['buildReckoningRow'];
+  alreadyConsidered: TickHandlerContext['alreadyConsidered'];
+  writ: WritDoc;
+  ext: ReckonerExt;
+  now: Date;
+  tickEventId: string | undefined;
+}): Promise<void> {
+  const { clerk, reckoningsBook, buildReckoningRow, alreadyConsidered, writ, ext, now, tickEventId } = args;
+
+  if (await alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+    return;
+  }
+  const resolution =
+    `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+  try {
+    await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (decline path): ${msg}`,
+    );
+    return;
+  }
+  const row = buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason: 'source_unregistered',
+    remediationHint: ext.source,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (decline path): ${msg}`,
+    );
+  }
+}
+
+/**
+ * Apply the disabled-source decline path: transition the writ to its
+ * cancelled target and append a `source_banned` Reckonings row carrying
+ * the source name in `remediationHint` (D2). The resolution-string
+ * template parallels the unregistered-strict shape but names the
+ * disabled-source path so operators can grep the two cases apart.
+ */
+async function applyDisabledSourceDecline(args: {
+  clerk: ClerkApi;
+  reckoningsBook: Book<ReckoningDoc>;
+  buildReckoningRow: TickHandlerContext['buildReckoningRow'];
+  alreadyConsidered: TickHandlerContext['alreadyConsidered'];
+  writ: WritDoc;
+  ext: ReckonerExt;
+  now: Date;
+  tickEventId: string | undefined;
+}): Promise<void> {
+  const { clerk, reckoningsBook, buildReckoningRow, alreadyConsidered, writ, ext, now, tickEventId } = args;
+
+  if (await alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+    return;
+  }
+  const resolution =
+    `[reckoner] declined: source '${ext.source}' is in reckoner.disabledSources.`;
+  try {
+    await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (disabled-source path): ${msg}`,
+    );
+    return;
+  }
+  const row = buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason: 'source_banned',
+    remediationHint: ext.source,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source path): ${msg}`,
+    );
+  }
+}
+
+// ── Relay factory ────────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. Wired into the apparatus's
+ * `supportKit.relays`; the matching kit-contributed standing order
+ * (`@every 60s`, `run: 'reckoner.tick'`) is wired alongside under
+ * `supportKit.standingOrders`.
+ *
+ * The factory takes the closure-supplied `TickHandlerContext`. The
+ * apparatus builds the context inside `start()` once Clerk, Stacks,
+ * the Reckonings book handle, and the seal-time-resolved active
+ * scheduler accessor are all available.
+ */
+export function createTickRelay(context: TickHandlerContext): RelayDefinition {
+  return relay({
+    name: TICK_RELAY_NAME,
+    description:
+      'Periodic-tick evaluation surface for the Reckoner: walks every held petition through the configured scheduler in one batch per fire.',
+    handler: async (event, _ctx) => {
+      await runTickHandler(event, context);
+    },
+  });
+}
