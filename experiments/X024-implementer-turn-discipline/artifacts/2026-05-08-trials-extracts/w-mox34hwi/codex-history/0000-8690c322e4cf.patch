+/**
+ * Reckoner tick handler tests.
+ *
+ * Covers the behavioral matrix the periodic-tick commission
+ * enumerates in its Acceptance Signal:
+ *
+ *   1. empty-candidate ticks — no rows, no errors.
+ *   2. first tick after start picks up pre-existing held writs that
+ *      petitioned before the apparatus was driving ticks.
+ *   3. evaluate-throw isolation — apparatus stays up, no rows
+ *      written.
+ *   4. disabled-source mid-flight produces a decline+cancel pair
+ *      (`declineReason: 'source_banned'`).
+ *   5. repeated-tick idempotency — re-running runTick at unchanged
+ *      writUpdatedAt produces no duplicate rows.
+ *   6. type-aware target-phase resolution (mandate → `open`; custom
+ *      type → its registered active state).
+ *   7. withdrawal-mid-flight — writs cancelled before the next tick
+ *      produce no row at all.
+ *   8. defer outcome (scheduler-emitted) writes a deferred row with
+ *      `deferReason: 'other'` and the decision's reason in
+ *      `deferNote`; no transition.
+ *   9. pre-seal tick throws fail-loud.
+ *
+ * The fixture mirrors the scaffolding from `reckoner-depends-on.test.ts`
+ * and the (replaced) CDC-test fixture: real Stacks + Clerk + Reckoner
+ * against MemoryBackend, with explicit book pre-creation. Tests drive
+ * the tick handler through `hooks.runTick(event?)` so the per-fire
+ * sequence runs without booting Clockworks.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /**
+   * Re-fire `phase:started` against the registered handlers. Tests
+   * call this manually to drive the seal step that production gets
+   * from Arbor's lifecycle.
+   */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  /**
+   * Additional `schedulers` kit contributions visible to the
+   * Reckoner's `start()`, on top of the built-in
+   * `reckoner.always-approve` instance the apparatus contributes
+   * from its own supportKit.
+   */
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  /** When true, do not include the built-in always-approve scheduler. */
+  omitDefaultScheduler?: boolean;
+  /** When true, do not fire phase:started after start (pre-seal tests). */
+  skipPhaseStarted?: boolean;
+  config?: ReckonerConfig | undefined;
+  /**
+   * Optional writ types to register on the Clerk before the Reckoner
+   * starts. Used to test type-aware target-phase resolution against a
+   * non-mandate type.
+   */
+  writTypes?: WritTypeConfig[];
+  /**
+   * When set, callers can pre-seed writs into the writs book before
+   * the Reckoner's `start()` runs — used to exercise the first-tick
+   * path picking up pre-existing held writs.
+   */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the Clerk needs — Stacks' Wire phase would
+  // do this in production from the supportKit declarations.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler): void {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  // ── Stacks ────────────────────────────────────────────────────────
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // ── Clerk ─────────────────────────────────────────────────────────
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  // Register optional writ types before the Reckoner starts so the
+  // type config is visible during tick dispatch.
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  // Optional pre-start seed (exercises the first-tick path).
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  // ── Reckoner ──────────────────────────────────────────────────────
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [];
+  if (!opts.omitDefaultScheduler) {
+    schedulerKitEntries.push({
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    });
+  }
+  for (const entry of opts.schedulerKits ?? []) {
+    schedulerKitEntries.push({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    });
+  }
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+/** Produce a fully-typed scheduler from a partial. */
+function makeScheduler(
+  partial: Partial<Scheduler> & Pick<Scheduler, 'id'>,
+): Scheduler {
+  return {
+    description: 'test scheduler',
+    async evaluate(): Promise<readonly SchedulerDecision[]> {
+      return [];
+    },
+    ...partial,
+  };
+}
+
+/** Synthetic GuildEvent stand-in for tests asserting tickEventId stamping. */
+function syntheticTickEvent(id: string = 'e-test-tick-1'): GuildEvent {
+  return {
+    id,
+    name: 'clockworks.timer',
+    payload: null,
+    emitter: 'clockworks',
+    firedAt: new Date().toISOString(),
+  };
+}
+
+const VISION_KEEPER_KIT = {
+  pluginId: 'vision-keeper',
+  value: [{ source: 'vision-keeper.snapshot', description: 'snapshots' }],
+};
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => {
+    clearGuild();
+  });
+
+  // ── 1: empty-candidate tick ────────────────────────────────────────
+
+  describe('empty-candidate tick', () => {
+    it('writes no rows and throws no errors when there are no held petitions', async () => {
+      const fix = await buildFixture({ petitionerKits: [VISION_KEEPER_KIT] });
+      // No petitions posted — fire a tick anyway.
+      await fix.hooks.runTick();
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0, 'empty-candidate tick produces no rows');
+    });
+
+    it('writes no rows when held writs exist but lack the reckoner ext slot', async () => {
+      const fix = await buildFixture({ petitionerKits: [] });
+      // Post a bare writ without ext.reckoner — the tick must skip it.
+      await fix.clerk.post({ title: 't', body: 'b' });
+      await fix.hooks.runTick();
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0);
+    });
+  });
+
+  // ── 2: first tick picks up pre-existing held writs ────────────────
+
+  describe('first tick after start', () => {
+    it('processes held petitions seeded before the apparatus started', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_KIT],
+        async preStart({ clerk }) {
+          // Seed a writ + ext before the Reckoner starts. Without CDC
+          // there's nothing to observe; the writ sits in `new` until
+          // the first tick runs.
+          const w = await clerk.post({ title: 'pre-seeded', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'vision-keeper.snapshot',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // The fixture fired phase:started, but no tick fires automatically
+      // any more — the operator's standing order would do that in
+      // production. Drive a tick by hand.
+      const before = await fix.clerk.list({ limit: 100 });
+      assert.equal(before.length, 1);
+      assert.equal(before[0]!.phase, 'new', 'pre-seeded writ stays in new pre-tick');
+
+      await fix.hooks.runTick();
+
+      const after = await fix.clerk.list({ limit: 100 });
+      assert.equal(
+        after[0]!.phase,
+        'open',
+        'first tick auto-approves the pre-seeded writ',
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', after[0]!.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ────────────────────────────────────
+
+  describe('evaluate-throw isolation', () => {
