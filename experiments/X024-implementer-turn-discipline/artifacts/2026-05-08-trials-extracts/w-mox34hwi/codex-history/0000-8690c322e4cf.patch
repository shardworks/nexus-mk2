+/**
+ * `reckoner.tick` — periodic-tick relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` and bound to the
+ * apparatus's own kit-contributed standing order:
+ *
+ *     { schedule: '@every 60s', run: 'reckoner.tick' }
+ *
+ * The tick is the canonical (and only) entry into the Reckoner's
+ * scheduler-evaluation path. On each fire it queries every held
+ * petition (initial-phase writs carrying `ext.reckoner`) in one batch,
+ * applies the source / disabled / dependency gates inline, hands the
+ * surviving candidate set to the active scheduler in a single
+ * `evaluate()` call, and applies each decision (approve → transition
+ * to active target + accepted row, decline → transition to cancelled
+ * + declined row, defer → no transition + deferred row).
+ *
+ * The CDC-driven per-writ evaluation surface that v0 shipped is gone —
+ * the global candidate-set view is what schedulers beyond v0
+ * (priority-walk, capacity-aware) need. The visible cost is held-
+ * petition latency (≤ 60s instead of milliseconds after `setWritExt`).
+ *
+ * Source-file layout follows the established stdlib-relay pattern:
+ * `summon-relay.ts` and `decline-relay.ts` are the templates. The pure
+ * `runTick` helper is exported alongside the `relay({ … })` factory so
+ * unit tests can drive the handler body directly with a synthetic
+ * dependency context — boot-Clockworks is reserved for the integration
+ * test only.
+ *
+ * See: docs/architecture/apparatus/reckoner.md (per-tick semantics);
+ * docs/architecture/reckonings-book.md (`tickEventId` rule);
+ * docs/architecture/petitioner-registration.md (rule sequence).
+ */
+
+import type { GuildEvent, RelayDefinition } from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  Book,
+  ReadOnlyBook,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+// ── Public relay name ───────────────────────────────────────────────
+
+/**
+ * The relay name registered with the Clockworks (D1). Hardcoded
+ * literal so that the kit-contributed standing order's `run:` field
+ * and any operator-authored standing orders can refer to the same
+ * key. The dotted form mirrors the Reckoner's other contributed-id
+ * grammars (scheduler ids, petitioner sources).
+ */
+export const RECKONER_TICK_RELAY = 'reckoner.tick';
+
+/**
+ * Plugin id stamped on `writ.ext['reckoner']`. Hardcoded literal —
+ * the same constant the apparatus core uses; replicated here so the
+ * tick handler does not have to reach back into `reckoner.ts` for a
+ * one-line constant.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+// ── Resolved-config shape (mirror of the apparatus's accessor) ──────
+
+/**
+ * Concrete shape returned by the apparatus's `resolveConfig` accessor.
+ * Mirrored verbatim here so the handler context can pass it without
+ * coupling the tick to the apparatus's internal type alias.
+ */
+export interface ResolvedReckonerConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+// ── Dependency-gate outcome (mirror of the apparatus's classifier) ──
+
+/**
+ * Aggregated dependency-gate outcome for one held petition. The
+ * apparatus's `evaluateDependencyGate` produces this; the tick
+ * handler maps it onto a deferred row (D3 of the dependency-aware-
+ * consideration commission) when not `proceed`.
+ */
+export type DependencyOutcome =
+  | { kind: 'proceed' }
+  | { kind: 'defer-pending'; gatingIds: string[] }
+  | { kind: 'defer-failed'; failedIds: string[] };
+
+// ── Dependency-injected context the tick handler needs ──────────────
+
+/**
+ * Dependency surface the tick handler reads. Constructed inside the
+ * apparatus closure so the handler can reach the registry,
+ * `activeScheduler`, the config resolvers, and the row-writer
+ * helpers without any of those being module-level state. Tests build
+ * a synthetic context to drive the handler in isolation.
+ *
+ * Most fields are accessor functions (lazy) rather than values —
+ * `activeScheduler`, `clerk`, `stacks`, and `reckoningsBook` are all
+ * populated during the apparatus's `start()` / `phase:started`
+ * sequence and may be `undefined` at the moment the relay factory is
+ * invoked. The handler resolves them on every fire.
+ */
+export interface TickHandlerContext {
+  /** Resolve the current Clerk handle. */
+  getClerk(): ClerkApi;
+  /** Resolve the current Stacks handle (set in `start()`). */
+  getStacks(): StacksApi | undefined;
+  /** Resolve the Reckonings book handle (set in `start()`). */
+  getReckoningsBook(): Book<ReckoningDoc> | undefined;
+  /** Test for source-id presence in the kit-static petitioner registry. */
+  isSourceRegistered(source: string): boolean;
+  /**
+   * Resolve the active scheduler instance. Returns `undefined` until
+   * the apparatus's `phase:started` handler runs and seals the
+   * registry. The tick's pre-seal guard (D8) treats `undefined` as
+   * fail-loud — production never trips it; tests asserting the throw
+   * drive the handler before firing `phase:started`.
+   */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Re-read + validate the `reckoner` config block per fire (D17/D20). */
+  resolveConfig(): ResolvedReckonerConfig;
+  /** Re-read the `reckoner.schedulerConfig` slot per fire (D17). */
+  resolveSchedulerConfig(): unknown;
+  /** Type-aware target-phase resolution shared with the per-call path. */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /** Run the dependency-aware classifier against one held writ. */
+  evaluateDependencyGate(writId: string): Promise<DependencyOutcome>;
+  /** Format a deterministic `deferNote` from a dependency outcome. */
+  buildDependencyDeferNote(
+    kind: 'defer-pending' | 'defer-failed',
+    ids: readonly string[],
+  ): string;
+  /** Idempotency lookup against the dedupe identity `(writId, writUpdatedAt)`. */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /** Most-recent deferred row for a writ, or `undefined`. */
+  findLastDeferredRow(
+    book: Book<ReckoningDoc>,
+    writId: string,
+  ): Promise<ReckoningDoc | undefined>;
+  /** Build a Reckonings row from the in-flight consideration state. */
+  buildReckoningRow(params: BuildReckoningRowParams): ReckoningDoc;
+}
+
+/**
+ * Parameter shape for the apparatus-side `buildReckoningRow` helper.
+ * Mirrors the helper's call signature byte-for-byte so the handler
+ * passes a single typed object across the apparatus boundary.
+ */
+export interface BuildReckoningRowParams {
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  outcome: 'accepted' | 'declined' | 'deferred';
+  declineReason?: ReckoningDoc['declineReason'];
+  remediationHint?: string;
+  deferReason?: ReckoningDoc['deferReason'];
+  deferNote?: string;
+  weight?: number;
+  tickEventId?: string;
+}
+
+// ── Pure handler body ───────────────────────────────────────────────
+
+/**
+ * Drive one tick against the apparatus's resolved state.
+ *
+ * Sequence (the brief's "per-fire sequence is fixed"):
+ *
+ *   1. Pre-seal guard: throw fail-loud when `getActiveScheduler()`
+ *      returns `undefined` (D8).
+ *   2. Re-read `reckoner.schedulerConfig` (D17) and run
+ *      `validateConfig` when the active scheduler declares it. A
+ *      throw is logged fail-loud and skips the entire tick — no rows.
+ *   3. Query held petitions: every writ in `phase: 'new'` that
+ *      carries `ext.reckoner`. The literal-phase query mirrors the
+ *      old `runCatchUpScan`'s shape verbatim — generalisation to
+ *      type-aware initial phases is observed and parked.
+ *   4. Apply source / disabled gates inline, per writ. A disabled
+ *      source produces a decline row carrying
+ *      `declineReason: 'source_banned'` (D2) and transitions the
+ *      writ to its cancelled target. An unregistered source under
+ *      `enforceRegistration: true` produces a decline row carrying
+ *      `declineReason: 'source_unregistered'` and transitions the
+ *      writ to its cancelled target. Both paths consult the
+ *      `(writId, writUpdatedAt)` dedupe so a re-tick at the same
+ *      writ-version does not duplicate rows.
+ *   5. Apply the dependency-aware defer rule, per writ. The
+ *      classifier's `defer-pending` / `defer-failed` outcomes
+ *      produce deferred rows (no transition); `proceed` carries the
+ *      writ forward into the scheduler candidate set. Re-evaluation
+ *      at the same outcome shape is suppressed via the no-op-row
+ *      check.
+ *   6. Filter the survivors against `alreadyConsidered` (D7) so the
+ *      scheduler never sees a writ-version it has already decided.
+ *      Pre-filter is intentional: pre-write dedupe would have the
+ *      scheduler emit decisions the row-write layer silently
+ *      discards, hiding drift.
+ *   7. Empty candidate set → early-return (D10). No rows, no errors.
+ *   8. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 capacity stub and call `evaluate`. A throw is
+ *      logged fail-loud and skips the entire tick — no rows.
+ *   9. Filter-and-warn on stranger writIds (D9). Fail-loud-skip the
+ *      entire tick on multi-decision-per-writ.
+ *  10. Apply each decision: approve → transition + accepted row;
+ *      decline → transition + declined row carrying
+ *      `declineReason: 'other'` and the decision's reason in
+ *      `remediationHint`; defer → deferred row carrying
+ *      `deferReason: 'other'` and the decision's reason in
+ *      `deferNote` (D3); no transition.
+ *
+ * Every Reckonings row this handler writes carries `tickEventId`
+ * stamped from the triggering `clockworks.timer` event id when the
+ * caller supplied one (D6). Direct test invocation passes `null` and
+ * the field is omitted.
+ */
+export async function runTick(
+  context: TickHandlerContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // 1. Pre-seal guard — fail-loud (D8). Production never trips this;
+  // tests asserting the throw drive the handler before phase:started.
+  const scheduler = context.getActiveScheduler();
+  if (!scheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  // The apparatus's `start()` always populates these before the relay
+  // can be invoked through the dispatcher. The defensive checks here
+  // surface a clear error rather than `undefined.book` if the order
+  // of operations is somehow inverted.
+  const stacks = context.getStacks();
+  const reckoningsBook = context.getReckoningsBook();
+  if (!stacks || !reckoningsBook) {
+    throw new Error(
+      '[reckoner] tick: stacks/reckoningsBook handles are unavailable — apparatus start() did not complete before the relay fired.',
+    );
+  }
+
+  // 2. Per-fire `schedulerConfig` re-read + validate. validateConfig
+  // throw → fail-loud-skip the entire tick (no rows).
+  let validatedConfig: unknown = context.resolveSchedulerConfig();
+  if (typeof scheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = scheduler.validateConfig(validatedConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // 3. Query held petitions. Same shape today's catch-up scan uses;
+  // the brief carries this forward unchanged. Type-agnostic
+  // generalisation across non-`'new'` initial phases is parked.
+  const writsBook: ReadOnlyBook<WritDoc> = stacks.readBook<WritDoc>('clerk', 'writs');
+  const allHeld = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+  const heldPetitions: WritDoc[] = [];
+  for (const writ of allHeld) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    heldPetitions.push(writ);
+  }
+
+  const config = context.resolveConfig();
+  const now = new Date();
+  const tickEventId = event?.id;
+  const clerk = context.getClerk();
+
+  // 4 + 5: per-writ gates (source / disabled / dependency). Survivors
+  // accumulate for the scheduler call.
+  const survivors: WritDoc[] = [];
+
+  for (const writ of heldPetitions) {
+    const ext = writ.ext![RECKONER_PLUGIN_ID] as ReckonerExt;
+    const isRegistered = context.isSourceRegistered(ext.source);
+
+    // Disabled-source decline (D2). Symmetric with the unregistered-
+    // strict decline path; uses the type's purpose-built
+    // `source_banned` reason and the source name as the
+    // remediationHint.
+    if (config.disabledSources.includes(ext.source)) {
+      if (await context.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is in disabledSources.`;
+      try {
+        await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (disabled-source decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = context.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unregistered + enforceRegistration → decline + cancel.
+    if (!isRegistered && config.enforceRegistration) {
+      if (await context.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+      try {
+        await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (decline path): ${msg}`,
+        );
+        continue;
+      }
+      const row = context.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (decline path): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Dependency-aware defer rule. The classifier throw (missing /
+    // unknown writ-type config) is surfaced and the writ is skipped
+    // for this tick — fail-loud at the operator level via the warn,
+    // never crashes the tick.
+    let depOutcome: DependencyOutcome;
+    try {
+      depOutcome = await context.evaluateDependencyGate(writ.id);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: dependency gate threw for writ "${writ.id}" — leaving in new without a row. ${msg}`,
+      );
+      continue;
+    }
+    if (depOutcome.kind !== 'proceed') {
+      const reason: ReckoningDoc['deferReason'] =
+        depOutcome.kind === 'defer-failed' ? 'dependency_failed' : 'dependency_pending';
+      const ids =
+        depOutcome.kind === 'defer-failed' ? depOutcome.failedIds : depOutcome.gatingIds;
+      const deferNote = context.buildDependencyDeferNote(depOutcome.kind, ids);
+
+      const last = await context.findLastDeferredRow(reckoningsBook, writ.id);
+      if (last && last.deferReason === reason && last.deferNote === deferNote) {
+        continue;
+      }
+
+      const row = context.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: reason,
+        deferNote,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (dependency-defer path): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // 6. Pre-scheduler dedupe (D7). Already-considered writs never
+    // reach the scheduler.
+    if (await context.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+      continue;
+    }
+
+    survivors.push(writ);
+  }
+
+  // 7. Empty set → early return (D10). No rows, no errors.
+  if (survivors.length === 0) return;
+
+  // 8. Build the single SchedulerInput and call evaluate. Throw →
+  // fail-loud-skip the entire tick (no rows for any writ in the
+  // batch).
+  let decisions: readonly SchedulerDecision[];
+  try {
+    decisions = await scheduler.evaluate({
+      candidates: survivors,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${scheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${scheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 9. Validate decisions: filter-and-warn on stranger writIds (D9).
+  const candidateIds = new Set<string>(survivors.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Skipping the entire tick.`,
+      );
+      return;
+    }
+  }
+
+  // 10. Apply decisions per writ in candidate order. Each writ that
+  // received a decision produces exactly one Reckonings row; writs
+  // the scheduler did not decide on are left untouched (no row, no
+  // transition — the next tick reconsiders them).
+  for (const writ of survivors) {
+    const ext = writ.ext![RECKONER_PLUGIN_ID] as ReckonerExt;
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) continue;
+
+    if (decision.outcome === 'defer') {
+      // D3: deferred row, no transition. `deferReason: 'other'` mirrors
+      // the decline path's `'other'` + `remediationHint` mapping byte-
+      // for-byte; the decision's reason lands in `deferNote`.
+      const row = context.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (
+      decision.outcome !== 'approve' &&
+      decision.outcome !== 'decline'
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+      );
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = context.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // approve.
+    let target: string;
+    try {
+      target = context.resolveActiveTargetPhase(writ);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+      );
+      continue;
+    }
+
+    try {
+      await clerk.transition(writ.id, target as WritPhase, {});
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+      );
+      continue;
+    }
+
+    const row = context.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'accepted',
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+      );
+    }
+  }
+}
+
+// ── Relay factory ───────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. The factory closes
+ * over the dependency context the apparatus assembles inside its own
+ * `start()` so the handler can reach the registry, the active
+ * scheduler, and the row-writer helpers without any module-level
+ * state.
+ */
+export function createTickRelay(context: TickHandlerContext): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY,
+    description:
+      'Periodic Reckoner tick — evaluates every held petition through ' +
+      'the active scheduler in one batch and applies decisions.',
+    handler: async (event, _ctx) => {
+      await runTick(context, event);
+    },
+  });
+}
