+ * additive-merge model from the kit-standing-orders commission). On
+ * each fire the relay's handler:
+ *
+ *   1. Resolves the active scheduler from the closure-scoped
+ *      `getActiveScheduler()` accessor. If unresolved (pre-seal),
+ *      throws fail-loud (D8) so a misordered fixture surfaces a clear
+ *      diagnostic instead of a silent no-op.
+ *   2. Re-reads `reckoner.schedulerConfig` from `guild.json` and runs
+ *      the scheduler's `validateConfig` narrower. A throw fail-loud-
+ *      skips the entire tick (no rows, no transitions).
+ *   3. Queries every held petition (writs in `'new'` carrying
+ *      `ext.reckoner`) using the same find-by-phase shape today's
+ *      the catch-up scan used.
+ *   4. Applies the source/disabled gates inline. Failing writs produce
+ *      a Reckonings decline row and transition to their type's
+ *      cancelled target — they never reach the scheduler.
+ *   5. Filters surviving candidates against the
+ *      `(writId, writUpdatedAt)` dedupe lookup so writs already
+ *      considered at their current version are not handed to the
+ *      scheduler at all (D7).
+ *   6. Empty candidate set → early return (D10): no scheduler call,
+ *      no rows, no errors.
+ *   7. Otherwise, builds one `SchedulerInput { candidates, capacity,
+ *      now, config }` (with the v0 capacity stub) and calls
+ *      `evaluate`. A throw fail-loud-skips the entire tick.
+ *   8. Validates decisions: filter-and-warn on stranger writIds (D9);
+ *      fail-loud-skip the whole tick on multi-decision-per-writ.
+ *   9. Applies each decision — `approve` → transition to active
+ *      target via `resolveActiveTargetPhase`; `decline` → transition
+ *      to cancelled with the decision's reason as resolution; `defer`
+ *      → no transition. Appends one Reckonings row per writ
+ *      considered. Defer rows carry `deferReason: 'other'` and the
+ *      decision's reason in `deferNote` (D3).
+ *
+ * The triggering Clockworks event id is stamped into the resulting
+ * Reckonings rows' `tickEventId` field when `event` is non-null
+ * (D6); when the relay handler is driven directly by tests with a
+ * `null` event the field is omitted from every row produced by that
+ * tick.
+ *
+ * Source-file layout follows the established stdlib-relay pattern
+ * (see `packages/plugins/clockworks/src/summon-relay.ts` and
+ * `packages/plugins/vision-keeper/src/decline-relay.ts`): the relay
+ * factory and a pure handler-body helper live in the same sibling
+ * file as the apparatus, and the test surface drives the helper
+ * directly without booting Clockworks.
+ *
+ * See: docs/architecture/apparatus/reckoner.md and
+ * docs/architecture/reckonings-book.md.
+ */
+
+import type { GuildEvent, RelayDefinition } from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  Book,
+  ReadOnlyBook,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/**
+ * Plugin id stamped on `writ.ext['reckoner']` — the contract slot the
+ * tick handler keys on. Hardcoded literal: the constant *is* the
+ * contract — every consumer keys on this string.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * Relay name registered with the Clockworks. Kept as a constant so
+ * the apparatus's `supportKit.standingOrders` entry and the relay
+ * factory's `name:` stay in lockstep.
+ */
+export const RECKONER_TICK_RELAY = 'reckoner.tick';
+
+/**
+ * Hard-coded tick cadence (D — brief constraint). Operators have no
+ * `reckoner.tickSchedule` knob in this commission; the schedule is
+ * shipped as a kit-default standing order via the apparatus's
+ * `supportKit.standingOrders`.
+ */
+export const RECKONER_TICK_SCHEDULE = '@every 60s';
+
+/**
+ * Resolved `reckoner` config slice the tick handler reads. Mirrors
+ * the closure-scoped helper in `reckoner.ts`; the tick context's
+ * `resolveConfig` is the same function body reused here.
+ */
+interface ResolvedReckonerConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Dependency-injection context the relay handler needs at call time.
+ *
+ * The Reckoner's `buildReckoner()` closure constructs this object and
+ * passes it into both the relay factory (production wiring) and the
+ * pure handler-body helper (test entry). Keeping the surface small
+ * makes the test fixture cheap and keeps the tick code from reaching
+ * back into apparatus-internal state.
+ */
+export interface TickContext {
+  /** Clerk handle. Used for transitions and writ-type config lookups. */
+  clerk: ClerkApi;
+  /** Stacks handle. Used to read the writs book during the held-petition query. */
+  stacks: StacksApi;
+  /** The Reckonings book. Reckoner is the sole writer. */
+  reckoningsBook: Book<ReckoningDoc>;
+  /** Petitioner registry — exposed as a membership predicate. */
+  isSourceRegistered(source: string): boolean;
+  /** Re-read of the `reckoner` config block at every tick (D20 from the parent commission). */
+  resolveConfig(): ResolvedReckonerConfig;
+  /** Re-read of `reckoner.schedulerConfig` per evaluation (D17 from the parent commission). */
+  resolveSchedulerConfig(): unknown;
+  /**
+   * Closure-local reference to the resolved active scheduler. Returns
+   * `undefined` until `phase:started` fires; the tick fail-loud-throws
+   * in that case (D8).
+   */
+  getActiveScheduler(): Scheduler | undefined;
+  /**
+   * Compute the type-aware target active phase for a writ (D5 from the
+   * parent commission). Throws fail-loud on ambiguity / missing config.
+   */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /**
+   * `(writId, writUpdatedAt)` dedupe lookup. Reuses the Reckoner's
+   * existing helper byte-for-byte so a writ already considered at its
+   * current version is filtered out before reaching the scheduler.
+   */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /** Build a Reckonings row from the in-flight consideration state. */
+  buildReckoningRow(params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    outcome: 'accepted' | 'declined' | 'deferred';
+    declineReason?: ReckoningDoc['declineReason'];
+    remediationHint?: string;
+    deferReason?: ReckoningDoc['deferReason'];
+    deferNote?: string;
+    weight?: number;
+    tickEventId?: string;
+  }): ReckoningDoc;
+}
+
+/**
+ * Pure handler-body helper. Exported so unit tests can drive a tick
+ * deterministically against the same context object the relay factory
+ * wires up in production — no need to boot the Clockworks.
+ *
+ * The relay factory below is a thin wrapper that adapts the
+ * `relay()`-shaped `(event, context)` callback to this helper.
+ */
+export async function runTick(
+  ctx: TickContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // 1. Pre-seal guard (D8). The brief explicitly overrides the silent-
+  //    skip default — fail-loud surfaces ordering drift in tests, and
+  //    production never trips this path because phase:started always
+  //    fires before the scheduler can dispatch a tick.
+  const activeScheduler = ctx.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  // 2. Re-read + validate `reckoner.schedulerConfig` (parent-commission
+  //    D17). A `validateConfig` throw fail-loud-skips the entire tick
+  //    — no rows for any writ, no transitions.
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // 3. Query held petitions. Same find-by-phase shape today's
+  //    the catch-up scan used: a direct read of `clerk/writs` filtered by
+  //    `phase = 'new'`, ordered by createdAt asc so the candidate set
+  //    is deterministic. The brief explicitly carries forward the
+  //    literal-phase query (the type-agnostic generalization is parked).
+  const writsBook: ReadOnlyBook<WritDoc> = ctx.stacks.readBook<WritDoc>('clerk', 'writs');
+  const heldRaw = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+
+  // Filter to writs carrying a Reckoner ext slot. The cheap pre-filter
+  // mirrors the parent commission's catch-up-scan path so a writs book
+  // littered with non-Reckoner held writs does not amplify the dedupe
+  // budget.
+  const held: WritDoc[] = [];
+  for (const writ of heldRaw) {
+    if (!writ.ext?.[RECKONER_PLUGIN_ID]) continue;
+    held.push(writ);
+  }
+
+  // Sample `now` once per tick so every row written by this tick
+  // shares a coherent `consideredAt` and id-seed.
+  const now = new Date();
+  const tickEventId = event?.id;
+
+  // 4. Apply source/disabled gates inline. Failing writs produce
+  //    decline rows + cancelled transitions and never reach the
+  //    scheduler. We accumulate the writs that survive the gate into
+  //    `surviving` so the dedupe pass and the scheduler see only the
+  //    set that the gates approve.
+  const config = ctx.resolveConfig();
+  const surviving: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+
+  for (const writ of held) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue; // defensive — pre-filter should have dropped this
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+
+    // Disabled-source gate (D2). Symmetric with the unregistered-
+    // strict source-gate decline path: write a `declined` Reckonings
+    // row carrying `declineReason: 'source_banned'` and the source
+    // name in `remediationHint`; transition the writ to its
+    // cancelled target phase. Distinct resolution-string template
+    // from the unregistered-strict path so operators can grep the
+    // two apart.
+    if (config.disabledSources.includes(ext.source)) {
+      await applyDecline({
+        ctx,
+        writ,
+        ext,
+        now,
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        resolution: `[reckoner] declined: source '${ext.source}' is in reckoner.disabledSources.`,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      continue;
+    }
+
+    // Unregistered-strict gate. Preserve the existing reason
+    // (`source_unregistered`) and resolution-string format for
+    // byte-faithful continuity with downstream consumers.
+    const isRegistered = ctx.isSourceRegistered(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      await applyDecline({
+        ctx,
+        writ,
+        ext,
+        now,
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        resolution: `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      continue;
+    }
+
+    surviving.push({ writ, ext });
+  }
+
+  // 5. Dedupe pass (D7). Filter surviving candidates against the
+  //    `(writId, writUpdatedAt)` lookup. Already-considered writs
+  //    never reach the scheduler — pre-write dedupe would let the
+  //    scheduler emit decisions the row-write layer silently
+  //    discards, hiding drift.
+  const candidates: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const entry of surviving) {
+    if (await ctx.alreadyConsidered(ctx.reckoningsBook, entry.writ.id, entry.writ.updatedAt)) {
+      continue;
+    }
+    candidates.push(entry);
+  }
+
+  // 6. Empty candidate set (D10) → early return. Skip the scheduler
+  //    call. No rows; no errors.
+  if (candidates.length === 0) return;
+
+  // 7. Build SchedulerInput and call evaluate. A throw fail-loud-
+  //    skips the entire tick.
+  const candidateWrits = candidates.map((c) => c.writ);
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates: candidateWrits,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 8. Validate decisions.
+  const candidateIds = new Set<string>(candidateWrits.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  // Group by writId; fail-loud-skip the entire tick on multi-decision-
+  // per-writ (D9 — safer than applying ambiguous decisions).
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate. Skipping the entire tick.`,
+      );
+      return;
+    }
+  }
+
+  // 9. Apply each decision. We iterate the candidate set rather than
+  //    the decisions map so a candidate without a decision is a no-op
+  //    (defer-equivalent: no transition, no row).
+  for (const { writ, ext } of candidates) {
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) continue; // no decision → silent skip
+
+    if (decision.outcome === 'defer') {
+      // Defer outcome (D3). Mirrors the decline-path's `'other'` +
+      // remediation mapping byte-for-byte: `deferReason: 'other'`
+      // with the decision's reason in `deferNote`. Other defer-
+      // metadata fields stay absent — `deferCount` / `deferUntil` /
+      // `deferSignal` await a real consumer.
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'approve') {
+      let target: string;
+      try {
+        target = ctx.resolveActiveTargetPhase(writ);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+        );
+        continue;
+      }
+      try {
+        await ctx.clerk.transition(writ.id, target as WritPhase, {});
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'accepted',
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unknown outcome — warn and skip this writ.
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+  }
+}
+
+/**
+ * Apply a source-gate decline to one writ. Used by both the
+ * disabled-source path (`source_banned`) and the unregistered-strict
+ * path (`source_unregistered`). The transition fires first; on
+ * failure we log and skip — the row is only written on a successful
+ * transition so a row never out-runs the writ's actual phase.
+ */
+async function applyDecline(args: {
+  ctx: TickContext;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  now: Date;
+  declineReason: NonNullable<ReckoningDoc['declineReason']>;
+  remediationHint: string;
+  resolution: string;
+  tickEventId?: string;
+}): Promise<void> {
+  const { ctx, writ, ext, now, declineReason, remediationHint, resolution, tickEventId } = args;
+  try {
+    await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (decline path: ${declineReason}): ${msg}`,
+    );
+    return;
+  }
+  const row = ctx.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason,
+    remediationHint,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await ctx.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (decline path: ${declineReason}): ${msg}`,
+    );
+  }
+}
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. Exported so the
+ * apparatus boot path can wire it into `supportKit.relays` and so
+ * unit tests can drive the relay handler directly.
+ *
+ * The factory closes over the `TickContext` the apparatus
+ * constructs in `start()` — every per-fire dependency the handler
+ * needs is reached through that context, never through a fresh
+ * `guild()` lookup, so test fixtures can drive the same code path
+ * without mounting a full Arbor lifecycle.
+ */
+export function createTickRelay(ctx: TickContext): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY,
+    description:
+      'Periodic Reckoner tick: query held petitions, run the active scheduler, apply decisions, and append Reckonings rows.',
+    handler: async (event, _relayContext) => {
+      await runTick(ctx, event);
+    },
+  });
+}
