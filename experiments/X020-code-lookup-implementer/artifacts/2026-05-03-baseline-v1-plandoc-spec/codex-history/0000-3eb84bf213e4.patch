+  async dropBook(ref: BookRef): Promise<void> {
+    const db = this.requireDb();
+    const table = tableName(ref);
+    // `DROP TABLE IF EXISTS` is the silent-on-no-op posture (D2). SQLite
+    // cascades any indexes attached to the table, so explicit DROP INDEX
