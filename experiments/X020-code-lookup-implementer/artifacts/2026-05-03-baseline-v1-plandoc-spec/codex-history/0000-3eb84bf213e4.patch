     assert.equal(rows[0].name, 'book.clockworks.event_dispatches.created');
     assert.equal(rows[0].emitter, 'framework');
   });
+
+  it('emits exactly one book.<owner>.<book>.book-dropped on a dropBook()', async () => {
+    const fix = await buildFixture({
+      syntheticBooks: [
+        { pluginId: 'test-plugin', bookName: 'myBook' },
+      ],
+    });
+
+    await fix.stacks.dropBook('test-plugin', 'myBook');
+
+    const rows = await fix.eventsAfter();
+    assert.equal(rows.length, 1, 'exactly one event row landed');
+    const evt = rows[0];
+    assert.equal(evt.name, 'book.test-plugin.myBook.book-dropped');
+    assert.equal(evt.emitter, 'framework');
+
+    const payload = evt.payload as { type: string; ownerId: string; book: string };
+    assert.equal(payload.type, 'delete-book');
+    assert.equal(payload.ownerId, 'test-plugin');
+    assert.equal(payload.book, 'myBook');
+    assert.equal(
+      (payload as Record<string, unknown>).entry,
+      undefined,
+      'BookDeleteEvent carries no entry payload',
+    );
+  });
+
+  it('dropBook() on the carve-out clockworks/events book emits no echo', async () => {
+    const fix = await buildFixture();
+
+    // The carve-out applies uniformly to every verb (D16): retiring the
+    // events book does not auto-emit a `book.clockworks.events.book-dropped`
+    // row. (We do not actually drop the book in production — this test
+    // proves the carve-out predicate is consistent.)
+    await fix.stacks.dropBook('clockworks', 'events');
+
+    // The events book has been dropped — re-create it so subsequent
+    // reads do not blow up. (`ensureBook` is idempotent and lazy
+    // re-creation in MemoryBackend covers fresh access.)
+    // Read from the fresh table (empty) and assert no echo emission.
+    const emitted = await fix.stacks
+      .readBook<EventDoc>('clockworks', 'events')
+      .find({});
+    const echoes = emitted.filter((r) =>
+      r.name.startsWith('book.clockworks.events.'),
+    );
+    assert.equal(echoes.length, 0, 'no book.clockworks.events.* echo row');
+  });
 });
 
