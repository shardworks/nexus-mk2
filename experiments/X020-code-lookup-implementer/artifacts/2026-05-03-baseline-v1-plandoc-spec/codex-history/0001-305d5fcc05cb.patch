+    // ── dropBook edge cases ─────────────────────────────────────────
+
+    it('4.12 dropBook on a missing book is a silent no-op', async () => {
+      // D2: mirrors `Book.delete(id)` precedent and SQLite's
+      // `DROP TABLE IF EXISTS` semantics. The absent state is the
+      // desired post-state — repeated drops must not throw.
+      await t.stacks.dropBook(OWNER, 'never-existed');
+      // Drop the existing book, then drop it again — second drop is the
+      // missing-book case and must not throw.
+      await t.stacks.dropBook(OWNER, BOOK);
+      await t.stacks.dropBook(OWNER, BOOK);
+    });
+
+    it('4.13 ensureBook after dropBook re-creates a fresh empty book', async () => {
+      const book = t.stacks.book<BookEntry>(OWNER, BOOK);
+      await book.put({ id: 'a', name: 'Alice' });
+      await book.put({ id: 'b', name: 'Bob' });
+
+      await t.stacks.dropBook(OWNER, BOOK);
+
+      // Re-create with a new schema (different indexes to prove it is
+      // a fresh book, not a re-attached old one).
+      t.backend.ensureBook(REF, { indexes: ['name'] });
+
+      const reborn = t.stacks.book<BookEntry>(OWNER, BOOK);
+      assert.deepStrictEqual(await reborn.list(), []);
+      assert.strictEqual(await reborn.count(), 0);
+
+      // And it must accept fresh writes that succeed cleanly.
+      await reborn.put({ id: 'x', name: 'Xena' });
+      assert.deepStrictEqual(await reborn.get('x'), { id: 'x', name: 'Xena' });
+      assert.strictEqual(await reborn.get('a'), null);
+    });
+
+    it('4.14 dropBook inside an active transaction throws (D6)', async () => {
+      // DDL-in-DML refusal: dropBook is a top-level imperative and
+      // must NOT participate in `transaction(...)`. The substrate
+      // refuses the mix rather than rationalizing it.
+      await assert.rejects(
+        () =>
+          t.stacks.transaction(async () => {
+            await t.stacks.dropBook(OWNER, BOOK);
+          }),
