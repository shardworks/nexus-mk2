+
+    it('1.12 dropBook on a populated book removes its documents', async () => {
+      // Populate the book, drop it, then re-create the book and assert
+      // it is empty. Backends differ on what raw post-drop reads do
+      // (MemoryBackend lazy-creates; SqliteBackend's table is missing
+      // and SELECT throws), so the cross-backend invariant we observe
+      // is "the documents do not survive the drop". Re-creating via
+      // ensureBook is the canonical post-drop access path (mirrors
+      // Tier 4's "ensureBook after dropBook re-creates fresh").
+      const book = t.stacks.book<BookEntry>(OWNER, BOOK);
+      await book.put({ id: 'a', name: 'Alice' });
+      await book.put({ id: 'b', name: 'Bob' });
+      assert.strictEqual(await book.count(), 2);
+
+      await t.stacks.dropBook(OWNER, BOOK);
+
+      // Re-create the book under the same ref. The previous documents
+      // must not reappear — they are gone with the storage.
+      t.backend.ensureBook(REF, {});
+      const reborn = t.stacks.book<BookEntry>(OWNER, BOOK);
+      assert.deepStrictEqual(await reborn.list(), []);
+      assert.strictEqual(await reborn.get('a'), null);
+      assert.strictEqual(await reborn.get('b'), null);
+    });
   });
 }
