index 67009a1..366a0e1 100644
--- a/packages/plugins/cartograph/src/cartograph.test.ts
+++ b/packages/plugins/cartograph/src/cartograph.test.ts
@@ -1006,4 +1006,136 @@ describe('Cartograph apparatus', () => {
       );
     });
   });
+
+  // ── Retro-cleanup of retired companion books ─────────────────────
+  //
+  // A previous commission removed the cartograph/visions, charges, and
+  // pieces companion books in favor of `writ.ext['cartograph']`. On
+  // existing on-disk databases the underlying tables persisted as
+  // dead-but-not-dropped storage. cartograph.start() now issues
+  // stacks.dropBook(...) for each retired book before any writ-type
+  // registration. These tests assert the retro-cleanup is wired
+  // correctly — sequenced, idempotent, fires the substrate's
+  // delete-book CDC event, and runs before the writ-types appear.
+
+  describe('retro-cleanup of retired companion books', () => {
+    it('drops cartograph/visions, charges, and pieces during start()', async () => {
+      // Stand up stacks + clerk by hand so we can install a CDC watcher
+      // on the dropBook events BEFORE cartograph.start() runs.
+      const memBackend = new MemoryBackend();
+      const stacksPlugin = createStacksApparatus(memBackend);
+      const clerkPlugin = createClerk();
+      const cartographPlugin = createCartograph();
+
+      const apparatusMap = new Map<string, unknown>();
+
+      const fakeGuildConfig: GuildConfig = {
+        name: 'cartograph-retro-cleanup-guild',
+        nexus: '0.0.0',
+        plugins: [],
+      };
+      const fakeGuild: Guild = {
+        home: '/tmp/cartograph-retro-cleanup-guild',
+        apparatus<T>(name: string): T {
+          const a = apparatusMap.get(name);
+          if (!a) throw new Error(`Apparatus "${name}" not installed`);
+          return a as T;
+        },
+        tryApparatus<T>(name: string): T | null {
+          try { return this.apparatus<T>(name); } catch { return null; }
+        },
+        config<T>(_pluginId: string): T { return {} as T; },
+        writeConfig(): void {},
+        guildConfig(): GuildConfig { return fakeGuildConfig; },
+        kits(): LoadedKit[] { return []; },
+        apparatuses(): LoadedApparatus[] { return []; },
+        failedPlugins() { return []; },
+        startupWarnings(): string[] { return []; },
+      };
+      setGuild(fakeGuild);
+
+      stacksPlugin.apparatus.start!(buildCtx());
+      const stacks = stacksPlugin.apparatus.provides as StacksApi;
+      apparatusMap.set('stacks', stacks);
+
+      memBackend.ensureBook({ ownerId: 'clerk', book: 'writs' }, {
+        indexes: ['phase', 'type', 'createdAt', 'parentId'],
+      });
+      memBackend.ensureBook({ ownerId: 'clerk', book: 'links' }, {});
+
+      await clerkPlugin.apparatus.start!(buildCtx());
+      const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+      apparatusMap.set('clerk', clerk);
+
+      // Pre-seed the three retired companion books with content. On a
+      // real on-disk database these are the dead-but-not-dropped tables;
+      // here we synthesize the same starting condition.
+      memBackend.ensureBook({ ownerId: 'cartograph', book: 'visions' }, {});
+      memBackend.ensureBook({ ownerId: 'cartograph', book: 'charges' }, {});
+      memBackend.ensureBook({ ownerId: 'cartograph', book: 'pieces' }, {});
+      await stacks.book('cartograph', 'visions').put({ id: 'old-v1' });
+      await stacks.book('cartograph', 'charges').put({ id: 'old-c1' });
+      await stacks.book('cartograph', 'pieces').put({ id: 'old-p1' });
+
+      // Record the delete-book events so we can assert sequencing.
+      const dropEvents: { ownerId: string; book: string }[] = [];
+      for (const book of ['visions', 'charges', 'pieces']) {
+        stacks.watch('cartograph', book, (event) => {
+          if (event.type === 'delete-book') {
+            dropEvents.push({ ownerId: event.ownerId, book: event.book });
+          }
+        }, { failOnError: false });
+      }
+
+      // Now start cartograph — the three dropBook calls should fire.
+      await cartographPlugin.apparatus.start!(buildCtx());
+      const cartograph = cartographPlugin.apparatus.provides as CartographApi;
+      apparatusMap.set('cartograph', cartograph);
+
+      // (a) Each retired book received exactly one drop event.
+      assert.deepEqual(
+        dropEvents,
+        [
+          { ownerId: 'cartograph', book: 'visions' },
+          { ownerId: 'cartograph', book: 'charges' },
+          { ownerId: 'cartograph', book: 'pieces' },
+        ],
+        'sequenced retro-cleanup: visions, then charges, then pieces',
+      );
+
+      // (b) Re-creating the books and reading them back yields empty —
+      // the seeded rows are gone.
+      memBackend.ensureBook({ ownerId: 'cartograph', book: 'visions' }, {});
+      memBackend.ensureBook({ ownerId: 'cartograph', book: 'charges' }, {});
+      memBackend.ensureBook({ ownerId: 'cartograph', book: 'pieces' }, {});
+      assert.deepEqual(await stacks.book('cartograph', 'visions').list(), []);
+      assert.deepEqual(await stacks.book('cartograph', 'charges').list(), []);
+      assert.deepEqual(await stacks.book('cartograph', 'pieces').list(), []);
+
+      // (c) Writ types are still registered after the cleanup — the
+      // cleanup hook precedes registerWritType but does not prevent it.
+      const types = clerk.listWritTypes().map((t) => t.name);
+      for (const name of ['vision', 'charge', 'piece']) {
+        assert.ok(types.includes(name), `${name} writ type registered after retro-cleanup`);
+      }
+    });
+
+    it('the dropBook calls are idempotent on subsequent boots (silent no-op)', async () => {
+      // Calling the substrate-level dropBook a second time on a
+      // missing book is exercised by Tier 4 conformance. The cartograph
+      // hook simply issues those calls; the idempotency property is
+      // inherited. Assert here that re-invoking the same dropBook
+      // sequence against the live guild does not throw.
+      const stacks = fix.stacks;
+      await stacks.dropBook('cartograph', 'visions');
+      await stacks.dropBook('cartograph', 'charges');
+      await stacks.dropBook('cartograph', 'pieces');
+      // No throw is the assertion. The writ-type registry is unaffected
+      // because dropBook does not touch the Clerk.
+      const types = fix.clerk.listWritTypes().map((t) => t.name);
+      for (const name of ['vision', 'charge', 'piece']) {
+        assert.ok(types.includes(name), `${name} writ type still registered after redundant dropBook`);
+      }
+    });
+  });
 });
