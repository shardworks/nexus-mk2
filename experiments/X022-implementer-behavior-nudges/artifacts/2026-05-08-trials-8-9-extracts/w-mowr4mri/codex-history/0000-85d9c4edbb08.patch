+/**
+ * `reckoner.tick` — periodic-tick relay for the Reckoner.
+ *
+ * The Reckoner's evaluation surface is event-driven: a Clockworks
+ * scheduled standing order (`@every 60s`) fires this relay, which
+ * sweeps every held petition through the configured scheduler in
+ * one batch per fire. The relay file is structurally trivial — the
+ * apparatus closure constructs a `TickContext` with everything the
+ * handler needs (registry handles, the resolved active scheduler,
+ * the live config accessors, target-phase resolution, dedupe lookup,
+ * Reckonings row construction). Both the relay factory and a pure
+ * handler-body helper close over the same context shape so unit
+ * tests can drive the tick without booting Clockworks.
+ *
+ * Per-fire sequence (originating brief, "Decisions" block):
+ *
+ *   1. Resolve the active scheduler. Throws fail-loud (D8) when
+ *      pre-seal — `phase:started` has not yet fired.
+ *   2. Re-read `reckoner.schedulerConfig` and run the scheduler's
+ *      `validateConfig` narrower (when present). On throw: log
+ *      fail-loud and skip the entire tick (no rows).
+ *   3. Query held petitions: writs in `new` phase carrying
+ *      `ext.reckoner` with a non-empty source string.
+ *   4. Source / disabled gates inline. A disabled-source writ is
+ *      declined with `declineReason: 'source_banned'` (D2); an
+ *      unregistered-source writ under `enforceRegistration: true`
+ *      is declined with `declineReason: 'source_unregistered'` (the
+ *      pre-existing path's shape).
+ *   5. Dedupe filter (D7). Already-considered writs (matching on the
+ *      `(writId, writUpdatedAt)` identity) never reach the scheduler.
+ *   6. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 capacity stub and call `evaluate`. On throw:
+ *      log fail-loud and skip the entire tick (no rows).
+ *   7. Validate decisions: filter-and-warn on stranger writIds (D9);
+ *      fail-loud-skip the whole tick on multi-decision-per-writ.
+ *   8. Apply each decision (approve / decline / defer) and append
+ *      one Reckonings row per writ considered. `tickEventId` is
+ *      stamped from the triggering `clockworks.timer` event id when
+ *      present; omitted when absent (D6). Defer rows carry
+ *      `deferReason: 'other'` and the decision's reason in
+ *      `deferNote` (D3).
+ *
+ * The handler treats every observable failure mode (transition throw,
+ * row-write throw, etc.) with `console.warn` + skip-this-writ semantics
+ * inside the per-writ loop — one corrupt held writ does not stop the
+ * tick from reaching the rest. Whole-tick fail-loud-skip is reserved for
+ * `validateConfig` / `evaluate` throws and multi-decision-per-writ —
+ * conditions where a partial application would be ambiguous.
+ *
+ * The pure handler entry (`runTickHandler`) is exported so the
+ * apparatus's `ReckonerTestHooks.runTick(event?)` can drive the
+ * tick directly; the relay factory (`createReckonerTickRelay`) is
+ * the production entry, wired into `apparatus.supportKit.relays`
+ * alongside the kit-contributed standing order at
+ * `apparatus.supportKit.standingOrders`.
+ *
+ * See: docs/architecture/apparatus/reckoner.md (per-fire sequence,
+ * outcome mapping) and docs/architecture/reckonings-book.md
+ * (`tickEventId` semantics).
+ */
+
+import {
+  relay,
+  type GuildEvent,
+  type RelayDefinition,
+} from '@shardworks/clockworks-apparatus';
+import type { Book, ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+import type { ClerkApi, WritDoc, WritPhase } from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/** Plugin id stamped on `writ.ext['reckoner']`. Hardcoded literal (D11). */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * The relay name registered in the Clockworks. Public constant so
+ * the apparatus's standing-order contribution and the test surface
+ * can reference the same string without drift.
+ */
+export const RECKONER_TICK_RELAY_NAME = 'reckoner.tick';
+
+/**
+ * Dependency context the apparatus closure passes into the tick
+ * handler. The closure constructs this once at `start()`; the relay
+ * factory and the pure-handler test entry both consume the same
+ * shape so an external boot of Clockworks is never required for unit
+ * coverage.
+ *
+ * Method-style accessors (rather than direct value fields) keep the
+ * closure-local state mutable from the apparatus side. The
+ * `getActiveScheduler()` accessor returns `undefined` until
+ * `phase:started` has fired and the registry has sealed; the tick
+ * handler throws fail-loud (D8) in that case so a misconfigured test
+ * fixture surfaces a deterministic, loud error rather than silently
+ * skipping work.
+ */
+export interface TickContext {
+  /** Clerk API. Used for `transition` calls. */
+  getClerk(): ClerkApi;
+  /** Stacks API. Used for the held-writ query against `clerk/writs`. */
+  getStacks(): StacksApi;
+  /** Reckonings book handle (writer). The Reckoner is the sole writer. */
+  getReckoningsBook(): Book<ReckoningDoc>;
+  /**
+   * Resolved active scheduler. Returns `undefined` until the registry
+   * seals at `phase:started`. The tick handler throws fail-loud (D8)
+   * when this returns undefined — production never trips it; test
+   * fixtures get a deterministic loud signal.
+   */
+  getActiveScheduler(): Scheduler | undefined;
+  /**
+   * Live `reckoner.disabledSources` config slice. Re-read per call
+   * so operators can hot-edit `guild.json` (D20).
+   */
+  getDisabledSources(): readonly string[];
+  /**
+   * Live `reckoner.enforceRegistration` config flag. Re-read per
+   * call so operators can hot-edit (D20).
+   */
+  getEnforceRegistration(): boolean;
+  /** Live source-registry membership check (sealed in-memory map). */
+  isSourceRegistered(source: string): boolean;
+  /**
+   * Live `reckoner.schedulerConfig` read. Returns `undefined` when
+   * the config slot is absent. The scheduler's `validateConfig` is
+   * the trust boundary — the Reckoner does not narrow this value
+   * before handing it through.
+   */
+  resolveSchedulerConfig(): unknown;
+  /**
+   * Compute the type-aware active target phase for a writ at
+   * transition time. Walks the current state's `allowedTransitions`
+   * and picks the candidate classified as `active`. Throws fail-loud
+   * on ambiguity / missing config — caller catches and logs.
+   */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /**
+   * Dedupe lookup. Returns `true` when a non-deferred Reckonings row
+   * already exists for `(writId, writUpdatedAt)`.
+   */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /**
+   * Build a Reckonings row from in-flight consideration state. The
+   * tick stamps `tickEventId` from the triggering `clockworks.timer`
+   * event id when present; absence is meaningful (D6).
+   */
+  buildReckoningRow(params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    outcome: 'accepted' | 'declined' | 'deferred';
+    declineReason?: ReckoningDoc['declineReason'];
+    remediationHint?: string;
+    deferReason?: ReckoningDoc['deferReason'];
+    deferNote?: string;
+    weight?: number;
+    tickEventId?: string;
+  }): ReckoningDoc;
+}
+
+/**
+ * Pure handler body. Exported for unit tests so the tick can run
+ * deterministically without a Clockworks dispatcher in the loop.
+ *
+ * `event` is nullable to match the relay-handler contract — the
+ * dispatcher exposes a direct-invocation surface alongside the
+ * standing-order path; the test hook also passes `null` when no
+ * triggering event is meaningful.
+ */
+export async function runTickHandler(
+  ctx: TickContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // 1. Pre-seal guard (D8). Production never trips this; test
+  // fixtures get a deterministic loud signal.
+  const activeScheduler = ctx.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      `[reckoner] tick: activeScheduler not resolved — phase:started has not fired.`,
+    );
+  }
+
+  const stacks = ctx.getStacks();
+  const clerk = ctx.getClerk();
+  const reckoningsBook = ctx.getReckoningsBook();
+
+  // tickEventId stamping (D6) — populate when present; omit when
+  // absent (test paths driving the handler with `null`).
+  const tickEventId: string | undefined = event?.id;
+
+  // 2. Re-read + validate `reckoner.schedulerConfig`. On throw,
+  // fail-loud-skip the entire tick (no rows).
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // 3. Query held petitions. Reads `clerk/writs` directly rather
+  // than `clerk.list({ phase: 'new' })` because the Clerk's list
+  // applies an implicit `type = 'mandate'` filter when phase is
+  // supplied without type, which would hide non-mandate held writs
+  // whose initial state is named `new`.
+  const writsBook: ReadOnlyBook<WritDoc> = stacks.readBook<WritDoc>('clerk', 'writs');
+  const heldRaw = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+  const held: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const writ of heldRaw) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    held.push({ writ, ext });
+  }
+
+  // D10 — empty candidate set: writes nothing, no rows, no errors.
+  if (held.length === 0) return;
+
+  // Sample `now` once at handler entry so every row's id-seed and
+  // `consideredAt` derive from the same Date.
+  const now = new Date();
+  const disabledSources = ctx.getDisabledSources();
+  const enforceRegistration = ctx.getEnforceRegistration();
+
+  // 4. Apply source/disabled gates inline. Writs failing either
+  // gate decline + transition to cancelled. Survivors carry forward
+  // to the dedupe filter and the scheduler call.
+  const survivors: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const entry of held) {
+    const { writ, ext } = entry;
