+  // drift. Keep parallel `candidates` and `candidateExts` slices so
+  // we can look the ext back up by writId during decision apply.
+  const candidates: WritDoc[] = [];
+  const candidateExts = new Map<string, ReckonerExt>();
+  for (const { writ, ext } of survivors) {
+    if (await ctx.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
