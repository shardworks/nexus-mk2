+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate threw — skipping tick (no rows). ${msg}`,
+    );
+    return;
+  }
