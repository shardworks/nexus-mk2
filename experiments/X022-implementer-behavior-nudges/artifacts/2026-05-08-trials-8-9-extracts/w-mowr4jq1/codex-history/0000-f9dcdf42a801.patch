+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+    });
+
+    it('dedupes within a single tick when alreadyConsidered short-circuits', async () => {
+      // Build a defer-emitting scheduler that leaves the writ in
+      // `new`. That keeps the writ visible to subsequent ticks; the
+      // dedupe lookup must still skip writs already considered at
+      // the same writUpdatedAt — the second tick runs but writes a
+      // fresh defer-row only when the writUpdatedAt has changed.
+      // Here, since the first tick wrote a deferred row (which does
+      // NOT count as "already considered" — see alreadyConsidered),
+      // the second tick re-runs the scheduler; but the writUpdatedAt
+      // is unchanged, so the no-op-row suppression in the scheduler
+      // path doesn't apply. Instead we exercise the simpler shape:
+      // an approve-emitting scheduler at unchanged writUpdatedAt.
