+    survivingFromSourceGates.push(writ);
+  }
+
+  // 6. Dependency gate per writ (preserved from the per-call CDC
+  //    path). Defer outcomes write deferred rows with no-op-row
+  //    suppression and drop the writ from the surviving set.
