+  // 4. Empty-candidate early-return (D10). Skip the scheduler call
+  //    entirely — no rows, no errors, no peculiar empty-array shape
+  //    handed to the scheduler.
+  if (heldWithExt.length === 0) return;
+
+  // 5. Source/disabled gates inline. A failing writ produces a
+  //    decline row + transition to its cancelled target and is
+  //    dropped from the candidate set. Surviving writs proceed to
+  //    the dep gate.
