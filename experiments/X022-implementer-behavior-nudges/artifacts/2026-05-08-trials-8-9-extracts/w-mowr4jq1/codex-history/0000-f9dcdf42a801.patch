+            source: 'vision-keeper.snapshot',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Pre-tick: writ stays in new because no tick has fired yet.
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      const writ = all[0]!;
+      assert.equal(writ.phase, 'new', 'no tick has fired yet — writ stays in new');
+      assert.equal(
+        (await fix.reckoningsBook.find({ where: [['writId', '=', writ.id]] })).length,
+        0,
+      );
+
+      // First tick: pick up the held writ + auto-accept.
+      await fix.hooks.runTick(null);
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open', 'first tick auto-approves the held writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ───────────────────────────────────
+
+  describe('evaluate throw', () => {
+    it('logs fail-loud and writes no rows for any writ in the tick', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad-evaluate',
+        description: 'always throws',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+      const fix = await buildFixture({
+        petitionerKits: [TESTER_KIT],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-evaluate' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      const writ2 = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't2',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => { warnings.push(String(msg)); };
+      try {
+        await fix.hooks.runTick(makeTickEvent());
+        // Both writs stay in new; no rows.
+        for (const id of [writ.id, writ2.id]) {
+          const reread = await fix.clerk.show(id);
+          assert.equal(reread.phase, 'new');
+          const rows = await fix.reckoningsBook.find({
+            where: [['writId', '=', id]],
