+      // Drive a second tick — the writ is now `open`, the held-writ
+      // query does not surface it. The dedupe path has nothing to
+      // check.
+      await fix.hooks.runTick(null);
+      const rowsAfterSecond = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rowsAfterSecond.length, 1);
+    });
+  });
