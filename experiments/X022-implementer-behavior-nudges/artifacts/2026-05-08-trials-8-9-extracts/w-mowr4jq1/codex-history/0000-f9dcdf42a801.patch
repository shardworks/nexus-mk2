+} from './types.ts';
+
+// ── Constants ───────────────────────────────────────────────────────
+
+/**
+ * Relay name. Dotted form per D1 — matches the apparatus's existing
+ * contributed-id grammar (scheduler ids, petitioner sources). The
+ * standing order under `apparatus.supportKit.standingOrders` names
+ * this constant via `run: 'reckoner.tick'`.
+ */
+export const TICK_RELAY_NAME = 'reckoner.tick';
+
+/**
+ * Plugin id stamped on `writ.ext['reckoner']` — duplicated from
+ * `reckoner.ts` as a hardcoded literal so the tick path has no
+ * import-time dependency on the apparatus factory module.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+// ── Dependency-gate types (mirrors reckoner.ts) ─────────────────────
+
+/**
+ * Aggregated dependency-gate outcome handed in from the closure
+ * helper `evaluateDependencyGate`. Mirrors the type declared in
+ * `reckoner.ts` — duplicated here so the pure helper does not have
+ * to reach back across files for a structural import.
+ */
+export type DependencyOutcome =
+  | { kind: 'proceed' }
+  | { kind: 'defer-pending'; gatingIds: string[] }
+  | { kind: 'defer-failed'; failedIds: string[] };
+
+// ── Reckoner-row builder context (mirrors reckoner.ts) ──────────────
+
+/**
+ * Mirror of `buildReckoningRow`'s parameter shape so the tick path
+ * does not have to construct the row inline. The closure exposes
+ * the actual builder via `TickHandlerContext.buildReckoningRow`.
+ *
+ * `tickEventId` is added in this commission — when the row is
+ * written from a tick fire, the handler stamps it from the
+ * triggering `clockworks.timer` event id. When the helper is driven
+ * directly with `null` (test paths), the field is omitted.
+ */
+export interface BuildReckoningRowParams {
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  outcome: 'accepted' | 'declined' | 'deferred';
+  declineReason?: ReckoningDoc['declineReason'];
+  remediationHint?: string;
+  deferReason?: ReckoningDoc['deferReason'];
+  deferNote?: string;
+  weight?: number;
+  tickEventId?: string;
+}
+
+// ── Dependency context ──────────────────────────────────────────────
+
+/**
+ * Dependency context the relay handler receives from
+ * `buildReckoner()`. Exposes only the closure-scoped state and
+ * helpers the tick path needs — keeps the relay handler isolated
+ * from the rest of the apparatus internals so the same context can
+ * be assembled from a unit-test fixture.
+ */
+export interface TickHandlerContext {
+  /** Live Clerk handle — used for transitions and writ-type config lookups. */
+  clerk: ClerkApi;
+  /** Live Stacks handle — used to read the writs book for the held-petition query. */
+  stacks: StacksApi;
+  /** Reckonings book handle — the only writer of this book. */
+  reckoningsBook: Book<ReckoningDoc>;
+  /** True when `source` is in the (sealed) petitioner registry. */
+  isSourceRegistered(source: string): boolean;
+  /** Resolved active scheduler, or `undefined` when pre-seal. */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Read + narrow the `reckoner` config block. */
+  resolveConfig(): { enforceRegistration: boolean; disabledSources: string[] };
+  /** Read the `reckoner.schedulerConfig` slot per evaluation. */
+  resolveSchedulerConfig(): unknown;
+  /** Pick the type-aware active target for an approve transition. */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /** Idempotency lookup — returns true when the writ has a non-deferred row at this updatedAt. */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /** Build a Reckonings row from the in-flight consideration state. */
+  buildReckoningRow(params: BuildReckoningRowParams): ReckoningDoc;
+  /** Walk a held writ's outbound `depends-on` links and aggregate per-target classifications. */
+  evaluateDependencyGate(writId: string): Promise<DependencyOutcome>;
+  /** Format the deferNote string for a dependency-defer Reckonings row. */
+  buildDependencyDeferNote(
+    kind: 'defer-pending' | 'defer-failed',
+    ids: readonly string[],
+  ): string;
+  /** Look up the most-recent deferred Reckonings row for `writId`, for no-op-row suppression. */
+  findLastDeferredRow(
+    book: Book<ReckoningDoc>,
+    writId: string,
+  ): Promise<ReckoningDoc | undefined>;
+}
+
+// ── Pure helper (test-friendly) ─────────────────────────────────────
+
+/**
+ * Pure handler body. Drives the per-fire sequence end-to-end,
+ * isolated from Clockworks runtime so unit tests can call it
+ * directly with a synthetic event id (or `null` for direct-drive).
+ *
+ * Caller is responsible for assembling the dependency context from
+ * the apparatus's closure state. Throws fail-loud on the pre-seal
+ * guard (D8); every other failure path is logged fail-loud and
+ * skips the tick (no rows, no transitions for any writ in the
+ * tick).
+ */
+export async function runTickHandler(
+  ctx: TickHandlerContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // 1. Pre-seal guard (D8). Production never trips this — the
+  //    standing order does not fire until phase:started has resolved
+  //    the active scheduler. A test fixture that drives the helper
+  //    pre-seal gets a deterministic loud signal naming the
+  //    invariant it violated.
+  const activeScheduler = ctx.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired',
+    );
+  }
+
+  // Sample now once at handler entry so every row written by this
+  // tick shares the same `consideredAt` and the same `generateId`
+  // timestamp seed.
+  const now = new Date();
+  const tickEventId = event?.id;
+
+  // 2. Re-read + validate the per-evaluation config slice. The
+  //    narrower throws on shape mismatch — log fail-loud and skip
+  //    the entire tick (no rows, no scheduler call).
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
