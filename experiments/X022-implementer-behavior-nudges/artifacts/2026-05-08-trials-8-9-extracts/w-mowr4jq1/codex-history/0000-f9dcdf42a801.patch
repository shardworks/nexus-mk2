+    let depOutcome: DependencyOutcome;
+    try {
+      depOutcome = await ctx.evaluateDependencyGate(writ.id);
+    } catch (err) {
+      // Classifier fail-loud (missing/unknown writ-type config).
+      // Surface but do not crash the tick; this writ stays in `new`
+      // without a row. Other writs continue to be processed.
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: dependency gate threw for writ "${writ.id}" — leaving in new without a row. ${msg}`,
+      );
+      continue;
+    }
+
+    if (depOutcome.kind === 'proceed') {
+      survivingFromDepGate.push(writ);
+      continue;
+    }
+
+    const reason: ReckoningDoc['deferReason'] =
+      depOutcome.kind === 'defer-failed' ? 'dependency_failed' : 'dependency_pending';
+    const ids =
+      depOutcome.kind === 'defer-failed' ? depOutcome.failedIds : depOutcome.gatingIds;
+    const deferNote = ctx.buildDependencyDeferNote(depOutcome.kind, ids);
+
+    // No-op-row suppression: re-evaluation at the same outcome
+    // shape produces no row.
+    const last = await ctx.findLastDeferredRow(ctx.reckoningsBook, writ.id);
+    if (last && last.deferReason === reason && last.deferNote === deferNote) {
+      continue;
+    }
+
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'deferred',
+      deferReason: reason,
+      deferNote,
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (dependency-defer path): ${msg}`,
+      );
+    }
+  }
+
+  // 7. Dedupe filter (D7). Already-considered writs never reach the
+  //    scheduler — drop them before building the input.
+  const candidates: WritDoc[] = [];
+  for (const writ of survivingFromDepGate) {
+    if (await ctx.alreadyConsidered(ctx.reckoningsBook, writ.id, writ.updatedAt)) {
+      continue;
+    }
+    candidates.push(writ);
+  }
+
+  // After dedupe, the candidate set may be empty. The brief allows
+  // skipping the scheduler call on an empty set (D10 applies post-
+  // dedupe too — handing schedulers a peculiar empty-array shape is
+  // unhelpful).
+  if (candidates.length === 0) return;
+
+  // 8. Build SchedulerInput. v0 capacity stub: empty object.
+  // 9. Evaluate inside a try/catch. A throw fail-loud-skips the
+  //    entire tick — no rows for any writ in this tick.
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 10. Decision validation. Stranger writIds are filter-and-warned;
+  //     multi-decision-per-writ fail-loud-skips the entire tick.
+  const candidateIds = new Set<string>(candidates.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof (decision as SchedulerDecision).writId !== 'string' ||
+      (decision as SchedulerDecision).writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate. Skipping the entire tick.`,
+      );
+      return;
+    }
+  }
+
+  // 11. Apply each decision per writ. A candidate with no decision
+  //     is treated as a defer-equivalent no-op (no row, no
+  //     transition) — the scheduler chose not to emit for it.
+  for (const writ of candidates) {
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) continue;
+
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+
+    if (decision.outcome === 'defer') {
+      // D3: scheduler-emitted defer now writes a row. deferReason is
+      //     the freeform 'other' bucket; the decision's reason is
+      //     threaded onto deferNote so the audit trail carries the
+      //     scheduler's lineage string.
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'approve') {
+      let target: string;
+      try {
+        target = ctx.resolveActiveTargetPhase(writ);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+        );
+        continue;
+      }
+
+      try {
+        await ctx.clerk.transition(writ.id, target as WritPhase, {});
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+        );
+        continue;
+      }
+
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'accepted',
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unknown outcome — log + ignore. Keep the writ in `new`; no
+    //   row, no transition.
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" returned an unknown outcome "${String(
+        (decision as { outcome?: unknown }).outcome,
+      )}" for writ "${writ.id}" — ignoring.`,
+    );
+  }
+}
+
+// ── Source-gate helper ──────────────────────────────────────────────
+
+interface SourceDeclineParams {
+  writ: WritDoc;
+  ext: ReckonerExt;
+  now: Date;
+  tickEventId: string | undefined;
+  declineReason: 'source_banned' | 'source_unregistered';
+  resolution: string;
+  remediationHint: string;
+}
+
+/**
+ * Drive the cancelled transition + write the decline row for one
+ * source-gate failure. Shared between the disabled-source and
+ * unregistered-strict paths so both fall through to one row-shape
+ * builder, differing only in `declineReason` and the resolution
+ * string.
+ */
+async function applySourceDecline(
+  ctx: TickHandlerContext,
+  params: SourceDeclineParams,
+): Promise<void> {
+  try {
+    await ctx.clerk.transition(
+      params.writ.id,
+      'cancelled' as WritPhase,
+      { resolution: params.resolution },
+    );
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${params.writ.id}" to cancelled (${params.declineReason}): ${msg}`,
+    );
+    return;
+  }
+
+  const row = ctx.buildReckoningRow({
+    now: params.now,
+    writ: params.writ,
+    ext: params.ext,
+    outcome: 'declined',
+    declineReason: params.declineReason,
+    remediationHint: params.remediationHint,
+    ...(params.tickEventId !== undefined ? { tickEventId: params.tickEventId } : {}),
+  });
+  try {
+    await ctx.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${params.writ.id}" (${params.declineReason}): ${msg}`,
+    );
+  }
+}
+
+// ── Relay factory ───────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. Exported so the
+ * apparatus boot path can wire it into `supportKit.relays`.
+ *
+ * The factory takes a context **builder** rather than a context
+ * directly because `apparatus.supportKit.relays` is assembled at
+ * apparatus-construction time — before `start()` has primed the
+ * closure-scoped `clerk` / `stacks` / `reckoningsBook` references.
+ * The builder is invoked lazily on each fire so the handler always
+ * sees the post-`start()` closure state.
+ */
+export function createTickRelay(getContext: () => TickHandlerContext): RelayDefinition {
+  return relay({
+    name: TICK_RELAY_NAME,
+    description:
+      'Sweep held petitions through the active scheduler. Fired periodically via the apparatus-contributed `@every 60s` standing order.',
+    handler: async (event, _relayContext) => {
+      await runTickHandler(getContext(), event);
+    },
+  });
+}
