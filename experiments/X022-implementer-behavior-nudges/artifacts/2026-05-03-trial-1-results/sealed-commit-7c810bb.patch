+/**
+ * `reckoner.tick` — periodic Reckoner evaluation relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` so any guild that
+ * installs the Reckoner alongside the Clockworks dispatches the tick
+ * relay every minute via the kit-contributed default standing order:
+ *
+ *   { schedule: '@every 60s', run: 'reckoner.tick' }
+ *
+ * Replaces the per-writ-update CDC evaluation path that v0 of the
+ * Reckoner shipped. The tick is the canonical evaluation entry: every
+ * fire re-reads the held-petition set, applies source/disabled gates,
+ * builds a single `SchedulerInput` for the entire candidate set, and
+ * applies each scheduler decision. Schedulers that need a global view
+ * of the candidate set (priority-walk, capacity-aware) get one in
+ * exactly one place.
+ *
+ * Per-fire sequence (the brief pins this; a `// step:` comment marks
+ * each step in {@link runReckonerTick}):
+ *
+ *   1. Resolve the active scheduler (closure-injected). Throw fail-loud
+ *      if it is not yet resolved — the tick fires post-seal in
+ *      production; tripping this branch is a fixture-ordering bug
+ *      (D8).
+ *   2. Re-read and validate `reckoner.schedulerConfig`. Throw inside
+ *      `validateConfig` is fail-loud-skip the tick — log and return
+ *      without writing rows.
+ *   3. Query held petitions: writs in their initial phase (today's
+ *      literal `phase = 'new'` query shape, mirroring the prior
+ *      `runCatchUpScan`) carrying `ext.reckoner`.
+ *   4. Apply source/disabled gates. Disabled-source writs produce a
+ *      `declined` row with `declineReason: 'source_banned'` and the
+ *      source name in `remediationHint`, then transition to the
+ *      cancelled target phase (D2). Unregistered-strict writs follow
+ *      the existing `source_unregistered` shape.
+ *   5. Dedupe candidates against `alreadyConsidered((writId,
+ *      writUpdatedAt))` *before* building `SchedulerInput` (D7).
+ *      Already-considered writs never reach the scheduler.
+ *   6. Empty candidate set → early-return (D10). No rows, no errors.
+ *   7. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 capacity stub; call `evaluate`. Throw inside
+ *      `evaluate` fails-loud-skips the entire tick (no rows written
+ *      for any writ in the tick).
+ *   8. Validate decisions. Filter-and-warn on stranger writIds (apply
+ *      only in-scope decisions). Fail-loud-skip the whole tick on any
+ *      multi-decision-per-writ (D9).
+ *   9. Apply each decision: `approve` → transition to active target
+ *      via `resolveActiveTargetPhase`; `decline` → transition to the
+ *      cancelled target with the decision's reason as the resolution
+ *      string; `defer` → no transition. Append one Reckonings row per
+ *      writ considered (D3 maps `defer` to `deferReason: 'other'` plus
+ *      the decision reason in `deferNote`).
+ *
+ * The relay handler runs through the closure-scoped state of the
+ * Reckoner apparatus — the active scheduler reference, the registry,
+ * the Reckonings book, the config resolvers, the type-aware target
+ * resolver. The {@link buildReckoner} factory constructs a
+ * {@link TickContext} once at `start()` and passes it into both
+ * {@link createTickRelay} (for the production wiring) and the
+ * test-only {@link runTick} hook.
+ *
+ * The `tickEventId` field on the Reckonings row is stamped from the
+ * triggering Clockworks `clockworks.timer` event id when present and
+ * omitted when absent (D6) — synthesizing a fallback would pollute
+ * rows with non-joinable identifiers.
+ *
+ * See: docs/architecture/apparatus/reckoner.md (Schedulers section)
+ * and docs/architecture/reckonings-book.md (`tickEventId` field).
+ */
+
+import type { GuildEvent, RelayDefinition } from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+import type {
+  Book,
+  ReadOnlyBook,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+
+import type {
+  ReckoningDoc,
+  ReckonerExt,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/**
+ * Plugin id stamped on `writ.ext['reckoner']` — duplicated from
+ * `reckoner.ts` because a tick handler reaches for the slot directly
+ * when projecting the held-writ extension and a single cross-file
+ * import would create a circular dependency at the file granularity.
+ * Kept in lockstep with the reckoner.ts constant; if they ever drift,
+ * the tick runs against a different ext slot than `petition()` writes.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * Resolved view of `guild.json reckoner.{enforceRegistration,
+ * disabledSources}` produced by the Reckoner's `resolveConfig` helper.
+ * Re-declared here as the structural shape the tick reads to keep the
+ * tick file's import surface narrow. Mirrors the type returned by
+ * `resolveConfig` byte-faithfully — any drift surfaces as a typecheck
+ * failure where the context is constructed.
+ */
+export interface TickResolvedConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Aggregated dependency-gate outcome for one held petition. Mirrors the
+ * type produced by the Reckoner's `evaluateDependencyGate`. The tick
+ * inspects `kind` to decide between proceeding to the scheduler call
+ * and writing a deferred row.
+ */
+export type TickDependencyOutcome =
+  | { kind: 'proceed' }
+  | { kind: 'defer-pending'; gatingIds: string[] }
+  | { kind: 'defer-failed'; failedIds: string[] };
+
+/**
+ * Dependency context handed to the tick handler. Keeps every closure-
+ * scoped Reckoner concern explicit at the call boundary so the pure
+ * helper {@link runReckonerTick} can be unit-tested without booting
+ * Clockworks (D11). The apparatus factory constructs one of these at
+ * `start()` and reuses it for both the production relay and the
+ * test-only hook.
+ */
+export interface TickContext {
+  /**
+   * Apparatus handles. Resolved during the Reckoner's `start()`. The
+   * tick path queries the writs book, transitions writs, and writes to
+   * the Reckonings book through these.
+   */
+  clerk(): ClerkApi;
+  stacks(): StacksApi;
+  reckoningsBook(): Book<ReckoningDoc> | undefined;
+
+  /**
+   * Active scheduler accessor. Returns `undefined` pre-seal (the
+   * apparatus has not fired `phase:started` yet) so the tick handler
+   * can throw fail-loud at handler entry (D8).
+   */
+  activeScheduler(): Scheduler | undefined;
+
+  /**
+   * Re-read the validated `enforceRegistration` / `disabledSources`
+   * config block per call. The tick uses this for its source/disabled
+   * gate. Throws fail-loud on bad operator input (delegated to the
+   * resolver in reckoner.ts).
+   */
+  resolveConfig(): TickResolvedConfig;
+
+  /**
+   * Re-read the raw `reckoner.schedulerConfig` slot per call. The tick
+   * runs `Scheduler.validateConfig` on the result before each
+   * `evaluate` call.
+   */
+  resolveSchedulerConfig(): unknown;
+
+  /**
+   * Reach into the closure-scoped petitioner registry. Used by the
+   * tick's source-registry gate. `true` iff the source has been
+   * declared in a `petitioners` kit contribution.
+   */
+  isSourceRegistered(source: string): boolean;
+
+  /**
+   * Compute the type-aware target active phase for a writ. The tick
+   * uses this on the approve path. Throws fail-loud on missing /
+   * ambiguous active candidates per the resolver's existing contract.
+   */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+
+  /**
+   * `(writId, writUpdatedAt)` dedupe lookup against the Reckonings
+   * book. Identical to the per-call helper today's CDC path used.
+   * Returns `true` iff a non-deferred row already exists for the
+   * pair.
+   */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+
+  /**
+   * Walk a held writ's outbound `depends-on` links and aggregate the
+   * per-target classifications. Carries forward the per-call dependency
+   * gate verbatim — the v0 dependency-aware-consideration commission
+   * shipped this aggregator and the tick reuses it unchanged. Returns
+   * a {@link TickDependencyOutcome} the handler maps to a deferred row
+   * or to a green-light into the scheduler call.
+   */
+  evaluateDependencyGate(writId: string): Promise<TickDependencyOutcome>;
+
+  /**
+   * Format the `deferNote` for a dependency-defer Reckonings row
+   * (`gating: <id>, <id>` or `failed: <id>, <id>`). Mirrors the per-
+   * call helper's deterministic-shape contract — the tick's no-op-row
+   * suppression keys on byte-identical notes between repeated
+   * evaluations at the same outcome.
+   */
+  buildDependencyDeferNote(
+    kind: 'defer-pending' | 'defer-failed',
+    ids: readonly string[],
+  ): string;
+
+  /**
+   * Look up the writ's most-recent deferred Reckonings row. The tick
+   * uses this for no-op-row suppression on dependency-defer paths:
+   * re-evaluating at the same `(deferReason, deferNote)` shape on a
+   * subsequent tick produces no row.
+   */
+  findLastDeferredRow(
+    book: Book<ReckoningDoc>,
+    writId: string,
+  ): Promise<ReckoningDoc | undefined>;
+
+  /**
+   * Build one Reckonings row from the in-flight consideration state.
+   * Mirrors the per-call `buildReckoningRow`. The tick passes the
+   * triggering event id when available so the resulting row carries
+   * a populated `tickEventId` (D6).
+   */
+  buildReckoningRow(params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    outcome: 'accepted' | 'declined' | 'deferred';
+    declineReason?: ReckoningDoc['declineReason'];
+    remediationHint?: string;
+    deferReason?: ReckoningDoc['deferReason'];
+    deferNote?: string;
+    weight?: number;
+    tickEventId?: string;
+  }): ReckoningDoc;
+}
+
+// ── Relay factory ────────────────────────────────────────────────────
+
+/**
+ * Construct the `reckoner.tick` `RelayDefinition`. The factory captures
+ * the apparatus's {@link TickContext} once and reuses it on every
+ * fire. The handler delegates to {@link runReckonerTick} so the same
+ * code path drives both the production relay and the test-only
+ * `runTick` hook.
+ */
+export function createTickRelay(context: TickContext): RelayDefinition {
+  return relay({
+    name: 'reckoner.tick',
+    description:
+      'Periodic Reckoner evaluation. Re-reads every held petition and ' +
+      'runs the active scheduler over the full candidate set.',
+    handler: async (event) => {
+      await runReckonerTick(context, event);
+    },
+  });
+}
+
+// ── Pure handler body (exported for tests) ───────────────────────────
+
+/**
+ * Execute one tick of Reckoner evaluation. Pure with respect to the
+ * Reckoner's closure state — every dependency is supplied through
+ * {@link TickContext}. See the file header for the per-fire sequence.
+ *
+ * @param ctx   Apparatus state injection point (closure-scoped in
+ *              production, test-built fixture in unit tests).
+ * @param event The triggering Clockworks `clockworks.timer` event when
+ *              fired through the standing-order path; `null` when the
+ *              tick is invoked directly (test-only `runTick(null)`).
+ */
+export async function runReckonerTick(
+  ctx: TickContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // step 1: pre-seal guard. The apparatus resolves the active
+  // scheduler at phase:started; firing the tick before then is a
+  // fixture-ordering bug, not a production condition. Throw with a
+  // grep-able prefix so test fixtures see a deterministic loud signal
+  // (D8).
+  const scheduler = ctx.activeScheduler();
+  if (!scheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  const reckoningsBook = ctx.reckoningsBook();
+  if (!reckoningsBook) {
+    // Defensive — the apparatus binds the book handle in start()
+    // before any tick can fire. Returning silently here is the same
+    // policy used by considerWrit's pre-handle guard.
+    return;
+  }
+
+  // step 2: re-read + validate `reckoner.schedulerConfig`. A throw
+  // from validateConfig is fail-loud-skip the entire tick.
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof scheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = scheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" validateConfig threw — skipping this tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // step 3: query held petitions. The literal-phase query shape is
+  // carried forward verbatim from the prior runCatchUpScan; the
+  // commission explicitly does not generalise to non-`'new'` initial
+  // states in this tick.
+  const writsBook: ReadOnlyBook<WritDoc> = ctx.stacks().readBook<WritDoc>(
+    'clerk',
+    'writs',
+  );
+  const heldRaw = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+
+  // Cheap pre-filter — only writs carrying ext.reckoner participate.
+  // Mirrors the prior runCatchUpScan's per-writ skip.
+  const held: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const writ of heldRaw) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    held.push({ writ, ext });
+  }
+
+  // Sample now once per tick (D17 in the per-call path; same idea
+  // hoisted to the tick boundary). Reused for row ids and
+  // consideredAt timestamps so every row written by this tick
+  // shares a deterministic instant.
+  const now = new Date();
+  const tickEventId = event?.id;
+
+  // step 4: source/disabled gates. Walk the held set inline; each
+  // gate failure transitions the writ + writes a decline row, then
+  // drops the writ from the candidate set so the scheduler never
+  // sees it.
+  const config = ctx.resolveConfig();
+  const clerk = ctx.clerk();
+  const cancelledTarget: WritPhase = 'cancelled';
+  const surviving: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+
+  for (const candidate of held) {
+    const { writ, ext } = candidate;
+
+    // Disabled-source gate (D2): symmetric with the unregistered-
+    // strict decline. Source-banned rows carry the source name in
+    // remediationHint so operators can grep for it the same way.
+    if (config.disabledSources.includes(ext.source)) {
+      if (await ctx.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+        // The disabled-source decline already landed for this
+        // writ-version. Skip silently — the writ is in the process of
+        // being cancelled by an earlier transition that has not yet
+        // surfaced through the writs book this tick is reading.
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is in disabledSources.`;
+      try {
+        await clerk.transition(writ.id, cancelledTarget, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (disabled-source decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unregistered-strict gate. Same shape as the per-call decline:
+    // declineReason 'source_unregistered', the source in
+    // remediationHint, the existing resolution-string template.
+    const isRegistered = ctx.isSourceRegistered(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      if (await ctx.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+      try {
+        await clerk.transition(writ.id, cancelledTarget, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (unregistered-strict decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (unregistered-strict decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    surviving.push(candidate);
+  }
+
+  // Dependency-aware consideration gate. Runs every tick *outside*
+  // the (writId, writUpdatedAt) dedupe (which sits below this
+  // block) so a dep-deferred writ keeps being re-evaluated as its
+  // dependencies clear. The row write is dedupe-aware via the
+  // no-op-row suppression — re-evaluation at the same
+  // (deferReason, deferNote) shape produces no second row.
+  const dependencyCleared: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const candidate of surviving) {
+    const { writ, ext } = candidate;
+
+    let depOutcome: TickDependencyOutcome;
+    try {
+      depOutcome = await ctx.evaluateDependencyGate(writ.id);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: dependency gate threw for writ "${writ.id}" — leaving in new without a row. ${msg}`,
+      );
+      continue;
+    }
+
+    if (depOutcome.kind === 'proceed') {
+      dependencyCleared.push(candidate);
+      continue;
+    }
+
+    const reason: ReckoningDoc['deferReason'] =
+      depOutcome.kind === 'defer-failed' ? 'dependency_failed' : 'dependency_pending';
+    const ids =
+      depOutcome.kind === 'defer-failed' ? depOutcome.failedIds : depOutcome.gatingIds;
+    const deferNote = ctx.buildDependencyDeferNote(depOutcome.kind, ids);
+
+    // No-op-row suppression: same outcome shape as the writ's
+    // most-recent deferred row → no new row.
+    const last = await ctx.findLastDeferredRow(reckoningsBook, writ.id);
+    if (last && last.deferReason === reason && last.deferNote === deferNote) {
+      continue;
+    }
+
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'deferred',
+      deferReason: reason,
+      deferNote,
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (dependency-defer): ${msg}`,
+      );
+    }
+  }
+
+  // step 5: dedupe pre-scheduler (D7). Already-considered writs at
+  // the same writUpdatedAt never reach the scheduler. Note that
+  // `alreadyConsidered` skips deferred rows — a dependency-deferred
+  // writ must remain free to advance once its deps clear.
+  const dedupedCandidates: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const candidate of dependencyCleared) {
+    if (
+      await ctx.alreadyConsidered(
+        reckoningsBook,
+        candidate.writ.id,
+        candidate.writ.updatedAt,
+      )
+    ) {
+      continue;
+    }
+    dedupedCandidates.push(candidate);
+  }
+
+  // step 6: empty candidate set → early return. Skips the scheduler
+  // call entirely (D10) — schedulers should not be handed an
+  // empty-array input shape.
+  if (dedupedCandidates.length === 0) {
+    return;
+  }
+
+  // step 7: build SchedulerInput + call evaluate. v0 capacity stub.
+  // Throw fails-loud-skips the entire tick.
+  const candidates = dedupedCandidates.map((c) => c.writ);
+  const candidateById = new Map<string, { writ: WritDoc; ext: ReckonerExt }>();
+  for (const c of dedupedCandidates) {
+    candidateById.set(c.writ.id, c);
+  }
+
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await scheduler.evaluate({
+      candidates,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${scheduler.id}" evaluate threw — skipping this tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${scheduler.id}" evaluate did not return an array — skipping this tick.`,
+    );
+    return;
+  }
+
+  // step 8: validate decisions. Stranger writIds are filtered with a
+  // warn (apply only in-scope); multi-decision-per-writ aborts the
+  // whole tick — applying ambiguous decisions is unsafer than
+  // skipping (D9).
+  const candidateIds = new Set(candidateById.keys());
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${scheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate.`,
+      );
+      return;
+    }
+  }
+
+  // step 9: apply decisions + write rows.
+  for (const candidate of dedupedCandidates) {
+    const { writ, ext } = candidate;
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) {
+      // No decision for this candidate — defer-equivalent. v0 carries
+      // forward the per-call "no decision = no row" semantics for
+      // candidates the scheduler simply did not weigh in on, separate
+      // from the explicit `defer` outcome below.
+      continue;
+    }
+
+    if (decision.outcome === 'defer') {
+      // D3: scheduler-emitted defer writes a row but no transition.
+      // Map to deferReason 'other' + the decision reason in deferNote
+      // (mirrors decline's 'other' + remediationHint pattern).
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await clerk.transition(writ.id, cancelledTarget, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'approve') {
+      let target: string;
+      try {
+        target = ctx.resolveActiveTargetPhase(writ);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+        );
+        continue;
+      }
+
+      try {
+        await clerk.transition(writ.id, target as WritPhase, {});
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'accepted',
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unknown outcome — log + skip.
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${scheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+  }
+}
