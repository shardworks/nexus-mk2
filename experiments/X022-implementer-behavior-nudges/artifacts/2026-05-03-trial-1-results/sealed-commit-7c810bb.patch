@@ -0,0 +1,747 @@
+/**
+ * Reckoner tick handler tests.
+ *
+ * Covers the behavioral cases enumerated in the periodic-tick
+ * commission's Acceptance Signal:
+ *
+ *   1. empty-candidate ticks — no rows, no errors.
+ *   2. first tick after start picks up pre-existing held petitions.
+ *   3. evaluate-throw isolation — apparatus stays up, no rows
+ *      written, the next tick's writs are unaffected.
+ *   4. disabled-source mid-flight — produces a `'declined'` row with
+ *      `declineReason: 'source_banned'` and transitions to
+ *      cancelled.
+ *   5. repeated-tick idempotency — same `(writId, writUpdatedAt)`
+ *      across two ticks produces exactly one accepted row.
+ *   6. type-aware target-phase resolution — `mandate` lands in
+ *      `'open'`; non-mandate types land in their declared active
+ *      state.
+ *   7. withdrawal-mid-flight — a petitioner withdrawal between
+ *      two ticks produces no Reckonings row.
+ *   8. scheduler-emitted `defer` outcome — writes a deferred row
+ *      with `deferReason: 'other'` and the decision reason in
+ *      `deferNote`; no transition.
+ *   9. fail-loud on pre-seal tick — calling `runTick` before
+ *      `phase:started` throws an `[reckoner] tick: activeScheduler
+ *      not resolved` error.
+ *  10. `tickEventId` is stamped on rows when the synthetic event
+ *      carries an id; absent when the test fires `runTick(null)`.
+ *
+ * Fixture mirrors the structural pattern from
+ * `reckoner-scheduler.test.ts` — real Stacks + Clerk + Reckoner
+ * against MemoryBackend, with explicit book pre-creation. The new
+ * `runTick` hook drives the tick handler directly through the same
+ * pure helper the production relay invokes; this matches the prior
+ * `handleWritsChange` / `runCatchUpScan` test pattern but against
+ * the new evaluation entry.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /**
+   * Re-fire `phase:started` against the registered handlers. The
+   * Reckoner's seal handler resolves the active scheduler so the
+   * next tick can run.
+   */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  /** When true, do not include the built-in always-approve scheduler. */
+  omitDefaultScheduler?: boolean;
+  /** When true, do not fire phase:started after start (pre-seal tests). */
+  skipPhaseStarted?: boolean;
+  config?: ReckonerConfig | undefined;
+  /** Optional non-mandate writ types to register on the Clerk. */
+  writTypes?: WritTypeConfig[];
+  /** Pre-seed writs / state before the Reckoner starts. */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the Clerk and Reckoner expect — Stacks' Wire
+  // phase would do this in production from the supportKit
+  // declarations.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler): void {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [];
+  if (!opts.omitDefaultScheduler) {
+    schedulerKitEntries.push({
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    });
+  }
+  for (const entry of opts.schedulerKits ?? []) {
+    schedulerKitEntries.push({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    });
+  }
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+/** Build a synthetic `clockworks.timer` event for the tick path. */
+function timerEvent(idSuffix: string): GuildEvent {
+  return {
+    id: `e-${idSuffix}`,
+    name: 'clockworks.timer',
+    payload: {},
+    emitter: 'clockworks',
+    firedAt: new Date().toISOString(),
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => {
+    clearGuild();
+  });
+
+  // ── 1: empty-candidate ticks — no rows, no errors ────────────────
+
+  describe('empty candidate set', () => {
+    it('writes nothing when there are no held petitions', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+
+      await fix.hooks.runTick(timerEvent('empty'));
+
+      const all = await fix.reckoningsBook.find({});
+      assert.equal(all.length, 0, 'empty tick produces no Reckonings rows');
+    });
+
+    it('writes nothing when held writs all skip the ext gate', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+
+      // A bare writ with no ext.reckoner — should not be considered.
+      await fix.clerk.post({ title: 't', body: 'b' });
+      await fix.hooks.runTick(timerEvent('no-ext'));
+
+      const all = await fix.reckoningsBook.find({});
+      assert.equal(all.length, 0, 'bare writ produces no rows');
+    });
+  });
+
+  // ── 2: first tick after start picks up pre-existing held petitions ─
+
+  describe('pre-existing held petitions', () => {
+    it('first tick after start picks them up and approves through always-approve', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        // Seed a held writ before the Reckoner starts. The tick path
+        // is the only entry that processes pre-existing held writs.
+        async preStart({ clerk }) {
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'tester.kind',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Before the tick fires, the pre-existing held writ is still
+      // in `new` — phase:started just sealed the registry; no
+      // catch-up scan replaces the tick.
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      assert.equal(all[0]!.phase, 'new', 'pre-existing held writ stays in new before the first tick');
+
+      await fix.hooks.runTick(timerEvent('first'));
+
+      const reread = await fix.clerk.show(all[0]!.id);
+      assert.equal(reread.phase, 'open', 'first tick auto-approves the pre-existing writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', all[0]!.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+      assert.equal(rows[0]!.tickEventId, 'e-first', 'tickEventId is stamped from the triggering event');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ──────────────────────────────────
+
+  describe('evaluate throw', () => {
+    it('skips the tick without writing rows or transitioning writs', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad-evaluate',
+        description: 'throws on every evaluate',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-evaluate' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick(timerEvent('throw'));
+
+        const reread = await fix.clerk.show(writ.id);
+        assert.equal(reread.phase, 'new', 'evaluate throw leaves writs in new');
+
+        const rows = await fix.reckoningsBook.find({
+          where: [['writId', '=', writ.id]],
+        });
+        assert.equal(rows.length, 0, 'no rows on evaluate throw');
+        assert.ok(
+          warnings.some(
+            (w) =>
+              /\[reckoner\] tick:/.test(w) &&
+              /evaluate threw/.test(w),
+          ),
+          `expected fail-loud log line; got: ${JSON.stringify(warnings)}`,
+        );
+      } finally {
+        console.warn = originalWarn;
+      }
+    });
+  });
+
+  // ── 4: disabled-source mid-flight ────────────────────────────────
+
+  describe('disabled source mid-flight', () => {
+    it('writes a declined row with source_banned and transitions to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        // No initial disable — petition lands in `new` first.
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      // Before the tick fires, mid-flight-disable the source. The
+      // writ is still in `new`; the next tick observes the disabled
+      // source and writes the source_banned decline + transitions
+      // to cancelled.
+      fix.fakeGuildConfig.reckoner = {
+        disabledSources: ['tester.kind'],
+      };
+
+      await fix.hooks.runTick(timerEvent('banned'));
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled', 'disabled-source decline transitions to cancelled');
+      assert.match(
+        String(reread.resolution ?? ''),
+        /\[reckoner\] declined: source 'tester\.kind' is in disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'tester.kind');
+    });
+
+    it('writes a declined row with source_unregistered when enforceRegistration is true', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [],
+        config: { enforceRegistration: true },
+      });
+
+      // The petition helper itself fail-loud rejects unregistered
+      // sources under strict registration; to drive the tick path,
+      // post the writ + ext via Clerk directly so the held petition
+      // exists without going through the helper's gate.
+      const writ = await fix.clerk.post({ title: 't', body: 'b' });
+      await fix.clerk.setWritExt(writ.id, 'reckoner', {
+        source: 'unknown.source',
+        priority: {
+          visionRelation: 'vision-neutral',
+          severity: 'minor',
+          scope: 'minor-area',
+          time: { decay: false, deadline: null },
+          domain: [],
+        },
+      });
+
+      await fix.hooks.runTick(timerEvent('unreg'));
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+      assert.match(
+        String(reread.resolution ?? ''),
+        /\[reckoner\] declined: source 'unknown\.source' is not registered \(enforceRegistration: true\)\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_unregistered');
+      assert.equal(rows[0]!.remediationHint, 'unknown.source');
+    });
+  });
+
+  // ── 5: repeated-tick idempotency ─────────────────────────────────
+
+  describe('repeated-tick idempotency', () => {
+    it('writes exactly one accepted row for the same writ across two ticks', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      await fix.hooks.runTick(timerEvent('a'));
+
+      const acceptedFirst = await fix.clerk.show(writ.id);
+      assert.equal(acceptedFirst.phase, 'open');
+
+      // The second tick observes a writ no longer in `new`; the
+      // initial-phase query naturally filters it out and the
+      // dedupe lookup never even fires. Either way: no second row.
+      await fix.hooks.runTick(timerEvent('b'));
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1, 'second tick does not produce a duplicate accepted row');
+    });
+  });
+
+  // ── 6: type-aware target-phase resolution ───────────────────────
+
+  describe('type-aware target-phase resolution', () => {
+    it('approves a mandate writ into `open`', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick(timerEvent('mandate'));
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open');
+      assert.equal(reread.type, 'mandate');
+    });
+
+    it('approves a non-mandate writ into its registered active state', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        writTypes: [
+          {
+            name: 'task',
+            states: [
+              {
+                name: 'new',
+                classification: 'initial',
+                allowedTransitions: ['running', 'cancelled'],
+              },
+              {
+                name: 'running',
+                classification: 'active',
+                allowedTransitions: ['done', 'cancelled'],
+              },
+              {
+                name: 'done',
+                classification: 'terminal',
+                attrs: ['success'],
+                allowedTransitions: [],
+              },
+              {
+                name: 'cancelled',
+                classification: 'terminal',
+                attrs: ['cancelled'],
+                allowedTransitions: [],
+              },
+            ],
+          },
+        ],
+      });
