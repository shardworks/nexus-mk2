@@ -0,0 +1,593 @@
+/**
+ * `reckoner.tick` — periodic-tick relay.
+ *
+ * The Reckoner's canonical evaluation surface in v0. Wired into the
+ * apparatus's `supportKit.relays` so every guild that installs the
+ * Reckoner alongside the Clockworks gets a default standing order of
+ * the shape:
+ *
+ *   { schedule: '@every 60s', run: 'reckoner.tick' }
+ *
+ * (contributed under `supportKit.standingOrders` from the same
+ * apparatus, with no `id` field — operators can append their own
+ * standing orders but cannot disable or override this one).
+ *
+ * On each fire the handler:
+ *
+ *   1. Resolves the active scheduler (D8) — throws fail-loud when
+ *      `phase:started` has not yet sealed the registries; production
+ *      never trips this gate, test fixtures get a deterministic
+ *      diagnostic.
+ *   2. Re-reads `reckoner.schedulerConfig` from `guild.json` and runs
+ *      the scheduler's optional `validateConfig` narrower. A throw
+ *      from `validateConfig` is fail-loud-skip — the entire tick is
+ *      abandoned and no rows are written.
+ *   3. Queries the held-petition candidate set from `clerk/writs`
+ *      using the same `phase = 'new' + ext.reckoner present` shape
+ *      the legacy `runCatchUpScan` used.
+ *   4. Applies the source / disabled gates inline: writs whose source
+ *      is in `disabledSources` produce a `declined` row carrying
+ *      `declineReason: 'source_banned'` plus the source name in
+ *      `remediationHint` (D2) and transition to the type's cancelled
+ *      target. Writs whose source is unregistered under
+ *      `enforceRegistration: true` decline + transition with the
+ *      existing `source_unregistered` shape and resolution string.
+ *   5. Filters the surviving candidate set against the persisted
+ *      `(writId, writUpdatedAt)` dedupe lookup (D7) — already-
+ *      considered writs never reach the scheduler.
+ *   6. Builds one `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 capacity stub and calls `evaluate` inside a
+ *      try/catch. Any throw fail-loud-skips the entire tick (no
+ *      rows for any writ).
+ *   7. Validates the returned decisions: stranger writIds are
+ *      filter-and-warn (the in-scope decisions still apply); a
+ *      multi-decision-per-writ shape fail-loud-skips the entire tick
+ *      (no rows for any writ). (D9)
+ *   8. Applies each decision: `approve` transitions to the type's
+ *      active target via `resolveActiveTargetPhase`; `decline`
+ *      transitions to the cancelled target with the decision's
+ *      reason as the resolution string and writes a row carrying
+ *      `declineReason: 'other'` plus the reason in `remediationHint`;
+ *      `defer` writes a row carrying `deferReason: 'other'` plus the
+ *      decision's reason in `deferNote` and does not transition (D3).
+ *   9. Stamps `tickEventId` from the triggering `clockworks.timer`
+ *      event id when present; omits the field when the handler is
+ *      driven directly with no event (D6).
+ *
+ * Source-file layout follows the established stdlib-relay pattern
+ * (`summon-relay.ts`, `decline-relay.ts`): the relay factory and a
+ * pure handler-body helper sit in this sibling file. The pure helper
+ * (`runReckonerTick`) lets unit tests drive the tick deterministically
+ * without booting Clockworks; the apparatus boot path wires the relay
+ * factory into `supportKit.relays`.
+ *
+ * See: docs/architecture/apparatus/reckoner.md (Schedulers section)
+ * and docs/architecture/reckonings-book.md (tick identity).
+ */
+
+import type {
+  GuildEvent,
+  RelayDefinition,
+} from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+// ── Public relay name ───────────────────────────────────────────────
+
+/**
+ * The relay name registered with Clockworks. Matches the apparatus's
+ * existing contributed-id grammar (`{pluginId}.{kebab-suffix}`).
+ * Standing orders reference this verbatim under the `run:` key.
+ */
+export const TICK_RELAY_NAME = 'reckoner.tick';
+
+// ── Plugin id stamped on `writ.ext['reckoner']` ─────────────────────
+
+/**
+ * Re-declared locally so the tick handler does not have to reach back
+ * across a circular import into `reckoner.ts`. The constant is the
+ * contract — every consumer keys on this string.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+// ── Dependency context ─────────────────────────────────────────────
+
+/**
+ * Dependency-injection bag handed to the pure handler. The Reckoner's
+ * `start()` builds one of these once and closes over the same state
+ * the legacy CDC handler used; tests can construct a stub context
+ * with the bare minimum each behavioral case needs.
+ *
+ * The accessors are pulled out of the closure (rather than the
+ * closure-scoped values themselves) so the `activeScheduler` and
+ * `schedulerConfig` lookups always read the live values — the
+ * scheduler resolves at `phase:started` (post-construction) and the
+ * config block is re-read on every consideration.
+ */
+export interface TickContext {
+  /** Clerk handle — used for `transition` and `getWritTypeConfig`. */
+  clerk: ClerkApi;
+  /** Stacks handle — used for `readBook<WritDoc>('clerk', 'writs')`. */
+  stacks: StacksApi;
+  /** Reckonings book handle — the row writer. */
+  reckoningsBook: import('@shardworks/stacks-apparatus').Book<ReckoningDoc>;
+  /** Lookup: registered petitioner sources. */
+  isRegistered(source: string): boolean;
+  /** Re-read the live `reckoner.{enforceRegistration, disabledSources}`. */
+  resolveConfig(): {
+    enforceRegistration: boolean;
+    disabledSources: string[];
+  };
+  /** Re-read the raw `reckoner.schedulerConfig` slot. */
+  resolveSchedulerConfig(): unknown;
+  /** Currently-resolved active scheduler, or undefined pre-seal. */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Idempotency lookup against the `(writId, writUpdatedAt)` dedupe. */
+  alreadyConsidered(writId: string, writUpdatedAt: string): Promise<boolean>;
+  /** Type-aware target-phase resolver for an approved writ. */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /** Build a Reckoning row from the in-flight consideration state. */
+  buildReckoningRow(params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    outcome: 'accepted' | 'declined' | 'deferred';
+    declineReason?: ReckoningDoc['declineReason'];
+    remediationHint?: string;
+    deferReason?: ReckoningDoc['deferReason'];
+    deferNote?: string;
+    weight?: number;
+    tickEventId?: string;
+  }): ReckoningDoc;
+}
+
+// ── Pure handler body ───────────────────────────────────────────────
+
+/**
+ * Run one Reckoner tick against the supplied context. The pure form
+ * the relay factory wraps and tests drive directly. Returns nothing —
+ * outcomes land as Reckonings rows and Clerk transitions.
+ *
+ * `event` is the triggering Clockworks event when the tick is fired
+ * by a standing order; tests pass `null` (or omit) when invoking the
+ * handler directly without a triggering event. `tickEventId` on the
+ * Reckonings row stamps from `event.id` when present and is omitted
+ * otherwise (D6).
+ */
+export async function runReckonerTick(
+  ctx: TickContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // 1. Pre-seal guard (D8) — throw fail-loud rather than silent-skip.
+  //    Production never trips it because the standing order cannot
+  //    fire before Clockworks's own start, which runs after Arbor's
+  //    `phase:started` signal has sealed the Reckoner registries.
+  const activeScheduler = ctx.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  const tickEventId = event?.id;
+
+  // 2. Re-read + validate `reckoner.schedulerConfig`. A throw from
+  //    validateConfig fail-loud-skips the entire tick (no rows).
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // 3. Query held-petition candidate set. Same `phase = 'new'` find
+  //    shape the legacy `runCatchUpScan` used; we read the writs
+  //    book directly to surface every type whose initial state is
+  //    literally `'new'`. Type-agnostic generalisation is parked.
+  const writsBook: ReadOnlyBook<WritDoc> = ctx.stacks.readBook<WritDoc>(
+    'clerk',
+    'writs',
+  );
+  const allHeld = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+  // Pre-filter: drop writs without a Reckoner ext slot up-front so
+  // they never enter the source/disabled-gate logic or the dedupe
+  // lookup.
+  const heldPetitions: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const writ of allHeld) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    heldPetitions.push({ writ, ext });
+  }
+
+  // 4. Empty candidate set → write nothing, skip the scheduler call
+  //    (D10). Cheap and avoids handing schedulers a peculiar empty-
+  //    array input.
+  if (heldPetitions.length === 0) return;
+
+  // Sample `now` once at handler entry so every row written by this
+  // tick shares the same consideredAt reference.
+  const now = new Date();
+
+  // 5. Apply source / disabled gates inline. Failing writs produce a
+  //    decline row + transition and are dropped from the scheduler
+  //    candidate set. The unregistered-strict path uses the existing
+  //    resolution-string format byte-for-byte; the disabled-source
+  //    path gets its own format keyed on `source_banned` (D2).
+  const config = ctx.resolveConfig();
+  const survivors: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const candidate of heldPetitions) {
+    const { writ, ext } = candidate;
+
+    // Disabled-source decline (D2).
+    if (config.disabledSources.includes(ext.source)) {
+      await applyDeclineGate(ctx, {
+        writ,
+        ext,
+        now,
+        tickEventId,
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        resolution: `[reckoner] declined: source '${ext.source}' is in reckoner.disabledSources.`,
+      });
+      continue;
+    }
+
+    // Unregistered-strict decline (existing format).
+    if (!ctx.isRegistered(ext.source) && config.enforceRegistration) {
+      await applyDeclineGate(ctx, {
+        writ,
+        ext,
+        now,
+        tickEventId,
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        resolution: `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`,
+      });
+      continue;
+    }
+
+    survivors.push(candidate);
+  }
+
+  // 6. Pre-evaluate dedupe (D7). Already-considered writs never reach
+  //    the scheduler; the scheduler sees only fresh candidates.
+  const candidates: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const candidate of survivors) {
+    const seen = await ctx.alreadyConsidered(
+      candidate.writ.id,
+      candidate.writ.updatedAt,
+    );
+    if (seen) continue;
+    candidates.push(candidate);
+  }
+
+  if (candidates.length === 0) return;
+
+  // 7. Build SchedulerInput and evaluate. Any throw fail-loud-skips
+  //    the entire tick (no rows for any writ).
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates: candidates.map((c) => c.writ),
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 8. Validate decisions: filter-and-warn on stranger writIds (D9).
+  const candidateIds = new Set<string>(candidates.map((c) => c.writ.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  // Group by writId; multi-decision-per-writ → fail-loud-skip the
+  // entire tick. Safer than applying ambiguous decisions per-writ.
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any decision in this tick.`,
+      );
+      return;
+    }
+  }
+
+  // 9. Apply each decision in candidate order. Per-writ failures are
+  //    isolated — one writ's transition / row failing does not
+  //    cascade to the others.
+  for (const candidate of candidates) {
+    const decision = grouped.get(candidate.writ.id)?.[0];
+    if (!decision) continue; // No decision → no transition, no row.
+    await applySchedulerDecision(ctx, {
+      candidate,
+      decision,
+      now,
+      tickEventId,
+      activeSchedulerId: activeScheduler.id,
+    });
+  }
+}
+
+// ── Source / disabled-gate decline ─────────────────────────────────
+
+interface DeclineGateInputs {
+  writ: WritDoc;
+  ext: ReckonerExt;
+  now: Date;
+  tickEventId: string | undefined;
+  declineReason: NonNullable<ReckoningDoc['declineReason']>;
+  remediationHint: string;
+  resolution: string;
+}
+
+/**
+ * Drive the `new → cancelled` transition for a source/disabled-gate
+ * decline and append the matching Reckonings row. Mirrors the per-
+ * call decline path's failure handling: a transition throw logs a
+ * warning and skips the row write so a partially-applied state never
+ * lands.
+ */
+async function applyDeclineGate(
+  ctx: TickContext,
+  inputs: DeclineGateInputs,
+): Promise<void> {
+  const { writ, ext, now, tickEventId, declineReason, remediationHint, resolution } =
+    inputs;
+
+  // Cancelled target is hardcoded — every Clerk-known writ-type config
+  // declares a `'cancelled'` terminal state with `attrs: ['cancelled']`.
+  // Non-mandate types may name their *active* state differently (hence
+  // `resolveActiveTargetPhase`), but the cancelled target is the
+  // contract-stable name. Mirrors the per-call decline path.
+  try {
+    await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (gate decline): ${msg}`,
+    );
+    return;
+  }
+
+  const row = ctx.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason,
+    remediationHint,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await ctx.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (gate decline): ${msg}`,
+    );
+  }
+}
+
+// ── Per-decision application ───────────────────────────────────────
+
+interface DecisionInputs {
+  candidate: { writ: WritDoc; ext: ReckonerExt };
+  decision: SchedulerDecision;
+  now: Date;
+  tickEventId: string | undefined;
+  activeSchedulerId: string;
+}
+
+/**
+ * Apply one scheduler decision: drive the right transition, write
+ * the right row. Mirrors the per-call `runScheduler`'s outcome
+ * mapping byte-for-byte except that:
+ *
+ *   - the `defer` outcome now writes a row carrying
+ *     `deferReason: 'other'` and the decision's `reason` in
+ *     `deferNote` (D3) — the per-call shape was row-less.
+ *   - the resolved target phases (active for approve, cancelled for
+ *     decline) flow through the type-aware resolvers on the context
+ *     so non-mandate writ types get their type-specific phases.
+ *   - `tickEventId` is stamped on every row when the tick is fired
+ *     by a standing order (D6).
+ */
+async function applySchedulerDecision(
+  ctx: TickContext,
+  inputs: DecisionInputs,
+): Promise<void> {
+  const { candidate, decision, now, tickEventId, activeSchedulerId } = inputs;
+  const { writ, ext } = candidate;
+
+  if (decision.outcome === 'defer') {
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'deferred',
+      deferReason: 'other',
+      deferNote: decision.reason,
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  if (decision.outcome !== 'approve' && decision.outcome !== 'decline') {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeSchedulerId}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+    return;
+  }
+
+  if (decision.outcome === 'decline') {
+    try {
+      await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, {
+        resolution: decision.reason,
+      });
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+      );
+      return;
+    }
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'declined',
+      declineReason: 'other',
+      remediationHint: decision.reason,
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  // approve.
+  let target: string;
+  try {
+    target = ctx.resolveActiveTargetPhase(writ);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+    );
+    return;
+  }
+  try {
+    await ctx.clerk.transition(writ.id, target as WritPhase, {});
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+    );
+    return;
+  }
+  const row = ctx.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'accepted',
+    ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await ctx.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+    );
+  }
+}
+
+// ── Relay factory ───────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. The apparatus boot
+ * path constructs the `TickContext` and passes it through; tests
+ * call `runReckonerTick` directly with a stubbed context.
+ */
+export function createTickRelay(ctx: TickContext): RelayDefinition {
+  return relay({
+    name: TICK_RELAY_NAME,
+    description:
+      'Periodic Reckoner consideration tick — sweeps held petitions through the active scheduler.',
+    handler: (event, _context) => runReckonerTick(ctx, event),
+  });
+}
