new file mode 100644
index 0000000..6957d0f
--- /dev/null
+++ b/packages/plugins/reckoner/src/reckoner-tick.test.ts
@@ -0,0 +1,755 @@
+/**
+ * Reckoner periodic-tick handler tests.
+ *
+ * Covers the behavioral cases enumerated in the periodic-tick
+ * commission's Acceptance Signal:
+ *
+ *   1. Empty candidate ticks — no rows, no errors.
+ *   2. First tick after start picks up pre-existing held writs.
+ *   3. Evaluate-throw isolation — the apparatus stays up, no rows
+ *      written, the writ stays in `new`.
+ *   4. Disabled-source mid-flight decline+cancel — the disabled-
+ *      source gate writes a `declined` row carrying
+ *      `declineReason: 'source_banned'` (D2) and transitions the
+ *      writ to `cancelled`.
+ *   5. Repeated-tick idempotency — driving the tick twice at the
+ *      same writ.updatedAt produces exactly one row.
+ *   6. Type-aware target-phase resolution — the tick uses the writ-
+ *      type config to pick the active target. Tested with a custom
+ *      non-mandate type whose active state is named `running`.
+ *   7. Withdrawal-mid-flight — a petitioner-initiated cancellation
+ *      before the tick fires produces no row (the candidate set
+ *      filter excludes non-`new` writs).
+ *   8. Defer outcome writes a row with no transition (D3).
+ *   9. Pre-seal tick fail-loud — driving `runTick` before
+ *      `phase:started` throws a `[reckoner] tick:` diagnostic with
+ *      no row and no transition (D8).
+ *
+ * The fixture mirrors the scaffolding in `reckoner-scheduler.test.ts`
+ * — real Stacks + Clerk + Reckoner against `MemoryBackend`, with
+ * explicit book pre-creation. The handler is invoked end-to-end
+ * through the test-only `hooks.runTick(event?)` surface (which calls
+ * the same pure helper the `reckoner.tick` relay's handler wraps);
+ * Clockworks is not booted.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /** Re-fire `phase:started` against the registered handlers. */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  /**
+   * Additional `schedulers` kit contributions visible to the
+   * Reckoner's `start()`, on top of the built-in
+   * `reckoner.always-approve` instance the apparatus contributes
+   * from its own supportKit.
+   */
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  config?: ReckonerConfig | undefined;
+  /**
+   * Optional writ types to register on the Clerk before the Reckoner
+   * starts. Used to test type-aware target-phase resolution against
+   * a non-mandate type.
+   */
+  writTypes?: WritTypeConfig[];
+  /**
+   * When set, callers can pre-seed writs into the writs book before
+   * the Reckoner's `start()` runs — used to exercise the "first tick
+   * picks up pre-existing held writs" path.
+   */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+  /** When true, do not fire phase:started after start (pre-seal tests). */
+  skipPhaseStarted?: boolean;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the Clerk needs.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler) {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [
+    {
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    },
+    ...(opts.schedulerKits ?? []).map((entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    })),
+  ];
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner periodic tick', () => {
+  afterEach(() => {
+    clearGuild();
+  });
+
+  // ── Case 1: empty candidate set ──────────────────────────────────────
+
+  describe('empty candidate ticks', () => {
+    it('writes no rows and produces no errors when no held petitions exist', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+
+      // No petitions yet — the tick must early-return (D10) without
+      // calling the scheduler or writing rows.
+      await fix.hooks.runTick();
+
+      const allRows = await fix.reckoningsBook.find({});
+      assert.equal(allRows.length, 0, 'empty tick writes no rows');
+    });
+  });
+
+  // ── Case 2: first tick picks up pre-existing held writs ─────────────
+
+  describe('first tick after start', () => {
+    it('picks up pre-existing held petitions from before apparatus boot', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        async preStart({ clerk }) {
+          // Seed a held writ before the Reckoner starts. The writ
+          // sits in `new` waiting for the first tick to pick it up.
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'tester.kind',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Before the first tick the writ is still in `new`.
+      const all0 = await fix.clerk.list({ limit: 100 });
+      assert.equal(all0.length, 1);
+      assert.equal(all0[0]!.phase, 'new', 'writ stays held until first tick');
+
+      await fix.hooks.runTick();
+
+      const all1 = await fix.clerk.list({ limit: 100 });
+      const writ = all1[0]!;
+      assert.equal(writ.phase, 'open', 'first tick auto-approves the pre-existing writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── Case 3: evaluate-throw isolation ────────────────────────────────
+
+  describe('evaluate-throw isolation', () => {
+    it('keeps the apparatus up; writes no rows; writ stays in new', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad',
+        description: 'always throws',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad' },
+      });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      console.warn = () => {};
+      try {
+        // The throw is absorbed inside the handler; the call itself
+        // must not throw (the apparatus stays up).
+        await fix.hooks.runTick();
+      } finally {
+        console.warn = originalWarn;
+      }
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'evaluate-throw must not transition');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0, 'evaluate-throw writes no rows');
+
+      // Apparatus is still alive — a fresh tick still works.
+      await fix.hooks.runTick();
+    });
+  });
+
+  // ── Case 4: disabled-source decline (D2) ────────────────────────────
+
+  describe('disabled-source mid-flight decline+cancel (D2)', () => {
+    it('writes a declined row with declineReason source_banned and transitions the writ to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        config: { disabledSources: ['tester.kind'] },
+      });
+
+      // Suppress the petition helper's expected warning about the
+      // disabled-source path; the helper warns when permissive
+      // mode is active. This isn't relevant to the gate behavior.
+      const originalWarn = console.warn;
+      console.warn = () => {};
+      try {
+        const writ = await fix.reckoner.petition({
+          source: 'tester.kind',
+          title: 't',
+          body: 'b',
+        });
+        await fix.hooks.runTick();
+
+        const reread = await fix.clerk.show(writ.id);
+        assert.equal(reread.phase, 'cancelled', 'disabled-source writ transitions to cancelled');
+        assert.match(
+          String(reread.resolution),
+          /\[reckoner\] declined: source 'tester\.kind' is in reckoner\.disabledSources\./,
+        );
+
+        const rows = await fix.reckoningsBook.find({
+          where: [['writId', '=', writ.id]],
+        });
+        assert.equal(rows.length, 1);
+        const row = rows[0]!;
+        assert.equal(row.outcome, 'declined');
+        assert.equal(row.declineReason, 'source_banned');
+        assert.equal(row.remediationHint, 'tester.kind');
+      } finally {
+        console.warn = originalWarn;
+      }
+    });
+  });
+
+  // ── Case 5: repeated-tick idempotency ───────────────────────────────
+
+  describe('repeated-tick idempotency', () => {
+    it('produces exactly one row per acceptance even when the tick is re-driven', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      // First tick: accept.
+      await fix.hooks.runTick();
+      // Second tick: writ no longer in `new`, so the candidate set
+      // does not include it. (The dedupe lookup is the secondary
+      // safety; the phase filter is the primary one.)
+      await fix.hooks.runTick();
+      // Third tick: same.
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1, 'repeated-tick idempotency: one row per acceptance');
+    });
+
+    it('dedupes when a held writ is present at unchanged updatedAt for repeated ticks', async () => {
+      // A scheduler that returns no decisions — the writ stays in
+      // `new` after the first tick. The second tick must dedupe
+      // against the prior `(writId, writUpdatedAt)` pair (deferred
+      // rows do not count, but acceptances/declines do; here we
+      // exercise the no-decision path to confirm the candidate set
+      // re-builds correctly without producing a second considera-
+      // tion).
+      const scheduler: Scheduler = {
+        id: 'kit-a.silent',
+        description: 'returns no decisions',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          return [];
+        },
+      };
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.silent' },
+      });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0, 'no-decision tick writes no rows; repeats are stable');
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new');
+    });
+  });
+
+  // ── Case 6: type-aware target-phase resolution ──────────────────────
+
+  describe('target-phase resolution', () => {
+    it('picks `open` for mandate writs (the default writ-type)', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open');
+      assert.equal(reread.type, 'mandate');
+    });
+
+    it('picks the registered active state for a non-mandate type', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        writTypes: [
+          {
+            name: 'task',
+            states: [
+              {
+                name: 'new',
+                classification: 'initial',
+                allowedTransitions: ['running', 'cancelled'],
+              },
+              {
+                name: 'running',
+                classification: 'active',
+                allowedTransitions: ['done', 'cancelled'],
+              },
+              {
+                name: 'done',
+                classification: 'terminal',
+                attrs: ['success'],
+                allowedTransitions: [],
+              },
+              {
+                name: 'cancelled',
+                classification: 'terminal',
+                attrs: ['cancelled'],
+                allowedTransitions: [],
+              },
+            ],
+          },
+        ],
+      });
+
+      const writ = await fix.reckoner.petition({
+        type: 'task',
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.type, 'task');
+      assert.equal(
+        reread.phase,
+        'running',
+        'non-mandate type lands in its registered active state, not `open`',
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── Case 7: withdrawal-mid-flight ───────────────────────────────────
+
+  describe('withdrawal mid-flight', () => {
+    it('produces no Reckonings row when the petitioner cancels a held writ before the tick fires', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      // Withdraw before the tick — moves the writ to `cancelled`.
+      await fix.reckoner.withdraw(writ.id, 'no longer relevant');
+
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0, 'no row on withdrawal-mid-flight');
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+    });
+  });
+
+  // ── Case 8: defer outcome writes a row with no transition (D3) ──────
+
+  describe('scheduler defer outcome (D3)', () => {
+    it('writes a deferred row carrying deferReason: other and the decision reason in deferNote; no transition', async () => {
+      const reason = 'capacity hold';
+      const scheduler: Scheduler = {
+        id: 'kit-a.defer',
+        description: 'always defers',
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          return input.candidates.map((w) => ({
+            writId: w.id,
+            outcome: 'defer' as const,
+            reason,
+          }));
+        },
+      };
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.defer' },
+      });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'defer leaves writ in new');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      const row = rows[0]!;
+      assert.equal(row.outcome, 'deferred');
+      assert.equal(row.deferReason, 'other');
+      assert.equal(row.deferNote, reason);
+      // v0 carve-out: deferUntil/deferSignal/counters absent.
+      assert.equal(row.deferUntil, undefined);
+      assert.equal(row.deferSignal, undefined);
+      assert.equal(row.deferCount, undefined);
+    });
+  });
+
+  // ── Case 9: pre-seal tick fail-loud (D8) ────────────────────────────
+
+  describe('pre-seal tick (D8)', () => {
+    it('throws fail-loud when activeScheduler is unresolved', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        skipPhaseStarted: true,
+      });
+      assert.equal(fix.hooks.getActiveSchedulerId(), undefined);
+
+      await assert.rejects(
+        () => fix.hooks.runTick(),
+        (err: Error) => {
+          assert.match(err.message, /\[reckoner\] tick:/);
+          assert.match(err.message, /activeScheduler not resolved/);
+          assert.match(err.message, /phase:started has not fired/);
+          return true;
+        },
+      );
+    });
+  });
+
+  // ── tickEventId stamping (D6) ───────────────────────────────────────
+
+  describe('tickEventId stamping (D6)', () => {
+    it('stamps tickEventId on the row when the tick is driven by a clockworks.timer event', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      const eventId = 'e-tick-event-stamp-1';
+      await fix.hooks.runTick({
+        id: eventId,
+        name: 'clockworks.timer',
+        payload: null,
+        emitter: 'clockworks',
+        firedAt: new Date().toISOString(),
+      });
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.tickEventId, eventId);
+    });
+
+    it('omits tickEventId when the tick is driven without an event', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.tickEventId, undefined);
+    });
+  });
+
+  // ── Unregistered-strict decline (existing format preserved) ─────────
+
+  describe('unregistered-strict decline (existing format preserved)', () => {
+    it('declines unregistered sources with source_unregistered and the existing resolution-string format', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [],
+        config: { enforceRegistration: true },
+      });
+
+      // Bypass the helper's pre-check: post writ + ext directly via
+      // Clerk so the gate sees a held petition with an unregistered
+      // source.
+      const writ = await fix.clerk.post({ title: 't', body: 'b' });
+      await fix.clerk.setWritExt(writ.id, 'reckoner', {
+        source: 'unknown.source',
+        priority: {
+          visionRelation: 'vision-neutral',
+          severity: 'minor',
+          scope: 'minor-area',
+          time: { decay: false, deadline: null },
+          domain: [],
+        },
+      });
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'unknown\.source' is not registered \(enforceRegistration: true\)\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_unregistered');
+      assert.equal(rows[0]!.remediationHint, 'unknown.source');
+    });
+  });
+});
