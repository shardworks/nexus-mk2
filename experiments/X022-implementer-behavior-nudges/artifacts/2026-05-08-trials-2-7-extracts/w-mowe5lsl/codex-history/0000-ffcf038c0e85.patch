-  // Pre-create the books the Clerk needs — Stacks' Wire phase would
-  // do this in production from the supportKit declarations.
-  memBackend.ensureBook(
-    { ownerId: 'clerk', book: 'writs' },
-    {
-      indexes: [
-        'phase',
-        'type',
-        'createdAt',
-        'parentId',
