@@ -0,0 +1,633 @@
+/**
+ * Reckoner periodic-tick handler tests.
+ *
+ * Covers the behavioral matrix the periodic-tick commission's
+ * Acceptance Signal enumerates, every case driven through
+ * `hooks.runTick`:
+ *
+ *   1. empty-candidate ticks — no rows, no errors.
+ *   2. first tick after start picks up pre-existing held writs.
+ *   3. evaluate-throw isolation — apparatus stays up, no rows.
+ *   4. disabled-source mid-flight decline + cancel (D2) —
+ *      writes a `declined` row carrying `declineReason: 'source_banned'`
+ *      and the source name in `remediationHint`; transitions the
+ *      writ to its cancelled target.
+ *   5. repeated-tick idempotency — same `(writId, writUpdatedAt)`
+ *      pair produces exactly one row.
+ *   6. type-aware target-phase resolution — non-mandate types land
+ *      in their registered active state.
+ *   7. withdrawal mid-flight — withdrawn writs leave the
+ *      candidate set without producing a row.
+ *   8. defer outcome (D3) — writes a deferred row with
+ *      `deferReason: 'other'` and the decision's reason in
+ *      `deferNote`; no transition.
+ *   9. pre-seal tick (D8) — fail-loud throw; no rows.
+ *
+ * The fixture mirrors `reckoner-scheduler.test.ts` — real Stacks
+ * + Clerk + Reckoner against `MemoryBackend`, with explicit book
+ * pre-creation. Writ types beyond `mandate` are registered through
+ * `clerk.registerWritType` for the type-aware target-phase case.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  config?: ReckonerConfig | undefined;
+  writTypes?: WritTypeConfig[];
+  /** When true, do not fire phase:started after start (pre-seal tests). */
+  skipPhaseStarted?: boolean;
+  /**
+   * Pre-Reckoner-start hook — used by the "first tick picks up
+   * pre-existing held writs" case to seed writs into the writs book
+   * before the apparatus is wired.
+   */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler) {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  // ── Stacks ────────────────────────────────────────────────────────
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // ── Clerk ─────────────────────────────────────────────────────────
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  // ── Reckoner ──────────────────────────────────────────────────────
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+  const schedulerKitEntries: KitEntry[] = [
+    {
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    },
+    ...(opts.schedulerKits ?? []).map((entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    })),
+  ];
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    fakeGuildConfig,
+    firePhaseStarted,
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester petitioner' }],
+};
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner periodic-tick handler', () => {
+  afterEach(() => clearGuild());
+
+  // ── 1: empty-candidate tick ────────────────────────────────────────
+
+  describe('empty candidate set', () => {
+    it('writes nothing and does not error when no held petitions exist', async () => {
+      const fix = await buildFixture({});
+
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0, 'empty tick produces no rows');
+    });
+  });
+
+  // ── 2: first tick picks up pre-existing held petitions ────────────
+
+  describe('first tick after start', () => {
+    it('picks up pre-existing held petitions seeded before apparatus boot', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        async preStart({ clerk }) {
+          // Seed a writ with ext before the apparatus starts —
+          // there is no CDC observer to pick it up; the first tick
+          // is expected to evaluate it.
+          const w = await clerk.post({ title: 'pre-existing', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'tester.kind',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // No tick has run yet.
+      const beforeTick = await fix.reckoningsBook.find({});
+      assert.equal(beforeTick.length, 0);
+
+      await fix.hooks.runTick();
+
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      const writ = all[0]!;
+      assert.equal(writ.phase, 'open', 'first tick auto-approves the seeded writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ────────────────────────────────────
+
+  describe('evaluate throw', () => {
+    it('apparatus stays up; no rows; no transitions for any candidate', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.thrower',
+        description: 'a scheduler that throws',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.thrower' },
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        const writA = await fix.reckoner.petition({
+          source: 'tester.kind',
+          title: 'a',
+          body: 'b',
+        });
+        const writB = await fix.reckoner.petition({
+          source: 'tester.kind',
+          title: 'b',
+          body: 'b',
+        });
+
+        // Should not throw — the apparatus stays up.
+        await fix.hooks.runTick();
+
+        for (const w of [writA, writB]) {
+          const reread = await fix.clerk.show(w.id);
+          assert.equal(reread.phase, 'new', 'no transition on evaluate throw');
+        }
+        const rows = await fix.reckoningsBook.find({});
+        assert.equal(rows.length, 0, 'no rows on evaluate throw');
+        assert.ok(
+          warnings.some((w) => /\[reckoner\] tick:/.test(w) && /evaluate threw/.test(w)),
+          `expected fail-loud log line; got: ${JSON.stringify(warnings)}`,
+        );
+      } finally {
+        console.warn = originalWarn;
+      }
+    });
+  });
+
+  // ── 4: disabled-source mid-flight decline + cancel ────────────────
+
+  describe('disabled source', () => {
+    it('declines (source_banned) and transitions to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        config: { disabledSources: ['tester.kind'] },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 'banned',
+        body: 'b',
+      });
+
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled', 'banned source transitions to cancelled');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'tester\.kind' is in disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      const row = rows[0]!;
+      assert.equal(row.outcome, 'declined');
+      assert.equal(row.declineReason, 'source_banned');
+      assert.equal(row.remediationHint, 'tester.kind');
+      assert.equal(row.source, 'tester.kind');
+    });
+  });
+
+  // ── 5: repeated-tick idempotency ──────────────────────────────────
+
+  describe('repeated-tick idempotency', () => {
+    it('produces exactly one row across repeated ticks at the same writ-version', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      // Tick three times — only the first does any work; the
+      // dedupe lookup short-circuits the rest.
+      await fix.hooks.runTick();
+      await fix.hooks.runTick();
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1, 'dedupe holds across repeated ticks');
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open', 'no second transition on replay');
+    });
+  });
+
+  // ── 6: type-aware target-phase resolution ─────────────────────────
+
+  describe('type-aware target-phase resolution', () => {
+    it('mandate writs land in `open`', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+      });
