@@ -0,0 +1,724 @@
+/**
+ * `reckoner.tick` — periodic-tick relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` so every guild that
+ * installs the Reckoner alongside the Clockworks evaluates its held
+ * petitions through the configured scheduler on a fixed cadence. The
+ * matching `supportKit.standingOrders` entry pins the cadence at
+ * `@every 60s`; operators cannot reduce it in this commission (the
+ * future improvement is a `reckoner.tickSchedule` knob, parked).
+ *
+ * The tick is the canonical evaluation surface — it replaces the
+ * earlier per-writ-update CDC handler, which could not give the
+ * scheduler a global candidate-set view. The handler:
+ *
+ *   1. Fail-loud throws when `activeScheduler` has not yet resolved
+ *      (D8 of the periodic-tick commission). In production
+ *      `phase:started` always fires before the first tick; the throw
+ *      surfaces ordering drift loudly rather than silently swallowing it.
+ *   2. Queries held petitions with the same shape the prior catch-up
+ *      scan used (`where: [['phase', '=', 'new']]`) and filters to
+ *      writs carrying `ext.reckoner`.
+ *   3. Applies the source-disabled and unregistered-strict gates
+ *      inline. Failing writs receive a decline Reckonings row and a
+ *      transition to their cancelled target; they never reach the
+ *      scheduler.
+ *   4. Filters the survivors against the persisted dedupe lookup
+ *      (`(writId, writUpdatedAt)` — D7) before assembling the
+ *      candidate set so the scheduler never sees a writ-version it
+ *      has already terminally considered.
+ *   5. Re-reads + validates `reckoner.schedulerConfig` per fire (D17
+ *      of the registry commission); a `validateConfig` throw
+ *      fail-loud-skips the tick.
+ *   6. Builds a single `SchedulerInput { candidates, capacity, now,
+ *      config }` with the v0 capacity stub and calls `evaluate`. A
+ *      throw inside `evaluate` fail-loud-skips the entire tick (no
+ *      rows, no transitions).
+ *   7. Filters-and-warns on stranger writIds (apply only in-scope
+ *      decisions). Fail-loud-skips the entire tick on any
+ *      multi-decision-per-writ (D9).
+ *   8. Applies each decision: approve → transition to active target;
+ *      decline → transition to cancelled with the decision's reason;
+ *      defer → no transition. Appends one Reckonings row per writ
+ *      considered, stamping `tickEventId` from `event.id` when
+ *      present (D6). Defer rows carry `deferReason: 'other'` and the
+ *      decision's reason in `deferNote` (D3).
+ *
+ * The handler is co-located with the apparatus (`tick.ts` sibling of
+ * `reckoner.ts`) following the `summon-relay.ts` / `decline-relay.ts`
+ * template. The pure handler-body helper exported alongside the
+ * factory takes a dependency-injection context object so unit tests
+ * can drive the tick directly without booting Clockworks.
+ *
+ * See: docs/architecture/apparatus/reckoner.md ("Schedulers"),
+ * docs/architecture/reckonings-book.md ("Tick identity"), and the
+ * commission brief w-moj12h4o.
+ */
+
+import type { Book, ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+import type { ClerkApi, WritDoc, WritPhase } from '@shardworks/clerk-apparatus';
+
+import type {
+  GuildEvent,
+  RelayDefinition,
+} from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  CapacitySnapshot,
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+// ── Relay-name constant ─────────────────────────────────────────────
+
+/**
+ * The relay name. Dotted form (D1) — matches the apparatus's
+ * existing contributed-id grammar (scheduler ids, petitioner sources).
+ * The kit-contributed standing order targets this relay verbatim.
+ */
+export const RECKONER_TICK_RELAY = 'reckoner.tick';
+
+// ── Dependency context — closed over the apparatus, passed in here ─
+
+/**
+ * Internal registry shape exposed to the tick handler. Mirrors the
+ * `RegistryEntry` declared in `reckoner.ts`'s `buildReckoner` closure;
+ * the tick reads `descriptor.source` only — `contributingPluginId` is
+ * part of the same object only because the apparatus's existing
+ * registry stores both.
+ */
+export interface PetitionerRegistryEntry {
+  descriptor: { source: string; description: string };
+  contributingPluginId: string;
+}
+
+/**
+ * Resolved Reckoner config fields the tick gate consults (subset of
+ * `ReckonerConfig` — selector + scheduler-config slot are read on
+ * separate paths). Defaulted (`enforceRegistration: false`,
+ * `disabledSources: []`) by `resolveConfig` in `reckoner.ts`.
+ */
+export interface TickReckonerConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Dependency-aware gate outcomes the tick consults via the injected
+ * `evaluateDependencyGate`. Mirrors the in-`reckoner.ts` shape —
+ * see the dep-gate doc block there for the classification rules.
+ */
+export type TickDependencyOutcome =
+  | { kind: 'proceed' }
+  | { kind: 'defer-pending'; gatingIds: string[] }
+  | { kind: 'defer-failed'; failedIds: string[] };
+
+/**
+ * Dependency-injection context for the tick handler. The apparatus
+ * builds one of these inside `buildReckoner()` and threads it into
+ * the relay factory; tests build a stub context to drive the pure
+ * handler-body helper directly.
+ */
+export interface TickHandlerContext {
+  /** Plugin id stamped on `writ.ext['reckoner']` — used to read the slot. */
+  pluginId: string;
+  /** Live Clerk handle. */
+  clerk: ClerkApi;
+  /** Live Stacks handle (for the held-writs query). */
+  stacks: StacksApi;
+  /** Reckoner-owned book handle (for row writes + dedupe lookups). */
+  reckoningsBook: Book<ReckoningDoc>;
+  /** Petitioner registry — `source` membership decides registration enforcement. */
+  registry: Map<string, PetitionerRegistryEntry>;
+  /** Resolved active scheduler accessor — returns `undefined` pre-seal. */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Re-reads + validates the operator-side Reckoner config block. */
+  resolveConfig(): TickReckonerConfig;
+  /** Re-reads the operator-side `reckoner.schedulerConfig` slot. */
+  resolveSchedulerConfig(): unknown;
+  /** Picks the type-aware active target phase for a writ. */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /** Persisted `(writId, writUpdatedAt)` dedupe lookup. */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /** Fetch the most-recent deferred row for `writId` (no-op-row suppression). */
+  findLastDeferredRow(
+    book: Book<ReckoningDoc>,
+    writId: string,
+  ): Promise<ReckoningDoc | undefined>;
+  /** Run the dependency gate against one held writ. */
+  evaluateDependencyGate(writId: string): Promise<TickDependencyOutcome>;
+  /** Format the dep-defer `deferNote` (deterministic id ordering). */
+  buildDependencyDeferNote(
+    kind: 'defer-pending' | 'defer-failed',
+    ids: readonly string[],
+  ): string;
+  /** Build a Reckonings row from in-flight consideration state. */
+  buildReckoningRow(params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    outcome: 'accepted' | 'declined' | 'deferred';
+    declineReason?: ReckoningDoc['declineReason'];
+    remediationHint?: string;
+    deferReason?: ReckoningDoc['deferReason'];
+    deferNote?: string;
+    weight?: number;
+    tickEventId?: string;
+  }): ReckoningDoc;
+}
+
+// ── Pure handler body — exported for unit tests ─────────────────────
+
+/**
+ * Run one tick of the Reckoner against the live writs/reckonings
+ * books using the supplied dependency context. Exported so unit tests
+ * can drive it without standing up Clockworks.
+ *
+ * `event` is `null` when invoked directly (tests, `hooks.runTick()`).
+ * In production it is the triggering `clockworks.timer` event id;
+ * `event.id` is stamped onto every Reckonings row this fire writes.
+ */
+export async function runTickHandler(
+  ctx: TickHandlerContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // D8 — fail-loud when the active scheduler has not yet resolved.
+  // Production never trips this (phase:started fires before the first
+  // tick). Test fixtures that drive runTick pre-seal get a loud signal.
+  const activeScheduler = ctx.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired',
+    );
+  }
+
+  // Sample `now` once at handler entry — reused for every Reckonings
+  // row this tick writes (consideredAt + the row id seed).
+  const now = new Date();
+
+  const tickEventId = event?.id;
+
+  // Held-petition query. Same shape today's catch-up scan uses — a
+  // direct read on `clerk/writs` rather than `clerk.list({ phase })`,
+  // because `clerk.list({ phase })` applies an implicit
+  // `type = 'mandate'` filter when `phase` is supplied without `type`.
+  // Non-mandate held petitions (with their own type carrying a `new`
+  // initial state) would not surface through that path.
+  const writsBook: ReadOnlyBook<WritDoc> = ctx.stacks.readBook<WritDoc>(
+    'clerk',
+    'writs',
+  );
+  const heldRaw = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+
+  // Filter to writs carrying a Reckoner ext slot. Without the slot,
+  // a writ in `new` phase is not a held petition and the tick must
+  // ignore it.
+  const held: WritDoc[] = [];
+  for (const writ of heldRaw) {
+    const ext = writ.ext?.[ctx.pluginId] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    held.push(writ);
+  }
+
+  // D10 — empty candidate set. No rows, no errors, no scheduler call.
+  if (held.length === 0) return;
+
+  const config = ctx.resolveConfig();
+
+  // ── Source / disabled gates ────────────────────────────────────────
+  //
+  // Run inline before dep gate / dedupe / scheduler. Two paths produce
+  // a row + transition (no scheduler call):
+  //
+  //   - disabled-source: D2 of the periodic-tick commission — write
+  //     a `declined` row carrying `declineReason: 'source_banned'`
+  //     and the source name in `remediationHint`; transition the
+  //     writ to the cancelled target.
+  //   - unregistered-strict: existing decline path — write a
+  //     `declined` row carrying `declineReason: 'source_unregistered'`,
+  //     `remediationHint: ext.source`; transition to cancelled.
+  //
+  // Survivors continue to the dep gate + dedupe + scheduler.
+  const survivors: WritDoc[] = [];
+  for (const writ of held) {
+    const ext = writ.ext?.[ctx.pluginId] as ReckonerExt;
+    const source = ext.source;
+
+    if (config.disabledSources.includes(source)) {
+      await applyDisabledSourceDecline({
+        ctx,
+        now,
+        writ,
+        ext,
+        tickEventId,
+      });
+      continue;
+    }
+
+    if (!ctx.registry.has(source) && config.enforceRegistration) {
+      await applyUnregisteredStrictDecline({
+        ctx,
+        now,
+        writ,
+        ext,
+        tickEventId,
+      });
+      continue;
+    }
+
+    survivors.push(writ);
+  }
+
+  // ── Dependency gate ────────────────────────────────────────────────
+  //
+  // Runs every tick, *outside* the dedupe short-circuit, so a writ
+  // that deferred on dep state keeps being re-evaluated as its
+  // dependencies clear. Failed-precedence aggregation chooses between
+  // `dependency_pending` and `dependency_failed`. No-op-row
+  // suppression (compare to the writ's most-recent deferred row)
+  // prevents heartbeat duplicates when the dep set is unchanged.
+  const cleared: WritDoc[] = [];
+  for (const writ of survivors) {
+    const ext = writ.ext?.[ctx.pluginId] as ReckonerExt;
+    let depOutcome: TickDependencyOutcome;
+    try {
+      depOutcome = await ctx.evaluateDependencyGate(writ.id);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: dependency gate threw for writ "${writ.id}" — leaving in new without a row. ${msg}`,
+      );
+      continue;
+    }
+    if (depOutcome.kind === 'proceed') {
+      cleared.push(writ);
+      continue;
+    }
+
+    const reason: ReckoningDoc['deferReason'] =
+      depOutcome.kind === 'defer-failed'
+        ? 'dependency_failed'
+        : 'dependency_pending';
+    const ids =
+      depOutcome.kind === 'defer-failed'
+        ? depOutcome.failedIds
+        : depOutcome.gatingIds;
+    const deferNote = ctx.buildDependencyDeferNote(depOutcome.kind, ids);
+
+    const last = await ctx.findLastDeferredRow(ctx.reckoningsBook, writ.id);
+    if (
+      last &&
+      last.deferReason === reason &&
+      last.deferNote === deferNote
+    ) {
+      continue;
+    }
+
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'deferred',
+      deferReason: reason,
+      deferNote,
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (dependency-defer path): ${msg}`,
+      );
+    }
+  }
+
+  // ── Dedupe (D7) ────────────────────────────────────────────────────
+  //
+  // Filter the candidate set against the persisted dedupe lookup
+  // *before* building SchedulerInput so the scheduler never sees a
+  // writ-version it already terminally considered. The dedupe lookup
+  // counts only non-deferred prior rows — repeated dep-deferred ticks
+  // remain free to keep evaluating.
+  const candidates: WritDoc[] = [];
+  for (const writ of cleared) {
+    const seen = await ctx.alreadyConsidered(
+      ctx.reckoningsBook,
+      writ.id,
+      writ.updatedAt,
+    );
+    if (!seen) candidates.push(writ);
+  }
+
+  if (candidates.length === 0) return;
+
+  // ── Scheduler config validation ────────────────────────────────────
+  //
+  // Per-fire re-read + narrow. A `validateConfig` throw fail-loud-skips
+  // the entire tick (no rows, no transitions for any writ in the
+  // candidate set).
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping the entire tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // ── Evaluate ───────────────────────────────────────────────────────
+  //
+  // One call against the whole candidate set per fire. A throw inside
+  // evaluate fail-loud-skips the entire tick.
+  const capacity: CapacitySnapshot = {};
+  let decisions: readonly SchedulerDecision[];
+  try {
+    decisions = await activeScheduler.evaluate({
+      candidates,
+      capacity,
+      now,
+      config: validatedConfig,
+    });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping the entire tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping the entire tick.`,
+    );
+    return;
+  }
+
+  // ── Decision validation (D9) ───────────────────────────────────────
+  //
+  // Filter-and-warn on stranger writIds; fail-loud-skip the whole tick
+  // on any multi-decision-per-writ.
+  const candidateIds = new Set<string>(candidates.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate. Skipping the entire tick.`,
+      );
+      return;
+    }
+  }
+
+  // ── Apply decisions ────────────────────────────────────────────────
+  //
+  // Walk the candidate set in iteration order so per-writ side effects
+  // are deterministic. A candidate with no decision is treated as a
+  // no-row, no-transition skip (defer-equivalent) — schedulers
+  // signalling "leave alone" simply omit a decision.
+  for (const writ of candidates) {
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) continue;
+
+    const ext = writ.ext?.[ctx.pluginId] as ReckonerExt;
+
+    // Validate outcome enum membership defensively. Unknown values
+    // surface as a warning and skip the writ.
+    if (
+      decision.outcome !== 'approve' &&
+      decision.outcome !== 'decline' &&
+      decision.outcome !== 'defer'
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+      );
+      continue;
+    }
+
+    if (decision.outcome === 'defer') {
+      // D3 — defer outcome writes a row, no transition. `deferReason`
+      // is `'other'`; the decision's reason lands in `deferNote`. The
+      // counter / deferUntil / deferSignal fields stay absent (the
+      // shape is reserved for a future named consumer).
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        ...(decision.reason !== undefined
+          ? { deferNote: decision.reason }
+          : {}),
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, {
+          resolution,
+        });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // approve.
+    let target: string;
+    try {
+      target = ctx.resolveActiveTargetPhase(writ);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+      );
+      continue;
+    }
+
+    try {
+      await ctx.clerk.transition(writ.id, target as WritPhase, {});
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+      );
+      continue;
+    }
+
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'accepted',
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+      );
+    }
+  }
+}
+
+// ── Source-gate decline helpers ────────────────────────────────────
+
+/**
+ * Disabled-source decline (D2). Symmetric with the unregistered-
+ * strict decline path: writes a `declined` Reckonings row with
+ * `declineReason: 'source_banned'` and the source name in
+ * `remediationHint`, then transitions the writ to its cancelled
+ * target. Builds a parallel resolution-string template (the
+ * unregistered-strict template is left untouched per the brief).
+ */
+async function applyDisabledSourceDecline(args: {
+  ctx: TickHandlerContext;
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  tickEventId: string | undefined;
+}): Promise<void> {
+  const { ctx, now, writ, ext, tickEventId } = args;
+  // Dedupe — only write the row + transition once for this writ-version.
+  if (await ctx.alreadyConsidered(ctx.reckoningsBook, writ.id, writ.updatedAt)) {
+    return;
+  }
+  const resolution =
+    `[reckoner] declined: source '${ext.source}' is in disabledSources.`;
+  try {
+    await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, {
+      resolution,
+    });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (disabled-source decline): ${msg}`,
+    );
+    return;
+  }
+  const row = ctx.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason: 'source_banned',
+    remediationHint: ext.source,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await ctx.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source decline): ${msg}`,
+    );
+  }
+}
+
+/**
+ * Unregistered-strict decline. Existing path — preserved verbatim
+ * from the prior CDC handler; the resolution-string template is
+ * unchanged so external consumers grepping for it stay green.
+ */
+async function applyUnregisteredStrictDecline(args: {
+  ctx: TickHandlerContext;
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  tickEventId: string | undefined;
+}): Promise<void> {
+  const { ctx, now, writ, ext, tickEventId } = args;
+  if (await ctx.alreadyConsidered(ctx.reckoningsBook, writ.id, writ.updatedAt)) {
+    return;
+  }
+  const resolution =
+    `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+  try {
+    await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, {
+      resolution,
+    });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (unregistered-strict decline): ${msg}`,
+    );
+    return;
+  }
+  const row = ctx.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason: 'source_unregistered',
+    remediationHint: ext.source,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await ctx.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (unregistered-strict decline): ${msg}`,
+    );
+  }
+}
+
+// ── Relay factory ───────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. The apparatus boot
+ * path wires this into `supportKit.relays`; the matching standing
+ * order targets `run: 'reckoner.tick'` on `schedule: '@every 60s'`.
+ *
+ * The factory closes over the apparatus's dependency context so the
+ * handler can reach the closure-scoped registry, scheduler, and
+ * helpers without re-resolving them per fire.
+ */
+export function createTickRelay(ctx: TickHandlerContext): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY,
+    description:
+      'Periodically evaluate every held petition through the configured scheduler.',
+    handler: async (event, _context) => {
+      await runTickHandler(ctx, event);
+    },
+  });
+}
