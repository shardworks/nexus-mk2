+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled', 'disabled-source writ is cancelled');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'vision-keeper\.snapshot' is in reckoner\.disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'vision-keeper.snapshot');
+    });
+  });
+
+  // ── 5: unregistered-strict decline ────────────────────────────────
+
+  describe('unregistered-strict decline', () => {
+    it('declines an unregistered source under enforceRegistration: true with the existing reason and resolution-string format', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [],
+        config: { enforceRegistration: true },
+      });
+
+      // Petition helper would refuse strict mode at the helper
+      // boundary; post + stamp directly through Clerk to drive the
+      // tick path instead.
+      const writ = await fix.clerk.post({ title: 't', body: 'b' });
+      await fix.clerk.setWritExt(writ.id, 'reckoner', {
+        source: 'unknown.source',
+        priority: {
+          visionRelation: 'vision-neutral',
+          severity: 'minor',
+          scope: 'minor-area',
+          time: { decay: false, deadline: null },
+          domain: [],
+        },
+      });
+
+      await fix.hooks.runTick();
+
