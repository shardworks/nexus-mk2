+/**
+ * `reckoner.tick` — periodic-evaluation relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` and paired with a
+ * kit-contributed standing order at `@every 60s`. Every fire walks
+ * every currently-held petition (initial-phase writs carrying
+ * `ext.reckoner`), applies the source/disabled gates inline, dedupes
+ * against the `(writId, writUpdatedAt)` lookup, then hands the
+ * surviving candidate set to the active scheduler in **one batch**.
+ * Each scheduler decision is applied in turn — approve → transition
+ * to the writ-type's active target; decline → transition to the
+ * cancelled target; defer → no transition — and one Reckonings row
+ * is appended per writ considered.
+ *
+ * Sequence per fire (brief-prescribed, fixed):
+ *
+ *   1. Resolve `activeScheduler`. If still unresolved (pre-seal)
+ *      throw fail-loud (D8) — production never trips this; tests get
+ *      a deterministic loud signal.
+ *   2. Query held petitions via `clerk/writs` `phase = 'new'`,
+ *      filter to those carrying `ext.reckoner`. Empty set → early
+ *      return (no rows, no scheduler call) per D10.
+ *   3. Per writ apply the source/disabled gates inline (D2):
+ *        - `disabledSources` includes the source → decline + cancel,
+ *          row carries `declineReason: 'source_banned'` and the
+ *          source name in `remediationHint`.
+ *        - source unregistered AND `enforceRegistration: true` →
+ *          decline + cancel, row carries
+ *          `declineReason: 'source_unregistered'` and the source
+ *          name in `remediationHint`.
+ *      Failing writs do not enter the candidate set.
+ *   4. Filter-and-drop the dedupe-blocked writs against
+ *      `alreadyConsidered((writId, writUpdatedAt))` (D7) — duplicate
+ *      consideration of an unchanged writ-version never reaches the
+ *      scheduler.
+ *   5. Re-read `reckoner.schedulerConfig` (D17 hot-edit) and call
+ *      `validateConfig` when present. A throw is logged fail-loud and
+ *      the **entire tick** is skipped (no rows for any writ).
+ *   6. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      and call `evaluate`. A throw is logged fail-loud and the entire
+ *      tick is skipped (D9).
+ *   7. Filter-and-warn on stranger `writId`s (decisions for writs not
+ *      in the candidate set). Fail-loud-skip the entire tick on
+ *      multi-decision-per-writ (D9).
+ *   8. Apply each decision (D3 / D6) — approve / decline / defer
+ *      shapes mirror the apparatus contract; `tickEventId` is stamped
+ *      from `event.id` when present, omitted when absent.
+ *
+ * The handler is split into a sibling-file pure helper so unit tests
+ * can drive it without booting Clockworks. See `reckoner.ts` for the
+ * `TickContext` factory that wires the closure-scoped reckoner state
+ * into the helper.
+ *
+ * See: docs/architecture/apparatus/reckoner.md §"Tick semantics".
+ */
+
+import {
+  relay,
+  type GuildEvent,
+  type RelayDefinition,
+} from '@shardworks/clockworks-apparatus';
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+import type {
+  Book,
+  ReadOnlyBook,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+
+import type {
+  ReckoningDoc,
+  ReckonerExt,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+// ── Public constants ─────────────────────────────────────────────────
+
+/**
+ * Relay name registered with Clockworks. Hardcoded literal — every
+ * call site (the kit-contributed standing order, the apparatus's
+ * supportKit.relays, the test hook) keys on this string verbatim.
+ */
+export const RECKONER_TICK_RELAY_NAME = 'reckoner.tick';
+
+/**
+ * Plugin id used to read the Reckoner's `ext` slot off a writ. Mirrors
+ * the constant in `reckoner.ts` — duplicated here to keep this file's
+ * dependency surface inside the package small.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+// ── Tick context ─────────────────────────────────────────────────────
+
+/**
+ * Resolved-Reckoner-config slice the tick reads. Mirrors the
+ * `ResolvedReckonerConfig` shape in `reckoner.ts` byte-for-byte. The
+ * full block (`scheduler`, `schedulerConfig`) is read separately —
+ * the tick keeps the boolean and source-list slice off the same
+ * accessor it shares with the helper functions inside the apparatus.
+ */
+export interface TickReckonerConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Per-fire dependency context the tick handler reads through. Built
+ * once inside `buildReckoner()` and closed over by the relay factory
+ * so the handler always sees the latest closure state without holding
+ * the Reckoner's internal lets directly.
+ *
+ * Every reference is a function so the context can be constructed
+ * before `start()` runs and read post-`start()` without rebinding —
+ * the tick relay must be wired into `supportKit.relays` at
+ * construction time, before the apparatus's start() populates
+ * `clerk` / `stacks` / `reckoningsBook` / `activeScheduler`.
+ */
+export interface TickContext {
+  /** Resolve the Clerk handle. Throws if start() has not yet wired it. */
+  getClerk(): ClerkApi;
+  /** Resolve the Stacks handle. Throws if start() has not yet wired it. */
+  getStacks(): StacksApi;
+  /** Resolve the Reckonings book handle. Throws if start() has not yet wired it. */
+  getReckoningsBook(): Book<ReckoningDoc>;
+  /**
+   * Return the resolved active scheduler, or `undefined` when the
+   * registry has not yet sealed (pre-`phase:started`). Tick handler
+   * throws fail-loud (D8) on `undefined` rather than silently skipping.
+   */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Re-read the resolved `reckoner` config block per call (D20). */
+  resolveConfig(): TickReckonerConfig;
+  /** Re-read the `reckoner.schedulerConfig` slot per call (D17). */
+  resolveSchedulerConfig(): unknown;
+  /** Whether `source` is in the kit-static petitioner registry. */
+  isSourceRegistered(source: string): boolean;
+  /**
+   * Compute the writ-type's active target phase for a writ at
+   * transition time (D5 in the apparatus contract). Throws fail-loud
+   * on missing config or ambiguous active-target candidates.
+   */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /**
+   * Return `true` when a non-deferred Reckonings row already exists
+   * for `(writId, writUpdatedAt)`. Mirrors the dedupe lookup the
+   * apparatus uses elsewhere; the tick consults it before building
+   * SchedulerInput so duplicate considerations never reach the
+   * scheduler (D7).
+   */
+  alreadyConsidered(writId: string, writUpdatedAt: string): Promise<boolean>;
+  /**
+   * Build a Reckoning record from in-flight consideration state.
+   * Mirrors the helper inside `reckoner.ts`; surfaced through the
+   * context object so the tick handler does not duplicate the row-
+   * shaping logic.
+   */
+  buildReckoningRow(params: BuildReckoningRowParams): ReckoningDoc;
+}
+
+/**
+ * Parameter shape for `TickContext.buildReckoningRow`. Mirrors the
+ * helper inside `reckoner.ts` so the tick handler can request rows
+ * without re-implementing field marshalling.
+ */
+export interface BuildReckoningRowParams {
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  outcome: 'accepted' | 'declined' | 'deferred';
+  declineReason?: ReckoningDoc['declineReason'];
+  remediationHint?: string;
+  deferReason?: ReckoningDoc['deferReason'];
+  deferNote?: string;
+  weight?: number;
+  /** Triggering Clockworks timer event id, when the tick was driven by one. */
+  tickEventId?: string;
+}
+
+// ── Pure handler ─────────────────────────────────────────────────────
+
+/**
+ * The tick handler body, exported for unit tests.
+ *
+ * Drives the per-fire sequence end-to-end against the supplied
+ * `TickContext`. Pure in the sense that every dependency reaches the
+ * handler through `ctx`; the only ambient global it touches is
+ * `console` for the operator-visible warnings described in the
+ * commission's diagnostics.
+ *
+ * `event` is `null` only when callers drive the handler directly
+ * (the test hook with no synthetic event); when invoked through
+ * Clockworks's scheduler dispatch the event always carries the
+ * triggering `clockworks.timer` id (D6 row stamping).
+ */
+export async function runTickHandler(
+  ctx: TickContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // Step 1 — pre-seal guard (D8). Throw rather than silent-skip so
+  // any ordering drift in production surfaces loudly. Tests can
+  // assert on the exact prefix.
+  const activeScheduler = ctx.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  const stacks = ctx.getStacks();
+  const reckoningsBook = ctx.getReckoningsBook();
+  const clerk = ctx.getClerk();
+
+  // Step 2 — query held petitions. Mirrors the catch-up scan's
+  // direct readBook query so non-mandate held writs surface alongside
+  // mandate ones.
+  const writsBook: ReadOnlyBook<WritDoc> = stacks.readBook<WritDoc>(
+    'clerk',
+    'writs',
+  );
+  const phaseNew = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+  const heldWrits: WritDoc[] = [];
+  for (const writ of phaseNew) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    heldWrits.push(writ);
+  }
+
+  if (heldWrits.length === 0) {
+    // D10: empty set — no scheduler call, no rows, no errors.
+    return;
+  }
+
+  const config = ctx.resolveConfig();
+  const now = new Date();
+  const tickEventId = event?.id ?? undefined;
+
+  // Step 3 — apply source / disabled gates inline. Failing writs
+  // produce a decline row + cancelled transition and never reach the
+  // scheduler. Surviving writs accumulate into `gatedCandidates`.
+  const gatedCandidates: WritDoc[] = [];
+  for (const writ of heldWrits) {
+    const ext = writ.ext![RECKONER_PLUGIN_ID] as ReckonerExt;
+
+    // Disabled-source decline (D2). `source_banned` is the type's
+    // purpose-built reason for exactly this case.
+    if (config.disabledSources.includes(ext.source)) {
+      // Idempotency: a previously-considered writ-version already
+      // produced its row + transition; do not re-stamp.
+      if (await ctx.alreadyConsidered(writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is in reckoner.disabledSources.`;
+      try {
+        await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (disabled-source decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unregistered + enforceRegistration: decline path (resolution
+    // string preserved verbatim — the existing test corpus and any
+    // operator-side log-grep convention key on it).
+    const isRegistered = ctx.isSourceRegistered(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      if (await ctx.alreadyConsidered(writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+      try {
+        await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (decline path): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (decline path): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    gatedCandidates.push(writ);
+  }
+
+  // Step 4 — dedupe filter (D7). Already-considered writs never
+  // reach the scheduler.
+  const candidates: WritDoc[] = [];
+  for (const writ of gatedCandidates) {
+    if (await ctx.alreadyConsidered(writ.id, writ.updatedAt)) continue;
+    candidates.push(writ);
+  }
+  if (candidates.length === 0) return;
+
+  // Step 5 — per-evaluation config validate (D17/D18). On throw, log
+  // fail-loud and skip the entire tick.
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // Step 6 — evaluate. On throw, log fail-loud and skip.
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // Step 7 — validate decisions: filter-and-warn on stranger writIds
+  // (D9), then fail-loud-skip the entire tick on multi-decision-per-writ.
+  const candidateIds = new Set<string>(candidates.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate.`,
+      );
+      return;
+    }
+  }
+
+  // Step 8 — apply each decision.
+  const candidateById = new Map<string, WritDoc>(
+    candidates.map((w) => [w.id, w]),
+  );
+  for (const [writId, list] of grouped) {
+    const decision = list[0]!;
+    const writ = candidateById.get(writId);
+    if (!writ) continue; // defensive — already filtered above
+    const ext = writ.ext![RECKONER_PLUGIN_ID] as ReckonerExt;
+
+    if (decision.outcome === 'defer') {
+      // D3: write a deferred row carrying `deferReason: 'other'` and
+      // the decision's reason in `deferNote`. No transition.
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'approve') {
+      let target: string;
+      try {
+        target = ctx.resolveActiveTargetPhase(writ);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+        );
+        continue;
+      }
+
+      try {
+        await clerk.transition(writ.id, target as WritPhase, {});
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'accepted',
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unknown outcome — defensive guard mirroring the pre-tick code path.
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+  }
+}
+
+// ── Relay factory ────────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. Wired into the
+ * apparatus's `supportKit.relays`; the apparatus's own kit-contributed
+ * standing order at `@every 60s` invokes it.
+ *
+ * The relay is a thin shell — it forwards the triggering event to
+ * `runTickHandler` and otherwise carries no behaviour of its own.
+ */
+export function createReckonerTickRelay(ctx: TickContext): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY_NAME,
+    description:
+      'Periodic-evaluation tick — walks every held petition, applies source/disabled gates, dedupes, runs the active scheduler in one batch, and applies each decision (approve / decline / defer).',
+    handler: async (event) => {
+      await runTickHandler(ctx, event);
+    },
+  });
+}
