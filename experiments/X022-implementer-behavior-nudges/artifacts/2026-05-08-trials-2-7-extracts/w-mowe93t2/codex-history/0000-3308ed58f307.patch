index 0000000..1147ad6
--- /dev/null
+++ b/packages/plugins/reckoner/src/reckoner-tick.test.ts
@@ -0,0 +1,807 @@
+/**
+ * Reckoner tick handler tests — the behavioral matrix the brief
+ * enumerates, all driven through `hooks.runTick()`:
+ *
+ *   1. empty-candidate ticks — no rows, no errors.
+ *   2. first tick after start picks up pre-existing held petitions.
+ *   3. evaluate-throw isolation — apparatus stays up, no rows
+ *      written.
+ *   4. disabled-source mid-flight produces a decline + cancel
+ *      (D2: row carries `declineReason: 'source_banned'` and the
+ *      source name in `remediationHint`).
+ *   5. unregistered-strict decline path — preserves the existing
+ *      reason and resolution-string format.
+ *   6. repeated-tick idempotency at unchanged updatedAt.
+ *   7. type-aware target-phase resolution (mandate + non-mandate).
+ *   8. withdrawal-mid-flight produces no row.
+ *   9. defer outcome writes a row carrying `deferReason: 'other'`
+ *      and the decision's reason in `deferNote` (D3); no transition.
+ *  10. pre-seal tick throws fail-loud (D8).
+ *  11. tickEventId stamping (D6) — present when the handler is
+ *      driven with a synthetic event, absent when driven with `null`.
+ *
+ * The fixture mirrors the scheduler test fixture: real Stacks +
+ * Clerk + Reckoner against `MemoryBackend`, plus an explicit
+ * `runTick` hook entry. The Reckoner is wired with the always-
+ * approve scheduler by default; tests that need to exercise a
+ * non-approve outcome contribute their own scheduler.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    tryApparatus<T>(name: string): T | null {
+      try { return this.apparatus<T>(name); } catch { return null; }
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  config?: ReckonerConfig | undefined;
+  writTypes?: WritTypeConfig[];
+  /**
+   * Skip firing `phase:started`. Used by the pre-seal tick test to
+   * exercise the fail-loud guard.
+   */
+  skipPhaseStarted?: boolean;
+  /**
+   * Pre-start callback used to seed held writs into the writs book
+   * before the Reckoner's `start()` runs — exercises the
+   * "first tick picks up pre-existing writs" case.
+   */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create books the apparatuses expect — Stacks' Wire phase
+  // would do this in production from supportKit declarations.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler) {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  // ── Stacks ────────────────────────────────────────────────────────
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // ── Clerk ─────────────────────────────────────────────────────────
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  // ── Reckoner ──────────────────────────────────────────────────────
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [
+    {
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    },
+    ...(opts.schedulerKits ?? []).map((entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    })),
+  ];
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+const VK_KIT = {
+  pluginId: 'vision-keeper',
+  value: [{ source: 'vision-keeper.snapshot', description: 'snapshots' }],
+};
+
+const TESTER_KIT = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => clearGuild());
+
+  // ── 1: empty-candidate ticks ──────────────────────────────────────
+
+  describe('empty candidate set', () => {
+    it('no held writs → no rows, no errors', async () => {
+      const fix = await buildFixture({ petitionerKits: [VK_KIT] });
+      await fix.hooks.runTick();
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0, 'no rows for an empty tick');
+    });
+
+    it('held writs all dedupe-blocked → scheduler not called, no rows', async () => {
+      // Track scheduler calls so we can assert the early-return path.
+      const calls: SchedulerInput<unknown>[] = [];
+      const trackedScheduler: Scheduler = {
+        id: 'tester.tracked',
+        description: 'tracks calls for assertion',
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          calls.push(input);
+          return input.candidates.map((w) => ({
+            writId: w.id,
+            outcome: 'approve' as const,
+            reason: 'tracked',
+          }));
+        },
+      };
+      const fix = await buildFixture({
+        petitionerKits: [VK_KIT],
+        schedulerKits: [{ pluginId: 'tester', value: [trackedScheduler] }],
+        config: { scheduler: 'tester.tracked' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+      // First tick: scheduler runs, writ is approved.
+      await fix.hooks.runTick();
+      assert.equal(calls.length, 1, 'first tick reaches the scheduler');
+
+      // Second tick: writ is no longer in `new`, so the candidate
+      // set is empty — scheduler is not called again.
+      await fix.hooks.runTick();
+      assert.equal(calls.length, 1, 'second tick early-returns at empty set');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1, 'only one row across two ticks');
+    });
+  });
+
+  // ── 2: first tick after start picks up pre-existing held writs ────
+
+  describe('first tick after start', () => {
+    it('processes held writs that pre-date apparatus startup', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VK_KIT],
+        async preStart({ clerk }) {
+          // Seed a held writ before the Reckoner starts. Petition
+          // helper would not work here because the Reckoner has not
+          // started yet; post + setWritExt directly.
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'vision-keeper.snapshot',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Pre-tick: the writ is still held.
+      const preTick = await fix.clerk.list({ limit: 100 });
+      assert.equal(preTick.length, 1);
+      assert.equal(preTick[0]!.phase, 'new', 'writ stays in new until tick');
+
+      await fix.hooks.runTick();
+
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all[0]!.phase, 'open', 'first tick after start auto-approves');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', all[0]!.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ───────────────────────────────────
+
+  describe('evaluate-throw isolation', () => {
+    it('apparatus stays up; no rows written', async () => {
+      const throwingScheduler: Scheduler = {
+        id: 'tester.boom',
+        description: 'always throws',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+      const fix = await buildFixture({
+        petitionerKits: [VK_KIT],
+        schedulerKits: [{ pluginId: 'tester', value: [throwingScheduler] }],
+        config: { scheduler: 'tester.boom' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        // The tick must not propagate the throw — apparatus stays up.
+        await fix.hooks.runTick();
+
+        const reread = await fix.clerk.show(writ.id);
+        assert.equal(reread.phase, 'new', 'writ untouched on evaluate-throw');
+        const rows = await fix.reckoningsBook.find({
+          where: [['writId', '=', writ.id]],
+        });
+        assert.equal(rows.length, 0);
+        assert.ok(
+          warnings.some((w) => /evaluate threw/.test(w)),
+          `expected fail-loud log line; got ${JSON.stringify(warnings)}`,
+        );
+      } finally {
+        console.warn = originalWarn;
+      }
+    });
+  });
+
+  // ── 4: disabled-source mid-flight ─────────────────────────────────
+
+  describe('disabled-source mid-flight', () => {
+    it('writes a decline row with declineReason "source_banned" and transitions to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VK_KIT],
