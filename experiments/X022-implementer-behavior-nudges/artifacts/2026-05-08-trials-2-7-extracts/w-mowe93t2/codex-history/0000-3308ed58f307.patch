+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'defer leaves writ in new');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      // The tick layer does not no-op-suppress; deferred rows are
+      // state-change audits and re-tick at the same updatedAt
+      // produces another row. (Suppression is a future-scheduler
+      // concern.)
+      assert.ok(rows.length >= 1, 'at least one deferred row');
+      for (const row of rows) {
+        assert.equal(row.outcome, 'deferred');
+        assert.equal(row.deferReason, 'other');
+      }
+    });
+  });
+
+  // ── 7: type-aware target-phase resolution ─────────────────────────
+
+  describe('target-phase resolution', () => {
