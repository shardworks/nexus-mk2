+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_unregistered');
+      assert.equal(rows[0]!.remediationHint, 'unknown.source');
+    });
+  });
+
+  // ── 6: repeated-tick idempotency ──────────────────────────────────
+
+  describe('repeated-tick idempotency', () => {
+    it('produces exactly one row across many ticks at unchanged updatedAt', async () => {
+      const fix = await buildFixture({ petitionerKits: [VK_KIT] });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      // Drive several ticks. Only the first reaches the scheduler;
+      // the rest short-circuit at the dedupe filter (the writ is no
+      // longer in `new`, but even if it were, the dedupe filter on
+      // (writId, writUpdatedAt) would short-circuit).
+      await fix.hooks.runTick();
+      await fix.hooks.runTick();
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1, 'only one row across repeated ticks');
+    });
+
+    it('a held petition that survives consideration (e.g. defer) does not duplicate the deferred row across ticks at the same updatedAt', async () => {
+      // A scheduler that always defers — the writ stays in `new`
+      // and the alreadyConsidered lookup must (correctly) treat
+      // deferred rows as non-terminal so a re-tick is allowed; but
+      // the writ's writUpdatedAt is unchanged, so the row's identity
+      // shape is identical, and the next tick should produce
+      // another deferred row only if the dedupe key differs. Today
+      // the tick handler does not suppress duplicate deferred rows
+      // — its dedupe lookup ignores deferred rows entirely (so they
+      // do not gate further consideration). Repeated deferral
+      // therefore does append more deferred rows; the scheduler-side
+      // owns no-op suppression if it cares to. We assert the
+      // tick-side guarantee: terminal (accept/decline) outcomes
+      // dedupe.
+      const deferringScheduler: Scheduler = {
+        id: 'tester.deferrer',
+        description: 'always defers',
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          return input.candidates.map((w) => ({
+            writId: w.id,
+            outcome: 'defer' as const,
+            reason: 'capacity hold',
