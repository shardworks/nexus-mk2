+    });
+  });
+
+  // ── 11: tickEventId stamping (D6) ─────────────────────────────────
+
+  describe('tickEventId stamping', () => {
+    it('stamps tickEventId from the triggering event when present', async () => {
+      const fix = await buildFixture({ petitionerKits: [VK_KIT] });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      const fakeEvent: GuildEvent = {
+        id: 'e-test-tick-id-123',
