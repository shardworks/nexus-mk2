diff --git a/__tests__/maxroll-import.test.ts b/__tests__/maxroll-import.test.ts
new file mode 100644
index 0000000..c50cb51
--- /dev/null
+++ b/__tests__/maxroll-import.test.ts
@@ -0,0 +1,278 @@
+/**
+ * Acceptance tests for the Maxroll planner importer (D25).
+ *
+ * All tests are hermetic — no live network access. Fixture payloads are served
+ * via ctx.fetch overrides (matching the __tests__/datamine-import-realdata.test.ts
+ * precedent). The checked-in fixtures cover only the nids referenced by the
+ * planner fixture so the subset stays minimal.
+ *
+ * Test cases:
+ *   1. Happy path: ok: true with equippedItems, class, paragonAllocation,
+ *      at least one mapped aspect, at least one mapped glyph (acceptance signal 1).
+ *   2. Unmapped reference report: every unmapped nid appears in the correct bucket
+ *      (acceptance signal 3).
+ *   3. Input shapes: bare id, planner URL, URL with hash, build-guide URL
+ *      (acceptance signal 2).
+ *   4. Patch-mismatch fail: version differs + <50% explicit mapping → ok:false
+ *      (acceptance signal 4a).
+ *   5. Patch-drift but above threshold: version differs + ≥50% mapping → ok:true
+ *      with versionMismatch in report (acceptance signal 4b).
+ */
+
+import { describe, it, expect, beforeEach } from "vitest";
+import * as path from "path";
+import * as fs from "fs";
+import { importMaxrollPlanner } from "@/lib/import/maxroll";
+import { clearDataMinMemoryCache } from "@/lib/import/maxroll/data-min-cache";
+
+// ─── Fixture helpers ────────────────────────────────────────────────────────
+
+const FIXTURE_DIR = path.join(__dirname, "fixtures");
+
+function loadFixture(name: string): unknown {
+  return JSON.parse(fs.readFileSync(path.join(FIXTURE_DIR, name), "utf-8"));
+}
+
+const plannerFixture = loadFixture("maxroll-planner-fixture.json");
+const dataMinSubset = loadFixture("maxroll-data-min-subset.json");
+const dataMinMismatch = loadFixture("maxroll-data-min-mismatch.json");
+const dataMinDriftOk = loadFixture("maxroll-data-min-drift-ok.json");
+
+/**
+ * Creates a ctx.fetch mock that serves fixture data for both
+ * planner-load and data.min.json requests.
+ */
+function makeFetch(
+  plannerData: unknown,
+  dataMinData: unknown,
+  buildGuideHtml?: string
+): typeof globalThis.fetch {
+  return async (input: RequestInfo | URL, _init?: RequestInit): Promise<Response> => {
+    const url = typeof input === "string" ? input : input instanceof URL ? input.href : (input as Request).url;
+
+    if (url.includes("/profiles/load/")) {
+      return new Response(JSON.stringify(plannerData), {
+        status: 200,
+        headers: { "Content-Type": "application/json" },
+      });
+    }
+    if (url.includes("data.min.json")) {
+      return new Response(JSON.stringify(dataMinData), {
+        status: 200,
+        headers: { "Content-Type": "application/json" },
+      });
+    }
+    if (url.includes("maxroll.gg/d4/build-guides/") && buildGuideHtml) {
+      return new Response(buildGuideHtml, {
+        status: 200,
+        headers: { "Content-Type": "text/html" },
+      });
+    }
+    return new Response("Not Found", { status: 404 });
+  };
+}
+
+// ─── Setup: clear in-memory cache before each test ─────────────────────────
+
+beforeEach(() => {
+  clearDataMinMemoryCache();
+});
+
+// ─── Test 1: Happy path ─────────────────────────────────────────────────────
+
+describe("importMaxrollPlanner — happy path", () => {
+  it("returns ok:true with a populated Sorcerer build", async () => {
+    const result = await importMaxrollPlanner("uHxkbvE0", {
+      fetch: makeFetch(plannerFixture, dataMinSubset),
+      cacheDir: "/tmp/mr-test-cache",
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return; // type-guard
+
+    // Acceptance signal 1: class set
+    expect(result.character.class).toBe("Sorcerer");
+
+    // Acceptance signal 1: level
+    expect(result.character.level).toBe(100);
+
+    // Acceptance signal 1: non-empty equippedItems
+    const items = result.character.equippedItems;
+    expect(Object.keys(items).length).toBeGreaterThan(0);
+
+    // Helm should be mapped to slot "helm" (Maxroll slot 0)
+    const helm = items["helm"];
+    expect(helm).toBeDefined();
+    expect(helm.slot).toBe("helm");
+
+    // Acceptance signal 1: at least one mapped aspect
+    expect(helm.aspect).toBeDefined();
+    expect(helm.aspect?.aspectId).toBe("aspect_of_disobedience");
+    expect(helm.aspect?.source).toBe("legendary"); // D11
+
+    // Explicits should contain mapped affixes
+    expect(helm.explicits.length).toBeGreaterThanOrEqual(2);
+    const affixIds = helm.explicits.map((a) => a.affixId);
+    expect(affixIds).toContain("affix_attack_speed");
+    expect(affixIds).toContain("affix_crit_damage");
+
+    // Ring1 (slot 6) should be mapped
+    const ring = items["ring1"];
+    expect(ring).toBeDefined();
+    // Lucky hit ring is implicit — should route to implicits
+    expect(ring.implicits.length).toBeGreaterThanOrEqual(1);
+    expect(ring.implicits[0].affixId).toBe("affix_implicit_lucky_hit_ring");
+    expect(ring.explicits.length).toBe(0); // no non-implicit affixes on ring
+
+    // Acceptance signal 1: paragonAllocation populated
+    const paragon = result.character.paragonAllocation;
+    expect(paragon.paragonLevel).toBe(200);
+    expect(paragon.boards.length).toBeGreaterThan(0);
+
+    const board = paragon.boards[0];
+    expect(board.boardId).toBe("sorc_starter");
+    // Nodes stored with mr: prefix (D17)
+    expect(board.nodes.every((n) => n.startsWith("mr:"))).toBe(true);
+    expect(board.spentPoints).toBe(board.nodes.length); // derived from nodes.length
+
+    // Acceptance signal 1: at least one mapped paragon glyph
+    expect(board.glyph).toBeDefined();
+    expect(board.glyph?.glyphId).toBe("glyph_cold_calc"); // bnetFileName Rare_009_Willpower_Side
+    expect(board.glyph?.level).toBe(21); // D18 default
+
+    // Acceptance signal 1: skill mapped
+    expect(result.character.skillSelections.length).toBeGreaterThan(0);
+    expect(result.character.skillSelections[0].skillId).toBe("sorc_frost_bolt");
+
+    // provenance attached
+    expect(result.importedFrom.source).toBe("maxroll");
+    expect(result.importedFrom.plannerId).toBe("uHxkbvE0");
+    expect(result.importedFrom.variantIndex).toBe(0);
+
+    // variantCount
+    expect(result.variantCount).toBe(1);
+  });
+});
+
+// ─── Test 2: Unmapped reference report ─────────────────────────────────────
+
+describe("importMaxrollPlanner — unmapped reference report", () => {
+  it("reports every unmapped nid in the correct bucket; no silent drops", async () => {
+    const result = await importMaxrollPlanner("uHxkbvE0", {
+      fetch: makeFetch(plannerFixture, dataMinSubset),
+      cacheDir: "/tmp/mr-test-cache-2",
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+
+    // The planner fixture contains "mr_UNMAPPED_affix" which is absent from
+    // the data.min.json subset — must appear in unmappedAffixes (acceptance signal 3)
+    const unmappedAffixNids = result.report.unmappedAffixes.map((r) => r.nid);
+    expect(unmappedAffixNids).toContain("mr_UNMAPPED_affix");
+
+    // Category discriminant is correct
+    const unmapped = result.report.unmappedAffixes.find((r) => r.nid === "mr_UNMAPPED_affix");
+    expect(unmapped?.category).toBe("affix");
+    if (unmapped?.category === "affix") {
+      expect(unmapped.slot).toBe("helm");
+    }
+
+    // No reports in wrong buckets
+    expect(result.report.unmappedAspects.map((r) => r.nid)).not.toContain("mr_UNMAPPED_affix");
+    expect(result.report.unmappedSkills.map((r) => r.nid)).not.toContain("mr_UNMAPPED_affix");
+  });
+});
+
+// ─── Test 3: All input shapes ───────────────────────────────────────────────
+
+describe("importMaxrollPlanner — input shapes", () => {
+  const ctx = {
+    fetch: makeFetch(plannerFixture, dataMinSubset),
+    cacheDir: "/tmp/mr-test-cache-3",
+  };
+
+  it("accepts bare planner ID", async () => {
+    beforeEach(() => clearDataMinMemoryCache());
+    const r = await importMaxrollPlanner("uHxkbvE0", ctx);
+    expect(r.ok).toBe(true);
+    if (!r.ok) return;
+    expect(r.importedFrom.plannerId).toBe("uHxkbvE0");
+    expect(r.variantIndex).toBe(0);
+  });
+
+  it("accepts planner URL without hash", async () => {
+    const r = await importMaxrollPlanner("https://maxroll.gg/d4/planner/uHxkbvE0", ctx);
+    expect(r.ok).toBe(true);
+    if (!r.ok) return;
+    expect(r.importedFrom.plannerId).toBe("uHxkbvE0");
+    expect(r.variantIndex).toBe(0);
+  });
+
+  it("accepts planner URL with variant hash", async () => {
+    const r = await importMaxrollPlanner(
+      "https://maxroll.gg/d4/planner/uHxkbvE0#0&equipment",
+      ctx
+    );
+    expect(r.ok).toBe(true);
+    if (!r.ok) return;
+    expect(r.importedFrom.plannerId).toBe("uHxkbvE0");
+    expect(r.variantIndex).toBe(0);
+  });
+
+  it("accepts build-guide URL (extracts planner ID from HTML)", async () => {
+    const guideHtml = `<html><body>
+      <a href="/d4/planner/uHxkbvE0">Check the planner</a>
+    </body></html>`;
+    const ctxWithGuide = {
+      fetch: makeFetch(plannerFixture, dataMinSubset, guideHtml),
+      cacheDir: "/tmp/mr-test-cache-4",
+    };
+    const r = await importMaxrollPlanner(
+      "https://maxroll.gg/d4/build-guides/frozen-orb-sorcerer-guide",
+      ctxWithGuide
+    );
+    expect(r.ok).toBe(true);
+    if (!r.ok) return;
+    expect(r.importedFrom.plannerId).toBe("uHxkbvE0");
+  });
+});
+
+// ─── Test 4: Patch-mismatch failure ────────────────────────────────────────
+
+describe("importMaxrollPlanner — patch-mismatch failure", () => {
+  it("returns ok:false with reason:'patch-mismatch' when version differs and mapping rate <50%", async () => {
+    // All bnetFileNames in the mismatch fixture point to non-existent catalog entries
+    // → 0 explicit affixes mapped → 0% rate → below threshold
+    const result = await importMaxrollPlanner("uHxkbvE0", {
+      fetch: makeFetch(plannerFixture, dataMinMismatch),
+      cacheDir: "/tmp/mr-test-cache-5",
+    });
+
+    expect(result.ok).toBe(false);
+    if (result.ok) return;
+    expect(result.reason).toBe("patch-mismatch");
+    expect(result.message).toContain("2.9.0.99999");
+  });
+});
+
+// ─── Test 5: Patch-drift but above threshold ────────────────────────────────
+
+describe("importMaxrollPlanner — patch-drift above threshold (ok:true with warning)", () => {
+  it("returns ok:true with versionMismatch in report when version differs but mapping rate >=50%", async () => {
+    // drift-ok fixture: version is different but all mapped affixes resolve fine
+    // The fixture has 3 explicit affixes: mr_attack_speed (mapped), mr_crit_damage (mapped),
+    // mr_UNMAPPED_affix (mr_UNMAPPED_affix is in the planner but listed in drift-ok as UNKNOWN_AFFIX)
+    // → 2/3 = 67% ≥ 50% → should pass with warning
+    const result = await importMaxrollPlanner("uHxkbvE0", {
+      fetch: makeFetch(plannerFixture, dataMinDriftOk),
+      cacheDir: "/tmp/mr-test-cache-6",
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+    expect(result.report.versionMismatch).toBeDefined();
+    expect(result.report.versionMismatch?.dataminVersion).toBe("2.9.0.99999");
+    expect(result.report.versionMismatch?.mappingRatePct).toBeGreaterThanOrEqual(50);
+  });
+});
