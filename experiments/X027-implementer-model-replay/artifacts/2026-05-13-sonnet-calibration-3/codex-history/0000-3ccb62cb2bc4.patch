diff --git a/app/api/import/maxroll/preview/route.ts b/app/api/import/maxroll/preview/route.ts
new file mode 100644
index 0000000..54b39bb
--- /dev/null
+++ b/app/api/import/maxroll/preview/route.ts
@@ -0,0 +1,93 @@
+/**
+ * POST /api/import/maxroll/preview
+ *
+ * Stateless preview endpoint (D23). Accepts a planner reference (id, URL, or
+ * build-guide URL), calls importMaxrollPlanner for ALL variants, and returns
+ * them in one response. No server-side state; no commit happens here.
+ *
+ * The UI then chooses a variant and POSTs the character payload directly to
+ * POST /api/characters?withDefaultBuild=true (which handles atomic character +
+ * default-build creation, plus the Build.importedFrom provenance field).
+ *
+ * HTTP status mapping (D23):
+ *   200 — success (array of variant results)
+ *   400 — parse-error (malformed input)
+ *   404 — not-found or private planner
+ *   409 — patch-mismatch (all variants failed the threshold)
+ *   422 — zero-mapped (all variants returned no usable data)
+ *   502 — network error reaching Maxroll upstream
+ */
+
+import { NextResponse } from "next/server";
+import { importMaxrollPlanner } from "@/lib/import/maxroll";
+import type { ImportResult } from "@/lib/import/maxroll";
+import { clearDataMinMemoryCache } from "@/lib/import/maxroll/data-min-cache";
+
+/** HTTP status for each library failure reason. */
+const REASON_STATUS: Record<string, number> = {
+  "parse-error": 400,
+  "not-found": 404,
+  private: 404,
+  "patch-mismatch": 409,
+  "zero-mapped": 422,
+  network: 502,
+};
+
+export async function POST(request: Request) {
+  let body: unknown;
+  try {
+    body = await request.json();
+  } catch {
+    return NextResponse.json({ error: "Invalid JSON body" }, { status: 400 });
+  }
+
+  if (typeof body !== "object" || body === null || !("input" in body)) {
+    return NextResponse.json(
+      { error: 'Request body must be { input: string }' },
+      { status: 400 }
+    );
+  }
+
+  const input = (body as Record<string, unknown>).input;
+  if (typeof input !== "string" || input.trim().length === 0) {
+    return NextResponse.json(
+      { error: '"input" must be a non-empty string' },
+      { status: 400 }
+    );
+  }
+
+  // Import the first variant to discover total variantCount
+  // (cache ensures the planner payload and data.min.json are fetched once)
+  const firstResult = await importMaxrollPlanner(input.trim());
+
+  if (!firstResult.ok) {
+    const status = REASON_STATUS[firstResult.reason] ?? 500;
+    return NextResponse.json(
+      { error: firstResult.message, reason: firstResult.reason, details: firstResult.details },
+      { status }
+    );
+  }
+
+  const { variantCount } = firstResult;
+  const variants: ImportResult[] = [firstResult];
+
+  // Fetch remaining variants (in-process cache means planner + data.min are not re-fetched)
+  for (let i = 1; i < variantCount; i++) {
+    // Construct a hash-variant URL from the raw input
+    const variantInput = buildVariantInput(input.trim(), firstResult.importedFrom.plannerId, i);
+    const result = await importMaxrollPlanner(variantInput);
+    variants.push(result);
+  }
+
+  // Clear in-process cache after response is built so the next request isn't
+  // served stale data if the planner was just updated.
+  clearDataMinMemoryCache();
+
+  return NextResponse.json({ variants }, { status: 200 });
+}
+
+/** Build an input string for a specific variant index. */
+function buildVariantInput(originalInput: string, plannerId: string, variantIndex: number): string {
+  // Prefer the canonical URL form so the parser extracts the variant index from the hash
+  return `https://maxroll.gg/d4/planner/${plannerId}#${variantIndex}&equipment`;
+}
