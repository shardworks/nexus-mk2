@@ -0,0 +1,9 @@
+/**
+ * Maxroll planner importer — public API.
+ *
+ * Exports ONLY `importMaxrollPlanner` (D3). All internal helpers
+ * (parser, fetcher, mapper, cache) are private to this package.
+ */
+
+export { importMaxrollPlanner } from "./importer";
+export type { ImportResult, ImportContext, ImportReport, UnmappedRef, ImportedCharacter, VersionMismatch } from "./types";
diff --git a/lib/import/maxroll/mapper.ts b/lib/import/maxroll/mapper.ts
new file mode 100644
index 0000000..2fd69ec
--- /dev/null
+++ b/lib/import/maxroll/mapper.ts
@@ -0,0 +1,388 @@
+/**
+ * Maxroll → canonical-schema mapper (T3).
+ *
+ * Translates a single Maxroll hero (variant) into an ImportedCharacter plus
+ * an ImportReport. All decisions reference brief decisions D9–D18.
+ *
+ * Join key: bnetFileName only — no label-match or tag fallbacks (D4/cross-cutting).
+ */
+
+import { verifiedAgainst } from "@/lib/catalog";
+import type { DataMin } from "./payload-schema";
+import type { MaxrollHero, MaxrollItem, MaxrollAffix } from "./payload-schema";
+import {
+  affixByBnet,
+  aspectByBnet,
+  uniqueByBnet,
+  skillByBnet,
+  boardByBnet,
+  glyphByBnet,
+} from "./catalog-index";
+import {
+  MAXROLL_SLOT_MAP,
+  MAXROLL_CLASS_MAP,
+  MAXROLL_QUALITY_MAP,
+  MAXROLL_SKILL_SLOT_MAP,
+} from "./slot-map";
+import type {
+  ImportedCharacter,
+  ImportReport,
+  UnmappedRef,
+  VersionMismatch,
+} from "./types";
+
+// ─── Types ─────────────────────────────────────────────────────────────────
+
+interface AffixInstance {
+  affixId: string;
+  rolledValue?: number;
+  rolledRange?: [number, number];
+}
+
+type ItemRarity = "common" | "magic" | "rare" | "legendary" | "unique" | "mythic";
+
+interface MappedItem {
+  slot: string;
+  name: string;
+  rarity: ItemRarity;
+  itemPower?: number;
+  isAncestral: boolean;
+  implicits: AffixInstance[];
+  explicits: AffixInstance[];
+  tempered: AffixInstance[];
+  aspect?: { aspectId: string; rolledValue: number; source: "legendary" | "codex" };
+  masterworkRank: number;
+  runes: string[];
+  sockets: string[];
+}
+
+// ─── Affix instance helpers ────────────────────────────────────────────────
+
+function affixInstance(affixId: string, value: number | undefined): AffixInstance {
+  // Use rolledValue for single-number affixes. rolledRange is for weapon-damage
+  // implicits but Maxroll doesn't carry min/max separately; we default to rolledValue.
+  return { affixId, rolledValue: value };
+}
+
+// ─── Item mapping ──────────────────────────────────────────────────────────
+
+function mapItem(
+  mrItem: MaxrollItem,
+  slotId: string,
+  dataMin: DataMin,
+  unmappedAffixes: UnmappedRef[],
+  unmappedAspects: UnmappedRef[],
+  explicitCounts: { total: number; mapped: number }
+): MappedItem {
+  const implicits: AffixInstance[] = [];
+  const explicits: AffixInstance[] = [];
+  const tempered: AffixInstance[] = [];
+
+  for (const mrAffix of mrItem.affixes ?? []) {
+    const bnetFileName = dataMin.affixes?.[mrAffix.nid]?.bnetFileName;
+    if (!bnetFileName) {
+      const isTempered = mrAffix.isTempered === true;
+      if (!isTempered) {
+        explicitCounts.total++;
+      }
+      unmappedAffixes.push({
+        category: "affix",
+        nid: mrAffix.nid,
+        slot: slotId,
+        reason: "nid not found in data.min.json affixes",
+      });
+      continue;
+    }
+
+    const catalogEntry = affixByBnet.get(bnetFileName);
+    if (!catalogEntry) {
+      const isTempered = mrAffix.isTempered === true;
+      if (!isTempered) {
+        explicitCounts.total++;
+      }
+      unmappedAffixes.push({
+        category: "affix",
+        nid: mrAffix.nid,
+        bnetFileName,
+        slot: slotId,
+        reason: `bnetFileName "${bnetFileName}" not found in catalog`,
+      });
+      continue;
+    }
+
+    const instance = affixInstance(catalogEntry.id, mrAffix.value);
+
+    // Route by position (D16): isImplicit → implicits; isTempered → tempered; else → explicits
+    if (catalogEntry.isImplicit) {
+      implicits.push(instance);
+    } else if (mrAffix.isTempered === true) {
+      tempered.push(instance);
+    } else {
+      explicits.push(instance);
+      explicitCounts.total++;
+      explicitCounts.mapped++;
+    }
+  }
+
+  // Map aspect
+  let aspect: MappedItem["aspect"] | undefined;
+  if (mrItem.aspect) {
+    const bnetFileName = dataMin.aspects?.[mrItem.aspect.nid]?.bnetFileName;
+    if (!bnetFileName) {
+      unmappedAspects.push({
+        category: "aspect",
+        nid: mrItem.aspect.nid,
+        slot: slotId,
+        reason: "nid not found in data.min.json aspects",
+      });
+    } else {
+      const catalogEntry = aspectByBnet.get(bnetFileName);
+      if (!catalogEntry) {
+        unmappedAspects.push({
+          category: "aspect",
+          nid: mrItem.aspect.nid,
+          bnetFileName,
+          slot: slotId,
+          reason: `bnetFileName "${bnetFileName}" not found in catalog`,
+        });
+      } else {
+        aspect = {
+          aspectId: catalogEntry.id,
+          rolledValue: mrItem.aspect.value ?? 0,
+          source: "legendary" as const, // D11: default to 'legendary'
+        };
+      }
+    }
+  }
+
+  // Determine rarity (D14):
+  // - unique if item bnetFileName maps to a UniqueEntry
+  // - legendary if an aspect is present
+  // - else rare (or quality-mapped if available)
+  let rarity: ItemRarity = "rare";
+  // Note: mrItem.id is a numeric type ID, not a bnetFileName; we can't join on it directly.
+  // Quality hint from Maxroll (D14 fallback)
+  if (mrItem.quality !== undefined) {
+    const qualityRarity = MAXROLL_QUALITY_MAP[mrItem.quality] as ItemRarity | undefined;
+    if (qualityRarity) rarity = qualityRarity;
+  }
+  if (aspect) {
+    rarity = "legendary";
+  }
+  // unique marker from quality overrides the aspect check
+  if (mrItem.quality === 4) {
+    rarity = "unique";
+  }
+
+  return {
+    slot: slotId,
+    name: "", // Maxroll payload doesn't carry display name for items
+    rarity,
+    itemPower: mrItem.power, // D13: leave undefined when absent; use when present
+    isAncestral: mrItem.isAncestral ?? false, // D15
+    implicits,
+    explicits,
+    tempered,
+    aspect,
+    masterworkRank: 0,
+    runes: [],
+    sockets: [],
+  };
+}
+
+// ─── Hero mapping ─────────────────────────────────────────────────────────
+
+export interface MapHeroResult {
+  character: ImportedCharacter;
+  report: ImportReport;
+  /** Whether the explicit-affix mapping rate is ≥ 50% (D9 threshold). */
+  mappingThresholdMet: boolean;
+}
+
+export function mapHero(
+  hero: MaxrollHero,
+  plannerId: string,
+  variantIndex: number,
+  plannerVersion: string,
+  dataMin: DataMin
+): MapHeroResult {
+  const unmappedAffixes: UnmappedRef[] = [];
+  const unmappedAspects: UnmappedRef[] = [];
+  const unmappedParagonNodes: UnmappedRef[] = [];
+  const unmappedGlyphs: UnmappedRef[] = [];
+  const unmappedSkills: UnmappedRef[] = [];
+
+  // ── Class mapping ────────────────────────────────────────────────────────
+  const className = MAXROLL_CLASS_MAP[hero.d4class] ?? "Sorcerer";
+
+  // ── Level (D12) ──────────────────────────────────────────────────────────
+  const level = typeof hero.level === "number" && hero.level > 0 ? hero.level : 100;
+
+  // ── Item mapping ─────────────────────────────────────────────────────────
+  const explicitCounts = { total: 0, mapped: 0 };
+  const equippedItems: ImportedCharacter["equippedItems"] = {};
+
+  // Normalise items to an array (handle both array and record shapes)
+  const itemsArray: Array<MaxrollItem & { slot: number }> = [];
+
+  if (Array.isArray(hero.items)) {
+    for (const item of hero.items) {
+      if (item.slot !== undefined) {
+        itemsArray.push(item as MaxrollItem & { slot: number });
+      }
+    }
+  } else if (hero.equipped) {
+    for (const [slotKey, item] of Object.entries(hero.equipped)) {
+      const slotNum = parseInt(slotKey, 10);
+      if (!isNaN(slotNum)) {
+        itemsArray.push({ ...item, slot: slotNum });
+      }
+    }
+  }
+
+  for (const mrItem of itemsArray) {
+    const slotId = MAXROLL_SLOT_MAP[mrItem.slot];
+    if (!slotId) continue; // unknown slot — skip silently
+
+    const mapped = mapItem(mrItem, slotId, dataMin, unmappedAffixes, unmappedAspects, explicitCounts);
+    equippedItems[slotId] = mapped;
+  }
+
+  // ── Skill mapping ─────────────────────────────────────────────────────────
+  const skillSelections: ImportedCharacter["skillSelections"] = [];
+
+  for (const mrSkill of hero.skills ?? []) {
+    const bnetFileName = dataMin.skills?.[mrSkill.nid]?.bnetFileName;
+    if (!bnetFileName) {
+      unmappedSkills.push({
+        category: "skill",
+        nid: mrSkill.nid,
+        reason: "nid not found in data.min.json skills",
+      });
+      continue;
+    }
+    const catalogEntry = skillByBnet.get(bnetFileName);
+    if (!catalogEntry) {
+      unmappedSkills.push({
+        category: "skill",
+        nid: mrSkill.nid,
+        bnetFileName,
+        reason: `bnetFileName "${bnetFileName}" not found in skill catalog`,
+      });
+      continue;
+    }
+    const slotString =
+      mrSkill.slot !== undefined ? MAXROLL_SKILL_SLOT_MAP[mrSkill.slot] : undefined;
+    skillSelections.push({
+      skillId: catalogEntry.entry.id,
+      rank: mrSkill.points ?? 0,
+      ...(slotString ? { slot: slotString } : {}),
+    });
+  }
+
+  // ── Paragon mapping ──────────────────────────────────────────────────────
+  const paragonLevel = hero.paragon?.paragonLevel ?? 0;
+  const boards: ImportedCharacter["paragonAllocation"]["boards"] = [];
+
+  for (const mrBoard of hero.paragon?.boards ?? []) {
+    const bnetFileName = dataMin.boards?.[mrBoard.nid]?.bnetFileName;
+    if (!bnetFileName) {
+      unmappedParagonNodes.push({
+        category: "paragon-node",
+        nid: mrBoard.nid,
+        reason: "nid not found in data.min.json boards",
+      });
+      continue;
+    }
+    const catalogEntry = boardByBnet.get(bnetFileName);
+    if (!catalogEntry) {
+      unmappedParagonNodes.push({
+        category: "paragon-node",
+        nid: mrBoard.nid,
+        bnetFileName,
+        reason: `bnetFileName "${bnetFileName}" not found in paragon board catalog`,
+      });
+      continue;
+    }
+
+    // Store node ids verbatim with mr: prefix (D17)
+    const nodes = (mrBoard.nodes ?? []).map((n) => `mr:${n}`);
+
+    // Map glyph
+    let glyph: { glyphId: string; level: number } | undefined;
+    if (mrBoard.glyph) {
+      const glyphBnetFileName = dataMin.glyphs?.[mrBoard.glyph.nid]?.bnetFileName;
+      if (!glyphBnetFileName) {
+        unmappedGlyphs.push({
+          category: "glyph",
+          nid: mrBoard.glyph.nid,
+          boardNid: mrBoard.nid,
+          reason: "nid not found in data.min.json glyphs",
+        });
+      } else {
+        const glyphCatalog = glyphByBnet.get(glyphBnetFileName);
+        if (!glyphCatalog) {
+          unmappedGlyphs.push({
+            category: "glyph",
+            nid: mrBoard.glyph.nid,
+            bnetFileName: glyphBnetFileName,
+            boardNid: mrBoard.nid,
+            reason: `bnetFileName "${glyphBnetFileName}" not found in glyph catalog`,
+          });
+        } else {
+          glyph = {
+            glyphId: glyphCatalog.entry.id,
+            level: mrBoard.glyph.level ?? 21, // D18: default to 21
+          };
+        }
+      }
+    }
+
+    boards.push({
+      boardId: catalogEntry.entry.id,
+      boardName: catalogEntry.entry.label,
+      spentPoints: nodes.length, // D17: derive from nodes.length
+      ...(glyph ? { glyph } : {}),
+      nodes,
+    });
+  }
+
+  // ── Patch-mismatch check (D9) ────────────────────────────────────────────
+  const catalogPatch = verifiedAgainst.patch;
+  const dataminVersion = dataMin.version;
+  const versionsDiffer = dataminVersion !== catalogPatch;
+
+  const mappingRatePct =
+    explicitCounts.total === 0
+      ? 100 // no explicits → no mismatch penalty
+      : Math.round((explicitCounts.mapped / explicitCounts.total) * 100);
+
+  const mappingThresholdMet = !versionsDiffer || mappingRatePct >= 50;
+
+  const versionMismatch: VersionMismatch | undefined = versionsDiffer
+    ? { dataminVersion, catalogPatch, mappingRatePct }
+    : undefined;
+
+  const character: ImportedCharacter = {
+    name: hero.name ?? `${className} Build`,
+    class: className,
+    level,
+    paragonAllocation: { paragonLevel, boards },
+    skillSelections,
+    equippedItems,
+    playstyleConstraints: [],
+  };
+
+  return {
+    character,
+    report: {
+      unmappedAffixes,
+      unmappedAspects,
+      unmappedParagonNodes,
+      unmappedGlyphs,
+      unmappedSkills,
+      ...(versionMismatch ? { versionMismatch } : {}),
+    },
+    mappingThresholdMet,
+  };
+}
diff --git a/lib/import/maxroll/parser.ts b/lib/import/maxroll/parser.ts
new file mode 100644
index 0000000..88023a0
--- /dev/null
+++ b/lib/import/maxroll/parser.ts
@@ -0,0 +1,74 @@
+/**
+ * Source-reference parser for Maxroll planner inputs.
+ *
+ * Resolves four input shapes (D24) to a canonical { plannerId, variantIndex }:
+ *   1. Bare planner ID:                    "uHxkbvE0"
+ *   2. Planner URL:                        "https://maxroll.gg/d4/planner/uHxkbvE0"
+ *   3. Planner URL with variant hash:      "https://maxroll.gg/d4/planner/uHxkbvE0#1&equipment"
+ *   4. Build-guide URL:                    "https://maxroll.gg/d4/build-guides/frozen-orb-sorcerer"
+ *      → fetches HTML, regex-matches /d4/planner/<id>, takes first match (D24)
+ *
+ * When no variant is specified, defaults to 0 (D10).
+ */
+
+import { fetchText, buildGuideUrl } from "./client";
+
+const PLANNER_ID_RE = /^[a-zA-Z0-9]+$/;
+const PLANNER_URL_RE =
+  /https?:\/\/(?:www\.)?maxroll\.gg\/d4\/planner\/([a-zA-Z0-9]+)(?:#(\d+))?/;
+const BUILD_GUIDE_URL_RE = /https?:\/\/(?:www\.)?maxroll\.gg\/d4\/build-guides\/([^?#\s]+)/;
+const HTML_PLANNER_RE = /\/d4\/planner\/([a-zA-Z0-9]+)/;
+
+export interface ParsedRef {
+  plannerId: string;
+  variantIndex: number;
+}
+
+/**
+ * Parse a Maxroll planner reference into a canonical { plannerId, variantIndex }.
+ *
+ * Throws with `{ code: 'parse-error' }` if the input cannot be resolved.
+ * For build-guide URLs, performs an HTTP fetch via the supplied fetchFn.
+ */
+export async function parseMaxrollInput(
+  input: string,
+  fetchFn: typeof globalThis.fetch = globalThis.fetch
+): Promise<ParsedRef> {
+  const trimmed = input.trim();
+
+  // ── Shape 3 / 2: Planner URL (with or without hash) ──────────────────────
+  const plannerMatch = PLANNER_URL_RE.exec(trimmed);
+  if (plannerMatch) {
+    const plannerId = plannerMatch[1];
+    const variantIndex = plannerMatch[2] !== undefined ? parseInt(plannerMatch[2], 10) : 0;
+    return { plannerId, variantIndex };
+  }
+
+  // ── Shape 4: Build-guide URL ──────────────────────────────────────────────
+  const buildGuideMatch = BUILD_GUIDE_URL_RE.exec(trimmed);
+  if (buildGuideMatch) {
+    const slug = buildGuideMatch[1];
+    const html = await fetchText(buildGuideUrl(slug), fetchFn);
+    const htmlMatch = HTML_PLANNER_RE.exec(html);
+    if (!htmlMatch) {
+      throw Object.assign(
+        new Error(`No planner reference found in build guide: ${trimmed}`),
+        { code: "parse-error" as const }
+      );
+    }
+    return { plannerId: htmlMatch[1], variantIndex: 0 };
+  }
+
+  // ── Shape 1: Bare planner ID ──────────────────────────────────────────────
+  if (PLANNER_ID_RE.test(trimmed) && trimmed.length >= 4) {
+    return { plannerId: trimmed, variantIndex: 0 };
+  }
+
+  throw Object.assign(
+    new Error(
+      `Cannot parse Maxroll input: "${trimmed}". ` +
+        `Expected a planner ID, maxroll.gg/d4/planner/<id> URL, or maxroll.gg/d4/build-guides/<slug> URL.`
+    ),
+    { code: "parse-error" as const }
+  );
+}
diff --git a/lib/import/maxroll/payload-schema.ts b/lib/import/maxroll/payload-schema.ts
new file mode 100644
index 0000000..b8e00d0
--- /dev/null
+++ b/lib/import/maxroll/payload-schema.ts
@@ -0,0 +1,164 @@
+/**
+ * Zod validation schemas for Maxroll API payloads (D28).
+ *
+ * Every object uses .passthrough() — parse-or-throw on missing required fields,
+ * tolerate unknown extras so future Maxroll additions don't break the importer.
+ */
+
+import { z } from "zod";
+
+// ─── Planner API payload ───────────────────────────────────────────────────
+
+export const MaxrollAffixSchema = z
+  .object({
+    nid: z.string(),
+    value: z.number().optional(),
+    isTempered: z.boolean().optional(),
+  })
+  .passthrough();
+
+export type MaxrollAffix = z.infer<typeof MaxrollAffixSchema>;
+
+export const MaxrollAspectSchema = z
+  .object({
+    nid: z.string(),
+    value: z.number().optional(),
+  })
+  .passthrough();
+
+export type MaxrollAspect = z.infer<typeof MaxrollAspectSchema>;
+
+export const MaxrollItemSchema = z
+  .object({
+    /** Maxroll numeric slot ID — used when items is an array. */
+    slot: z.number().optional(),
+    /** Maxroll internal item type ID (used for unique detection). */
+    id: z.number().optional(),
+    power: z.number().optional(),
+    /** 0=common, 1=magic, 2=rare, 3=legendary, 4=unique, 5=mythic */
+    quality: z.number().optional(),
+    isAncestral: z.boolean().optional(),
+    affixes: z.array(MaxrollAffixSchema).optional(),
+    aspect: MaxrollAspectSchema.optional(),
+  })
+  .passthrough();
+
+export type MaxrollItem = z.infer<typeof MaxrollItemSchema>;
+
+export const MaxrollSkillSchema = z
+  .object({
+    nid: z.string(),
+    points: z.number().optional(),
+    /** Numeric bar slot (0=basic, 1=core, …). */
+    slot: z.number().optional(),
+  })
+  .passthrough();
+
+export type MaxrollSkill = z.infer<typeof MaxrollSkillSchema>;
+
+export const MaxrollGlyphSchema = z
+  .object({
+    nid: z.string(),
+    level: z.number().optional(),
+  })
+  .passthrough();
+
+export type MaxrollGlyph = z.infer<typeof MaxrollGlyphSchema>;
+
+export const MaxrollBoardSchema = z
+  .object({
+    nid: z.string(),
+    /** Numeric node IDs for this board — stored verbatim with mr: prefix (D17). */
+    nodes: z.array(z.number()).optional(),
+    glyph: MaxrollGlyphSchema.optional(),
+  })
+  .passthrough();
+
+export type MaxrollBoard = z.infer<typeof MaxrollBoardSchema>;
+
+export const MaxrollParagonSchema = z
+  .object({
+    paragonLevel: z.number().optional(),
+    boards: z.array(MaxrollBoardSchema).optional(),
+  })
+  .passthrough();
+
+export type MaxrollParagon = z.infer<typeof MaxrollParagonSchema>;
+
+export const MaxrollHeroSchema = z
+  .object({
+    /** Display name for this variant/hero. */
+    name: z.string().optional(),
+    /** Numeric class ID (0=Barbarian, 1=Druid, …, 4=Sorcerer, …). */
+    d4class: z.number(),
+    level: z.number().optional(),
+    /** Items as array (each with a numeric slot property). */
+    items: z.array(MaxrollItemSchema).optional(),
+    /**
+     * Alternate representation: items keyed by numeric slot string ("0" = helm, etc.).
+     * Some Maxroll planner versions use this shape instead of the array form.
+     */
+    equipped: z.record(z.string(), MaxrollItemSchema).optional(),
+    skills: z.array(MaxrollSkillSchema).optional(),
+    paragon: MaxrollParagonSchema.optional(),
+  })
+  .passthrough();
+
+export type MaxrollHero = z.infer<typeof MaxrollHeroSchema>;
+
+export const MaxrollPlannerDataSchema = z
+  .object({
+    id: z.string(),
+    name: z.string().optional(),
+    lastUpdate: z.number().optional(),
+    /** Maxroll planner format/content version string. */
+    version: z.string().optional(),
+    heroes: z.array(MaxrollHeroSchema),
+  })
+  .passthrough();
+
+export type MaxrollPlannerData = z.infer<typeof MaxrollPlannerDataSchema>;
+
+/**
+ * Outer API response envelope from planners.maxroll.gg/profiles/load/<id>.
+ * The planner data lives in `data`; `code` is an HTTP-like status.
+ */
+export const MaxrollApiResponseSchema = z
+  .object({
+    code: z.number().optional(),
+    data: MaxrollPlannerDataSchema.optional(),
+  })
+  .passthrough();
+
+export type MaxrollApiResponse = z.infer<typeof MaxrollApiResponseSchema>;
+
+// ─── data.min.json payload ─────────────────────────────────────────────────
+
+/** A single entry in a data.min.json mapping table. */
+export const DataMinEntrySchema = z
+  .object({
+    bnetFileName: z.string().optional(),
+  })
+  .passthrough();
+
+export type DataMinEntry = z.infer<typeof DataMinEntrySchema>;
+
+/**
+ * Top-level structure of the data.min.json asset.
+ *
+ * All mapping tables are records keyed by Maxroll's internal nid string.
+ * `version` identifies the catalog/patch version for cache invalidation (D4).
+ */
+export const DataMinSchema = z
+  .object({
+    /** Patch/content version string — compared against catalog.verifiedAgainst.patch (D9). */
+    version: z.string(),
+    affixes: z.record(z.string(), DataMinEntrySchema).optional(),
+    aspects: z.record(z.string(), DataMinEntrySchema).optional(),
+    skills: z.record(z.string(), DataMinEntrySchema).optional(),
+    boards: z.record(z.string(), DataMinEntrySchema).optional(),
+    glyphs: z.record(z.string(), DataMinEntrySchema).optional(),
+  })
+  .passthrough();
+
+export type DataMin = z.infer<typeof DataMinSchema>;
