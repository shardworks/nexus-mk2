@@ -0,0 +1,70 @@
+/**
+ * Maxroll slot + class translation tables (D27).
+ *
+ * These are importer-private — not part of the catalog.
+ * Maps Maxroll's numeric slot IDs and class IDs to our catalog ids.
+ */
+
+/**
+ * Maxroll numeric slot ID → catalog slot id.
+ * Barbarian-specific slots (10-13) map to the barb_ prefixed catalog ids.
+ */
+export const MAXROLL_SLOT_MAP: Record<number, string> = {
+  0: "helm",
+  1: "chest",
+  2: "gloves",
+  3: "pants",
+  4: "boots",
+  5: "amulet",
+  6: "ring1",
+  7: "ring2",
+  8: "weapon",        // main-hand (non-Barbarian) or 1H main (Barbarian)
+  9: "offHand",       // off-hand (non-Barbarian) or 1H off (Barbarian)
+  10: "barb_1h_main",
+  11: "barb_1h_off",
+  12: "barb_2h_bludgeoning",
+  13: "barb_2h_slashing",
+};
+
+/**
+ * Maxroll numeric class ID → canonical D4Class string.
+ * Matches the D4_CLASSES order in CharacterSchema.
+ */
+export const MAXROLL_CLASS_MAP: Record<number, string> = {
+  0: "Barbarian",
+  1: "Druid",
+  2: "Necromancer",
+  3: "Rogue",
+  4: "Sorcerer",
+  5: "Spiritborn",
+  6: "Paladin",
+  7: "Warlock",
+};
+
+/**
+ * Maxroll numeric item quality → catalog rarity string.
+ * Used as a hint only — D14 rarity determination takes precedence when
+ * a unique catalog entry is matched.
+ */
+export const MAXROLL_QUALITY_MAP: Record<number, string> = {
+  0: "common",
+  1: "magic",
+  2: "rare",
+  3: "legendary",
+  4: "unique",
+  5: "mythic",
+};
+
+/**
+ * Maxroll numeric skill slot → canonical slot string for SkillSelectionSchema.
+ * Maxroll uses 0-indexed bar slot numbers.
+ */
+export const MAXROLL_SKILL_SLOT_MAP: Record<number, string> = {
+  0: "basic",
+  1: "core",
+  2: "defensive",
+  3: "conjuration",
+  4: "mastery",
+  5: "ultimate",
+  6: "key-passive",
+};
diff --git a/lib/import/maxroll/types.ts b/lib/import/maxroll/types.ts
new file mode 100644
index 0000000..96b4603
--- /dev/null
+++ b/lib/import/maxroll/types.ts
@@ -0,0 +1,119 @@
+/**
+ * Public types for the Maxroll planner importer (D7/D8).
+ *
+ * Only the top-level ImportResult and related types are exported here.
+ * Internal parser/fetcher/mapper types stay in their own private modules.
+ */
+
+import type { BuildImportedFrom } from "@/lib/schema/build";
+
+// ─── Per-character output shape ────────────────────────────────────────────
+
+/**
+ * Minimal character data shape returned by the importer.
+ * Matches CharacterSchema minus id/createdAt/updatedAt (server generates those).
+ */
+export interface ImportedCharacter {
+  name: string;
+  class: string;
+  level: number;
+  paragonAllocation: {
+    paragonLevel: number;
+    boards: Array<{
+      boardId: string;
+      boardName: string;
+      spentPoints: number;
+      glyph?: { glyphId: string; level: number };
+      nodes: string[];
+    }>;
+  };
+  skillSelections: Array<{
+    skillId: string;
+    rank: number;
+    slot?: string;
+  }>;
+  equippedItems: Record<
+    string,
+    {
+      slot: string;
+      name: string;
+      rarity: "common" | "magic" | "rare" | "legendary" | "unique" | "mythic";
+      itemPower?: number;
+      isAncestral: boolean;
+      implicits: Array<{ affixId: string; rolledValue?: number; rolledRange?: [number, number] }>;
+      explicits: Array<{ affixId: string; rolledValue?: number; rolledRange?: [number, number] }>;
+      tempered: Array<{ affixId: string; rolledValue?: number; rolledRange?: [number, number] }>;
+      aspect?: { aspectId: string; rolledValue: number; source: "legendary" | "codex" };
+      masterworkRank: number;
+      runes: string[];
+      sockets: string[];
+    }
+  >;
+  playstyleConstraints: [];
+}
+
+// ─── Unmapped reference discriminated union (D8) ───────────────────────────
+
+export type UnmappedRef =
+  | { category: "affix"; nid: string; bnetFileName?: string; slot: string; reason: string }
+  | { category: "aspect"; nid: string; bnetFileName?: string; slot: string; reason: string }
+  | { category: "paragon-node"; nid: string; bnetFileName?: string; reason: string }
+  | { category: "glyph"; nid: string; bnetFileName?: string; boardNid: string; reason: string }
+  | { category: "skill"; nid: string; bnetFileName?: string; reason: string }
+  | { category: "unique"; nid: string; bnetFileName?: string; slot: string; reason: string };
+
+// ─── Import report ─────────────────────────────────────────────────────────
+
+export interface VersionMismatch {
+  dataminVersion: string;
+  catalogPatch: string;
+  mappingRatePct: number;
+}
+
+export interface ImportReport {
+  unmappedAffixes: UnmappedRef[];
+  unmappedAspects: UnmappedRef[];
+  unmappedParagonNodes: UnmappedRef[];
+  unmappedGlyphs: UnmappedRef[];
+  unmappedSkills: UnmappedRef[];
+  /** Present when data.min version differs from catalog patch but mapping threshold was met. */
+  versionMismatch?: VersionMismatch;
+}
+
+// ─── ImportResult discriminated union (D7) ─────────────────────────────────
+
