+++ b/app/import/maxroll/page.tsx
@@ -0,0 +1,400 @@
+"use client";
+
+/**
+ * /import/maxroll — Maxroll planner importer UI.
+ *
+ * Four states (D20):
+ *   1. "paste"   — URL/ID input + Import button
+ *   2. "preview" — build summary, variant picker, gear list, unmapped counts
+ *   3. "confirm" — selected variant summary + "Import this build" / "Back" buttons
+ *   4. Loading   — transient state while committing; redirects to /builds/<id>
+ *
+ * Commit path (D23): POST chosen character payload to /api/characters?withDefaultBuild=true
+ * including buildImportedFrom provenance, then router.push to /builds/<id>.
+ */
+
+import { useState, useCallback } from "react";
+import { useRouter } from "next/navigation";
+import { Button } from "@/components/ui/button";
+import { Input } from "@/components/ui/input";
+import { ArrowLeft, Download, AlertTriangle, CheckCircle2 } from "lucide-react";
+
+// ─── Types mirroring ImportResult ─────────────────────────────────────────
+
+interface ImportReport {
+  unmappedAffixes: unknown[];
+  unmappedAspects: unknown[];
+  unmappedParagonNodes: unknown[];
+  unmappedGlyphs: unknown[];
+  unmappedSkills: unknown[];
+  versionMismatch?: { dataminVersion: string; catalogPatch: string; mappingRatePct: number };
+}
+
+interface VariantResult {
+  ok: true;
+  character: {
+    name: string;
+    class: string;
+    level: number;
+    paragonAllocation: { paragonLevel: number; boards: unknown[] };
+    skillSelections: unknown[];
+    equippedItems: Record<string, unknown>;
+    playstyleConstraints: [];
+  };
+  importedFrom: {
+    source: "maxroll";
+    plannerId: string;
+    variantIndex: number;
+    importedAt: string;
+    plannerVersion: string;
+  };
+  report: ImportReport;
+  variantIndex: number;
+  variantCount: number;
+}
+
+type FlowState =
+  | { kind: "paste" }
+  | { kind: "preview"; variants: VariantResult[]; selectedIdx: number }
+  | { kind: "confirm"; variant: VariantResult }
+  | { kind: "loading" };
+
+// ─── Helpers ────────────────────────────────────────────────────────────────
+
+function unmappedTotal(report: ImportReport): number {
+  return (
+    report.unmappedAffixes.length +
+    report.unmappedAspects.length +
+    report.unmappedParagonNodes.length +
+    report.unmappedGlyphs.length +
+    report.unmappedSkills.length
+  );
+}
+
+// ─── Component ──────────────────────────────────────────────────────────────
+
+export default function ImportMaxrollPage() {
+  const router = useRouter();
+  const [state, setState] = useState<FlowState>({ kind: "paste" });
+  const [inputValue, setInputValue] = useState("");
+  const [importError, setImportError] = useState<string | null>(null);
+  const [importing, setImporting] = useState(false);
+
+  // ── Paste state: trigger preview ─────────────────────────────────────────
+  const handleImport = useCallback(async () => {
+    const trimmed = inputValue.trim();
+    if (!trimmed) return;
+
+    setImportError(null);
+    setImporting(true);
+
+    try {
+      const res = await fetch("/api/import/maxroll/preview", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ input: trimmed }),
+      });
+
+      const json = await res.json();
+
+      if (!res.ok) {
+        setImportError(json.error ?? `Import failed (HTTP ${res.status})`);
+        return;
+      }
+
+      const variants: VariantResult[] = (json.variants ?? []).filter(
+        (v: unknown): v is VariantResult => (v as VariantResult)?.ok === true
+      );
+
+      if (variants.length === 0) {
+        setImportError("No usable variants returned from this planner.");
+        return;
+      }
+
+      setState({ kind: "preview", variants, selectedIdx: 0 });
+    } catch (err) {
+      setImportError(err instanceof Error ? err.message : "Network error");
+    } finally {
+      setImporting(false);
+    }
+  }, [inputValue]);
+
+  // ── Preview state: proceed to confirm ─────────────────────────────────────
+  const handleConfirm = useCallback((variant: VariantResult) => {
+    setState({ kind: "confirm", variant });
+  }, []);
+
+  // ── Confirm state: commit ─────────────────────────────────────────────────
+  const handleCommit = useCallback(
+    async (variant: VariantResult) => {
+      setState({ kind: "loading" });
+      try {
+        const res = await fetch("/api/characters?withDefaultBuild=true", {
+          method: "POST",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify({
+            ...variant.character,
+            buildImportedFrom: variant.importedFrom,
+          }),
+        });
+
+        if (!res.ok) {
+          const err = await res.json();
+          throw new Error(err.error ?? "Failed to create character");
+        }
+
+        const { build } = await res.json();
+        router.push(`/builds/${build.id}`);
+      } catch (err) {
+        setImportError(err instanceof Error ? err.message : "Failed to import build");
+        setState({ kind: "paste" });
+      }
+    },
+    [router]
+  );
+
+  // ─── Render ───────────────────────────────────────────────────────────────
+
+  if (state.kind === "loading") {
+    return (
+      <div className="p-6 max-w-[640px]">
+        <p className="text-stone-400 text-sm animate-pulse">Importing build…</p>
+      </div>
+    );
+  }
+
+  return (
+    <div className="p-6 max-w-[640px]">
+      {/* Header */}
+      <div className="flex items-center gap-3 mb-6">
+        <Button
+          variant="ghost"
+          size="sm"
+          className="gap-1 text-[11px] px-2 text-stone-400"
+          onClick={() => router.back()}
+        >
+          <ArrowLeft size={12} />
+          Back
+        </Button>
+        <h1 className="text-[20px] font-bold text-stone-100 m-0">Import from Maxroll</h1>
+      </div>
+
+      {/* Error banner */}
+      {importError && (
+        <div className="error-banner font-mono whitespace-pre-wrap mb-4 text-xs">
+          {importError}
+        </div>
+      )}
+
+      {/* ── State: paste ── */}
+      {state.kind === "paste" && (
+        <div className="flex flex-col gap-4">
+          <p className="text-stone-400 text-sm">
+            Paste a Maxroll planner ID, planner URL, or build-guide URL to import a build.
+          </p>
+          <div className="flex gap-2">
+            <Input
+              placeholder="e.g. uHxkbvE0 or https://maxroll.gg/d4/planner/…"
+              value={inputValue}
+              onChange={(e) => setInputValue(e.target.value)}
+              onKeyDown={(e) => {
+                if (e.key === "Enter") handleImport();
+              }}
+              className="font-mono text-sm"
+              autoFocus
+            />
+            <Button
+              onClick={handleImport}
+              disabled={importing || !inputValue.trim()}
+              className="shrink-0 gap-[6px]"
+            >
+              <Download size={14} />
+              {importing ? "Importing…" : "Import"}
+            </Button>
+          </div>
+          <p className="text-stone-500 text-xs">
+            Accepted formats: planner ID, <code>https://maxroll.gg/d4/planner/&lt;id&gt;</code>,{" "}
+            <code>https://maxroll.gg/d4/build-guides/&lt;slug&gt;</code>
+          </p>
+        </div>
+      )}
+
+      {/* ── State: preview ── */}
+      {state.kind === "preview" && (
+        <div className="flex flex-col gap-5">
+          <div className="flex items-center justify-between">
+            <h2 className="text-[15px] font-semibold text-stone-200">
+              Preview — {state.variants.length} variant
+              {state.variants.length !== 1 ? "s" : ""}
+            </h2>
+            <Button
+              variant="ghost"
+              size="sm"
+              className="text-[11px] text-stone-400"
+              onClick={() => setState({ kind: "paste" })}
+            >
+              ← New import
+            </Button>
+          </div>
+
+          {/* Variant picker */}
+          {state.variants.length > 1 && (
+            <div className="flex gap-2 flex-wrap">
+              {state.variants.map((v, idx) => (
+                <Button
+                  key={idx}
+                  variant={state.selectedIdx === idx ? "default" : "outline"}
+                  size="sm"
+                  className="text-xs"
+                  onClick={() => setState({ ...state, selectedIdx: idx })}
+                >
+                  {v.character.name || `Variant ${idx + 1}`}
+                </Button>
+              ))}
+            </div>
+          )}
+
+          {/* Selected variant summary */}
+          <VariantSummary variant={state.variants[state.selectedIdx]} />
+
+          <Button
+            className="self-start gap-[6px]"
+            onClick={() => handleConfirm(state.variants[state.selectedIdx])}
+          >
+            <CheckCircle2 size={14} />
+            Continue with this variant
+          </Button>
+        </div>
+      )}
+
+      {/* ── State: confirm ── */}
+      {state.kind === "confirm" && (
+        <div className="flex flex-col gap-5">
+          <div className="flex items-center justify-between">
+            <h2 className="text-[15px] font-semibold text-stone-200">Confirm import</h2>
+            <Button
+              variant="ghost"
+              size="sm"
+              className="text-[11px] text-stone-400"
+              onClick={() => setState({ kind: "preview", variants: [state.variant], selectedIdx: 0 })}
+            >
+              ← Back to preview
+            </Button>
+          </div>
+
+          <VariantSummary variant={state.variant} />
+
+          <p className="text-stone-400 text-sm">
+            A new character and build will be created in your library. You can edit it after import.
+          </p>
+
+          <div className="flex gap-3">
+            <Button
+              className="gap-[6px]"
+              onClick={() => handleCommit(state.variant)}
+            >
+              <Download size={14} />
+              Import this build
+            </Button>
+            <Button
+              variant="outline"
+              onClick={() => setState({ kind: "paste" })}
+            >
+              Cancel
+            </Button>
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
+
+// ─── VariantSummary sub-component ─────────────────────────────────────────
+
+function VariantSummary({ variant }: { variant: VariantResult }) {
+  const { character, report } = variant;
+  const itemCount = Object.keys(character.equippedItems).length;
+  const total = unmappedTotal(report);
+
+  return (
+    <div className="border border-stone-800 rounded-md bg-surface-2 p-4 flex flex-col gap-3">
+      {/* Character info */}
+      <div>
+        <div className="text-sm font-semibold text-stone-100">{character.name}</div>
+        <div className="text-[11px] text-stone-400 mt-0.5">
+          {character.class} · Lvl {character.level} · Paragon{" "}
+          {character.paragonAllocation.paragonLevel}
+        </div>
+      </div>
+
+      {/* Stats row */}
+      <div className="grid grid-cols-3 gap-3 text-center">
+        <StatCell label="Items" value={itemCount} />
+        <StatCell label="Skills" value={character.skillSelections.length} />
+        <StatCell
+          label="Paragon boards"
+          value={character.paragonAllocation.boards.length}
+        />
+      </div>
+
+      {/* Version mismatch warning */}
+      {report.versionMismatch && (
+        <div className="flex items-start gap-2 text-amber-400 bg-amber-900/20 border border-amber-800 rounded p-2">
+          <AlertTriangle size={14} className="mt-0.5 shrink-0" />
+          <span className="text-[11px]">
+            Data version mismatch: Maxroll data is{" "}
+            <code>{report.versionMismatch.dataminVersion}</code> vs catalog{" "}
+            <code>{report.versionMismatch.catalogPatch}</code>.{" "}
+            {report.versionMismatch.mappingRatePct}% of affixes mapped.
+          </span>
+        </div>
+      )}
+
+      {/* Unmapped summary */}
+      {total > 0 && (
+        <div className="text-[11px] text-stone-500">
+          {total} reference{total !== 1 ? "s" : ""} could not be mapped from the catalog
+          {report.unmappedAffixes.length > 0 &&
+            ` (${report.unmappedAffixes.length} affix${report.unmappedAffixes.length !== 1 ? "es" : ""})`}
+          {report.unmappedAspects.length > 0 &&
+            `, ${report.unmappedAspects.length} aspect${report.unmappedAspects.length !== 1 ? "s" : ""}`}
+          {report.unmappedSkills.length > 0 &&
+            `, ${report.unmappedSkills.length} skill${report.unmappedSkills.length !== 1 ? "s" : ""}`}
+          {report.unmappedGlyphs.length > 0 &&
+            `, ${report.unmappedGlyphs.length} glyph${report.unmappedGlyphs.length !== 1 ? "s" : ""}`}
+          .
+        </div>
+      )}
+
+      {/* Gear-by-slot list */}
+      {itemCount > 0 && (
+        <div className="mt-1">
+          <div className="text-[10px] font-semibold text-stone-500 uppercase tracking-[0.06em] mb-1.5">
+            Gear
+          </div>
+          <div className="flex flex-col gap-0.5">
+            {Object.entries(character.equippedItems).map(([slot]) => (
+              <div key={slot} className="flex items-center gap-2 text-[11px]">
+                <span className="text-stone-500 w-24 shrink-0 capitalize">
+                  {slot.replace(/_/g, " ")}
+                </span>
+                <span className="text-stone-300">
+                  {(character.equippedItems[slot] as { rarity?: string }).rarity ?? "?"}
+                </span>
+              </div>
+            ))}
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
+
+function StatCell({ label, value }: { label: string; value: number }) {
+  return (
+    <div className="flex flex-col">
+      <span className="text-[18px] font-bold text-stone-100 tabular-nums">{value}</span>
+      <span className="text-[10px] text-stone-500 uppercase tracking-[0.06em]">{label}</span>
+    </div>
+  );
+}
