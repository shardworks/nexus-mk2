@@ -0,0 +1,15 @@
+/**
+ * Top-level import subsystem re-export (D1).
+ *
+ * All import sources are namespaced under lib/import/<source>/.
+ * This file re-exports only the public surface from each source.
+ */
+
+export { importMaxrollPlanner } from "./maxroll";
+export type {
+  ImportResult,
+  ImportContext,
+  ImportReport,
+  UnmappedRef,
+  ImportedCharacter,
+} from "./maxroll";
diff --git a/lib/import/maxroll/catalog-index.ts b/lib/import/maxroll/catalog-index.ts
new file mode 100644
index 0000000..d740331
--- /dev/null
+++ b/lib/import/maxroll/catalog-index.ts
@@ -0,0 +1,105 @@
+/**
+ * Catalog join indices for the Maxroll importer (built once at module load).
+ *
+ * All lookups are exact-match on bnetFileName — no label-match or tag fallbacks (D4).
+ * Class-specific indices (skills, boards, glyphs) are built for ALL supported classes
+ * at startup since the importer is stateless and the class isn't known at index-build time.
+ */
+
+import {
+  affixes,
+  aspects,
+  uniques,
+  getSkillsForClass,
+  getParagonCatalogForClass,
+  type AffixEntry,
+  type AspectEntry,
+  type UniqueEntry,
+  type SkillEntry,
+  type ParagonBoardEntry,
+  type ParagonGlyphEntry,
+} from "@/lib/catalog";
+import { D4_CLASSES } from "@/lib/schema";
+
+// ─── Affixes ───────────────────────────────────────────────────────────────
+
+/** Map from bnetFileName → AffixEntry (first non-deprecated match wins). */
+export const affixByBnet: Map<string, AffixEntry> = new Map();
+for (const entry of affixes) {
+  if (!entry.deprecated && entry.bnetFileName && !affixByBnet.has(entry.bnetFileName)) {
+    affixByBnet.set(entry.bnetFileName, entry);
+  }
+}
+
+// ─── Aspects ──────────────────────────────────────────────────────────────
+
+/** Map from bnetFileName → AspectEntry. */
+export const aspectByBnet: Map<string, AspectEntry> = new Map();
+for (const entry of aspects) {
+  if (!entry.deprecated && entry.bnetFileName && !aspectByBnet.has(entry.bnetFileName)) {
+    aspectByBnet.set(entry.bnetFileName, entry);
+  }
+}
+
+// ─── Uniques ──────────────────────────────────────────────────────────────
+
+/** Map from bnetFileName → UniqueEntry. */
+export const uniqueByBnet: Map<string, UniqueEntry> = new Map();
+for (const entry of uniques) {
+  if (!entry.deprecated && entry.bnetFileName && !uniqueByBnet.has(entry.bnetFileName)) {
+    uniqueByBnet.set(entry.bnetFileName, entry);
+  }
+}
+
+// ─── Skills (per-class) ────────────────────────────────────────────────────
+
+export interface SkillIndexEntry {
+  className: string;
+  entry: SkillEntry;
+}
+
+/** Map from bnetFileName → first SkillIndexEntry found across all classes. */
+export const skillByBnet: Map<string, SkillIndexEntry> = new Map();
+for (const className of D4_CLASSES) {
+  for (const entry of getSkillsForClass(className)) {
+    if (entry.bnetFileName && !skillByBnet.has(entry.bnetFileName)) {
+      skillByBnet.set(entry.bnetFileName, { className, entry });
+    }
+  }
+}
+
+// ─── Paragon boards (per-class) ────────────────────────────────────────────
+
+export interface BoardIndexEntry {
+  className: string;
+  entry: ParagonBoardEntry;
+}
+
+/** Map from bnetFileName → first BoardIndexEntry found across all classes. */
+export const boardByBnet: Map<string, BoardIndexEntry> = new Map();
+for (const className of D4_CLASSES) {
+  const { boards } = getParagonCatalogForClass(className);
+  for (const entry of boards) {
+    if (entry.bnetFileName && !boardByBnet.has(entry.bnetFileName)) {
+      boardByBnet.set(entry.bnetFileName, { className, entry });
+    }
+  }
+}
+
+// ─── Paragon glyphs (per-class) ────────────────────────────────────────────
+
+export interface GlyphIndexEntry {
+  className: string;
+  entry: ParagonGlyphEntry;
+}
+
+/** Map from bnetFileName → first GlyphIndexEntry found across all classes. */
+export const glyphByBnet: Map<string, GlyphIndexEntry> = new Map();
+for (const className of D4_CLASSES) {
+  const { glyphs } = getParagonCatalogForClass(className);
+  for (const entry of glyphs) {
+    if (entry.bnetFileName && !glyphByBnet.has(entry.bnetFileName)) {
+      glyphByBnet.set(entry.bnetFileName, { className, entry });
+    }
+  }
+}
diff --git a/lib/import/maxroll/client.ts b/lib/import/maxroll/client.ts
new file mode 100644
index 0000000..7365c11
--- /dev/null
+++ b/lib/import/maxroll/client.ts
@@ -0,0 +1,107 @@
+/**
+ * Maxroll network client — env-var URL helpers + fetch wrappers.
+ *
+ * Two env-var overrides (D6), mirroring lib/triage/anthropic.ts pattern:
+ *   MAXROLL_PLANNER_API_BASE — full base override for planners.maxroll.gg
+ *   MAXROLL_DATA_BASE        — full base override for assets-ng.maxroll.gg
+ *
+ * Native fetch only; no SDK deps. Fail-loud on non-2xx.
+ */
+
+/** Returns the base URL for the Maxroll planner API. */
+function getPlannerApiBase(): string {
+  const override = process.env.MAXROLL_PLANNER_API_BASE;
+  if (override && override.length > 0) return override.replace(/\/$/, "");
+  return "https://planners.maxroll.gg";
+}
+
+/** Returns the base URL for Maxroll data assets (data.min.json). */
+function getDataBase(): string {
+  const override = process.env.MAXROLL_DATA_BASE;
+  if (override && override.length > 0) return override.replace(/\/$/, "");
+  return "https://assets-ng.maxroll.gg";
+}
+
+/** Full URL for loading a planner profile by ID. */
+export function plannerLoadUrl(plannerId: string): string {
+  return `${getPlannerApiBase()}/profiles/load/${encodeURIComponent(plannerId)}`;
+}
+
+/** Full URL for fetching the data.min.json data asset. */
+export function dataMinUrl(): string {
+  return `${getDataBase()}/d4/data.min.json`;
+}
+
+/** Full URL for fetching a build guide HTML page (used to extract embedded planner ID). */
+export function buildGuideUrl(slug: string): string {
+  return `https://maxroll.gg/d4/build-guides/${slug}`;
+}
+
+/**
+ * Fetch a URL and return the parsed JSON body.
+ * Throws on non-2xx with a descriptive message.
+ */
+export async function fetchJson<T>(
+  url: string,
+  fetchFn: typeof globalThis.fetch = globalThis.fetch
+): Promise<T> {
+  let res: Response;
+  try {
+    res = await fetchFn(url, {
+      headers: { Accept: "application/json" },
+    });
+  } catch (err) {
+    throw Object.assign(
+      new Error(`Network error fetching ${url}: ${err instanceof Error ? err.message : String(err)}`),
+      { code: "network" as const }
+    );
+  }
+
+  if (res.status === 404) {
+    throw Object.assign(new Error(`Not found: ${url}`), { code: "not-found" as const });
+  }
+  if (res.status === 403 || res.status === 401) {
+    throw Object.assign(new Error(`Access denied: ${url}`), { code: "private" as const });
+  }
+  if (!res.ok) {
+    throw Object.assign(
+      new Error(`HTTP ${res.status} fetching ${url}`),
+      { code: "network" as const }
+    );
+  }
+
+  try {
+    return (await res.json()) as T;
+  } catch (err) {
+    throw Object.assign(
+      new Error(`Failed to parse JSON from ${url}: ${err instanceof Error ? err.message : String(err)}`),
+      { code: "parse-error" as const }
+    );
+  }
+}
+
+/**
+ * Fetch a URL and return the raw text body (used for HTML extraction).
+ * Throws on non-2xx.
+ */
+export async function fetchText(
+  url: string,
+  fetchFn: typeof globalThis.fetch = globalThis.fetch
+): Promise<string> {
+  let res: Response;
+  try {
+    res = await fetchFn(url);
+  } catch (err) {
+    throw Object.assign(
+      new Error(`Network error fetching ${url}: ${err instanceof Error ? err.message : String(err)}`),
+      { code: "network" as const }
+    );
+  }
+  if (!res.ok) {
+    throw Object.assign(
+      new Error(`HTTP ${res.status} fetching ${url}`),
+      { code: "network" as const }
+    );
+  }
+  return res.text();
+}
diff --git a/lib/import/maxroll/data-min-cache.ts b/lib/import/maxroll/data-min-cache.ts
new file mode 100644
index 0000000..f50a5cd
--- /dev/null
+++ b/lib/import/maxroll/data-min-cache.ts
@@ -0,0 +1,90 @@
+/**
+ * data.min.json fetcher + two-layer cache (D4/D5).
+ *
+ * Cache layers:
+ *   1. In-memory:   per-process Map keyed by catalogPatch string
+ *   2. Disk:        DATA_DIR/maxroll-cache/data.min.<patch>.json
+ *
+ * Invalidation: patch-version-keyed filename — switching catalog patches
+ * automatically reads a fresh file (D4). No sliding TTL (D5).
+ *
+ * On first call for a given patch, the full data.min.json is fetched,
+ * validated with Zod, written to the disk cache, and stored in-memory.
+ * Subsequent in-process calls return the in-memory copy without I/O.
+ */
+
+import * as fs from "fs/promises";
+import * as path from "path";
+import { DataMinSchema, type DataMin } from "./payload-schema";
+import { dataMinUrl, fetchJson } from "./client";
+import { verifiedAgainst } from "@/lib/catalog";
+import { getDataDir } from "@/lib/persistence/paths";
+
+/** In-process cache keyed by catalog patch string. */
+const memoryCache = new Map<string, DataMin>();
+
+/** Default disk cache directory (DATA_DIR/maxroll-cache). */
+function defaultCacheDir(): string {
+  return path.join(getDataDir(), "maxroll-cache");
+}
+
+/** Disk cache file path for a given patch string. */
+function diskCachePath(cacheDir: string, patchVersion: string): string {
+  // Sanitise patch version for use as a filename segment
+  const safe = patchVersion.replace(/[^a-zA-Z0-9._-]/g, "_");
+  return path.join(cacheDir, `data.min.${safe}.json`);
+}
+
+/**
+ * Fetch (or load from cache) the data.min.json for the current catalog patch.
+ *
+ * The catalog patch is `verifiedAgainst.patch` from lib/catalog.
+ * Any data.min.json whose `version` doesn't match gets persisted normally — the
+ * version-mismatch check is the mapper's concern (D9); the cache layer just stores
+ * whatever was fetched.
+ */
+export async function getDataMin(
+  options: {
+    fetchFn?: typeof globalThis.fetch;
+    cacheDir?: string;
+  } = {}
+): Promise<DataMin> {
+  const fetchFn = options.fetchFn ?? globalThis.fetch;
+  const cacheDir = options.cacheDir ?? defaultCacheDir();
+  const catalogPatch = verifiedAgainst.patch;
+
+  // ── Layer 1: in-memory ────────────────────────────────────────────────────
+  const cached = memoryCache.get(catalogPatch);
+  if (cached) return cached;
+
+  // ── Layer 2: disk ─────────────────────────────────────────────────────────
+  const diskPath = diskCachePath(cacheDir, catalogPatch);
+  try {
+    const raw = await fs.readFile(diskPath, "utf-8");
+    const parsed = DataMinSchema.parse(JSON.parse(raw));
+    memoryCache.set(catalogPatch, parsed);
+    return parsed;
+  } catch {
+    // File doesn't exist or is corrupt — fall through to fetch
+  }
+
+  // ── Fetch from network ────────────────────────────────────────────────────
+  const raw = await fetchJson<unknown>(dataMinUrl(), fetchFn);
+  const dataMin = DataMinSchema.parse(raw);
+
+  // Write to disk cache (best-effort — don't fail the import if this fails)
+  await fs
+    .mkdir(cacheDir, { recursive: true })
+    .then(() => fs.writeFile(diskPath, JSON.stringify(dataMin), "utf-8"))
+    .catch(() => undefined);
+
+  memoryCache.set(catalogPatch, dataMin);
+  return dataMin;
+}
+
+/**
+ * Clear the in-memory cache. Used by tests to reset between test cases.
+ */
+export function clearDataMinMemoryCache(): void {
+  memoryCache.clear();
+}
diff --git a/lib/import/maxroll/importer.ts b/lib/import/maxroll/importer.ts
new file mode 100644
index 0000000..24c2e65
--- /dev/null
+++ b/lib/import/maxroll/importer.ts
@@ -0,0 +1,179 @@
+/**
+ * Top-level importMaxrollPlanner orchestrator.
+ *
+ * Flow:
+ *   1. Parse input → { plannerId, variantIndex }
+ *   2. Fetch planner data from planners.maxroll.gg/profiles/load/<id>
+ *   3. Fetch (or load from cache) data.min.json
+ *   4. Map the selected variant using mapHero()
+ *   5. Apply patch-mismatch fail rule (D9)
+ *   6. Return ImportResult
+ *
+ * Returns ImportResult (discriminated union) — never throws for domain failures.
+ * Only throws for programming errors (should not happen in normal usage).
+ */
+
+import { parseMaxrollInput } from "./parser";
+import { fetchJson, plannerLoadUrl } from "./client";
+import { getDataMin } from "./data-min-cache";
+import { MaxrollApiResponseSchema, type MaxrollPlannerData } from "./payload-schema";
+import { mapHero } from "./mapper";
+import type { ImportResult, ImportContext } from "./types";
+
+export async function importMaxrollPlanner(
+  input: string,
+  ctx: ImportContext = {}
+): Promise<ImportResult> {
+  const fetchFn = ctx.fetch ?? globalThis.fetch;
+  const now = ctx.now ?? new Date();
+
+  // ── 1. Parse input ────────────────────────────────────────────────────────
+  let parsedRef: { plannerId: string; variantIndex: number };
+  try {
+    parsedRef = await parseMaxrollInput(input, fetchFn);
+  } catch (err) {
+    const code = (err as { code?: string }).code;
+    return {
+      ok: false,
+      reason: code === "not-found" ? "not-found" : "parse-error",
+      message: err instanceof Error ? err.message : String(err),
+      details: err,
+    };
+  }
+
+  const { plannerId, variantIndex } = parsedRef;
+
+  // ── 2. Fetch planner data ─────────────────────────────────────────────────
+  let plannerData: MaxrollPlannerData;
+  try {
+    const raw = await fetchJson<unknown>(plannerLoadUrl(plannerId), fetchFn);
+    const apiResponse = MaxrollApiResponseSchema.parse(raw);
+
+    // The planner data lives in apiResponse.data.
+    // Some API versions expose heroes directly at the top level — fall back to
+    // treating the entire response as a MaxrollPlannerData if .data is absent.
+    const unwrapped: MaxrollPlannerData | undefined =
+      apiResponse.data ??
+      ((apiResponse as unknown as MaxrollPlannerData).heroes
+        ? (apiResponse as unknown as MaxrollPlannerData)
+        : undefined);
+
+    if (!unwrapped) {
+      return {
+        ok: false,
+        reason: "parse-error",
+        message: `Planner API response did not contain heroes array for planner: ${plannerId}`,
+      };
+    }
+
+    plannerData = unwrapped;
+  } catch (err) {
+    const code = (err as { code?: string }).code;
+    if (code === "not-found") {
+      return { ok: false, reason: "not-found", message: `Planner not found: ${plannerId}` };
+    }
+    if (code === "private") {
+      return { ok: false, reason: "private", message: `Planner is private: ${plannerId}` };
+    }
+    if (code === "parse-error") {
+      return {
+        ok: false,
+        reason: "parse-error",
+        message: err instanceof Error ? err.message : String(err),
+        details: err,
+      };
+    }
+    return {
+      ok: false,
+      reason: "network",
+      message: err instanceof Error ? err.message : String(err),
+      details: err,
+    };
+  }
+
+  const heroes = plannerData.heroes;
+  if (!heroes || heroes.length === 0) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: `Planner has no heroes/variants: ${plannerId}`,
+    };
+  }
+  const variantCount = heroes.length;
+
+  // Clamp variant index to valid range
+  const safeVariantIndex = Math.max(0, Math.min(variantIndex, variantCount - 1));
+  const hero = heroes[safeVariantIndex];
+
+  // ── 3. Fetch data.min.json ─────────────────────────────────────────────────
+  let dataMin;
+  try {
+    dataMin = await getDataMin({ fetchFn, cacheDir: ctx.cacheDir });
+  } catch (err) {
+    const code = (err as { code?: string }).code;
+    return {
+      ok: false,
+      reason: code === "parse-error" ? "parse-error" : "network",
+      message: err instanceof Error ? err.message : String(err),
+      details: err,
+    };
+  }
+
+  // ── 4. Map hero ───────────────────────────────────────────────────────────
+  const plannerVersion = plannerData.version ?? dataMin.version;
+
+  let mapResult;
+  try {
+    mapResult = mapHero(hero, plannerId, safeVariantIndex, plannerVersion, dataMin);
+  } catch (err) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: `Mapping failed: ${err instanceof Error ? err.message : String(err)}`,
+      details: err,
+    };
+  }
+
+  const { character, report, mappingThresholdMet } = mapResult;
+
+  // ── 5. Patch-mismatch fail rule (D9) ──────────────────────────────────────
+  if (report.versionMismatch && !mappingThresholdMet) {
+    return {
+      ok: false,
+      reason: "patch-mismatch",
+      message:
+        `data.min.json version (${report.versionMismatch.dataminVersion}) differs from ` +
+        `catalog patch (${report.versionMismatch.catalogPatch}) and explicit-affix mapping rate ` +
+        `is only ${report.versionMismatch.mappingRatePct}% (threshold: 50%).`,
+      details: report.versionMismatch,
+    };
+  }
+
+  // ── 6. Zero-mapped guard ──────────────────────────────────────────────────
+  const hasAnyItem = Object.keys(character.equippedItems).length > 0;
+  const hasAnySkill = character.skillSelections.length > 0;
+  const hasAnyParagon = character.paragonAllocation.boards.length > 0;
+  if (!hasAnyItem && !hasAnySkill && !hasAnyParagon) {
+    return {
+      ok: false,
+      reason: "zero-mapped",
+      message: "No items, skills, or paragon boards could be mapped from this planner variant.",
+    };
+  }
+
+  // ── 7. Return success ─────────────────────────────────────────────────────
+  return {
+    ok: true,
+    character,
+    importedFrom: {
+      source: "maxroll",
+      plannerId,
+      variantIndex: safeVariantIndex,
+      importedAt: now.toISOString(),
+      plannerVersion,
+    },
+    report,
+    variantIndex: safeVariantIndex,
+    variantCount,
+  };
+}
