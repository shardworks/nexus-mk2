diff --git a/app/api/import/maxroll/preview/route.ts b/app/api/import/maxroll/preview/route.ts
new file mode 100644
index 0000000..6323f9a
--- /dev/null
+++ b/app/api/import/maxroll/preview/route.ts
@@ -0,0 +1,68 @@
+/**
+ * POST /api/import/maxroll/preview
+ *
+ * Stateless server adapter for the Maxroll planner importer (D23).
+ * Accepts a planner reference (id, planner URL, build-guide URL) in the
+ * request body and returns ALL variants' mapped preview payloads in one
+ * response — no server-side preview state.
+ *
+ * The UI then POSTs the chosen variant's character payload directly to
+ * POST /api/characters?withDefaultBuild=true (existing commit endpoint).
+ *
+ * HTTP status mapping for library failures:
+ *   not-found     → 404
+ *   private       → 403
+ *   patch-mismatch→ 409
+ *   zero-mapped   → 422
+ *   network       → 502
+ *   parse-error   → 400
+ */
+
+import { NextResponse } from "next/server";
+import { importMaxrollPlanner } from "@/lib/import/maxroll";
+
+export async function POST(request: Request) {
+  let body: unknown;
+  try {
+    body = await request.json();
+  } catch {
+    return NextResponse.json({ error: "Invalid JSON body" }, { status: 400 });
+  }
+
+  if (typeof body !== "object" || body === null || !("input" in body)) {
+    return NextResponse.json(
+      { error: 'Request body must have an "input" field with a planner id or URL.' },
+      { status: 400 }
+    );
+  }
+
+  const { input } = body as { input: unknown };
+  if (typeof input !== "string" || !input.trim()) {
+    return NextResponse.json(
+      { error: '"input" must be a non-empty string.' },
+      { status: 400 }
+    );
+  }
+
+  const result = await importMaxrollPlanner(input.trim());
+
+  if (result.ok) {
+    return NextResponse.json(result, { status: 200 });
+  }
+
+  // Map failure reasons to HTTP status codes
+  const statusMap: Record<string, number> = {
+    "not-found": 404,
+    "private": 403,
+    "patch-mismatch": 409,
+    "zero-mapped": 422,
+    "network": 502,
+    "parse-error": 400,
+  };
+
+  const status = statusMap[result.reason] ?? 400;
+  return NextResponse.json(
+    { error: result.message, reason: result.reason, details: result.details },
+    { status }
+  );
+}
