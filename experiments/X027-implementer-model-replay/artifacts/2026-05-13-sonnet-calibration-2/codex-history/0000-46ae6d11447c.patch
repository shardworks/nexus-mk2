@@ -0,0 +1,85 @@
+/**
+ * Disk + in-memory cache for data.min.json (D4 / D5).
+ *
+ * Cache key: catalog patch string (from verifiedAgainst.patch).
+ * File path: DATA_DIR/maxroll-cache/data.min.<patch>.json
+ * No sliding TTL — patch-version invalidation only (D5).
+ *
+ * In-memory map keyed by patch string prevents repeated disk reads within
+ * the same Node process (relevant for batch calibration runs).
+ */
+
+import * as fs from "fs/promises";
+import * as path from "path";
+import { getDataDir } from "@/lib/persistence/paths";
+import { DataMinSchema, type DataMin } from "./data-min-schema";
+import { fetchDataMinRaw } from "./client";
+import type { ImportContext } from "./types";
+
+// In-memory cache (keyed by patch string)
+const memoryCache = new Map<string, DataMin>();
+
+/**
+ * Returns the directory where data.min.json files are cached.
+ * Uses ctx.cacheDir override when present (for tests); otherwise
+ * DATA_DIR/maxroll-cache.
+ */
+function getCacheDir(ctx: ImportContext): string {
+  if (ctx.cacheDir) return ctx.cacheDir;
+  return path.join(getDataDir(), "maxroll-cache");
+}
+
+function cacheFilePath(cacheDir: string, patch: string): string {
+  // Sanitize patch string to be safe as a filename component
+  const safePatch = patch.replace(/[^a-zA-Z0-9._-]/g, "_");
+  return path.join(cacheDir, `data.min.${safePatch}.json`);
+}
+
+/**
+ * Loads data.min.json for the given catalog patch, using:
+ * 1. In-memory cache (fastest)
+ * 2. Disk cache at DATA_DIR/maxroll-cache/data.min.<patch>.json
+ * 3. Live fetch from assets-ng.maxroll.gg (populates disk + memory cache)
+ *
+ * The cache is NOT invalidated by time — only by patch version change (D5).
+ * A file for the old patch remains on disk but is never read for a different
+ * patch key.
+ */
+export async function loadDataMin(patch: string, ctx: ImportContext): Promise<DataMin> {
+  // 1. In-memory cache
+  const cached = memoryCache.get(patch);
+  if (cached) return cached;
+
+  const cacheDir = getCacheDir(ctx);
+  const filePath = cacheFilePath(cacheDir, patch);
+
+  // 2. Disk cache
+  try {
+    const raw = await fs.readFile(filePath, "utf-8");
+    const parsed = DataMinSchema.parse(JSON.parse(raw));
+    memoryCache.set(patch, parsed);
+    return parsed;
+  } catch {
+    // Cache miss or parse error — fall through to live fetch
+  }
+
+  // 3. Live fetch
+  const raw = await fetchDataMinRaw(ctx);
+  const parsed = DataMinSchema.parse(raw);
+
+  // Populate disk cache (best-effort — ignore write failures)
+  try {
+    await fs.mkdir(cacheDir, { recursive: true });
+    await fs.writeFile(filePath, JSON.stringify(parsed), "utf-8");
+  } catch {
+    // Non-fatal — in-memory cache still works
+  }
+
+  memoryCache.set(patch, parsed);
+  return parsed;
+}
+
+/** Test helper: clear in-memory cache between test cases. */
+export function clearDataMinMemoryCache(): void {
+  memoryCache.clear();
+}
