+++ b/lib/import/maxroll/data-min-schema.ts
@@ -0,0 +1,47 @@
+/**
+ * Zod schema for Maxroll's data.min.json catalog file (D28).
+ *
+ * data.min.json is hosted at MAXROLL_DATA_BASE/d4t/data.min.json.
+ * It maps Maxroll numeric nids → { bnetFileName } for each entry type,
+ * allowing the importer to join against our catalog by bnetFileName (D4).
+ *
+ * All objects use .passthrough() — tolerate extra fields from Maxroll additions.
+ * The `version` field is compared to verifiedAgainst.patch to detect drift (D9).
+ */
+import { z } from "zod";
+
+// A single lookup entry in the data.min catalog
+const DataMinEntrySchema = z
+  .object({
+    nid: z.number().int(),
+    bnetFileName: z.string().optional(),
+  })
+  .passthrough();
+
+export type DataMinEntry = z.infer<typeof DataMinEntrySchema>;
+
+/**
+ * Full data.min.json shape.
+ *
+ * Each sub-catalog is a record keyed by nid (as string) → DataMinEntry.
+ * Missing sub-catalogs are tolerated (default empty record) for forward
+ * compatibility when Maxroll adds new data sections.
+ */
+export const DataMinSchema = z
+  .object({
+    /**
+     * Maxroll's patch/version string — compared against verifiedAgainst.patch
+     * from our catalog to detect staleness (D9).
+     */
+    version: z.string(),
+    affixes: z.record(z.string(), DataMinEntrySchema).default({}),
+    aspects: z.record(z.string(), DataMinEntrySchema).default({}),
+    /** Item type catalog (used for unique detection by item nid). */
+    items: z.record(z.string(), DataMinEntrySchema).default({}),
+    paragonBoards: z.record(z.string(), DataMinEntrySchema).default({}),
+    paragonGlyphs: z.record(z.string(), DataMinEntrySchema).default({}),
+    skills: z.record(z.string(), DataMinEntrySchema).default({}),
+  })
+  .passthrough();
+
+export type DataMin = z.infer<typeof DataMinSchema>;
