--- /dev/null
+++ b/lib/import/maxroll/catalog-index.ts
@@ -0,0 +1,80 @@
+/**
+ * Catalog lookup indices for the Maxroll importer (D3 — built at module load).
+ *
+ * The only mapping mechanism is exact bnetFileName match (D4 decision-3):
+ * no label-match, no attribute-id, no tag-heuristic fallbacks.
+ *
+ * Per-class indices (skills, paragon boards, paragon glyphs) are built lazily
+ * and memoized — getParagonCatalogForClass() is called once per class per
+ * process lifetime.
+ */
+
+import {
+  affixes,
+  aspects,
+  uniques,
+  getSkillsForClass,
+  getParagonCatalogForClass,
+  type AffixEntry,
+  type AspectEntry,
+  type UniqueEntry,
+  type SkillEntry,
+  type ParagonBoardEntry,
+  type ParagonGlyphEntry,
+} from "@/lib/catalog";
+
+// ─── Global indices (built once at module load) ────────────────────────────
+
+/** bnetFileName → AffixEntry (all, including implicits and deprecated) */
+export const affixByBnetFileName = new Map<string, AffixEntry>(
+  affixes
+    .filter((a) => a.bnetFileName)
+    .map((a) => [a.bnetFileName!, a])
+);
+
+/** bnetFileName → AspectEntry */
+export const aspectByBnetFileName = new Map<string, AspectEntry>(
+  aspects
+    .filter((a) => a.bnetFileName)
+    .map((a) => [a.bnetFileName!, a])
+);
+
+/** bnetFileName → UniqueEntry */
+export const uniqueByBnetFileName = new Map<string, UniqueEntry>(
+  uniques
+    .filter((u) => u.bnetFileName)
+    .map((u) => [u.bnetFileName!, u])
+);
+
+// ─── Per-class lazy indices ────────────────────────────────────────────────
+
+type ClassCatalogIndex = {
+  skillByBnetFileName: Map<string, SkillEntry>;
+  boardByBnetFileName: Map<string, ParagonBoardEntry>;
+  glyphByBnetFileName: Map<string, ParagonGlyphEntry>;
+};
+
+const classCatalogCache = new Map<string, ClassCatalogIndex>();
+
+export function getClassCatalogIndex(className: string): ClassCatalogIndex {
+  const cached = classCatalogCache.get(className);
+  if (cached) return cached;
+
+  const skills = getSkillsForClass(className);
+  const { boards, glyphs } = getParagonCatalogForClass(className);
+
+  const index: ClassCatalogIndex = {
+    skillByBnetFileName: new Map(
+      skills.filter((s) => s.bnetFileName).map((s) => [s.bnetFileName!, s])
+    ),
+    boardByBnetFileName: new Map(
+      boards.filter((b) => b.bnetFileName).map((b) => [b.bnetFileName!, b])
+    ),
+    glyphByBnetFileName: new Map(
+      glyphs.filter((g) => g.bnetFileName).map((g) => [g.bnetFileName!, g])
+    ),
+  };
+
+  classCatalogCache.set(className, index);
+  return index;
+}
