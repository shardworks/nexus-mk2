+/**
+ * Maxroll-slot → our-slot translation table (D27).
+ *
+ * Maxroll uses 0-based numeric string keys for item slots in the planner
+ * payload. Barbarian-specific weapon slots (indices 10–13) are included for
+ * forward compatibility; the importer routes them to the canonical slot ids
+ * from lib/catalog/slots.json.
+ *
+ * This map is importer-private. It is NOT exported from lib/import/index.ts.
+ */
+export const MAXROLL_SLOT_MAP: Record<number, string> = {
+  0: "helm",
+  1: "chest",
+  2: "gloves",
+  3: "pants",
+  4: "boots",
+  5: "amulet",
+  6: "ring1",
+  7: "ring2",
+  8: "weapon",
+  9: "offHand",
+  // Barbarian-specific weapon slots
+  10: "barb_1h_main",
+  11: "barb_1h_off",
+  12: "barb_2h_bludgeoning",
+  13: "barb_2h_slashing",
+};
+
+/**
+ * Maxroll numeric class id → canonical D4_CLASSES string (D27).
+ * Sourced from lib/catalog/classes.json bnetClassId fields.
+ */
+export const MAXROLL_CLASS_MAP: Record<number, string> = {
+  1: "Sorcerer",
+  2: "Druid",
+  3: "Necromancer",
+  4: "Barbarian",
+  5: "Rogue",
+  6: "Spiritborn",
+  7: "Paladin",
+  8: "Warlock",
+};
