@@ -0,0 +1,145 @@
+/**
+ * Types for the Maxroll planner importer (lib/import/maxroll).
+ *
+ * ImportContext (D2): all-optional so callers only override what they need.
+ * ImportResult (D7): discriminated union — ok/fail.
+ * UnmappedRef (D8): per-category discriminated union for the report.
+ */
+
+import type { Character } from "@/lib/schema/character";
+import type { BuildImportedFrom } from "@/lib/schema/build";
+
+// ─── Import context (D2) ──────────────────────────────────────────────────────
+
+export interface ImportContext {
+  /**
+   * Custom fetch function — defaults to global fetch.
+   * Override in Vitest via a fixture-server fetch mock (D25).
+   */
+  fetch?: typeof globalThis.fetch;
+
+  /**
+   * Override for the disk-cache directory.
+   * Defaults to DATA_DIR/maxroll-cache at runtime.
+   */
+  cacheDir?: string;
+
+  /**
+   * Override for the current timestamp (used to populate importedAt).
+   * Defaults to new Date().
+   */
+  now?: Date;
+}
+
+// ─── Unmapped references (D8) ────────────────────────────────────────────────
+
+export type UnmappedAffix = {
+  category: "affix";
+  nid: number;
+  bnetFileName?: string;
+  slot: string;
+};
+
+export type UnmappedAspect = {
+  category: "aspect";
+  nid: number;
+  bnetFileName?: string;
+  slot: string;
+};
+
+export type UnmappedParagonNode = {
+  category: "paragon-node";
+  nid: number;
+  bnetFileName?: string;
+};
+
+export type UnmappedGlyph = {
+  category: "glyph";
+  nid: number;
+  bnetFileName?: string;
+  boardNid: number;
+};
+
+export type UnmappedSkill = {
+  category: "skill";
+  nid: number;
+  bnetFileName?: string;
+};
+
+export type UnmappedUnique = {
+  category: "unique";
+  nid: number;
+  bnetFileName?: string;
+  slot: string;
+};
+
+export type UnmappedRef =
+  | UnmappedAffix
+  | UnmappedAspect
+  | UnmappedParagonNode
+  | UnmappedGlyph
+  | UnmappedSkill
+  | UnmappedUnique;
+
+// ─── Import report ─────────────────────────────────────────────────────────────
+
+export interface VersionMismatch {
+  catalogPatch: string;
+  plannerVersion: string;
+  mappedExplicitCount: number;
+  totalExplicitCount: number;
+  mappingRate: number;
+}
+
+export interface ImportReport {
+  unmappedAffixes: UnmappedAffix[];
+  unmappedAspects: UnmappedAspect[];
+  unmappedParagonNodes: UnmappedParagonNode[];
+  unmappedGlyphs: UnmappedGlyph[];
+  unmappedSkills: UnmappedSkill[];
+  unmappedUniques: UnmappedUnique[];
+  /** Present when data.min.json version differs from catalog patch but mapping rate ≥ 50% (D9). */
+  versionMismatch?: VersionMismatch;
+}
+
+// ─── Per-variant result ───────────────────────────────────────────────────────
+
+export interface VariantResult {
+  variantIndex: number;
+  variantName: string;
+  /**
+   * Character payload without id (server generates on commit).
+   * playstyleConstraints always empty on import.
+   */
+  character: Omit<Character, "id">;
+  /** Provenance to be attached to the build on commit (D19). */
+  importedFrom: BuildImportedFrom;
+  report: ImportReport;
+}
+
+// ─── Top-level ImportResult (D7) ─────────────────────────────────────────────
+
+export type ImportResultOk = {
+  ok: true;
+  plannerId: string;
+  /** data.min.json version string observed during import. */
+  plannerVersion: string;
+  /** Default variant index from URL hash or 0 (D10). */
+  defaultVariantIndex: number;
+  variants: VariantResult[];
+};
+
+export type ImportResultFail = {
+  ok: false;
+  reason:
+    | "not-found"
+    | "private"
+    | "patch-mismatch"
+    | "zero-mapped"
+    | "network"
+    | "parse-error";
+  message: string;
+  details?: unknown;
+};
+
+export type ImportResult = ImportResultOk | ImportResultFail;
