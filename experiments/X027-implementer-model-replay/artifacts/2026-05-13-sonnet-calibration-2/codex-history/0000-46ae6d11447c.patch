index 0000000..c9c8e43
--- /dev/null
+++ b/lib/import/maxroll/index.ts
@@ -0,0 +1,124 @@
+/**
+ * Maxroll planner importer — public entry point (D3).
+ *
+ * Only `importMaxrollPlanner` is exported from this package.
+ * All helpers (parser, fetcher, mapper, cache) are private to lib/import/maxroll/.
+ *
+ * Usage:
+ *   import { importMaxrollPlanner } from "@/lib/import/maxroll";
+ *   const result = await importMaxrollPlanner("abc123", ctx);
+ */
+
+import { parseSource } from "./parser";
+import { fetchPlannerRaw, NetworkError, PlannerNotFoundError, PlannerPrivateError, ParseError } from "./client";
+import { loadDataMin } from "./data-min-cache";
+import { MaxrollPlannerPayloadSchema } from "./payload-schema";
+import { DataMinSchema } from "./data-min-schema";
+import { mapPayload } from "./mapper";
+import { verifiedAgainst } from "@/lib/catalog";
+import type { ImportContext, ImportResult } from "./types";
+
+export type { ImportContext, ImportResult } from "./types";
+
+/**
+ * Import a Maxroll planner build into the d4-tools character + build schema.
+ *
+ * Accepts any of four input shapes (D24):
+ *   - Bare planner id:        "abc123"
+ *   - Planner URL:            "https://maxroll.gg/d4/planner/abc123"
+ *   - Planner URL with hash:  "https://maxroll.gg/d4/planner/abc123#2&equipment"
+ *   - Build-guide URL:        "https://maxroll.gg/d4/build-guides/frozen-orb-sorcerer"
+ *
+ * Returns an ImportResult — discriminated union (D7):
+ *   ok: true  → all variants mapped, pick via result.defaultVariantIndex
+ *   ok: false → structured failure reason
+ *
+ * All ctx fields are optional (D2). Override fetch for tests (D25).
+ */
+export async function importMaxrollPlanner(
+  input: string,
+  ctx: ImportContext = {}
+): Promise<ImportResult> {
+  const now = ctx.now ?? new Date();
+
+  // ── 1. Parse input → plannerId + variantIndex ──────────────────────────
+  let parsed: { plannerId: string; variantIndex: number | null } | null;
+  try {
+    parsed = await parseSource(input, ctx);
+  } catch (err) {
+    return mapError(err);
+  }
+
+  if (!parsed) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: `Cannot parse planner reference: '${input}'. Expected a planner id, planner URL, or build-guide URL.`,
+    };
+  }
+
+  const { plannerId } = parsed;
+  const variantIndex = parsed.variantIndex ?? 0; // D10: default 0
+
+  // ── 2. Fetch planner payload ─────────────────────────────────────────────
+  let rawPayload: unknown;
+  try {
+    rawPayload = await fetchPlannerRaw(plannerId, ctx);
+  } catch (err) {
+    return mapError(err);
+  }
+
+  // ── 3. Validate planner payload shape (D28) ───────────────────────────────
+  const payloadResult = MaxrollPlannerPayloadSchema.safeParse(rawPayload);
+  if (!payloadResult.success) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: `Planner payload failed schema validation: ${payloadResult.error.message}`,
+      details: payloadResult.error.issues,
+    };
+  }
+  const payload = payloadResult.data;
+
+  // ── 4. Fetch + validate data.min.json ────────────────────────────────────
+  let dataMin: import("./data-min-schema").DataMin;
+  try {
+    const catalogPatch = verifiedAgainst.patch;
+    const rawDataMin = await loadDataMin(catalogPatch, ctx);
+    // DataMinSchema already validated inside loadDataMin — but if ctx.fetch
+    // returns a different version, validate explicitly
+    const dataMinResult = DataMinSchema.safeParse(rawDataMin);
+    if (!dataMinResult.success) {
+      return {
+        ok: false,
+        reason: "parse-error",
+        message: `data.min.json failed schema validation: ${dataMinResult.error.message}`,
+      };
+    }
+    dataMin = dataMinResult.data;
+  } catch (err) {
+    return mapError(err);
+  }
+
+  // ── 5. Map all variants → ImportResult ──────────────────────────────────
+  return mapPayload(plannerId, payload, dataMin, variantIndex, now);
+}
+
+// ─── Error mapper ─────────────────────────────────────────────────────────────
+
+function mapError(err: unknown): ImportResult {
+  if (err instanceof PlannerNotFoundError) {
+    return { ok: false, reason: "not-found", message: err.message };
+  }
+  if (err instanceof PlannerPrivateError) {
+    return { ok: false, reason: "private", message: err.message };
+  }
+  if (err instanceof NetworkError) {
+    return { ok: false, reason: "network", message: err.message };
+  }
+  if (err instanceof ParseError) {
+    return { ok: false, reason: "parse-error", message: err.message };
+  }
+  const message = err instanceof Error ? err.message : String(err);
+  return { ok: false, reason: "parse-error", message };
+}
diff --git a/lib/import/maxroll/mapper.ts b/lib/import/maxroll/mapper.ts
new file mode 100644
index 0000000..a3962a9
--- /dev/null
+++ b/lib/import/maxroll/mapper.ts
@@ -0,0 +1,505 @@
+/**
+ * Schema-mapping pipeline for the Maxroll planner importer (t3).
+ *
+ * Translates a parsed MaxrollPlannerPayload + DataMin into our canonical
+ * Character/Build/Item/Paragon/Skill shapes.
+ *
+ * Decisions implemented:
+ *   D9  — patch-mismatch fail threshold (< 50% explicits mapped → fail)
+ *   D11 — AspectInstance.source default: 'legendary'
+ *   D12 — Character.level default: 100
+ *   D13 — Item.itemPower: undefined when Maxroll omits it
+ *   D14 — Item.rarity inference: unique > legendary (has aspect) > rare
+ *   D15 — Item.isAncestral: false unless Maxroll marks it
+ *   D16 — Affix routing: implicits/explicits/tempered via catalog isImplicit + Maxroll tempered marker
+ *   D17 — Paragon node ids stored as "mr:<nid>" strings, spentPoints from nodes.length
+ *   D18 — Glyph level default: 21
+ */
+
+import type { Character } from "@/lib/schema/character";
+import type { Item, ItemRarity } from "@/lib/schema/item";
+import type { AffixInstance } from "@/lib/schema/affix";
+import type { AspectInstance } from "@/lib/schema/aspect";
+import type { SkillSelection } from "@/lib/schema/skill";
+import type { ParagonAllocation } from "@/lib/schema/paragon";
+import type { BuildImportedFrom } from "@/lib/schema/build";
+
+import { verifiedAgainst } from "@/lib/catalog";
+import { D4_CLASSES } from "@/lib/schema/character";
+import type { MaxrollPlannerPayload, MaxrollVariant, MaxrollItem } from "./payload-schema";
+import type { DataMin } from "./data-min-schema";
+import type {
+  ImportReport,
+  ImportResultFail,
+  ImportResultOk,
+  VariantResult,
+  VersionMismatch,
+  UnmappedAffix,
+  UnmappedAspect,
+  UnmappedParagonNode,
+  UnmappedGlyph,
+  UnmappedSkill,
+} from "./types";
+import {
+  affixByBnetFileName,
+  aspectByBnetFileName,
+  uniqueByBnetFileName,
+  getClassCatalogIndex,
+} from "./catalog-index";
+import { MAXROLL_SLOT_MAP, MAXROLL_CLASS_MAP } from "./slot-map";
+
+// ─── Patch mismatch check (D9) ────────────────────────────────────────────────
+
+interface PatchCheck {
+  isDrifted: boolean;
+  versionMismatch?: VersionMismatch;
+}
+
+/**
+ * Checks whether data.min.json version matches our catalog patch.
+ * Returns isDrifted=false when versions match.
+ * When drifted, computes the explicit-affix mapping rate across ALL items
+ * in the given variant to determine the failure threshold.
+ *
+ * Called before mapping — if this returns a fail, we short-circuit.
+ * If it returns a warning-level mismatch, we embed it in the report.
+ */
+function checkPatchDrift(
+  dataMin: DataMin,
+  variant: MaxrollVariant,
+  className: string
+): { fail: true; failResult: ImportResultFail } | { fail: false; patchCheck: PatchCheck } {
+  const catalogPatch = verifiedAgainst.patch;
+  const plannerVersion = dataMin.version;
+
+  if (plannerVersion === catalogPatch) {
+    return { fail: false, patchCheck: { isDrifted: false } };
+  }
+
+  // Count explicit affixes across all items in the variant
+  let totalExplicit = 0;
+  let mappedExplicit = 0;
+
+  for (const item of Object.values(variant.items)) {
+    for (const aff of item.affixes) {
+      if (aff.isTemperedAffix) continue; // tempered excluded from ratio (D9)
+      const entry = dataMin.affixes[String(aff.nid)];
+      if (!entry?.bnetFileName) { totalExplicit++; continue; }
+      const catalogEntry = affixByBnetFileName.get(entry.bnetFileName);
+      if (catalogEntry?.isImplicit) continue; // implicits excluded from ratio
+      totalExplicit++;
+      if (catalogEntry) mappedExplicit++;
+    }
+  }
+
+  const mappingRate = totalExplicit === 0 ? 1.0 : mappedExplicit / totalExplicit;
+
+  if (mappingRate < 0.5) {
+    return {
+      fail: true,
+      failResult: {
+        ok: false,
+        reason: "patch-mismatch",
+        message:
+          `data.min.json version '${plannerVersion}' differs from catalog patch '${catalogPatch}' ` +
+          `and explicit-affix mapping rate is ${(mappingRate * 100).toFixed(1)}% (threshold: 50%). ` +
+          `Delete DATA_DIR/maxroll-cache/data.min.${plannerVersion}.json to force a re-fetch.`,
+        details: { catalogPatch, plannerVersion, mappingRate, mappedExplicit, totalExplicit },
+      },
+    };
+  }
+
+  // Above threshold — warn but continue
+  const versionMismatch: VersionMismatch = {
+    catalogPatch,
+    plannerVersion,
+    mappedExplicitCount: mappedExplicit,
+    totalExplicitCount: totalExplicit,
+    mappingRate,
+  };
+  return {
+    fail: false,
+    patchCheck: { isDrifted: true, versionMismatch },
+  };
+}
+
+// ─── Item mapper ──────────────────────────────────────────────────────────────
+
+interface ItemMapResult {
+  slot: string;
+  item: Item;
+  unmappedAffixes: UnmappedAffix[];
+  unmappedAspects: UnmappedAspect[];
+}
+
+function mapItem(
+  maxrollSlotKey: string,
+  maxrollItem: MaxrollItem,
+  dataMin: DataMin,
+  className: string
+): ItemMapResult {
+  const slotNum = parseInt(maxrollSlotKey, 10);
+  const slot = MAXROLL_SLOT_MAP[slotNum] ?? `unknown_${maxrollSlotKey}`;
+
+  const unmappedAffixes: UnmappedAffix[] = [];
+  const unmappedAspects: UnmappedAspect[] = [];
+
+  const implicits: AffixInstance[] = [];
+  const explicits: AffixInstance[] = [];
+  const tempered: AffixInstance[] = [];
+
+  // ── Walk affixes (D16) ────────────────────────────────────────────────────
+  for (const aff of maxrollItem.affixes) {
+    const minEntry = dataMin.affixes[String(aff.nid)];
+    const bnetFileName = minEntry?.bnetFileName;
+
+    if (!bnetFileName) {
+      // Not in data.min.json at all
+      const bucket: "affix" = "affix";
+      if (aff.isTemperedAffix) {
+        unmappedAffixes.push({ category: bucket, nid: aff.nid, slot });
+      } else {
+        unmappedAffixes.push({ category: bucket, nid: aff.nid, slot });
+      }
+      continue;
+    }
+
+    const catalogEntry = affixByBnetFileName.get(bnetFileName);
+    if (!catalogEntry) {
+      unmappedAffixes.push({ category: "affix", nid: aff.nid, bnetFileName, slot });
+      continue;
+    }
+
+    const instance: AffixInstance = { affixId: catalogEntry.id, rolledValue: aff.value };
+
+    if (aff.isTemperedAffix) {
+      tempered.push(instance);
+    } else if (catalogEntry.isImplicit) {
+      implicits.push(instance);
+    } else {
+      explicits.push(instance);
+    }
+  }
+
+  // ── Aspect (D16) ─────────────────────────────────────────────────────────
+  let aspect: AspectInstance | undefined;
+  if (maxrollItem.aspect) {
+    const minEntry = dataMin.aspects[String(maxrollItem.aspect.nid)];
+    const bnetFileName = minEntry?.bnetFileName;
+
+    if (!bnetFileName) {
+      unmappedAspects.push({ category: "aspect", nid: maxrollItem.aspect.nid, slot });
+    } else {
+      const catalogEntry = aspectByBnetFileName.get(bnetFileName);
+      if (!catalogEntry) {
+        unmappedAspects.push({ category: "aspect", nid: maxrollItem.aspect.nid, bnetFileName, slot });
+      } else {
+        aspect = {
+          aspectId: catalogEntry.id,
+          rolledValue: maxrollItem.aspect.value,
+          source: "legendary", // D11: default to 'legendary'
+        };
+      }
+    }
+  }
+
+  // ── Item type / rarity (D14) ──────────────────────────────────────────────
+  let rarity: ItemRarity;
+  if (maxrollItem.id !== undefined) {
+    const itemMinEntry = dataMin.items[String(maxrollItem.id)];
+    if (itemMinEntry?.bnetFileName && uniqueByBnetFileName.has(itemMinEntry.bnetFileName)) {
+      rarity = "unique";
+    } else if (aspect) {
+      rarity = "legendary";
+    } else {
+      rarity = "rare";
+    }
+  } else if (aspect) {
+    rarity = "legendary";
+  } else {
+    rarity = "rare";
+  }
+
+  // ── Item power (D13: leave undefined when absent) ─────────────────────────
+  const itemPower: number | undefined =
+    maxrollItem.power !== undefined && maxrollItem.power > 0
+      ? maxrollItem.power
+      : undefined;
+
+  const item: Item = {
+    slot,
+    name: "",
+    rarity,
+    itemPower,
+    isAncestral: maxrollItem.isAncestral ?? false, // D15
+    implicits,
+    explicits,
+    tempered,
+    aspect,
+    masterworkRank: 0,
+    runes: [],
+    sockets: [],
+  };
+
+  return { slot, item, unmappedAffixes, unmappedAspects };
+}
+
+// ─── Skill mapper ─────────────────────────────────────────────────────────────
+
+interface SkillMapResult {
+  skillSelections: SkillSelection[];
+  unmappedSkills: UnmappedSkill[];
+}
+
+function mapSkills(
+  variant: MaxrollVariant,
+  dataMin: DataMin,
+  className: string
+): SkillMapResult {
+  const { skillByBnetFileName } = getClassCatalogIndex(className);
+  const skillSelections: SkillSelection[] = [];
+  const unmappedSkills: UnmappedSkill[] = [];
+
+  for (const skill of variant.skills) {
+    const minEntry = dataMin.skills[String(skill.id)];
+    const bnetFileName = minEntry?.bnetFileName;
+
+    if (!bnetFileName) {
+      unmappedSkills.push({ category: "skill", nid: skill.id });
+      continue;
+    }
+
+    const catalogEntry = skillByBnetFileName.get(bnetFileName);
+    if (!catalogEntry) {
+      unmappedSkills.push({ category: "skill", nid: skill.id, bnetFileName });
+      continue;
+    }
+
+    skillSelections.push({ skillId: catalogEntry.id, rank: skill.points });
+  }
+
+  return { skillSelections, unmappedSkills };
+}
+
+// ─── Paragon mapper ────────────────────────────────────────────────────────────
+
+interface ParagonMapResult {
+  paragonAllocation: ParagonAllocation;
+  unmappedNodes: UnmappedParagonNode[];
+  unmappedGlyphs: UnmappedGlyph[];
+}
+
+function mapParagon(
+  variant: MaxrollVariant,
+  paragonLevel: number,
+  dataMin: DataMin,
+  className: string
+): ParagonMapResult {
+  const { boardByBnetFileName, glyphByBnetFileName } = getClassCatalogIndex(className);
+  const unmappedNodes: UnmappedParagonNode[] = [];
+  const unmappedGlyphs: UnmappedGlyph[] = [];
+
+  const boards: ParagonAllocation["boards"] = [];
+
+  for (const maxBoard of variant.paragonBoards) {
+    const boardMinEntry = dataMin.paragonBoards[String(maxBoard.id)];
+    const boardBnetFileName = boardMinEntry?.bnetFileName;
+
+    if (!boardBnetFileName) {
+      // Board nid unknown — record unmapped nodes + glyph, skip board
+      unmappedNodes.push({ category: "paragon-node", nid: maxBoard.id });
+      if (maxBoard.glyph) {
+        unmappedGlyphs.push({ category: "glyph", nid: maxBoard.glyph.id, boardNid: maxBoard.id });
+      }
+      continue;
+    }
+
+    const boardEntry = boardByBnetFileName.get(boardBnetFileName);
+    if (!boardEntry) {
+      unmappedNodes.push({ category: "paragon-node", nid: maxBoard.id, bnetFileName: boardBnetFileName });
+      if (maxBoard.glyph) {
+        unmappedGlyphs.push({
+          category: "glyph",
+          nid: maxBoard.glyph.id,
+          bnetFileName: boardBnetFileName,
+          boardNid: maxBoard.id,
+        });
+      }
+      continue;
+    }
+
+    // D17: node ids stored verbatim with "mr:" prefix; spentPoints from nodes.length
+    const nodes = maxBoard.nodes.map((nid) => `mr:${nid}`);
+    const spentPoints = nodes.length;
+
+    // Glyph mapping
+    let glyph: { glyphId: string; level: number } | undefined;
+    if (maxBoard.glyph) {
+      const glyphMinEntry = dataMin.paragonGlyphs[String(maxBoard.glyph.id)];
+      const glyphBnetFileName = glyphMinEntry?.bnetFileName;
+
+      if (!glyphBnetFileName) {
+        unmappedGlyphs.push({ category: "glyph", nid: maxBoard.glyph.id, boardNid: maxBoard.id });
+      } else {
+        const glyphEntry = glyphByBnetFileName.get(glyphBnetFileName);
+        if (!glyphEntry) {
+          unmappedGlyphs.push({
+            category: "glyph",
+            nid: maxBoard.glyph.id,
+            bnetFileName: glyphBnetFileName,
+            boardNid: maxBoard.id,
+          });
+        } else {
+          glyph = {
+            glyphId: glyphEntry.id,
+            level: maxBoard.glyph.level ?? 21, // D18: default 21
+          };
+        }
+      }
+    }
+
+    boards.push({
+      boardId: boardEntry.id,
+      boardName: boardEntry.label,
+      spentPoints,
+      glyph,
+      nodes,
+    });
+  }
+
+  return {
+    paragonAllocation: { paragonLevel, boards },
+    unmappedNodes,
+    unmappedGlyphs,
+  };
+}
+
+// ─── Variant mapper ────────────────────────────────────────────────────────────
+
+function mapVariant(
+  variantIndex: number,
+  variant: MaxrollVariant,
+  payload: MaxrollPlannerPayload,
+  dataMin: DataMin,
+  className: string,
+  patchCheck: PatchCheck,
+  now: Date,
+  plannerId: string
+): VariantResult {
+  const equippedItems: Record<string, Item> = {};
+  const allUnmappedAffixes: UnmappedAffix[] = [];
+  const allUnmappedAspects: UnmappedAspect[] = [];
+
+  for (const [slotKey, maxItem] of Object.entries(variant.items)) {
+    const { slot, item, unmappedAffixes, unmappedAspects } = mapItem(
+      slotKey, maxItem, dataMin, className
+    );
+    equippedItems[slot] = item;
+    allUnmappedAffixes.push(...unmappedAffixes);
+    allUnmappedAspects.push(...unmappedAspects);
+  }
+
+  const { skillSelections, unmappedSkills } = mapSkills(variant, dataMin, className);
+
+  const paragonLevel = payload.paragonLevel ?? 0;
+  const { paragonAllocation, unmappedNodes, unmappedGlyphs } = mapParagon(
+    variant, paragonLevel, dataMin, className
+  );
+
+  const report: ImportReport = {
+    unmappedAffixes: allUnmappedAffixes,
+    unmappedAspects: allUnmappedAspects,
+    unmappedParagonNodes: unmappedNodes,
+    unmappedGlyphs,
+    unmappedSkills,
+    unmappedUniques: [], // unique miss is surfaced via rarity=rare rather than unmapped
+    versionMismatch: patchCheck.versionMismatch,
+  };
+
+  const character: Omit<Character, "id"> = {
+    name: payload.name || `Imported ${className}`,
+    class: className as Character["class"],
+    level: payload.level ?? 100, // D12: default 100
+    paragonAllocation,
+    skillSelections,
+    equippedItems,
+    playstyleConstraints: [],
+  };
+
+  const importedFrom: BuildImportedFrom = {
+    source: "maxroll",
+    plannerId,
+    variantIndex,
+    importedAt: now.toISOString(),
+    plannerVersion: dataMin.version,
+  };
+
+  return {
+    variantIndex,
+    variantName: variant.name || `Variant ${variantIndex + 1}`,
+    character,
+    importedFrom,
+    report,
+  };
+}
+
+// ─── Top-level mapper entry point ─────────────────────────────────────────────
+
+/**
+ * Maps a validated Maxroll planner payload + data.min.json into ImportResultOk
+ * or ImportResultFail.
+ *
+ * Returns all variants mapped (D23).
+ */
+export function mapPayload(
+  plannerId: string,
+  payload: MaxrollPlannerPayload,
+  dataMin: DataMin,
+  defaultVariantIndex: number,
+  now: Date
+): ImportResultOk | ImportResultFail {
+  // Resolve class
+  const className = MAXROLL_CLASS_MAP[payload.class];
+  if (!className || !D4_CLASSES.includes(className as (typeof D4_CLASSES)[number])) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: `Unknown Maxroll class id: ${payload.class}`,
+    };
+  }
+
+  // Per D9: patch-mismatch check is done per variant (using first variant for the ratio)
+  // We perform the check once on the first variant (representative sample).
+  const firstVariant = payload.variants[0];
+  const patchResult = checkPatchDrift(dataMin, firstVariant, className);
+  if (patchResult.fail) return patchResult.failResult;
+  const { patchCheck } = patchResult;
+
+  // Map all variants
+  const variantResults: VariantResult[] = payload.variants.map((variant, idx) =>
+    mapVariant(idx, variant, payload, dataMin, className, patchCheck, now, plannerId)
+  );
+
+  // D7: zero-mapped check — if ALL items across ALL variants have zero mapped explicits
+  const totalMappedItems = variantResults.reduce(
+    (sum, vr) => sum + Object.keys(vr.character.equippedItems).length,
+    0
+  );
+  if (totalMappedItems === 0 && payload.variants.some((v) => Object.keys(v.items).length > 0)) {
+    return {
+      ok: false,
+      reason: "zero-mapped",
+      message:
+        "No items could be mapped from the planner payload. " +
+        "This may indicate a catalog version mismatch or an empty planner.",
+    };
+  }
+
+  return {
+    ok: true,
+    plannerId,
+    plannerVersion: dataMin.version,
+    defaultVariantIndex,
+    variants: variantResults,
+  };
+}
diff --git a/lib/import/maxroll/parser.ts b/lib/import/maxroll/parser.ts
new file mode 100644
index 0000000..e80f1ac
--- /dev/null
+++ b/lib/import/maxroll/parser.ts
@@ -0,0 +1,107 @@
+/**
+ * Source reference parser for the Maxroll planner importer (D24).
+ *
+ * Resolves all four input shapes to a canonical { plannerId, variantIndex }:
+ *   1. Bare planner id:                        "abc123"
+ *   2. Planner URL:                            "https://maxroll.gg/d4/planner/abc123"
+ *   3. Planner URL with variant/tab hash:      "https://maxroll.gg/d4/planner/abc123#2&equipment"
+ *   4. Build-guide URL:                        "https://maxroll.gg/d4/build-guides/frozen-orb-sorcerer"
+ *
+ * Build-guide URLs require fetching the page HTML and regex-matching
+ * /d4/planner/<id> (D24 — no DOM-parser dep, take first match).
+ *
+ * Returns null if the input is unrecognizable (caller maps to parse-error).
+ */
+
+import type { ImportContext } from "./types";
+import { NetworkError, ParseError } from "./client";
+
+export interface ParsedSource {
+  plannerId: string;
+  variantIndex: number | null;  // null = use default (D10)
+}
+
+const PLANNER_ID_RE = /^[a-zA-Z0-9_-]+$/;
+const PLANNER_URL_RE = /\/d4\/planner\/([a-zA-Z0-9_-]+)/;
+const BUILD_GUIDE_RE = /\/d4\/build-guides\//;
+const HASH_VARIANT_RE = /^#(\d+)/;
+
+/**
+ * Parses the input string to extract plannerId and optional variantIndex.
+ *
+ * For build-guide URLs, fetches the page HTML and extracts the first
+ * embedded planner reference via regex (D24).
+ */
+export async function parseSource(
+  input: string,
+  ctx: ImportContext
+): Promise<ParsedSource | null> {
+  const trimmed = input.trim();
+  if (!trimmed) return null;
+
+  // ── 1. Bare planner id ───────────────────────────────────────────────────
+  if (PLANNER_ID_RE.test(trimmed) && !trimmed.includes("://")) {
+    return { plannerId: trimmed, variantIndex: null };
+  }
+
+  // ── URL inputs ────────────────────────────────────────────────────────────
+  let url: URL;
+  try {
+    url = new URL(trimmed);
+  } catch {
+    // Not a URL and not a bare id
+    return null;
+  }
+
+  // ── 4. Build-guide URL ───────────────────────────────────────────────────
+  if (BUILD_GUIDE_RE.test(url.pathname)) {
+    return fetchAndExtractPlannerIdFromGuide(trimmed, ctx);
+  }
+
+  // ── 2 & 3. Planner URL (with or without hash) ────────────────────────────
+  const pathMatch = PLANNER_URL_RE.exec(url.pathname);
+  if (pathMatch) {
+    const plannerId = pathMatch[1];
+    const hashMatch = HASH_VARIANT_RE.exec(url.hash);
+    const variantIndex = hashMatch ? parseInt(hashMatch[1], 10) : null;
+    return { plannerId, variantIndex };
+  }
+
+  return null;
+}
+
+/**
+ * Fetches the build-guide page and extracts the first /d4/planner/<id>
+ * match (D24). Returns null if no planner reference is found.
+ */
+async function fetchAndExtractPlannerIdFromGuide(
+  guideUrl: string,
+  ctx: ImportContext
+): Promise<ParsedSource | null> {
+  const fetchFn = ctx.fetch ?? globalThis.fetch;
+
+  let res: Response;
+  try {
+    res = await fetchFn(guideUrl);
+  } catch (err) {
+    throw new NetworkError(`Failed to fetch build-guide page: ${String(err)}`);
+  }
+
+  if (!res.ok) {
+    throw new NetworkError(`Build-guide page returned HTTP ${res.status}`);
+  }
+
+  let html: string;
+  try {
+    html = await res.text();
+  } catch (err) {
+    throw new ParseError(`Failed to read build-guide response body: ${String(err)}`);
+  }
+
+  const match = PLANNER_URL_RE.exec(html);
+  if (!match) {
+    return null;
+  }
+
+  return { plannerId: match[1], variantIndex: null };
+}
diff --git a/lib/import/maxroll/payload-schema.ts b/lib/import/maxroll/payload-schema.ts
new file mode 100644
index 0000000..b71170c
--- /dev/null
+++ b/lib/import/maxroll/payload-schema.ts
@@ -0,0 +1,106 @@
+/**
+ * Zod schema for the Maxroll planner API response.
+ *
+ * All object types use .passthrough() so unknown extra fields from Maxroll
+ * additions don't break the importer (D28). parse-or-throw on missing
+ * required fields (fail-loud on real shape drift).
+ *
+ * Endpoint: GET planners.maxroll.gg/profiles/load?code=<id>
+ */
+import { z } from "zod";
+
+// A single affix entry on an item
+export const MaxrollAffixEntrySchema = z
+  .object({
+    nid: z.number().int(),
+    value: z.number(),
+    /** True when this affix is a tempered imprint (D16). */
+    isTemperedAffix: z.boolean().default(false),
+  })
+  .passthrough();
+
+export type MaxrollAffixEntry = z.infer<typeof MaxrollAffixEntrySchema>;
+
+// An aspect slot on an item
+export const MaxrollAspectEntrySchema = z
+  .object({
+    nid: z.number().int(),
+    value: z.number(),
+  })
+  .passthrough();
+
+export type MaxrollAspectEntry = z.infer<typeof MaxrollAspectEntrySchema>;
+
+// A single item in the planner
+export const MaxrollItemSchema = z
+  .object({
+    slot: z.number().int(),
+    id: z.number().int().optional(),  // item-type nid (for unique detection)
+    power: z.number().int().optional(),  // item power (D13: leave undefined when absent)
+    isAncestral: z.boolean().default(false),
+    affixes: z.array(MaxrollAffixEntrySchema).default([]),
+    aspect: MaxrollAspectEntrySchema.nullable().optional(),
+  })
+  .passthrough();
+
+export type MaxrollItem = z.infer<typeof MaxrollItemSchema>;
+
+// A skill selection in the planner
+export const MaxrollSkillSchema = z
+  .object({
+    id: z.number().int(),
+    points: z.number().int().min(0),
+  })
+  .passthrough();
+
+export type MaxrollSkill = z.infer<typeof MaxrollSkillSchema>;
+
+// A glyph on a paragon board
+export const MaxrollParagonGlyphSchema = z
+  .object({
+    id: z.number().int(),
+    level: z.number().int().min(1).max(21).optional(),
+  })
+  .passthrough();
+
+export type MaxrollParagonGlyph = z.infer<typeof MaxrollParagonGlyphSchema>;
+
+// A paragon board allocation
+export const MaxrollParagonBoardSchema = z
+  .object({
+    id: z.number().int(),
+    nodes: z.array(z.number().int()).default([]),
+    glyph: MaxrollParagonGlyphSchema.nullable().optional(),
+  })
+  .passthrough();
+
+export type MaxrollParagonBoard = z.infer<typeof MaxrollParagonBoardSchema>;
+
+// A single variant in the planner
+export const MaxrollVariantSchema = z
+  .object({
+    name: z.string().default(""),
+    /** Items keyed by Maxroll slot index (numeric string keys). */
+    items: z.record(z.string(), MaxrollItemSchema).default({}),
+    skills: z.array(MaxrollSkillSchema).default([]),
+    paragonBoards: z.array(MaxrollParagonBoardSchema).default([]),
+  })
+  .passthrough();
+
+export type MaxrollVariant = z.infer<typeof MaxrollVariantSchema>;
+
+// Top-level planner payload
+export const MaxrollPlannerPayloadSchema = z
+  .object({
+    code: z.string(),
+    name: z.string().default(""),
+    /** Maxroll numeric class id (MAXROLL_CLASS_MAP maps to our D4Class). */
+    class: z.number().int(),
+    level: z.number().int().min(1).max(100).optional(),
+    paragonLevel: z.number().int().min(0).optional(),
+    selectedVariant: z.number().int().min(0).default(0),
+    variants: z.array(MaxrollVariantSchema).min(1),
+  })
+  .passthrough();
+
+export type MaxrollPlannerPayload = z.infer<typeof MaxrollPlannerPayloadSchema>;
