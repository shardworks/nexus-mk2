diff --git a/__tests__/maxroll-import.test.ts b/__tests__/maxroll-import.test.ts
new file mode 100644
index 0000000..8e38bf2
--- /dev/null
+++ b/__tests__/maxroll-import.test.ts
@@ -0,0 +1,332 @@
+/**
+ * Acceptance tests for the Maxroll planner importer (t4 / D25).
+ *
+ * All tests are hermetic — they feed checked-in fixture payloads via
+ * ctx.fetch overrides and never hit live network endpoints.
+ *
+ * Fixture design:
+ *   maxroll-planner-fixture.json  — Sorcerer "Frozen Orb" build with 2 variants.
+ *     Variant 0: 3 items (helm, chest, offHand), 2 skills, 1 board+glyph.
+ *       Helm has 1 unmapped affix (nid 999999 → "UnknownAffix_TestOnly" not in catalog).
+ *       Chest has 1 implicit (DamageReduction), 3 explicits, 1 tempered.
+ *       OffHand has an aspect (aspect_of_frozen_orbit).
+ *   maxroll-data-min-subset.json  — minimal data.min.json covering only referenced nids.
+ *     version: "3.0.1.71747" (matches verifiedAgainst.patch from classes.json).
+ *
+ * Tests:
+ *   1. Success case (acceptance signal 1 + 2 + 3)
+ *   2. Patch-mismatch fail (acceptance signal 4a — mapping rate < 50%)
+ *   3. Patch-drift but above threshold (acceptance signal 4b — ok: true with warning)
+ *   4. Input shapes (acceptance signal 2)
+ */
+
+import { describe, it, expect, beforeEach } from "vitest";
+import { importMaxrollPlanner } from "@/lib/import/maxroll";
+import { clearDataMinMemoryCache } from "@/lib/import/maxroll/data-min-cache";
+
+import plannerFixture from "./fixtures/maxroll-planner-fixture.json";
+import dataMinSubset from "./fixtures/maxroll-data-min-subset.json";
+
+// ─── Fixture fetch factory ────────────────────────────────────────────────────
+
+const PLANNER_URL_RE = /profiles\/load/;
+const DATA_MIN_URL_RE = /data\.min\.json/;
+
+/**
+ * Creates a mock fetch that serves the planner fixture and data.min subset.
+ * Pass overrideDataMin to swap out the data.min payload (for patch-mismatch tests).
+ */
+function makeFetch(
+  plannerPayload: unknown = plannerFixture,
+  overrideDataMin: unknown = dataMinSubset
+) {
+  return async (url: string | URL | Request): Promise<Response> => {
+    const urlStr = typeof url === "string" ? url : url instanceof URL ? url.toString() : url.url;
+
+    if (PLANNER_URL_RE.test(urlStr)) {
+      return new Response(JSON.stringify(plannerPayload), {
+        status: 200,
+        headers: { "content-type": "application/json" },
+      });
+    }
+
+    if (DATA_MIN_URL_RE.test(urlStr)) {
+      return new Response(JSON.stringify(overrideDataMin), {
+        status: 200,
+        headers: { "content-type": "application/json" },
+      });
+    }
+
+    return new Response("Not found", { status: 404 });
+  };
+}
+
+// Clear in-memory cache between tests so fixture swaps take effect
+beforeEach(() => {
+  clearDataMinMemoryCache();
+});
+
+// ─── Test 1: Success case ─────────────────────────────────────────────────────
+
+describe("importMaxrollPlanner — success case", () => {
+  it("returns ok: true with expected character fields", async () => {
+    const result = await importMaxrollPlanner("fixture-sorc-01", {
+      fetch: makeFetch() as typeof globalThis.fetch,
+      cacheDir: "/tmp/maxroll-test-cache",
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+
+    // Both variants returned (acceptance signal 1: non-empty equippedItems)
+    expect(result.variants).toHaveLength(2);
+
+    const v0 = result.variants[0];
+    expect(v0.variantIndex).toBe(0);
+    expect(v0.character.class).toBe("Sorcerer");
+    expect(v0.character.level).toBe(100);
+
+    // equippedItems has all 3 slots
+    const items = v0.character.equippedItems;
+    expect(Object.keys(items).length).toBeGreaterThan(0);
+    expect(items["helm"]).toBeDefined();
+    expect(items["chest"]).toBeDefined();
+    expect(items["offHand"]).toBeDefined();
+
+    // Affix routing (D16): chest has 1 implicit, 3 explicits, 1 tempered
+    const chest = items["chest"];
+    expect(chest.implicits).toHaveLength(1);
+    expect(chest.implicits[0].affixId).toBe("affix_implicit_damage_reduction_chest");
+    expect(chest.explicits).toHaveLength(3);
+    expect(chest.tempered).toHaveLength(1);
+
+    // At least one mapped aspect (acceptance signal 1)
+    const offHand = items["offHand"];
+    expect(offHand.aspect).toBeDefined();
+    expect(offHand.aspect!.aspectId).toBe("aspect_of_frozen_orbit");
+    expect(offHand.aspect!.rolledValue).toBe(15.5);
+    expect(offHand.aspect!.source).toBe("legendary"); // D11
+
+    // At least one mapped paragon glyph (acceptance signal 1)
+    const boards = v0.character.paragonAllocation.boards;
+    expect(boards.length).toBeGreaterThan(0);
+    expect(boards[0].boardId).toBe("sorc_starter");
+    expect(boards[0].glyph).toBeDefined();
+    expect(boards[0].glyph!.glyphId).toBe("glyph_cold_calc");
+    expect(boards[0].glyph!.level).toBe(21);
+
+    // Paragon nodes stored with mr: prefix (D17)
+    expect(boards[0].nodes).toEqual(["mr:10001", "mr:10002", "mr:10003"]);
+    expect(boards[0].spentPoints).toBe(3); // derived from nodes.length
+
+    // Skill selections
+    const skills = v0.character.skillSelections;
+    expect(skills.length).toBeGreaterThan(0);
+    const frozenOrb = skills.find((s) => s.skillId === "sorc_frozen_orb");
+    expect(frozenOrb).toBeDefined();
+    expect(frozenOrb!.rank).toBe(5);
+
+    // paragonAllocation populated
+    expect(v0.character.paragonAllocation.paragonLevel).toBe(200);
+  });
+
+  it("reports unmapped references — never silently drops (acceptance signal 3)", async () => {
+    const result = await importMaxrollPlanner("fixture-sorc-01", {
+      fetch: makeFetch() as typeof globalThis.fetch,
+      cacheDir: "/tmp/maxroll-test-cache",
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+
+    const report = result.variants[0].report;
+
+    // nid 999999 → bnetFileName "UnknownAffix_TestOnly" (not in catalog) → unmapped
+    expect(report.unmappedAffixes.length).toBeGreaterThan(0);
+    const unmapped = report.unmappedAffixes.find((u) => u.nid === 999999);
+    expect(unmapped).toBeDefined();
+    expect(unmapped!.bnetFileName).toBe("UnknownAffix_TestOnly");
+    expect(unmapped!.slot).toBe("helm");
+
+    // No unmapped aspects (aspect_of_frozen_orbit is in catalog)
+    expect(report.unmappedAspects).toHaveLength(0);
+  });
+
+  it("populates importedFrom provenance (D19)", async () => {
+    const result = await importMaxrollPlanner("fixture-sorc-01", {
+      fetch: makeFetch() as typeof globalThis.fetch,
+      cacheDir: "/tmp/maxroll-test-cache",
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+
+    const importedFrom = result.variants[0].importedFrom;
+    expect(importedFrom.source).toBe("maxroll");
+    expect(importedFrom.plannerId).toBe("fixture-sorc-01");
+    expect(importedFrom.variantIndex).toBe(0);
+    expect(importedFrom.plannerVersion).toBe("3.0.1.71747");
+    expect(typeof importedFrom.importedAt).toBe("string");
+  });
+});
+
+// ─── Test 2: Patch-mismatch fail (acceptance signal 4a) ──────────────────────
+
+describe("importMaxrollPlanner — patch-mismatch fail", () => {
+  it("fails when version drifts AND mapping rate < 50%", async () => {
+    // Construct a data.min that has a different version AND only maps 0/4 explicits
+    // on the helm (3 known + 1 unknown affix in fixture → deliberately omit the known ones)
+    const driftedDataMin = {
+      ...dataMinSubset,
+      version: "9.9.9.99999",  // Drifted version
+      affixes: {
+        // Only provide the unknown affix — all others unmapped → 0% rate
+        "999999": { "nid": 999999, "bnetFileName": "UnknownAffix_TestOnly" }
+      }
+    };
+
+    const result = await importMaxrollPlanner("fixture-sorc-01", {
+      fetch: makeFetch(plannerFixture, driftedDataMin) as typeof globalThis.fetch,
+      cacheDir: "/tmp/maxroll-test-cache-drift",
+    });
+
+    expect(result.ok).toBe(false);
+    if (result.ok) return;
+
+    expect(result.reason).toBe("patch-mismatch");
+    expect(result.message).toContain("3.0.1.71747");
+    expect(result.message).toContain("9.9.9.99999");
+  });
+});
+
+// ─── Test 3: Patch drift above threshold (acceptance signal 4b) ───────────────
+
+describe("importMaxrollPlanner — patch drift above threshold", () => {
+  it("returns ok: true with versionMismatch warning when mapping rate >= 50%", async () => {
+    // Drift version but keep enough affixes mapped (≥ 50% of explicits across all items)
+    const driftedDataMinAboveThreshold = {
+      ...dataMinSubset,
+      version: "3.0.1.99999",  // Drifted version
+      // Keep most affix mappings — helm has 3 explicits (3 in catalog), chest has 3 explicits
+      // Total explicits: helm=3, chest=3, offHand=2 → 8 total
+      // Mapped with below set: helm=3, chest=3, offHand=2 → 8/8 = 100% → above threshold
+    };
+
+    const result = await importMaxrollPlanner("fixture-sorc-01", {
+      fetch: makeFetch(plannerFixture, driftedDataMinAboveThreshold) as typeof globalThis.fetch,
+      cacheDir: "/tmp/maxroll-test-cache-above",
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+
+    // All variants should have versionMismatch in their reports
+    const report = result.variants[0].report;
+    expect(report.versionMismatch).toBeDefined();
+    expect(report.versionMismatch!.catalogPatch).toBe("3.0.1.71747");
+    expect(report.versionMismatch!.plannerVersion).toBe("3.0.1.99999");
+    expect(report.versionMismatch!.mappingRate).toBeGreaterThanOrEqual(0.5);
+  });
+});
+
+// ─── Test 4: Input shapes (acceptance signal 2) ───────────────────────────────
+
+describe("importMaxrollPlanner — all input shapes resolve", () => {
+  const ctx = {
+    fetch: makeFetch() as typeof globalThis.fetch,
+    cacheDir: "/tmp/maxroll-test-cache",
+  };
+
+  it("accepts a bare planner id", async () => {
+    const result = await importMaxrollPlanner("fixture-sorc-01", ctx);
+    expect(result.ok).toBe(true);
+  });
+
+  it("accepts a planner URL", async () => {
+    const result = await importMaxrollPlanner(
+      "https://maxroll.gg/d4/planner/fixture-sorc-01",
+      ctx
+    );
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+    expect(result.plannerId).toBe("fixture-sorc-01");
+    expect(result.defaultVariantIndex).toBe(0);
+  });
+
+  it("accepts a planner URL with variant hash", async () => {
+    const result = await importMaxrollPlanner(
+      "https://maxroll.gg/d4/planner/fixture-sorc-01#1&equipment",
+      ctx
+    );
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+    expect(result.plannerId).toBe("fixture-sorc-01");
+    expect(result.defaultVariantIndex).toBe(1);
+  });
+
+  it("accepts a build-guide URL and extracts planner id from HTML", async () => {
+    // The mock fetch needs to handle the build-guide URL by returning HTML
+    // containing a planner reference
+    const guideHtml = `<html><body>
+      <p>Check out this build: <a href="/d4/planner/fixture-sorc-01">Frozen Orb</a></p>
+    </body></html>`;
+
+    const guideFetch = async (url: string | URL | Request): Promise<Response> => {
+      const urlStr = typeof url === "string" ? url : url instanceof URL ? url.toString() : (url as Request).url;
+      if (urlStr.includes("build-guides")) {
+        return new Response(guideHtml, { status: 200, headers: { "content-type": "text/html" } });
+      }
+      return (makeFetch() as typeof globalThis.fetch)(url as string);
+    };
+
+    const result = await importMaxrollPlanner(
+      "https://maxroll.gg/d4/build-guides/frozen-orb-sorcerer",
+      { ...ctx, fetch: guideFetch as typeof globalThis.fetch }
+    );
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+    expect(result.plannerId).toBe("fixture-sorc-01");
+  });
+});
+
+// ─── Test 5: Item defaults (D11–D15) ─────────────────────────────────────────
+
+describe("importMaxrollPlanner — item defaults", () => {
+  it("sets isAncestral from Maxroll payload (D15)", async () => {
+    const result = await importMaxrollPlanner("fixture-sorc-01", {
+      fetch: makeFetch() as typeof globalThis.fetch,
+      cacheDir: "/tmp/maxroll-test-cache",
+    });
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+
+    const items = result.variants[0].character.equippedItems;
+    expect(items["helm"].isAncestral).toBe(true);   // fixture has isAncestral: true
+    expect(items["chest"].isAncestral).toBe(false);  // fixture has isAncestral: false
+  });
+
+  it("sets itemPower from Maxroll payload, leaves undefined when absent (D13)", async () => {
+    const result = await importMaxrollPlanner("fixture-sorc-01", {
+      fetch: makeFetch() as typeof globalThis.fetch,
+      cacheDir: "/tmp/maxroll-test-cache",
+    });
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+
+    const items = result.variants[0].character.equippedItems;
+    expect(items["helm"].itemPower).toBe(925);
+    expect(items["chest"].itemPower).toBe(925);
+  });
+
+  it("defaults Character.level to 100 when Maxroll omits it (D12)", async () => {
+    const payloadWithoutLevel = { ...plannerFixture };
+    const { level: _removed, ...rest } = payloadWithoutLevel;
+    const result = await importMaxrollPlanner("fixture-sorc-01", {
+      fetch: makeFetch(rest) as typeof globalThis.fetch,
+      cacheDir: "/tmp/maxroll-test-cache",
+    });
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+    expect(result.variants[0].character.level).toBe(100);
+  });
+});
