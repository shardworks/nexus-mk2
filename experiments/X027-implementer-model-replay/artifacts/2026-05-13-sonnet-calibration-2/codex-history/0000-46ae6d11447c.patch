diff --git a/app/import/maxroll/MaxrollImportClient.tsx b/app/import/maxroll/MaxrollImportClient.tsx
new file mode 100644
index 0000000..85e26e6
--- /dev/null
+++ b/app/import/maxroll/MaxrollImportClient.tsx
@@ -0,0 +1,396 @@
+"use client";
+
+/**
+ * Maxroll planner importer — four-state client component (D20).
+ *
+ * States:
+ *   paste    — User inputs a planner id or URL
+ *   loading  — Fetching preview from the server adapter
+ *   preview  — Shows all variants, user picks one; unmapped-ref counts in report
+ *   confirm  — Review before committing; Cancel → preview
+ *   done     — Character created; redirect to /builds/<id>
+ *
+ * On confirm the chosen variant's character payload is POSTed to
+ * POST /api/characters?withDefaultBuild=true (D23).
+ */
+
+import { useState, useCallback } from "react";
+import { useRouter } from "next/navigation";
+import { Button } from "@/components/ui/button";
+import { Input } from "@/components/ui/input";
+import { Loader2, AlertCircle, CheckCircle2 } from "lucide-react";
+import type { ImportResultOk, VariantResult } from "@/lib/import/maxroll/types";
+
+// ─── Types ────────────────────────────────────────────────────────────────────
+
+type State =
+  | { phase: "paste" }
+  | { phase: "loading" }
+  | { phase: "preview"; result: ImportResultOk; selectedVariantIndex: number }
+  | { phase: "confirm"; result: ImportResultOk; variant: VariantResult }
+  | { phase: "error"; message: string; back: "paste" | "preview" };
+
+// ─── Report summary ───────────────────────────────────────────────────────────
+
+function ReportSummary({ report }: { report: VariantResult["report"] }) {
+  const counts = [
+    { label: "unmapped affixes", count: report.unmappedAffixes.length },
+    { label: "unmapped aspects", count: report.unmappedAspects.length },
+    { label: "unmapped paragon nodes", count: report.unmappedParagonNodes.length },
+    { label: "unmapped glyphs", count: report.unmappedGlyphs.length },
+    { label: "unmapped skills", count: report.unmappedSkills.length },
+  ].filter((c) => c.count > 0);
+
+  if (counts.length === 0 && !report.versionMismatch) {
+    return (
+      <div className="flex items-center gap-1.5 text-xs text-green-400">
+        <CheckCircle2 size={12} />
+        All references resolved
+      </div>
+    );
+  }
+
+  return (
+    <div className="text-xs text-stone-400 space-y-0.5">
+      {report.versionMismatch && (
+        <div className="text-amber-400 flex items-start gap-1.5">
+          <AlertCircle size={12} className="shrink-0 mt-0.5" />
+          <span>
+            Patch drift: catalog {report.versionMismatch.catalogPatch} vs planner{" "}
+            {report.versionMismatch.plannerVersion} (
+            {(report.versionMismatch.mappingRate * 100).toFixed(0)}% mapped)
+          </span>
+        </div>
+      )}
+      {counts.map((c) => (
+        <div key={c.label} className="text-stone-500">
+          {c.count} {c.label}
+        </div>
+      ))}
+    </div>
+  );
+}
+
+// ─── Main component ───────────────────────────────────────────────────────────
+
+export function MaxrollImportClient() {
+  const [state, setState] = useState<State>({ phase: "paste" });
+  const [inputValue, setInputValue] = useState("");
+  const router = useRouter();
+
+  // ── Paste → Loading → Preview ────────────────────────────────────────────
+  const handleImport = useCallback(async () => {
+    const input = inputValue.trim();
+    if (!input) return;
+
+    setState({ phase: "loading" });
+
+    try {
+      const res = await fetch("/api/import/maxroll/preview", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ input }),
+      });
+
+      const data = await res.json();
+
+      if (!res.ok) {
+        setState({
+          phase: "error",
+          message: data.error ?? `Import failed (HTTP ${res.status})`,
+          back: "paste",
+        });
+        return;
+      }
+
+      const result = data as ImportResultOk;
+      setState({
+        phase: "preview",
+        result,
+        selectedVariantIndex: result.defaultVariantIndex,
+      });
+    } catch (err) {
+      setState({
+        phase: "error",
+        message: err instanceof Error ? err.message : "Network error — could not reach the server.",
+        back: "paste",
+      });
+    }
+  }, [inputValue]);
+
+  // ── Preview → Confirm ────────────────────────────────────────────────────
+  const handleSelectVariant = useCallback((result: ImportResultOk, variantIndex: number) => {
+    const variant = result.variants[variantIndex];
+    if (!variant) return;
+    setState({ phase: "confirm", result, variant });
+  }, []);
+
+  // ── Confirm → Commit → /builds/<id> ─────────────────────────────────────
+  const handleConfirm = useCallback(async (variant: VariantResult) => {
+    try {
+      // POST character + importedFrom to the existing create endpoint (D23)
+      const body = {
+        ...variant.character,
+        _buildImportedFrom: variant.importedFrom,
+      };
+
+      const res = await fetch("/api/characters?withDefaultBuild=true", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(body),
+      });
+
+      if (!res.ok) {
+        const err = await res.json();
+        setState((prev) => ({
+          phase: "error",
+          message: err.error ?? "Failed to create character",
+          back: prev.phase === "confirm" ? "preview" : "paste",
+        }));
+        return;
+      }
+
+      const { build } = await res.json();
+      router.push(`/builds/${build.id}`);
+    } catch (err) {
+      setState({
+        phase: "error",
+        message: err instanceof Error ? err.message : "Network error during commit.",
+        back: "preview",
+      });
+    }
+  }, [router]);
+
+  // ─────────────────────────────────────────────────────────────────────────
+  // Render
+  // ─────────────────────────────────────────────────────────────────────────
+
+  if (state.phase === "paste") {
+    return (
+      <div className="space-y-4">
+        <div>
+          <label className="block text-sm text-stone-300 mb-1.5">
+            Maxroll planner id or URL
+          </label>
+          <div className="flex gap-2">
+            <Input
+              value={inputValue}
+              onChange={(e) => setInputValue(e.target.value)}
+              placeholder="e.g. abc123  or  https://maxroll.gg/d4/planner/abc123"
+              className="font-mono text-sm"
+              onKeyDown={(e) => { if (e.key === "Enter") handleImport(); }}
+            />
+            <Button onClick={handleImport} disabled={!inputValue.trim()}>
+              Import
+            </Button>
+          </div>
+        </div>
+        <p className="text-xs text-stone-500">
+          Paste a planner id, planner URL (with optional variant hash like{" "}
+          <code className="text-stone-400">#1&equipment</code>), or a build-guide URL.
+        </p>
+      </div>
+    );
+  }
+
+  if (state.phase === "loading") {
+    return (
+      <div className="flex items-center gap-2 text-stone-400 text-sm py-4">
+        <Loader2 size={16} className="animate-spin" />
+        Fetching planner…
+      </div>
+    );
+  }
+
+  if (state.phase === "error") {
+    return (
+      <div className="space-y-3">
+        <div className="flex items-start gap-2 text-sm text-red-400">
+          <AlertCircle size={16} className="shrink-0 mt-0.5" />
+          <span>{state.message}</span>
+        </div>
+        <Button
+          variant="outline"
+          size="sm"
+          onClick={() => setState({ phase: state.back === "paste" ? "paste" : "paste" })}
+        >
+          ← Try again
+        </Button>
+      </div>
+    );
+  }
+
+  if (state.phase === "preview") {
+    const { result, selectedVariantIndex } = state;
+
+    return (
+      <div className="space-y-5">
+        <div>
+          <h2 className="text-sm font-semibold text-stone-300 mb-0.5">
+            {result.variants[0]?.character.name}
+          </h2>
+          <p className="text-xs text-stone-500">
+            Planner <code className="text-stone-400">{result.plannerId}</code> ·{" "}
+            {result.variants.length} variant{result.variants.length !== 1 ? "s" : ""}
+          </p>
+        </div>
+
+        {/* Variant picker */}
+        <div className="space-y-2">
+          <p className="text-xs font-semibold text-stone-400 uppercase tracking-wide">
+            Choose variant
+          </p>
+          {result.variants.map((v) => {
+            const isSelected = v.variantIndex === selectedVariantIndex;
+            const slotCount = Object.keys(v.character.equippedItems).length;
+            return (
+              <button
+                key={v.variantIndex}
+                onClick={() => setState({ ...state, selectedVariantIndex: v.variantIndex })}
+                className={[
+                  "w-full text-left px-3 py-2.5 rounded-md border transition-colors",
+                  isSelected
+                    ? "border-accent bg-surface-1 text-stone-100"
+                    : "border-stone-700 bg-surface-2 text-stone-400 hover:border-stone-600",
+                ].join(" ")}
+              >
+                <div className="flex items-center justify-between">
+                  <span className="text-sm font-medium">{v.variantName}</span>
+                  <span className="text-xs text-stone-500">
+                    {v.character.class} · {slotCount} slot{slotCount !== 1 ? "s" : ""}
+                  </span>
+                </div>
+                <div className="mt-1">
+                  <ReportSummary report={v.report} />
+                </div>
+              </button>
+            );
+          })}
+        </div>
+
+        {/* Selected variant detail */}
+        {(() => {
+          const selected = result.variants[selectedVariantIndex];
+          if (!selected) return null;
+          const slots = Object.entries(selected.character.equippedItems);
+          return (
+            <div className="space-y-2">
+              <p className="text-xs font-semibold text-stone-400 uppercase tracking-wide">
+                Gear preview
+              </p>
+              <div className="rounded-md border border-stone-800 divide-y divide-stone-800">
+                {slots.map(([slot, item]) => (
+                  <div key={slot} className="px-3 py-1.5 flex items-center justify-between text-xs">
+                    <span className="text-stone-500 w-20 shrink-0">{slot}</span>
+                    <span className="text-stone-300 truncate">
+                      {item.rarity}
+                      {item.itemPower ? ` · iLvl ${item.itemPower}` : ""}
+                      {item.isAncestral ? " (anc)" : ""}
+                    </span>
+                  </div>
+                ))}
+              </div>
+            </div>
+          );
+        })()}
+
+        <div className="flex gap-2 pt-1">
+          <Button
+            onClick={() => handleSelectVariant(result, selectedVariantIndex)}
+            className="flex-1"
+          >
+            Continue with {result.variants[selectedVariantIndex]?.variantName ?? "this variant"}
+          </Button>
+          <Button
+            variant="outline"
+            onClick={() => {
+              setInputValue("");
+              setState({ phase: "paste" });
+            }}
+          >
+            Cancel
+          </Button>
+        </div>
+      </div>
+    );
+  }
+
+  if (state.phase === "confirm") {
+    const { variant, result } = state;
+    const slotCount = Object.keys(variant.character.equippedItems).length;
+    const skillCount = variant.character.skillSelections.length;
+    const boardCount = variant.character.paragonAllocation.boards.length;
+    const totalUnmapped =
+      variant.report.unmappedAffixes.length +
+      variant.report.unmappedAspects.length +
+      variant.report.unmappedGlyphs.length +
+      variant.report.unmappedSkills.length;
+
+    return (
+      <div className="space-y-5">
+        <div>
+          <h2 className="text-sm font-semibold text-stone-300 mb-0.5">Confirm import</h2>
+          <p className="text-xs text-stone-500">
+            Creates a new character and build. You can edit gear and skills after import.
+          </p>
+        </div>
+
+        <div className="rounded-md border border-stone-800 divide-y divide-stone-800 text-sm">
+          <div className="px-3 py-2 flex justify-between">
+            <span className="text-stone-400">Character</span>
+            <span className="text-stone-100">{variant.character.name}</span>
+          </div>
+          <div className="px-3 py-2 flex justify-between">
+            <span className="text-stone-400">Class</span>
+            <span className="text-stone-100">{variant.character.class}</span>
+          </div>
+          <div className="px-3 py-2 flex justify-between">
+            <span className="text-stone-400">Level</span>
+            <span className="text-stone-100">{variant.character.level}</span>
+          </div>
+          <div className="px-3 py-2 flex justify-between">
+            <span className="text-stone-400">Variant</span>
+            <span className="text-stone-100">{variant.variantName}</span>
+          </div>
+          <div className="px-3 py-2 flex justify-between">
+            <span className="text-stone-400">Gear slots</span>
+            <span className="text-stone-100">{slotCount}</span>
+          </div>
+          <div className="px-3 py-2 flex justify-between">
+            <span className="text-stone-400">Skills</span>
+            <span className="text-stone-100">{skillCount}</span>
+          </div>
+          <div className="px-3 py-2 flex justify-between">
+            <span className="text-stone-400">Paragon boards</span>
+            <span className="text-stone-100">{boardCount}</span>
+          </div>
+          {totalUnmapped > 0 && (
+            <div className="px-3 py-2 flex justify-between">
+              <span className="text-amber-400">Unmapped references</span>
+              <span className="text-amber-400">{totalUnmapped}</span>
+            </div>
+          )}
+        </div>
+
+        <div className="flex gap-2">
+          <Button
+            onClick={() => handleConfirm(variant)}
+            className="flex-1"
+          >
+            Import Build
+          </Button>
+          <Button
+            variant="outline"
+            onClick={() =>
+              setState({ phase: "preview", result, selectedVariantIndex: variant.variantIndex })
+            }
+          >
+            ← Back
+          </Button>
+        </div>
+      </div>
+    );
+  }
+
+  return null;
+}
