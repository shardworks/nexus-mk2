@@ -0,0 +1,119 @@
+/**
+ * Fetch functions for the Maxroll planner API and data.min.json.
+ *
+ * Env-var endpoint overrides (D6) mirror the lib/triage/anthropic.ts pattern:
+ *   MAXROLL_PLANNER_API_BASE — default https://planners.maxroll.gg
+ *   MAXROLL_DATA_BASE        — default https://assets-ng.maxroll.gg
+ *
+ * Both functions use native fetch only; fail-loud on non-2xx (D6).
+ */
+
+import type { ImportContext } from "./types";
+
+// ─── Endpoint helpers (D6) ────────────────────────────────────────────────────
+
+function getMaxrollPlannerApiBase(): string {
+  const override = process.env.MAXROLL_PLANNER_API_BASE;
+  if (override && override.length > 0) return override.replace(/\/$/, "");
+  return "https://planners.maxroll.gg";
+}
+
+function getMaxrollDataBase(): string {
+  const override = process.env.MAXROLL_DATA_BASE;
+  if (override && override.length > 0) return override.replace(/\/$/, "");
+  return "https://assets-ng.maxroll.gg";
+}
+
+// ─── Fetch helpers ────────────────────────────────────────────────────────────
+
+/**
+ * Fetch the raw planner JSON for the given code.
+ * Throws with a typed reason on non-2xx so the caller can map HTTP codes to
+ * ImportResultFail.reason values.
+ */
+export async function fetchPlannerRaw(
+  code: string,
+  ctx: ImportContext
+): Promise<unknown> {
+  const fetchFn = ctx.fetch ?? globalThis.fetch;
+  const url = `${getMaxrollPlannerApiBase()}/profiles/load?code=${encodeURIComponent(code)}`;
+
+  let res: Response;
+  try {
+    res = await fetchFn(url);
+  } catch (err) {
+    throw new NetworkError(`Failed to fetch planner ${code}: ${String(err)}`);
+  }
+
+  if (res.status === 404) throw new PlannerNotFoundError(code);
+  if (res.status === 403 || res.status === 401) throw new PlannerPrivateError(code);
+  if (!res.ok) {
+    throw new NetworkError(`Planner API returned HTTP ${res.status} for code ${code}`);
+  }
+
+  try {
+    return await res.json();
+  } catch (err) {
+    throw new ParseError(`Planner response for ${code} is not valid JSON: ${String(err)}`);
+  }
+}
+
+/**
+ * Fetch data.min.json raw payload.
+ * The cache layer (data-min-cache.ts) sits on top of this.
+ */
+export async function fetchDataMinRaw(ctx: ImportContext): Promise<unknown> {
+  const fetchFn = ctx.fetch ?? globalThis.fetch;
+  const url = `${getMaxrollDataBase()}/d4t/data.min.json`;
+
+  let res: Response;
+  try {
+    res = await fetchFn(url);
+  } catch (err) {
+    throw new NetworkError(`Failed to fetch data.min.json: ${String(err)}`);
+  }
+
+  if (!res.ok) {
+    throw new NetworkError(`data.min.json returned HTTP ${res.status}`);
+  }
+
+  try {
+    return await res.json();
+  } catch (err) {
+    throw new ParseError(`data.min.json is not valid JSON: ${String(err)}`);
+  }
+}
+
+// ─── Typed errors ─────────────────────────────────────────────────────────────
+
+export class NetworkError extends Error {
+  readonly kind = "network" as const;
+  constructor(msg: string) {
+    super(msg);
+    this.name = "NetworkError";
+  }
+}
+
+export class PlannerNotFoundError extends Error {
+  readonly kind = "not-found" as const;
+  constructor(code: string) {
+    super(`Planner '${code}' not found (HTTP 404)`);
+    this.name = "PlannerNotFoundError";
+  }
+}
+
+export class PlannerPrivateError extends Error {
+  readonly kind = "private" as const;
+  constructor(code: string) {
+    super(`Planner '${code}' is private or access denied`);
+    this.name = "PlannerPrivateError";
+  }
+}
+
+export class ParseError extends Error {
+  readonly kind = "parse-error" as const;
+  constructor(msg: string) {
+    super(msg);
+    this.name = "ParseError";
+  }
+}
