index 0000000..925b6a4
--- /dev/null
+++ b/lib/import/maxroll/data-min-cache.ts
@@ -0,0 +1,98 @@
+/**
+ * Disk + in-memory cache for Maxroll's data.min.json (D4, D5).
+ *
+ * Cache key: patch version string extracted from the Maxroll profile response.
+ * Disk path: DATA_DIR/maxroll-cache/data.min.<patch>.json
+ * No sliding TTL — patch-only invalidation (D5).
+ *
+ * In-process in-memory layer prevents re-reading from disk on repeated imports
+ * within the same Node process.
+ */
+
+import * as fs from "fs/promises";
+import * as path from "path";
+import { getDataDir } from "@/lib/persistence/paths";
+import { MaxrollDataMinSchema, type MaxrollDataMin } from "./payload-schema";
+import { fetchDataMin } from "./fetcher";
+
+/** In-memory cache: patch string → parsed DataMin object */
+const memoryCache = new Map<string, MaxrollDataMin>();
+
+/**
+ * Returns the disk cache directory for data.min.json files.
+ * Respects the cacheDir override from ImportContext (used in tests).
+ */
+function getCacheDir(override?: string): string {
+  return override ?? path.join(getDataDir(), "maxroll-cache");
+}
+
+function cachePath(cacheDir: string, patch: string): string {
+  // Sanitize patch string for use in a filename (replace path separators and dots aren't an issue)
+  const safePatch = patch.replace(/[^a-zA-Z0-9._-]/g, "-");
+  return path.join(cacheDir, `data.min.${safePatch}.json`);
+}
+
+/**
+ * Load data.min.json for the given patch version.
+ *
+ * Resolution order:
+ *   1. In-memory cache (fastest, zero I/O)
+ *   2. Disk cache at DATA_DIR/maxroll-cache/data.min.<patch>.json
+ *   3. Network fetch from assets-ng.maxroll.gg (writes to disk + memory)
+ *
+ * @param patch    Patch string from the Maxroll profile response (used as cache key)
+ * @param cacheDir Optional override (from ImportContext.cacheDir; used in tests)
+ * @param fetchFn  Optional fetch override (from ImportContext.fetch; used in tests)
+ */
+export async function loadDataMin(
+  patch: string,
+  cacheDir?: string,
+  fetchFn: typeof globalThis.fetch = globalThis.fetch
+): Promise<MaxrollDataMin> {
+  // 1. In-memory
+  const cached = memoryCache.get(patch);
+  if (cached) return cached;
+
+  const dir = getCacheDir(cacheDir);
+  const filePath = cachePath(dir, patch);
+
+  // 2. Disk cache
+  try {
+    const raw = await fs.readFile(filePath, "utf-8");
+    const parsed = MaxrollDataMinSchema.parse(JSON.parse(raw));
+    memoryCache.set(patch, parsed);
+    return parsed;
+  } catch (err) {
+    // ENOENT → cache miss, continue to fetch; anything else is re-thrown
+    if ((err as NodeJS.ErrnoException).code !== "ENOENT") {
+      // Corrupt cache file — log and re-fetch
+      console.warn(`[maxroll-cache] Failed to read disk cache ${filePath}: ${err}. Re-fetching.`);
+    }
+  }
+
+  // 3. Network fetch
+  const raw = await fetchDataMin(fetchFn);
+
+  let parsed: MaxrollDataMin;
+  try {
+    parsed = MaxrollDataMinSchema.parse(raw);
+  } catch (err) {
+    throw new Error(`Maxroll data.min.json did not match expected schema: ${err}`);
+  }
+
+  // Write to disk (best-effort — failure should not abort the import)
+  try {
+    await fs.mkdir(dir, { recursive: true });
+    await fs.writeFile(filePath, JSON.stringify(parsed), "utf-8");
+  } catch (writeErr) {
+    console.warn(`[maxroll-cache] Failed to write disk cache ${filePath}: ${writeErr}`);
+  }
+
+  memoryCache.set(patch, parsed);
+  return parsed;
+}
+
+/** Clear the in-memory cache (exposed for test teardown). */
+export function clearMemoryCache(): void {
+  memoryCache.clear();
+}
diff --git a/lib/import/maxroll/fetcher.ts b/lib/import/maxroll/fetcher.ts
