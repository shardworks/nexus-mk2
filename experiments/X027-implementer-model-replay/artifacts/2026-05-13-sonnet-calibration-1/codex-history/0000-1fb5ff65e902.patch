@@ -0,0 +1,118 @@
+/**
+ * Catalog join indices for the Maxroll importer (T3 — catalog index builders).
+ *
+ * Built once at module load time. All indices are keyed by bnetFileName —
+ * the only join key used by the importer (D3 patron decision: no label-match,
+ * no attribute-id, no tag-heuristic fallbacks).
+ *
+ * Per-class indices are built lazily on first request to avoid loading all
+ * class catalogs when only one class is being imported.
+ */
+
+import {
+  affixes,
+  aspects,
+  uniques,
+  getSkillsForClass,
+  getParagonCatalogForClass,
+  type AffixEntry,
+  type AspectEntry,
+  type UniqueEntry,
+  type SkillEntry,
+  type ParagonBoardEntry,
+  type ParagonGlyphEntry,
+} from "@/lib/catalog";
+
+// ─── Global indices (class-agnostic) ──────────────────────────────────────
+
+/**
+ * Map from bnetFileName → AffixEntry.
+ * Excludes deprecated affixes.
+ * Built once at module load.
+ */
+export const affixIndexByBnetFileName: Map<string, AffixEntry> = (() => {
+  const m = new Map<string, AffixEntry>();
+  for (const entry of affixes) {
+    if (!entry.deprecated && entry.bnetFileName) {
+      m.set(entry.bnetFileName, entry);
+    }
+  }
+  return m;
+})();
+
+/**
+ * Map from bnetFileName → AspectEntry.
+ * Excludes deprecated aspects.
+ * Built once at module load.
+ */
+export const aspectIndexByBnetFileName: Map<string, AspectEntry> = (() => {
+  const m = new Map<string, AspectEntry>();
+  for (const entry of aspects) {
+    if (!entry.deprecated && entry.bnetFileName) {
+      m.set(entry.bnetFileName, entry);
+    }
+  }
+  return m;
+})();
+
+/**
+ * Map from bnetFileName → UniqueEntry.
+ * Excludes deprecated uniques.
+ * Built once at module load.
+ */
+export const uniqueIndexByBnetFileName: Map<string, UniqueEntry> = (() => {
+  const m = new Map<string, UniqueEntry>();
+  for (const entry of uniques) {
+    if (!entry.deprecated && entry.bnetFileName) {
+      m.set(entry.bnetFileName, entry);
+    }
+  }
+  return m;
+})();
+
+// ─── Per-class lazy indices ────────────────────────────────────────────────
+
+const skillIndexByClass = new Map<string, Map<string, SkillEntry>>();
+const boardIndexByClass = new Map<string, Map<string, ParagonBoardEntry>>();
+const glyphIndexByClass = new Map<string, Map<string, ParagonGlyphEntry>>();
+
+export function getSkillIndex(className: string): Map<string, SkillEntry> {
+  let idx = skillIndexByClass.get(className);
+  if (idx) return idx;
+  idx = new Map<string, SkillEntry>();
+  for (const entry of getSkillsForClass(className)) {
+    if (entry.bnetFileName) {
+      idx.set(entry.bnetFileName, entry);
+    }
+  }
+  skillIndexByClass.set(className, idx);
+  return idx;
+}
+
+export function getBoardIndex(className: string): Map<string, ParagonBoardEntry> {
+  let idx = boardIndexByClass.get(className);
+  if (idx) return idx;
+  idx = new Map<string, ParagonBoardEntry>();
+  const { boards } = getParagonCatalogForClass(className);
+  for (const entry of boards) {
+    if (entry.bnetFileName) {
+      idx.set(entry.bnetFileName, entry);
+    }
+  }
+  boardIndexByClass.set(className, idx);
+  return idx;
+}
+
+export function getGlyphIndex(className: string): Map<string, ParagonGlyphEntry> {
+  let idx = glyphIndexByClass.get(className);
+  if (idx) return idx;
+  idx = new Map<string, ParagonGlyphEntry>();
+  const { glyphs } = getParagonCatalogForClass(className);
+  for (const entry of glyphs) {
+    if (entry.bnetFileName) {
+      idx.set(entry.bnetFileName, entry);
+    }
+  }
+  glyphIndexByClass.set(className, idx);
+  return idx;
+}
diff --git a/lib/import/maxroll/data-min-cache.ts b/lib/import/maxroll/data-min-cache.ts
