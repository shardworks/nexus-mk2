+/**
+ * Public types for the Maxroll planner importer (lib/import/maxroll/).
+ *
+ * ImportResult is a discriminated union — ok:true carries the full mapped
+ * payload for ALL variants of the planner; ok:false carries a structured
+ * failure reason so callers can batch-collect failures without try/catch.
+ *
+ * UnmappedRef is a per-category discriminated union capturing every reference
+ * that could not be resolved via bnetFileName join. Every unmapped reference
+ * is surfaced here — none are silently dropped (D8).
+ */
+
+import type { Character } from "@/lib/schema/character";
+import type { Item } from "@/lib/schema/item";
+import type { BuildImportedFrom } from "@/lib/schema/build";
+
+// ─── ImportContext ─────────────────────────────────────────────────────────
+
+/**
+ * Optional context for importMaxrollPlanner.
+ * All slots have sensible server-side defaults; tests override via ctx.fetch.
+ */
+export interface ImportContext {
+  /** Override the global fetch (used in tests to serve fixture data). */
+  fetch?: typeof globalThis.fetch;
+  /** Directory for the data.min.json disk cache. Defaults to DATA_DIR/maxroll-cache. */
+  cacheDir?: string;
+  /** Returns the current Date (used in tests to pin importedAt timestamps). */
+  now?: () => Date;
+}
+
+// ─── UnmappedRef (D8) ─────────────────────────────────────────────────────
+
+export type UnmappedRef =
+  | {
+      category: "affix";
+      /** Maxroll nid for the affix */
+      nid: number;
+      /** Rolled value from the Maxroll payload */
+      value: number;
+      /** Our slot id where this affix appeared */
+      slot: string;
+      /** Whether Maxroll marked this as tempered */
+      tempered: boolean;
+    }
+  | {
+      category: "aspect";
+      nid: number;
+      value: number;
+      slot: string;
+    }
+  | {
+      category: "unique";
+      /** Maxroll item type nid */
+      nid: number;
+      slot: string;
+    }
+  | {
+      category: "paragon-node";
+      /** Maxroll node id (stored as mr:<nid>) */
+      nid: number;
+      boardNid: number;
+    }
+  | {
+      category: "glyph";
+      nid: number;
+      boardNid: number;
+    }
+  | {
+      category: "skill";
+      nid: number;
+      isActive: boolean;
+    };
+
+// ─── ImportReport ──────────────────────────────────────────────────────────
+
+export interface ImportReport {
+  unmappedAffixes: UnmappedRef[];
+  unmappedAspects: UnmappedRef[];
+  unmappedUniques: UnmappedRef[];
+  unmappedParagonNodes: UnmappedRef[];
+  unmappedGlyphs: UnmappedRef[];
+  unmappedSkills: UnmappedRef[];
+  /**
+   * Present when the Maxroll planner's patch string differs from the catalog's
+   * verifiedAgainst.patch but the explicit mapping rate is still above the
+   * fail threshold. Absent when patches match or when ok:false is returned.
+   */
+  versionMismatch?: {
+    catalogPatch: string;
+    maxrollPatch: string;
+    /** Ratio of successfully-mapped explicit affixes across all items in this variant. */
+    explicitMappingRate: number;
+  };
+}
+
+// ─── Mapped variant ────────────────────────────────────────────────────────
+
+export interface MappedVariant {
+  variantIndex: number;
+  variantName: string;
+  /** Character shape ready to POST to /api/characters (id omitted; server generates). */
+  character: Omit<Character, "id">;
+  /** Build provenance for /api/characters?withDefaultBuild=true to attach. */
+  buildProvenance: BuildImportedFrom;
+  /** equippedItems record keyed by our slot id. */
+  items: Record<string, Item>;
+  report: ImportReport;
+}
+
+// ─── ImportResult (D7) ────────────────────────────────────────────────────
+
+export type ImportResult =
+  | {
+      ok: true;
+      plannerId: string;
+      plannerName: string;
+      /** All variants mapped — at least one entry, preserving Maxroll tab order. */
+      variants: MappedVariant[];
+    }
+  | {
+      ok: false;
+      reason:
+        | "not-found"
+        | "private"
+        | "patch-mismatch"
+        | "zero-mapped"
+        | "network"
+        | "parse-error";
+      message: string;
+      details?: unknown;
+    };
