diff --git a/app/api/import/maxroll/preview/route.ts b/app/api/import/maxroll/preview/route.ts
new file mode 100644
index 0000000..3c2827a
--- /dev/null
+++ b/app/api/import/maxroll/preview/route.ts
@@ -0,0 +1,98 @@
+/**
+ * POST /api/import/maxroll/preview — stateless Maxroll planner preview (D23).
+ *
+ * Accepts a planner reference (bare id, planner URL, or build-guide URL),
+ * invokes the library, and returns ALL variants' mapped data in one response.
+ * No server-side preview state is maintained.
+ *
+ * The UI picks one variant and commits it directly via the existing
+ * POST /api/characters?withDefaultBuild=true endpoint.
+ *
+ * HTTP error mapping:
+ *   400  parse-error
+ *   404  not-found | private
+ *   409  patch-mismatch
+ *   422  zero-mapped
+ *   502  network
+ *   500  unexpected errors
+ */
+
+import { NextResponse } from "next/server";
+import { importMaxrollPlanner } from "@/lib/import/maxroll";
+import { z } from "zod";
+
+const RequestBodySchema = z.object({
+  /** Planner reference: bare id, planner URL, planner URL with hash, or build-guide URL */
+  input: z.string().min(1, "input is required"),
+});
+
+export async function POST(request: Request) {
+  // Parse request body
+  let body: unknown;
+  try {
+    body = await request.json();
+  } catch {
+    return NextResponse.json({ error: "Invalid JSON body" }, { status: 400 });
+  }
+
+  const parsed = RequestBodySchema.safeParse(body);
+  if (!parsed.success) {
+    return NextResponse.json(
+      { error: parsed.error.message },
+      { status: 400 }
+    );
+  }
+
+  const { input } = parsed.data;
+
+  // Invoke the importer library
+  const result = await importMaxrollPlanner(input);
+
+  if (!result.ok) {
+    // Map failure reasons to appropriate HTTP status codes
+    const statusMap: Record<string, number> = {
+      "parse-error": 400,
+      "not-found": 404,
+      private: 404,
+      "patch-mismatch": 409,
+      "zero-mapped": 422,
+      network: 502,
+    };
+
+    const status = statusMap[result.reason] ?? 500;
+    return NextResponse.json(
+      { error: result.message, reason: result.reason, details: result.details },
+      { status }
+    );
+  }
+
+  // Success — return all variants so the UI can display a picker
+  return NextResponse.json({
+    plannerId: result.plannerId,
+    plannerName: result.plannerName,
+    variants: result.variants.map((v) => ({
+      variantIndex: v.variantIndex,
+      variantName: v.variantName,
+      character: v.character,
+      buildProvenance: v.buildProvenance,
+      items: v.items,
+      report: {
+        unmappedAffixes: v.report.unmappedAffixes,
+        unmappedAspects: v.report.unmappedAspects,
+        unmappedUniques: v.report.unmappedUniques,
+        unmappedParagonNodes: v.report.unmappedParagonNodes,
+        unmappedGlyphs: v.report.unmappedGlyphs,
+        unmappedSkills: v.report.unmappedSkills,
+        versionMismatch: v.report.versionMismatch,
+        // Summary counts for UI display
+        unmappedCount:
+          v.report.unmappedAffixes.length +
+          v.report.unmappedAspects.length +
+          v.report.unmappedUniques.length +
+          v.report.unmappedParagonNodes.length +
+          v.report.unmappedGlyphs.length +
+          v.report.unmappedSkills.length,
+      },
+    })),
+  });
+}
