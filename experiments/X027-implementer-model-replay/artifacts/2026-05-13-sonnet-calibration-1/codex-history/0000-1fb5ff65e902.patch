+++ b/lib/import/maxroll/slot-map.ts
@@ -0,0 +1,47 @@
+/**
+ * Maxroll planner slot-key → d4-tools canonical slot-id translation table (D27).
+ *
+ * Maxroll's equipment object uses string keys that differ from our catalog slot ids
+ * in several places (case conventions, Barbarian-specific names). This map is the
+ * single authoritative translation; it lives here rather than in lib/catalog/ because
+ * it is importer-private Maxroll vocabulary.
+ *
+ * Our slot ids come from lib/catalog/slots.json.
+ */
+export const MAXROLL_SLOT_MAP: Record<string, string> = {
+  // Standard slots — most match our catalog ids exactly
+  helm: "helm",
+  chest: "chest",
+  gloves: "gloves",
+  pants: "pants",
+  boots: "boots",
+  amulet: "amulet",
+  ring1: "ring1",
+  ring2: "ring2",
+
+  // Weapons — generic classes (non-Barbarian)
+  weapon: "weapon",
+  offhand: "offHand",
+  offHand: "offHand",
+
+  // Barbarian dual-wield + 2H slots
+  "1h-main": "barb_1h_main",
+  "1h-off": "barb_1h_off",
+  "2h-bludgeoning": "barb_2h_bludgeoning",
+  "2h-slashing": "barb_2h_slashing",
+  // Alternative naming conventions seen in Maxroll exports
+  weapon1: "barb_1h_main",
+  weapon2: "barb_1h_off",
+  weapon3: "barb_2h_bludgeoning",
+  weapon4: "barb_2h_slashing",
+  bludgeoning: "barb_2h_bludgeoning",
+  slashing: "barb_2h_slashing",
+};
+
+/**
+ * Resolve a Maxroll slot key to our canonical slot id.
+ * Returns undefined when the key is unknown (caller should emit a warning).
+ */
+export function resolveSlot(maxrollSlotKey: string): string | undefined {
+  return MAXROLL_SLOT_MAP[maxrollSlotKey];
+}
