index 0000000..28fe3b0
--- /dev/null
+++ b/lib/import/maxroll/mapper.ts
@@ -0,0 +1,528 @@
+/**
+ * Schema-mapping pipeline for the Maxroll planner importer (T3).
+ *
+ * Maps a parsed Maxroll profile + data.min.json into canonical d4-tools
+ * Character / Item / Build shapes using bnetFileName as the exclusive join key.
+ *
+ * Key decisions implemented here:
+ *   D9  — patch-mismatch fail threshold (50% explicit mapping rate)
+ *   D11 — aspect.source defaults to 'legendary'
+ *   D12 — Character.level defaults to 100
+ *   D13 — Item.itemPower left undefined when absent
+ *   D14 — Item.rarity: unique > legendary (if aspect) > rare
+ *   D15 — Item.isAncestral defaults to false
+ *   D16 — Affix routing: catalog isImplicit → implicits; Maxroll tempered → tempered; else → explicits
+ *   D17 — Paragon nodes stored verbatim as mr:<nid> strings; spentPoints = nodes.length
+ *   D18 — Glyph level defaults to 21
+ */
+
+import { classes, verifiedAgainst } from "@/lib/catalog";
+import type { Character } from "@/lib/schema/character";
+import type { Item, ItemRarity } from "@/lib/schema/item";
+import type { AffixInstance } from "@/lib/schema/affix";
+import type { AspectInstance } from "@/lib/schema/aspect";
+import type { SkillSelection } from "@/lib/schema/skill";
+import type { ParagonBoardAllocation, ParagonAllocation } from "@/lib/schema/paragon";
+import type { BuildImportedFrom } from "@/lib/schema/build";
+import type { MaxrollProfile, MaxrollVariant, MaxrollItem, MaxrollDataMin } from "./payload-schema";
+import type { UnmappedRef, ImportReport, MappedVariant, ImportResult } from "./types";
+import { resolveSlot } from "./slot-map";
+import {
+  affixIndexByBnetFileName,
+  aspectIndexByBnetFileName,
+  uniqueIndexByBnetFileName,
+  getSkillIndex,
+  getBoardIndex,
+  getGlyphIndex,
+} from "./catalog-index";
+
+// ─── Class ID mapping ──────────────────────────────────────────────────────
+
+/** Map from Maxroll d4Class numeric id → our class name string. */
+const classIdToName: Map<number, string> = (() => {
+  const m = new Map<number, string>();
+  for (const entry of classes) {
+    if (entry.bnetClassId !== undefined) {
+      m.set(entry.bnetClassId, entry.id);
+    }
+  }
+  return m;
+})();
+
+// ─── Item mapper ───────────────────────────────────────────────────────────
+
+interface MappedItemResult {
+  item: Item;
+  unmappedAffixes: UnmappedRef[];
+  unmappedAspects: UnmappedRef[];
+  unmappedUniques: UnmappedRef[];
+  explicitCount: number;
+  explicitMappedCount: number;
+}
+
+function mapItem(
+  slotKey: string,
+  mrItem: MaxrollItem,
+  datMin: MaxrollDataMin
+): MappedItemResult | null {
+  const ourSlot = resolveSlot(slotKey);
+  if (!ourSlot) return null; // unknown slot — caller logs a warning
+
+  const unmappedAffixes: UnmappedRef[] = [];
+  const unmappedAspects: UnmappedRef[] = [];
+  const unmappedUniques: UnmappedRef[] = [];
+
+  let explicitCount = 0;
+  let explicitMappedCount = 0;
+
+  // Resolve unique item type via item nid → data.min items → bnetFileName → catalog
+  let isUniqueMapped = false;
+  let uniqueId: string | undefined;
+
+  if (mrItem.nid !== undefined) {
+    const nidStr = String(mrItem.nid);
+    const dmEntry = datMin.items[nidStr];
+    if (dmEntry?.bnetFileName) {
+      const catalogUnique = uniqueIndexByBnetFileName.get(dmEntry.bnetFileName);
+      if (catalogUnique) {
+        isUniqueMapped = true;
+        uniqueId = catalogUnique.id;
+      }
+    }
+    if (!isUniqueMapped) {
+      unmappedUniques.push({ category: "unique", nid: mrItem.nid, slot: ourSlot });
+    }
+  }
+
+  // Map affixes
+  const implicits: AffixInstance[] = [];
+  const explicits: AffixInstance[] = [];
+  const tempered: AffixInstance[] = [];
+
+  for (const mrAffix of mrItem.affixes) {
+    const nidStr = String(mrAffix.nid);
+    const dmEntry = datMin.affixes[nidStr];
+    const bnetFileName = dmEntry?.bnetFileName;
+
+    if (!bnetFileName) {
+      // No data.min entry for this nid — unmapped
+      const isTempered = mrAffix.tempered === true;
+      if (!isTempered) {
+        explicitCount++;
+      }
+      unmappedAffixes.push({
+        category: "affix",
+        nid: mrAffix.nid,
+        value: mrAffix.value,
+        slot: ourSlot,
+        tempered: isTempered,
+      });
+      continue;
+    }
+
+    const catalogAffix = affixIndexByBnetFileName.get(bnetFileName);
+    if (!catalogAffix) {
+      const isTempered = mrAffix.tempered === true;
+      if (!isTempered) {
+        explicitCount++;
+      }
+      unmappedAffixes.push({
+        category: "affix",
+        nid: mrAffix.nid,
+        value: mrAffix.value,
+        slot: ourSlot,
+        tempered: isTempered,
+      });
+      continue;
+    }
+
+    const affixInstance: AffixInstance = {
+      affixId: catalogAffix.id,
+      rolledValue: mrAffix.value,
+    };
+
+    // D16: route by catalog isImplicit, then Maxroll tempered flag, else explicit
+    if (catalogAffix.isImplicit) {
+      implicits.push(affixInstance);
+    } else if (mrAffix.tempered === true) {
+      tempered.push(affixInstance);
+    } else {
+      explicits.push(affixInstance);
+      explicitCount++;
+      explicitMappedCount++;
+    }
+  }
+
+  // Map aspect
+  let aspect: AspectInstance | undefined;
+  if (mrItem.aspect !== undefined) {
+    const nidStr = String(mrItem.aspect.nid);
+    const dmEntry = datMin.aspects[nidStr];
+    const bnetFileName = dmEntry?.bnetFileName;
+
+    if (bnetFileName) {
+      const catalogAspect = aspectIndexByBnetFileName.get(bnetFileName);
+      if (catalogAspect) {
+        aspect = {
+          aspectId: catalogAspect.id,
+          rolledValue: mrItem.aspect.value,
+          source: "legendary" as const, // D11
+        };
+      } else {
+        unmappedAspects.push({
+          category: "aspect",
+          nid: mrItem.aspect.nid,
+          value: mrItem.aspect.value,
+          slot: ourSlot,
+        });
+      }
+    } else {
+      unmappedAspects.push({
+        category: "aspect",
+        nid: mrItem.aspect.nid,
+        value: mrItem.aspect.value,
+        slot: ourSlot,
+      });
+    }
+  }
+
+  // D14: rarity inference
+  let rarity: ItemRarity;
+  if (uniqueId) {
+    rarity = "unique";
+  } else if (aspect !== undefined) {
+    rarity = "legendary";
+  } else {
+    // If quality is present, use it as a hint; else default to rare
+    const q = mrItem.quality;
+    if (q === 5) rarity = "unique";
+    else if (q === 4) rarity = "legendary";
+    else if (q === 2) rarity = "magic";
+    else if (q === 1) rarity = "common";
+    else rarity = "rare";
+  }
+
+  const item: Item = {
+    slot: ourSlot,
+    name: uniqueId ? (uniqueIndexByBnetFileName.get(
+      datMin.items[String(mrItem.nid)]?.bnetFileName ?? ""
+    )?.label ?? "") : "",
+    rarity,
+    itemPower: mrItem.power !== undefined ? Math.round(mrItem.power) : undefined, // D13
+    isAncestral: mrItem.ancestral === true, // D15
+    implicits,
+    explicits,
+    tempered,
+    aspect,
+    masterworkRank: 0,
+    runes: [],
+    sockets: [],
+  };
+
+  return {
+    item,
+    unmappedAffixes,
+    unmappedAspects,
+    unmappedUniques,
+    explicitCount,
+    explicitMappedCount,
+  };
+}
+
+// ─── Skill mapper ──────────────────────────────────────────────────────────
+
+function mapSkills(
+  variant: MaxrollVariant,
+  className: string,
+  datMin: MaxrollDataMin
+): { skillSelections: SkillSelection[]; unmappedSkills: UnmappedRef[] } {
+  const skillIndex = getSkillIndex(className);
+  const skillSelections: SkillSelection[] = [];
+  const unmappedSkills: UnmappedRef[] = [];
+
+  const processSkill = (nid: number, rank: number, slot: number | undefined, isActive: boolean) => {
+    const nidStr = String(nid);
+    const dmEntry = datMin.skills[nidStr];
+    const bnetFileName = dmEntry?.bnetFileName;
+    if (!bnetFileName) {
+      unmappedSkills.push({ category: "skill", nid, isActive });
+      return;
+    }
+    const catalogSkill = skillIndex.get(bnetFileName);
+    if (!catalogSkill) {
+      unmappedSkills.push({ category: "skill", nid, isActive });
+      return;
+    }
+    const sel: SkillSelection = {
+      skillId: catalogSkill.id,
+      rank: Math.min(Math.max(rank, 0), 15),
+      slot: slot !== undefined ? String(slot) : undefined,
+    };
+    skillSelections.push(sel);
+  };
+
+  for (const s of variant.skills?.active ?? []) {
+    processSkill(s.nid, s.rank, s.slot, true);
+  }
+  for (const s of variant.skills?.passive ?? []) {
+    processSkill(s.nid, s.rank, undefined, false);
+  }
+
+  return { skillSelections, unmappedSkills };
+}
+
+// ─── Paragon mapper ────────────────────────────────────────────────────────
+
+function mapParagon(
+  variant: MaxrollVariant,
+  className: string,
+  datMin: MaxrollDataMin
+): {
+  paragonAllocation: ParagonAllocation;
+  unmappedParagonNodes: UnmappedRef[];
+  unmappedGlyphs: UnmappedRef[];
+} {
+  const boardIndex = getBoardIndex(className);
+  const glyphIndex = getGlyphIndex(className);
+
+  const boards: ParagonBoardAllocation[] = [];
+  const unmappedParagonNodes: UnmappedRef[] = [];
+  const unmappedGlyphs: UnmappedRef[] = [];
+
+  for (const mrBoard of variant.paragon?.boards ?? []) {
+    const nidStr = String(mrBoard.nid);
+    const dmEntry = datMin.paragonBoards[nidStr];
+    const bnetFileName = dmEntry?.bnetFileName;
+
+    if (!bnetFileName) {
+      // Board itself unmapped — still emit node unmapped refs
+      for (const nodeNid of mrBoard.nodes) {
+        unmappedParagonNodes.push({ category: "paragon-node", nid: nodeNid, boardNid: mrBoard.nid });
+      }
+      if (mrBoard.glyph) {
+        unmappedGlyphs.push({ category: "glyph", nid: mrBoard.glyph.nid, boardNid: mrBoard.nid });
+      }
+      continue;
+    }
+
+    const catalogBoard = boardIndex.get(bnetFileName);
+    if (!catalogBoard) {
+      for (const nodeNid of mrBoard.nodes) {
+        unmappedParagonNodes.push({ category: "paragon-node", nid: nodeNid, boardNid: mrBoard.nid });
+      }
+      if (mrBoard.glyph) {
+        unmappedGlyphs.push({ category: "glyph", nid: mrBoard.glyph.nid, boardNid: mrBoard.nid });
+      }
+      continue;
+    }
+
+    // D17: store node ids verbatim as "mr:<nid>" strings; spentPoints = nodes.length
+    const nodeStrings = mrBoard.nodes.map((n) => `mr:${n}`);
+
+    // Map glyph
+    let mappedGlyph: ParagonBoardAllocation["glyph"] | undefined;
+    if (mrBoard.glyph) {
+      const glyphNidStr = String(mrBoard.glyph.nid);
+      const glyphDmEntry = datMin.paragonGlyphs[glyphNidStr];
+      const glyphBnetFileName = glyphDmEntry?.bnetFileName;
+      if (glyphBnetFileName) {
+        const catalogGlyph = glyphIndex.get(glyphBnetFileName);
+        if (catalogGlyph) {
+          mappedGlyph = {
+            glyphId: catalogGlyph.id,
+            level: mrBoard.glyph.level ?? 21, // D18: default to 21
+          };
+        } else {
+          unmappedGlyphs.push({ category: "glyph", nid: mrBoard.glyph.nid, boardNid: mrBoard.nid });
+        }
+      } else {
+        unmappedGlyphs.push({ category: "glyph", nid: mrBoard.glyph.nid, boardNid: mrBoard.nid });
+      }
+    }
+
+    boards.push({
+      boardId: catalogBoard.id,
+      boardName: catalogBoard.label,
+      spentPoints: nodeStrings.length, // D17: derived from nodes.length
+      glyph: mappedGlyph,
+      nodes: nodeStrings,
+    });
+  }
+
+  const paragonAllocation: ParagonAllocation = {
+    paragonLevel: Math.min(Math.max(variant.paragonLevel ?? 0, 0), 300),
+    boards,
+  };
+
+  return { paragonAllocation, unmappedParagonNodes, unmappedGlyphs };
+}
+
+// ─── Variant mapper ────────────────────────────────────────────────────────
+
+function mapVariant(
+  profile: MaxrollProfile,
+  variant: MaxrollVariant,
+  variantIndex: number,
+  className: string,
+  datMin: MaxrollDataMin,
+  importedAt: string,
+  catalogPatch: string
+): MappedVariant {
+  // Map equipment
+  const equippedItems: Record<string, Item> = {};
+  const allUnmappedAffixes: UnmappedRef[] = [];
+  const allUnmappedAspects: UnmappedRef[] = [];
+  const allUnmappedUniques: UnmappedRef[] = [];
+
+  let totalExplicitCount = 0;
+  let totalExplicitMappedCount = 0;
+
+  for (const [slotKey, mrItem] of Object.entries(variant.equipment)) {
+    const result = mapItem(slotKey, mrItem, datMin);
+    if (!result) {
+      // Unknown slot key — skip
+      continue;
+    }
+    equippedItems[result.item.slot] = result.item;
+    allUnmappedAffixes.push(...result.unmappedAffixes);
+    allUnmappedAspects.push(...result.unmappedAspects);
+    allUnmappedUniques.push(...result.unmappedUniques);
+    totalExplicitCount += result.explicitCount;
+    totalExplicitMappedCount += result.explicitMappedCount;
+  }
+
+  // Map skills
+  const { skillSelections, unmappedSkills } = mapSkills(variant, className, datMin);
+
+  // Map paragon
+  const { paragonAllocation, unmappedParagonNodes, unmappedGlyphs } = mapParagon(
+    variant,
+    className,
+    datMin
+  );
+
+  // Compute version mismatch info (D9/D25: compare datMin.version vs catalog patch)
+  const datMinVersion = datMin.version;
+  const patchesDiffer = catalogPatch !== datMinVersion;
+  const explicitMappingRate =
+    totalExplicitCount > 0 ? totalExplicitMappedCount / totalExplicitCount : 1;
+
+  const report: ImportReport = {
+    unmappedAffixes: allUnmappedAffixes,
+    unmappedAspects: allUnmappedAspects,
+    unmappedUniques: allUnmappedUniques,
+    unmappedParagonNodes,
+    unmappedGlyphs,
+    unmappedSkills,
+    versionMismatch: patchesDiffer
+      ? { catalogPatch, maxrollPatch: datMinVersion, explicitMappingRate }
+      : undefined,
+  };
+
+  const character: Omit<Character, "id"> = {
+    name: `${profile.name || className} (Maxroll Import)`,
+    class: className as Character["class"],
+    level: Math.min(Math.max(variant.level ?? 100, 1), 100), // D12: default 100
+    paragonAllocation,
+    skillSelections,
+    equippedItems,
+    playstyleConstraints: [],
+  };
+
+  const buildProvenance: BuildImportedFrom = {
+    source: "maxroll",
+    plannerId: profile.id,
+    variantIndex,
+    importedAt,
+    plannerVersion: profile.patch ?? datMinVersion,
+  };
+
+  return {
+    variantIndex,
+    variantName: variant.name || `Variant ${variantIndex + 1}`,
+    character,
+    buildProvenance,
+    items: equippedItems,
+    report,
+  };
+}
+
+// ─── Top-level mapper ──────────────────────────────────────────────────────
+
+/**
+ * Map a fully parsed MaxrollProfile + data.min into an ImportResult.
+ *
+ * Applies patch-mismatch fail rule (D9):
+ *   If patches differ AND any variant has explicit mapping rate < 50% → ok: false
+ */
+export function mapProfile(
+  profile: MaxrollProfile,
+  datMin: MaxrollDataMin,
+  now: Date
+): ImportResult {
+  const className = classIdToName.get(profile.d4Class);
+  if (!className) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: `Unknown Maxroll d4Class value: ${profile.d4Class}`,
+    };
+  }
+
+  const catalogPatch = verifiedAgainst.patch;
+  const importedAt = now.toISOString();
+
+  const mappedVariants: MappedVariant[] = [];
+
+  for (let i = 0; i < profile.data.length; i++) {
+    const variant = profile.data[i];
+    const mapped = mapVariant(profile, variant, i, className, datMin, importedAt, catalogPatch);
+    mappedVariants.push(mapped);
+  }
+
+  if (mappedVariants.length === 0) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: "Maxroll planner has no variants",
+    };
+  }
+
+  // D9: patch-mismatch fail threshold (compare datMin.version vs catalog patch)
+  const datMinVersion = datMin.version;
+  if (catalogPatch !== datMinVersion) {
+    for (const v of mappedVariants) {
+      const vm = v.report.versionMismatch;
+      if (vm && vm.explicitMappingRate < 0.5) {
+        return {
+          ok: false,
+          reason: "patch-mismatch",
+          message:
+            `data.min.json version (${datMinVersion}) differs from catalog patch (${catalogPatch}) ` +
+            `and explicit mapping rate for variant "${v.variantName}" is ${(vm.explicitMappingRate * 100).toFixed(0)}% ` +
+            `(below 50% threshold). Delete the data.min cache and retry after a catalog update.`,
+          details: { catalogPatch, maxrollPatch: datMinVersion, explicitMappingRate: vm.explicitMappingRate },
+        };
+      }
+    }
+  }
+
+  // D20 zero-mapped check (no equipped items across all variants)
+  const hasAnyItems = mappedVariants.some((v) => Object.keys(v.items).length > 0);
+  if (!hasAnyItems && profile.data.some((d) => Object.keys(d.equipment ?? {}).length > 0)) {
+    return {
+      ok: false,
+      reason: "zero-mapped",
+      message:
+        "No items could be mapped from the Maxroll planner. " +
+        "This planner may use a catalog that is incompatible with the current patch.",
+    };
+  }
+
+  return {
+    ok: true,
+    plannerId: profile.id,
+    plannerName: profile.name || className,
+    variants: mappedVariants,
+  };
+}
diff --git a/lib/import/maxroll/parser.ts b/lib/import/maxroll/parser.ts
new file mode 100644
index 0000000..6941cf1
--- /dev/null
+++ b/lib/import/maxroll/parser.ts
@@ -0,0 +1,96 @@
+/**
+ * Source-reference parser for Maxroll planner inputs (D2/D24).
+ *
+ * Resolves four input shapes into a canonical planner id:
+ *   1. Bare planner id: /^[a-zA-Z0-9]+$/
+ *   2. Planner URL: https://maxroll.gg/d4/planner/<id>
+ *   3. Planner URL with hash: https://maxroll.gg/d4/planner/<id>#<n>&equipment
+ *   4. Build-guide URL: https://maxroll.gg/d4/build-guides/<slug>
+ *      — requires fetching the page HTML and regex-matching /d4/planner/([a-zA-Z0-9]+)
+ *
+ * Returns { plannerId, variantIndex } where variantIndex defaults to 0 (D10)
+ * unless extracted from the URL hash.
+ */
+
+const PLANNER_ID_RE = /^[a-zA-Z0-9-]+$/;
+const PLANNER_URL_RE = /maxroll\.gg\/d4\/planner\/([a-zA-Z0-9]+)/;
+const BUILD_GUIDE_URL_RE = /maxroll\.gg\/d4\/build-guides\//;
+const GUIDE_EMBEDDED_PLANNER_RE = /\/d4\/planner\/([a-zA-Z0-9]+)/;
+
+export interface ParsedInput {
+  plannerId: string;
+  variantIndex: number;
+}
+
+function extractVariantFromHash(hash: string): number {
+  // Hash format: #<n>&equipment or #<n> — the leading # is stripped by URL parsing
+  const match = hash.match(/^(\d+)/);
+  if (match) return parseInt(match[1], 10);
+  return 0;
+}
+
+/**
+ * Parse a Maxroll planner input into a canonical plannerId + variantIndex.
+ * Throws for inputs that don't match any known pattern.
+ * Build-guide URLs require a fetch (ctx.fetch must be provided or global fetch used).
+ */
+export async function parseMaxrollInput(
+  input: string,
+  fetchFn: typeof globalThis.fetch = globalThis.fetch
+): Promise<ParsedInput> {
+  const trimmed = input.trim();
+
+  // Shape 1: bare id
+  if (PLANNER_ID_RE.test(trimmed)) {
+    return { plannerId: trimmed, variantIndex: 0 };
+  }
+
+  // Shape 2 + 3: planner URL (with or without hash)
+  if (PLANNER_URL_RE.test(trimmed)) {
+    let url: URL;
+    try {
+      url = new URL(trimmed);
+    } catch {
+      // If URL() fails, try raw regex
+      const m = PLANNER_URL_RE.exec(trimmed);
+      if (!m) throw new Error(`Could not extract planner id from URL: ${trimmed}`);
+      return { plannerId: m[1], variantIndex: 0 };
+    }
+
+    const m = PLANNER_URL_RE.exec(trimmed);
+    if (!m) throw new Error(`Could not extract planner id from URL: ${trimmed}`);
+    const plannerId = m[1];
+    const variantIndex = url.hash ? extractVariantFromHash(url.hash.replace(/^#/, "")) : 0;
+    return { plannerId, variantIndex };
+  }
+
+  // Shape 4: build-guide URL — fetch HTML and regex-match
+  if (BUILD_GUIDE_URL_RE.test(trimmed)) {
+    let html: string;
+    try {
+      const res = await fetchFn(trimmed);
+      if (!res.ok) {
+        throw new Error(`Build-guide fetch failed: HTTP ${res.status}`);
+      }
+      html = await res.text();
+    } catch (err) {
+      throw new Error(
+        `Failed to fetch build-guide page at ${trimmed}: ${err instanceof Error ? err.message : String(err)}`
+      );
+    }
+
+    // D24: regex-match /d4/planner/([a-zA-Z0-9]+), take the first match
+    const match = GUIDE_EMBEDDED_PLANNER_RE.exec(html);
+    if (!match) {
+      throw new Error(
+        `No Maxroll planner link found in build-guide page: ${trimmed}`
+      );
+    }
+    return { plannerId: match[1], variantIndex: 0 };
+  }
+
+  throw new Error(
+    `Unrecognized Maxroll planner input: "${trimmed}". ` +
+      `Expected a bare planner id, a maxroll.gg/d4/planner/<id> URL, or a maxroll.gg/d4/build-guides/<slug> URL.`
+  );
+}
diff --git a/lib/import/maxroll/payload-schema.ts b/lib/import/maxroll/payload-schema.ts
new file mode 100644
index 0000000..100ac75
--- /dev/null
+++ b/lib/import/maxroll/payload-schema.ts
@@ -0,0 +1,178 @@
+/**
+ * Zod validation schemas for the Maxroll planner API payload (D28).
+ *
+ * Every object uses .passthrough() so that unknown extra fields from Maxroll
+ * are tolerated without throwing. Required fields still throw on absence.
+ *
+ * Two top-level schemas:
+ *   MaxrollProfileSchema   — the planners.maxroll.gg/profiles/load response
+ *   MaxrollDataMinSchema   — the assets-ng.maxroll.gg/d4planner/data.min.json file
+ */
+
+import { z } from "zod";
+
+// ─── Profile API payload ────────────────────────────────────────────────────
+
+const MaxrollAffixSchema = z
+  .object({
+    /** Maxroll internal numeric id for the affix entry */
+    nid: z.number(),
+    /** Rolled numeric value */
+    value: z.number(),
+    /** Present and true when this is a tempered affix (D16) */
+    tempered: z.boolean().optional(),
+  })
+  .passthrough();
+
+export type MaxrollAffix = z.infer<typeof MaxrollAffixSchema>;
+
+const MaxrollAspectSchema = z
+  .object({
+    nid: z.number(),
+    value: z.number(),
+  })
+  .passthrough();
+
+export type MaxrollAspect = z.infer<typeof MaxrollAspectSchema>;
+
+const MaxrollItemSchema = z
+  .object({
+    /** Item type nid (used for unique lookup via data.min items catalog) */
+    nid: z.number().optional(),
+    /** Item power */
+    power: z.number().optional(),
+    /** True if this is an ancestral item */
+    ancestral: z.boolean().optional(),
+    /**
+     * Maxroll quality value:
+     *   1 = Normal/Common, 2 = Magic, 3 = Rare, 4 = Legendary, 5 = Unique/Mythic
+     */
+    quality: z.number().optional(),
+    /** All affixes (implicits, explicits, tempered) in a flat array. */
+    affixes: z.array(MaxrollAffixSchema).default([]),
+    /** The single legendary/codex aspect on this item. */
+    aspect: MaxrollAspectSchema.optional(),
+  })
+  .passthrough();
+
+export type MaxrollItem = z.infer<typeof MaxrollItemSchema>;
+
+const MaxrollActiveSkillSchema = z
+  .object({
+    nid: z.number(),
+    rank: z.number().int().min(0),
+    /** Bar slot index (0-5) */
+    slot: z.number().int().optional(),
+  })
+  .passthrough();
+
+export type MaxrollActiveSkill = z.infer<typeof MaxrollActiveSkillSchema>;
+
+const MaxrollPassiveSkillSchema = z
+  .object({
+    nid: z.number(),
+    rank: z.number().int().min(0),
+  })
+  .passthrough();
+
+export type MaxrollPassiveSkill = z.infer<typeof MaxrollPassiveSkillSchema>;
+
+const MaxrollSkillsSchema = z
+  .object({
+    active: z.array(MaxrollActiveSkillSchema).default([]),
+    passive: z.array(MaxrollPassiveSkillSchema).default([]),
+  })
+  .passthrough();
+
+const MaxrollGlyphSchema = z
+  .object({
+    nid: z.number(),
+    /** Glyph level (1-21). Absent → default to 21 per D18. */
+    level: z.number().int().optional(),
+  })
+  .passthrough();
+
+export type MaxrollGlyph = z.infer<typeof MaxrollGlyphSchema>;
+
+const MaxrollBoardSchema = z
+  .object({
+    /** Maxroll board nid */
+    nid: z.number(),
+    /** Raw paragon node ids — stored verbatim as mr:<nid> strings per D17. */
+    nodes: z.array(z.number()).default([]),
+    glyph: MaxrollGlyphSchema.optional(),
+  })
+  .passthrough();
+
+export type MaxrollBoard = z.infer<typeof MaxrollBoardSchema>;
+
+const MaxrollParagonSchema = z
+  .object({
+    boards: z.array(MaxrollBoardSchema).default([]),
+  })
+  .passthrough();
+
+const MaxrollVariantSchema = z
+  .object({
+    id: z.number().int().optional(),
+    name: z.string().default(""),
+    level: z.number().int().optional(),
+    paragonLevel: z.number().int().optional(),
+    /** Equipment items keyed by Maxroll slot name (resolved via slot-map.ts). */
+    equipment: z.record(z.string(), MaxrollItemSchema).default({}),
+    skills: MaxrollSkillsSchema.optional(),
+    paragon: MaxrollParagonSchema.optional(),
+  })
+  .passthrough();
+
+export type MaxrollVariant = z.infer<typeof MaxrollVariantSchema>;
+
+export const MaxrollProfileSchema = z
+  .object({
+    id: z.string(),
+    name: z.string().default(""),
+    /** Numeric class id matching bnetClassId in lib/catalog/classes.json */
+    d4Class: z.number().int(),
+    /** Maxroll's reported patch version string */
+    patch: z.string().optional(),
+    /** Array of build variants/tabs */
+    data: z.array(MaxrollVariantSchema),
+  })
+  .passthrough();
+
+export type MaxrollProfile = z.infer<typeof MaxrollProfileSchema>;
+
+// ─── data.min.json ──────────────────────────────────────────────────────────
+
+/**
+ * A single entry in data.min.json category maps.
+ * The bnetFileName field is the join key to our catalog.
+ */
+const DataMinEntrySchema = z
+  .object({
+    bnetFileName: z.string().optional(),
+    name: z.string().optional(),
+  })
+  .passthrough();
+
+export type DataMinEntry = z.infer<typeof DataMinEntrySchema>;
+
+/**
+ * The complete data.min.json shape.
+ * Nid keys are stored as string representations of integers.
+ */
+export const MaxrollDataMinSchema = z
+  .object({
+    /** Patch version string — used to key the disk cache (D4). */
+    version: z.string(),
+    affixes: z.record(z.string(), DataMinEntrySchema).default({}),
+    aspects: z.record(z.string(), DataMinEntrySchema).default({}),
+    skills: z.record(z.string(), DataMinEntrySchema).default({}),
+    paragonBoards: z.record(z.string(), DataMinEntrySchema).default({}),
+    paragonGlyphs: z.record(z.string(), DataMinEntrySchema).default({}),
+    /** Unique item type entries (nid → entry with bnetFileName). */
+    items: z.record(z.string(), DataMinEntrySchema).default({}),
+  })
+  .passthrough();
+
+export type MaxrollDataMin = z.infer<typeof MaxrollDataMinSchema>;
