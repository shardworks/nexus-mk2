diff --git a/app/import/maxroll/MaxrollImportClient.tsx b/app/import/maxroll/MaxrollImportClient.tsx
new file mode 100644
index 0000000..595c335
--- /dev/null
+++ b/app/import/maxroll/MaxrollImportClient.tsx
@@ -0,0 +1,406 @@
+"use client";
+
+/**
+ * Maxroll planner importer — four-state client flow (D20/D23).
+ *
+ * States:
+ *   paste   — input a planner reference (id or URL)
+ *   preview — multi-variant picker + gear summary + unmapped-ref counts
+ *   confirm — single commit action
+ *   (redirect on success)
+ *
+ * Commit path: POST chosen variant's character to /api/characters?withDefaultBuild=true
+ * (existing atomic endpoint per D23), then PATCH the created build with importedFrom
+ * provenance (D19).
+ */
+
+import { useState, useCallback } from "react";
+import { useRouter } from "next/navigation";
+import { Button } from "@/components/ui/button";
+import { AlertCircle, ArrowLeft, CheckCircle, Loader2, Upload } from "lucide-react";
+
+// ─── Types mirrored from API response ─────────────────────────────────────
+
+interface VersionMismatch {
+  catalogPatch: string;
+  maxrollPatch: string;
+  explicitMappingRate: number;
+}
+
+interface VariantReport {
+  unmappedCount: number;
+  versionMismatch?: VersionMismatch;
+}
+
+interface VariantPreview {
+  variantIndex: number;
+  variantName: string;
+  character: {
+    name: string;
+    class: string;
+    level: number;
+    paragonAllocation: { paragonLevel: number; boards: unknown[] };
+    equippedItems: Record<string, unknown>;
+    skillSelections: unknown[];
+  };
+  buildProvenance: {
+    source: string;
+    plannerId: string;
+    variantIndex: number;
+    importedAt: string;
+    plannerVersion: string;
+  };
+  items: Record<string, unknown>;
+  report: VariantReport;
+}
+
+interface PreviewPayload {
+  plannerId: string;
+  plannerName: string;
+  variants: VariantPreview[];
+}
+
+// ─── Component ─────────────────────────────────────────────────────────────
+
+type FlowState = "paste" | "preview" | "confirm" | "committing";
+
+export function MaxrollImportClient() {
+  const router = useRouter();
+
+  const [state, setState] = useState<FlowState>("paste");
+  const [inputValue, setInputValue] = useState("");
+  const [isLoading, setIsLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+
+  const [preview, setPreview] = useState<PreviewPayload | null>(null);
+  const [selectedVariantIndex, setSelectedVariantIndex] = useState(0);
+
+  // ── Paste state: submit ──────────────────────────────────────────────────
+
+  const handlePreview = useCallback(async () => {
+    const trimmed = inputValue.trim();
+    if (!trimmed) {
+      setError("Please enter a Maxroll planner URL or id.");
+      return;
+    }
+
+    setError(null);
+    setIsLoading(true);
+
+    try {
+      const res = await fetch("/api/import/maxroll/preview", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify({ input: trimmed }),
+      });
+
+      const data = await res.json();
+
+      if (!res.ok) {
+        setError(data.error ?? `Import failed (${res.status})`);
+        setIsLoading(false);
+        return;
+      }
+
+      setPreview(data as PreviewPayload);
+      setSelectedVariantIndex(0);
+      setState("preview");
+    } catch (err) {
+      setError(err instanceof Error ? err.message : "Network error");
+    } finally {
+      setIsLoading(false);
+    }
+  }, [inputValue]);
+
+  // ── Preview state: select variant, confirm ───────────────────────────────
+
+  const handleConfirm = useCallback(() => {
+    setState("confirm");
+  }, []);
+
+  // ── Confirm state: commit ────────────────────────────────────────────────
+
+  const handleCommit = useCallback(async () => {
+    if (!preview) return;
+
+    const variant = preview.variants[selectedVariantIndex];
+    if (!variant) return;
+
+    setState("committing");
+    setError(null);
+
+    try {
+      // Step 1: Create character + default build atomically
+      const createRes = await fetch("/api/characters?withDefaultBuild=true", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(variant.character),
+      });
+
+      if (!createRes.ok) {
+        const err = await createRes.json().catch(() => ({}));
+        throw new Error(err.error ?? `Failed to create character (${createRes.status})`);
+      }
+
+      const { build } = await createRes.json();
+
+      // Step 2: PATCH the build with importedFrom provenance (D19)
+      try {
+        await fetch(`/api/builds/${build.id}`, {
+          method: "PATCH",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify({ importedFrom: variant.buildProvenance }),
+        });
+      } catch {
+        // Provenance write is best-effort — do not abort on failure
+        console.warn("[MaxrollImport] Failed to write importedFrom provenance to build", build.id);
+      }
+
+      // Step 3: Navigate to the new build (setActiveBuildId happens server-side on visit)
+      router.push(`/builds/${build.id}`);
+    } catch (err) {
+      setError(err instanceof Error ? err.message : "Commit failed");
+      setState("confirm");
+    }
+  }, [preview, selectedVariantIndex, router]);
+
+  // ── Selected variant ─────────────────────────────────────────────────────
+
+  const selectedVariant = preview?.variants[selectedVariantIndex];
+
+  // ─── Render ─────────────────────────────────────────────────────────────
+
+  return (
+    <div className="max-w-[640px] p-6">
+      <h1 className="text-[20px] font-bold text-stone-100 mb-6">
+        Import from Maxroll Planner
+      </h1>
+
+      {/* ── Paste state ── */}
+      {state === "paste" && (
+        <div className="flex flex-col gap-4">
+          <p className="text-sm text-stone-400">
+            Paste a Maxroll planner URL or planner id. The planner must be publicly shared.
+          </p>
+
+          <div className="flex flex-col gap-1">
+            <label className="text-xs text-stone-500 uppercase tracking-wider" htmlFor="planner-input">
+              Planner URL or ID
+            </label>
+            <input
+              id="planner-input"
+              type="text"
+              className="w-full rounded-md border border-stone-700 bg-surface-2 px-3 py-2 text-sm text-stone-100 placeholder-stone-600 focus:border-stone-500 focus:outline-none"
+              placeholder="https://maxroll.gg/d4/planner/abc123 or abc123"
+              value={inputValue}
+              onChange={(e) => setInputValue(e.target.value)}
+              onKeyDown={(e) => e.key === "Enter" && handlePreview()}
+              autoFocus
+            />
+          </div>
+
+          {error && (
+            <div className="flex items-start gap-2 rounded-md border border-destructive/50 bg-destructive/10 px-3 py-2 text-sm text-destructive">
+              <AlertCircle size={15} className="mt-0.5 shrink-0" />
+              <span>{error}</span>
+            </div>
+          )}
+
+          <div className="flex gap-2">
+            <Button onClick={handlePreview} disabled={isLoading} className="gap-2">
+              {isLoading ? (
+                <Loader2 size={14} className="animate-spin" />
+              ) : (
+                <Upload size={14} />
+              )}
+              {isLoading ? "Loading…" : "Preview"}
+            </Button>
+          </div>
+
+          <p className="text-xs text-stone-600">
+            Accepted formats: bare planner id, maxroll.gg/d4/planner/&lt;id&gt; URL,
+            maxroll.gg/d4/build-guides/&lt;slug&gt; URL
+          </p>
+        </div>
+      )}
+
+      {/* ── Preview state ── */}
+      {state === "preview" && preview && selectedVariant && (
+        <div className="flex flex-col gap-5">
+          <div className="flex items-center gap-3">
+            <button
+              onClick={() => setState("paste")}
+              className="flex items-center gap-1 text-xs text-stone-500 hover:text-stone-300 transition-colors"
+            >
+              <ArrowLeft size={13} />
+              Back
+            </button>
+            <span className="text-stone-600">·</span>
+            <span className="text-sm text-stone-300">{preview.plannerName}</span>
+          </div>
+
+          {/* Variant picker */}
+          {preview.variants.length > 1 && (
+            <div className="flex flex-col gap-2">
+              <span className="text-xs text-stone-500 uppercase tracking-wider">
+                Variant / Tab
+              </span>
+              <div className="flex flex-wrap gap-2">
+                {preview.variants.map((v) => (
+                  <button
+                    key={v.variantIndex}
+                    onClick={() => setSelectedVariantIndex(v.variantIndex)}
+                    className={`rounded-md border px-3 py-1.5 text-xs transition-colors ${
+                      v.variantIndex === selectedVariantIndex
+                        ? "border-accent bg-accent/10 text-accent"
+                        : "border-stone-700 text-stone-400 hover:border-stone-500"
+                    }`}
+                  >
+                    {v.variantName}
+                  </button>
+                ))}
+              </div>
+            </div>
+          )}
+
+          {/* Build summary */}
+          <div className="rounded-md border border-stone-800 bg-surface-2 p-4 flex flex-col gap-3">
+            <div className="grid grid-cols-3 gap-3 text-sm">
+              <div>
+                <div className="text-xs text-stone-500 mb-1">Class</div>
+                <div className="text-stone-100">{selectedVariant.character.class}</div>
+              </div>
+              <div>
+                <div className="text-xs text-stone-500 mb-1">Level</div>
+                <div className="text-stone-100">{selectedVariant.character.level}</div>
+              </div>
+              <div>
+                <div className="text-xs text-stone-500 mb-1">Paragon</div>
+                <div className="text-stone-100">
+                  {selectedVariant.character.paragonAllocation.paragonLevel}
+                </div>
+              </div>
+            </div>
+
+            <div className="grid grid-cols-3 gap-3 text-sm">
+              <div>
+                <div className="text-xs text-stone-500 mb-1">Items</div>
+                <div className="text-stone-100">
+                  {Object.keys(selectedVariant.items).length} slots
+                </div>
+              </div>
+              <div>
+                <div className="text-xs text-stone-500 mb-1">Skills</div>
+                <div className="text-stone-100">
+                  {selectedVariant.character.skillSelections.length}
+                </div>
+              </div>
+              <div>
+                <div className="text-xs text-stone-500 mb-1">Paragon boards</div>
+                <div className="text-stone-100">
+                  {selectedVariant.character.paragonAllocation.boards.length}
+                </div>
+              </div>
+            </div>
+          </div>
+
+          {/* Unmapped references summary */}
+          {selectedVariant.report.unmappedCount > 0 && (
+            <div className="rounded-md border border-amber-900/50 bg-amber-900/10 px-4 py-3">
+              <div className="text-xs font-semibold text-amber-400 mb-1">
+                {selectedVariant.report.unmappedCount} unmapped reference
+                {selectedVariant.report.unmappedCount !== 1 ? "s" : ""}
+              </div>
+              <div className="text-xs text-amber-600">
+                Some affixes, skills, or paragon nodes from this planner could not be matched
+                to the current catalog. They will be omitted from the import.
+              </div>
+            </div>
+          )}
+
+          {/* Version mismatch warning */}
+          {selectedVariant.report.versionMismatch && (
+            <div className="rounded-md border border-amber-900/50 bg-amber-900/10 px-4 py-3">
+              <div className="text-xs font-semibold text-amber-400 mb-1">
+                Patch version mismatch
+              </div>
+              <div className="text-xs text-amber-600">
+                Maxroll data is from patch {selectedVariant.report.versionMismatch.maxrollPatch};
+                catalog is {selectedVariant.report.versionMismatch.catalogPatch}.
+                Mapping rate:{" "}
+                {(selectedVariant.report.versionMismatch.explicitMappingRate * 100).toFixed(0)}%.
+              </div>
+            </div>
+          )}
+
+          {error && (
+            <div className="flex items-start gap-2 rounded-md border border-destructive/50 bg-destructive/10 px-3 py-2 text-sm text-destructive">
+              <AlertCircle size={15} className="mt-0.5 shrink-0" />
+              <span>{error}</span>
+            </div>
+          )}
+
+          <div className="flex gap-2">
+            <Button onClick={handleConfirm}>
+              Import This Build
+            </Button>
+            <Button variant="outline" onClick={() => setState("paste")}>
+              Start Over
+            </Button>
+          </div>
+        </div>
+      )}
+
+      {/* ── Confirm state ── */}
+      {state === "confirm" && selectedVariant && (
+        <div className="flex flex-col gap-5">
+          <div className="flex items-center gap-3">
+            <button
+              onClick={() => setState("preview")}
+              className="flex items-center gap-1 text-xs text-stone-500 hover:text-stone-300 transition-colors"
+            >
+              <ArrowLeft size={13} />
+              Back to preview
+            </button>
+          </div>
+
+          <div className="rounded-md border border-stone-800 bg-surface-2 p-4 flex flex-col gap-2">
+            <div className="flex items-center gap-2 text-sm text-stone-300">
+              <CheckCircle size={15} className="text-green-500 shrink-0" />
+              Ready to import
+            </div>
+            <div className="text-xs text-stone-500">
+              Creating character <strong className="text-stone-300">{selectedVariant.character.name}</strong>
+              {" "}({selectedVariant.character.class}, Lvl {selectedVariant.character.level}) with{" "}
+              {Object.keys(selectedVariant.items).length} equipped items.
+            </div>
+          </div>
+
+          {error && (
+            <div className="flex items-start gap-2 rounded-md border border-destructive/50 bg-destructive/10 px-3 py-2 text-sm text-destructive">
+              <AlertCircle size={15} className="mt-0.5 shrink-0" />
+              <span>{error}</span>
+            </div>
+          )}
+
+          <div className="flex gap-2">
+            <Button onClick={handleCommit} className="gap-2">
+              Confirm Import
+            </Button>
+            <Button variant="outline" onClick={() => setState("preview")}>
+              Cancel
+            </Button>
+          </div>
+        </div>
+      )}
+
+      {/* ── Committing state ── */}
+      {state === "committing" && (
+        <div className="flex items-center gap-3 text-sm text-stone-400">
+          <Loader2 size={16} className="animate-spin shrink-0" />
+          Saving character and build…
+        </div>
+      )}
+    </div>
+  );
+}
