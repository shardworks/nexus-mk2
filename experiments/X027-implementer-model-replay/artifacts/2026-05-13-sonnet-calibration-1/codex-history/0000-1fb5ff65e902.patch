@@ -0,0 +1,116 @@
+/**
+ * Maxroll planner importer — public entry point.
+ *
+ * Exports only importMaxrollPlanner (D3 patron override: no public helpers).
+ * All parser/fetcher/mapper modules remain private to this package.
+ *
+ * Usage:
+ *   import { importMaxrollPlanner } from "@/lib/import/maxroll";
+ *   const result = await importMaxrollPlanner("abc123", { fetch: customFetch });
+ */
+
+import { parseMaxrollInput } from "./parser";
+import { fetchPlannerProfile } from "./fetcher";
+import { loadDataMin } from "./data-min-cache";
+import { MaxrollProfileSchema } from "./payload-schema";
+import { mapProfile } from "./mapper";
+import type { ImportContext, ImportResult } from "./types";
+
+export type { ImportContext, ImportResult, MappedVariant, ImportReport, UnmappedRef } from "./types";
+
+/**
+ * Import a Maxroll planner by id, URL, or build-guide URL.
+ *
+ * Input shapes accepted:
+ *   - Bare planner id: "abc123def"
+ *   - Planner URL: "https://maxroll.gg/d4/planner/abc123def"
+ *   - Planner URL with variant hash: "https://maxroll.gg/d4/planner/abc123def#2&equipment"
+ *   - Build-guide URL: "https://maxroll.gg/d4/build-guides/my-build-guide"
+ *
+ * Returns an ImportResult discriminated union:
+ *   ok: true  — { plannerId, plannerName, variants: MappedVariant[] }
+ *   ok: false — { reason, message, details? }
+ *
+ * The result carries ALL variants from the planner. The server route
+ * (POST /api/import/maxroll/preview) returns all of them to the UI
+ * which lets the user pick one to commit.
+ */
+export async function importMaxrollPlanner(
+  input: string,
+  ctx: ImportContext = {}
+): Promise<ImportResult> {
+  const fetchFn = ctx.fetch ?? globalThis.fetch;
+  const now = ctx.now ?? (() => new Date());
+
+  // 1. Parse input → planner id
+  let parsedInput: Awaited<ReturnType<typeof parseMaxrollInput>>;
+  try {
+    parsedInput = await parseMaxrollInput(input, fetchFn);
+  } catch (err) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: err instanceof Error ? err.message : String(err),
+    };
+  }
+
+  const { plannerId } = parsedInput;
+
+  // 2. Fetch planner profile
+  let rawProfile: unknown;
+  try {
+    rawProfile = await fetchPlannerProfile(plannerId, fetchFn);
+  } catch (err) {
+    const code = (err as { code?: string }).code;
+    if (code === "not-found") {
+      return {
+        ok: false,
+        reason: "not-found",
+        message: `Maxroll planner not found: ${plannerId}`,
+      };
+    }
+    if (code === "private") {
+      return {
+        ok: false,
+        reason: "private",
+        message: `Maxroll planner is private: ${plannerId}`,
+      };
+    }
+    const isNetwork =
+      err instanceof Error &&
+      (err.message.includes("Network error") || err.message.includes("fetch"));
+    return {
+      ok: false,
+      reason: isNetwork ? "network" : "parse-error",
+      message: err instanceof Error ? err.message : String(err),
+    };
+  }
+
+  // 3. Validate profile schema
+  const profileResult = MaxrollProfileSchema.safeParse(rawProfile);
+  if (!profileResult.success) {
+    return {
+      ok: false,
+      reason: "parse-error",
+      message: `Maxroll profile did not match expected schema: ${profileResult.error.message}`,
+      details: profileResult.error.issues,
+    };
+  }
+  const profile = profileResult.data;
+
+  // 4. Load data.min.json (disk cache → network)
+  const patch = profile.patch ?? "unknown";
+  let datMin: Awaited<ReturnType<typeof loadDataMin>>;
+  try {
+    datMin = await loadDataMin(patch, ctx.cacheDir, fetchFn);
+  } catch (err) {
+    return {
+      ok: false,
+      reason: "network",
+      message: `Failed to load Maxroll data.min.json: ${err instanceof Error ? err.message : String(err)}`,
+    };
+  }
+
+  // 5. Map to canonical schemas
+  return mapProfile(profile, datMin, now());
+}
diff --git a/lib/import/maxroll/mapper.ts b/lib/import/maxroll/mapper.ts
