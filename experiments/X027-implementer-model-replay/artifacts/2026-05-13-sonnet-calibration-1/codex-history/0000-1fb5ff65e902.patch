diff --git a/__tests__/maxroll-import.test.ts b/__tests__/maxroll-import.test.ts
new file mode 100644
index 0000000..c9f09ca
--- /dev/null
+++ b/__tests__/maxroll-import.test.ts
@@ -0,0 +1,323 @@
+/**
+ * Acceptance tests for the Maxroll planner importer (D25).
+ *
+ * Hermetic fixture-based tests — no live network calls.
+ * ctx.fetch is overridden to serve checked-in fixture data.
+ *
+ * Three test cases:
+ *   1. ok:true result for a realistic planner fixture (AS1)
+ *   2. ok:false / patch-mismatch when patch differs AND explicit rate < 50% (AS4)
+ *   3. ok:true with versionMismatch warning when patch differs but rate >= 50% (AS4)
+ */
+
+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as path from "path";
+import * as fs from "fs";
+import * as os from "os";
+import { importMaxrollPlanner } from "../lib/import/maxroll";
+import { clearMemoryCache } from "../lib/import/maxroll/data-min-cache";
+
+/** Unique temp dir for disk-cache isolation — created fresh before each test. */
+let testCacheDir: string;
+
+// ─── Fixture loading ──────────────────────────────────────────────────────
+
+const FIXTURE_DIR = path.join(__dirname, "fixtures");
+
+function loadFixture(filename: string): unknown {
+  const raw = fs.readFileSync(path.join(FIXTURE_DIR, filename), "utf-8");
+  return JSON.parse(raw);
+}
+
+const plannerFixture = loadFixture("maxroll-planner-fixture.json");
+const dataMinSubset = loadFixture("maxroll-data-min-subset.json");
+
+/** A data.min subset with a different patch version but the same good coverage. */
+const dataMinDriftAboveThreshold = {
+  ...(dataMinSubset as Record<string, unknown>),
+  version: "99.0.0", // differs from catalog patch AND fixture patch
+};
+
+/**
+ * A data.min subset with a different patch version and NO valid bnetFileNames
+ * (all affixes map to unknown entries → 0% explicit mapping rate).
+ */
+const dataMinDriftBelowThreshold = {
+  version: "99.0.0",
+  affixes: {
+    "1001": { bnetFileName: "Unknown_Affix_A" },
+    "1002": { bnetFileName: "Unknown_Affix_B" },
+    "1003": { bnetFileName: "Unknown_Affix_C" },
+    "1004": { bnetFileName: "Unknown_Affix_D" },
+    "1005": { bnetFileName: "Unknown_Affix_E" },
+    "1006": { bnetFileName: "Unknown_Affix_F" },
+    "1007": { bnetFileName: "Unknown_Affix_G" },
+  },
+  aspects: {},
+  skills: {},
+  paragonBoards: {},
+  paragonGlyphs: {},
+  items: {},
+};
+
+// ─── Fixture fetch helper ──────────────────────────────────────────────────
+
+/**
+ * Create a mock fetch function that serves fixture data.
+ *
+ * - planners.maxroll.gg/profiles/load → planner fixture
+ * - assets-ng.maxroll.gg/d4planner/data.min.json → data.min fixture
+ * - anything else → 404
+ */
+function makeMockFetch(
+  plannerData: unknown,
+  dataMinData: unknown
+): typeof globalThis.fetch {
+  return async (input: RequestInfo | URL): Promise<Response> => {
+    const url = typeof input === "string" ? input : input.toString();
+    if (url.includes("/profiles/load")) {
+      return new Response(JSON.stringify(plannerData), {
+        status: 200,
+        headers: { "Content-Type": "application/json" },
+      });
+    }
+    if (url.includes("data.min.json")) {
+      return new Response(JSON.stringify(dataMinData), {
+        status: 200,
+        headers: { "Content-Type": "application/json" },
+      });
+    }
+    // build-guide redirect fallback
+    if (url.includes("maxroll.gg")) {
+      return new Response(
+        `<html><a href="/d4/planner/sorc-blizzard-fixture">view planner</a></html>`,
+        { status: 200 }
+      );
+    }
+    return new Response("Not Found", { status: 404 });
+  };
+}
+
+// ─── Setup / Teardown ─────────────────────────────────────────────────────
+
+beforeEach(() => {
+  // Fresh isolated temp dir per test — prevents disk-cache cross-contamination
+  testCacheDir = fs.mkdtempSync(path.join(os.tmpdir(), "maxroll-test-"));
+});
+
+afterEach(() => {
+  // Clear in-memory cache so each test starts with a clean slate
+  clearMemoryCache();
+  // Clean up temp dir
+  try {
+    fs.rmSync(testCacheDir, { recursive: true, force: true });
+  } catch {
+    // Ignore cleanup errors
+  }
+});
+
+// ─── Test 1: happy path ───────────────────────────────────────────────────
+
+describe("importMaxrollPlanner — happy path (AS1)", () => {
+  it("returns ok:true with non-empty equippedItems, class, paragonAllocation, mapped aspect, and mapped glyph", async () => {
+    const result = await importMaxrollPlanner("sorc-blizzard-fixture", {
+      fetch: makeMockFetch(plannerFixture, dataMinSubset),
+      cacheDir: testCacheDir,
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return; // narrow type
+
+    // Has variants
+    expect(result.variants.length).toBeGreaterThanOrEqual(1);
+
+    const v = result.variants[0];
+
+    // Class is set
+    expect(v.character.class).toBe("Sorcerer");
+
+    // Level is set (should be 100 from fixture)
+    expect(v.character.level).toBe(100);
+
+    // Non-empty equippedItems
+    expect(Object.keys(v.items).length).toBeGreaterThan(0);
+    expect(v.items).toHaveProperty("helm");
+
+    // ParagonAllocation populated
+    expect(v.character.paragonAllocation.paragonLevel).toBeGreaterThan(0);
+    expect(v.character.paragonAllocation.boards.length).toBeGreaterThan(0);
+
+    // At least one mapped aspect
+    const helmItem = v.items["helm"];
+    expect(helmItem).toBeDefined();
+    expect(helmItem.aspect).toBeDefined();
+    expect(helmItem.aspect?.aspectId).toBe("aspect_of_frozen_orbit");
+
+    // At least one mapped paragon glyph
+    const board = v.character.paragonAllocation.boards[0];
+    expect(board.glyph).toBeDefined();
+    expect(board.glyph?.glyphId).toBe("glyph_cold_calc");
+    expect(board.glyph?.level).toBe(21);
+
+    // Paragon nodes stored with mr: prefix (D17)
+    expect(board.nodes[0]).toMatch(/^mr:\d+$/);
+
+    // spentPoints = nodes.length (D17)
+    expect(board.spentPoints).toBe(board.nodes.length);
+  });
+
+  it("resolves all four input shapes", async () => {
+    const mockFetch = makeMockFetch(plannerFixture, dataMinSubset);
+    const ctx = { fetch: mockFetch, cacheDir: testCacheDir };
+
+    const bareId = await importMaxrollPlanner("sorc-blizzard-fixture", ctx);
+    expect(bareId.ok).toBe(true);
+
+    const plannerUrl = await importMaxrollPlanner(
+      "https://maxroll.gg/d4/planner/sorc-blizzard-fixture",
+      ctx
+    );
+    expect(plannerUrl.ok).toBe(true);
+
+    const plannerUrlWithHash = await importMaxrollPlanner(
+      "https://maxroll.gg/d4/planner/sorc-blizzard-fixture#1&equipment",
+      ctx
+    );
+    expect(plannerUrlWithHash.ok).toBe(true);
+
+    const buildGuideUrl = await importMaxrollPlanner(
+      "https://maxroll.gg/d4/build-guides/my-cool-sorcerer-guide",
+      ctx
+    );
+    expect(buildGuideUrl.ok).toBe(true);
+  });
+
+  it("routes implicit affixes into implicits[], tempered-unmapped into unmapped report", async () => {
+    const result = await importMaxrollPlanner("sorc-blizzard-fixture", {
+      fetch: makeMockFetch(plannerFixture, dataMinSubset),
+      cacheDir: testCacheDir,
+    });
+    if (!result.ok) throw new Error("Expected ok:true");
+
+    const v = result.variants[0];
+
+    // helm has Barrier_Strength_Percent (isImplicit:true) → should land in implicits
+    const helm = v.items["helm"];
+    expect(helm).toBeDefined();
+    const hasImplicit = helm.implicits.some((a) => a.affixId === "affix_implicit_barrier_offhand");
+    expect(hasImplicit).toBe(true);
+
+    // gloves has nid 9999 (no data.min entry) with tempered:true → unmapped
+    const report = v.report;
+    const unmappedTempered = report.unmappedAffixes.find(
+      (a) => a.category === "affix" && a.nid === 9999
+    );
+    expect(unmappedTempered).toBeDefined();
+  });
+
+  it("reports are never empty for known unmapped references", async () => {
+    const result = await importMaxrollPlanner("sorc-blizzard-fixture", {
+      fetch: makeMockFetch(plannerFixture, dataMinSubset),
+      cacheDir: testCacheDir,
+    });
+    if (!result.ok) throw new Error("Expected ok:true");
+
+    const v = result.variants[0];
+    const report = v.report;
+
+    // nid 9999 has no data.min entry → should appear in unmappedAffixes
+    expect(report.unmappedAffixes.some((a) => a.nid === 9999)).toBe(true);
+
+    // No version mismatch in this case (patches match)
+    expect(report.versionMismatch).toBeUndefined();
+  });
+
+  it("maps skills into skillSelections", async () => {
+    const result = await importMaxrollPlanner("sorc-blizzard-fixture", {
+      fetch: makeMockFetch(plannerFixture, dataMinSubset),
+      cacheDir: testCacheDir,
+    });
+    if (!result.ok) throw new Error("Expected ok:true");
+
+    const v = result.variants[0];
+    const skills = v.character.skillSelections;
+    expect(skills.length).toBeGreaterThan(0);
+    const blizzard = skills.find((s) => s.skillId === "sorc_blizzard");
+    expect(blizzard).toBeDefined();
+    expect(blizzard?.rank).toBe(5);
+  });
+
+  it("sets buildProvenance correctly", async () => {
+    const fixedDate = new Date("2026-05-13T00:00:00.000Z");
+    const result = await importMaxrollPlanner("sorc-blizzard-fixture", {
+      fetch: makeMockFetch(plannerFixture, dataMinSubset),
+      cacheDir: testCacheDir,
+      now: () => fixedDate,
+    });
+    if (!result.ok) throw new Error("Expected ok:true");
+
+    const provenance = result.variants[0].buildProvenance;
+    expect(provenance.source).toBe("maxroll");
+    expect(provenance.plannerId).toBe("sorc-blizzard-fixture");
+    expect(provenance.variantIndex).toBe(0);
+    expect(provenance.importedAt).toBe("2026-05-13T00:00:00.000Z");
+    expect(provenance.plannerVersion).toBe("3.0.1.71747");
+  });
+});
+
+// ─── Test 2: patch-mismatch fail (AS4) ───────────────────────────────────
+
+describe("importMaxrollPlanner — patch-mismatch fail (AS4)", () => {
+  it("returns ok:false with reason patch-mismatch when patch differs AND explicit rate < 50%", async () => {
+    const result = await importMaxrollPlanner("sorc-blizzard-fixture", {
+      fetch: makeMockFetch(plannerFixture, dataMinDriftBelowThreshold),
+      cacheDir: testCacheDir,
+    });
+
+    expect(result.ok).toBe(false);
+    if (result.ok) return;
+    expect(result.reason).toBe("patch-mismatch");
+    expect(result.message).toMatch(/patch|version.*differs|differs.*version/i);
+  });
+});
+
+// ─── Test 3: patch drift but above threshold (AS4) ───────────────────────
+
+describe("importMaxrollPlanner — patch drift above threshold (AS4)", () => {
+  it("returns ok:true with versionMismatch warning when patch differs but mapping rate >= 50%", async () => {
+    const result = await importMaxrollPlanner("sorc-blizzard-fixture", {
+      fetch: makeMockFetch(plannerFixture, dataMinDriftAboveThreshold),
+      cacheDir: testCacheDir,
+    });
+
+    expect(result.ok).toBe(true);
+    if (!result.ok) return;
+
+    // At least one variant should have a versionMismatch warning
+    const hasWarning = result.variants.some((v) => v.report.versionMismatch !== undefined);
+    expect(hasWarning).toBe(true);
+
+    const withWarning = result.variants.find((v) => v.report.versionMismatch !== undefined);
+    expect(withWarning?.report.versionMismatch?.catalogPatch).toBeTruthy();
+    expect(withWarning?.report.versionMismatch?.maxrollPatch).toBe("99.0.0");
+    expect(withWarning?.report.versionMismatch?.explicitMappingRate).toBeGreaterThanOrEqual(0.5);
+  });
+});
+
+// ─── Test 4: not-found handling ───────────────────────────────────────────
+
+describe("importMaxrollPlanner — error handling", () => {
+  it("returns ok:false with reason not-found for 404 response", async () => {
+    const fetch404: typeof globalThis.fetch = async () =>
+      new Response("Not Found", { status: 404 });
+
+    const result = await importMaxrollPlanner("nonexistent-planner", {
+      fetch: fetch404,
+      cacheDir: testCacheDir,
+    });
+
+    expect(result.ok).toBe(false);
+    if (result.ok) return;
+    expect(result.reason).toBe("not-found");
+  });
+});
