@@ -0,0 +1,108 @@
+/**
+ * HTTP client for Maxroll planner API and data assets (D6).
+ *
+ * Two env-var overrides following lib/triage/anthropic.ts pattern:
+ *   MAXROLL_PLANNER_API_BASE  — default https://planners.maxroll.gg
+ *   MAXROLL_DATA_BASE         — default https://assets-ng.maxroll.gg
+ *
+ * Native fetch only, no SDK dependency. Fails loud on non-2xx responses.
+ */
+
+/**
+ * Returns the base URL for the Maxroll planner API.
+ * Override via MAXROLL_PLANNER_API_BASE for testing.
+ */
+export function getMaxrollPlannerApiBase(): string {
+  const override = process.env.MAXROLL_PLANNER_API_BASE;
+  if (override && override.length > 0) return override.replace(/\/$/, "");
+  return "https://planners.maxroll.gg";
+}
+
+/**
+ * Returns the base URL for Maxroll data assets (data.min.json).
+ * Override via MAXROLL_DATA_BASE for testing.
+ */
+export function getMaxrollDataBase(): string {
+  const override = process.env.MAXROLL_DATA_BASE;
+  if (override && override.length > 0) return override.replace(/\/$/, "");
+  return "https://assets-ng.maxroll.gg";
+}
+
+/**
+ * Fetch the Maxroll planner profile for a given planner id.
+ * Returns the raw JSON body (unparsed — validation happens in payload-schema.ts).
+ */
+export async function fetchPlannerProfile(
+  plannerId: string,
+  fetchFn: typeof globalThis.fetch = globalThis.fetch
+): Promise<unknown> {
+  const base = getMaxrollPlannerApiBase();
+  const url = `${base}/profiles/load?profileId=${encodeURIComponent(plannerId)}`;
+
+  let res: Response;
+  try {
+    res = await fetchFn(url, {
+      headers: { Accept: "application/json" },
+    });
+  } catch (err) {
+    throw new Error(
+      `Network error fetching Maxroll profile ${plannerId}: ${err instanceof Error ? err.message : String(err)}`
+    );
+  }
+
+  if (res.status === 404) {
+    const err = new Error(`Maxroll planner not found: ${plannerId}`);
+    (err as Error & { code: string }).code = "not-found";
+    throw err;
+  }
+
+  if (res.status === 403 || res.status === 401) {
+    const err = new Error(`Maxroll planner is private: ${plannerId}`);
+    (err as Error & { code: string }).code = "private";
+    throw err;
+  }
+
+  if (!res.ok) {
+    throw new Error(
+      `Maxroll profile fetch failed with HTTP ${res.status} for planner: ${plannerId}`
+    );
+  }
+
+  try {
+    return await res.json();
+  } catch {
+    throw new Error(`Maxroll profile response was not valid JSON for planner: ${plannerId}`);
+  }
+}
+
+/**
+ * Fetch the Maxroll data.min.json game-data file.
+ * This is a large file (~11MB) — callers should cache aggressively.
+ */
+export async function fetchDataMin(
+  fetchFn: typeof globalThis.fetch = globalThis.fetch
+): Promise<unknown> {
+  const base = getMaxrollDataBase();
+  const url = `${base}/d4planner/data.min.json`;
+
+  let res: Response;
+  try {
+    res = await fetchFn(url, {
+      headers: { Accept: "application/json" },
+    });
+  } catch (err) {
+    throw new Error(
+      `Network error fetching Maxroll data.min.json: ${err instanceof Error ? err.message : String(err)}`
+    );
+  }
+
+  if (!res.ok) {
+    throw new Error(`Maxroll data.min.json fetch failed with HTTP ${res.status}`);
+  }
+
+  try {
+    return await res.json();
+  } catch {
+    throw new Error("Maxroll data.min.json response was not valid JSON");
+  }
+}
diff --git a/lib/import/maxroll/index.ts b/lib/import/maxroll/index.ts
