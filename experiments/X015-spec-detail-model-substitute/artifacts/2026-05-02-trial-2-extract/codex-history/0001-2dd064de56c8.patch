diff --git a/packages/plugins/clerk/src/testing.ts b/packages/plugins/clerk/src/testing.ts
new file mode 100644
index 0000000..07d2fa0
--- /dev/null
+++ b/packages/plugins/clerk/src/testing.ts
@@ -0,0 +1,37 @@
+/**
+ * Test helpers for the Clerk apparatus.
+ *
+ * These helpers are intended for use in tests that need to register writ types
+ * with the Clerk. They mirror the production path (a plugin apparatus calling
+ * `registerWritType` in its own `start()`), so that ordering bugs the framework
+ * would catch stay caught in tests.
+ *
+ * Usage:
+ *   const fixture = makeWritTypeApparatus([ERRAND_CONFIG, TASK_CONFIG]);
+ *   fixture.start(); // call after clerk.start() but before phase:started seals
+ */
+
+import { guild } from '@shardworks/nexus-core';
+import type { WritTypeConfig } from './writ-type-config.ts';
+import type { ClerkApi } from './types.ts';
+
+/**
+ * Creates a minimal apparatus-like object whose `start()` method registers
+ * the given writ types with the Clerk via `guild().apparatus<ClerkApi>('clerk')`.
+ *
+ * This mirrors the production path (e.g. astrolabe's `start()` calls
+ * `registerWritType`), so ordering bugs the framework would catch stay
+ * caught in tests.
+ */
+export function makeWritTypeApparatus(types: WritTypeConfig[]): {
+  start(): void;
+} {
+  return {
+    start(): void {
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+      for (const config of types) {
+        clerk.registerWritType(config);
+      }
+    },
+  };
+}
