+## Registering a Writ Type
+
+Any apparatus plugin can register a custom writ type during its `start()` call:
+
+```typescript
+import { validateWritTypeConfig, type WritTypeConfig } from '@shardworks/clerk-apparatus';
+import type { ClerkApi } from '@shardworks/clerk-apparatus';
+
+const EPIC_CONFIG: WritTypeConfig = {
+  name: 'epic',
+  states: [
+    { name: 'new',       classification: 'initial',  allowedTransitions: ['in-progress', 'cancelled'] },
+    { name: 'in-progress', classification: 'active', allowedTransitions: ['done', 'failed', 'cancelled'] },
+    { name: 'done',      classification: 'terminal', attrs: ['success'],   allowedTransitions: [] },
+    { name: 'failed',    classification: 'terminal', attrs: ['failure'],   allowedTransitions: [] },
+    { name: 'cancelled', classification: 'terminal', attrs: ['cancelled'], allowedTransitions: [] },
+  ],
+};
+
+// In your apparatus plugin's start():
+async start(ctx) {
+  const clerk = guild().apparatus<ClerkApi>('clerk');
+  clerk.registerWritType(EPIC_CONFIG);
 }
 ```
 
