+      start?: (ctx: unknown) => void | Promise<void>;
+    });
+    if (typeof apparatus.start === 'function') {
+      await apparatus.start({ on: () => {}, kits: () => [] });
+    }
+  }
+
   return clerkPlugin;
 }
 
