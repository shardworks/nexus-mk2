+/**
+ * animator-status tool — show current Animator rate-limit status.
+ *
+ * Returns the AnimatorStatusDoc: state (running | paused), pausedUntil,
+ * backoffLevel, and related metadata. Callers use this to determine whether
+ * new sessions will be dispatched or held until the back-off window clears.
+ *
+ * See: docs/architecture/apparatus/animator.md
+ */
+
+import { tool } from '@shardworks/tools-apparatus';
+import { guild } from '@shardworks/nexus-core';
+import type { AnimatorApi } from '../types.ts';
+
+export default tool({
+  name: 'animator-status',
+  description: 'Show current Animator rate-limit status',
+  instructions:
+    'Returns the Animator\'s current dispatch state. When state is "paused" ' +
+    'the Animator is in a rate-limit back-off window and no new sessions will ' +
+    'be launched until pausedUntil elapses. backoffLevel indicates how many ' +
+    'consecutive rate-limit hits have occurred (resets to 0 after a clean run).',
+  params: {},
+  permission: 'read',
+  handler: async () => {
+    const animator = guild().apparatus<AnimatorApi>('animator');
+    return animator.getStatus();
+  },
+});
