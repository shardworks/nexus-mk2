+/**
+ * Built-in block type: animator-paused.
+ *
+ * Blocks an engine while the Animator is within a rate-limit back-off window.
+ * Clears when:
+ *   - Animator state is 'running', OR
+ *   - Animator state is 'paused' but pausedUntil <= now (window has elapsed)
+ *
+ * Condition: {} (empty — the block type carries no per-engine payload;
+ * the Animator status doc is the single source of truth)
+ *
+ * See: docs/architecture/apparatus/animator.md
+ */
+
+import { z } from 'zod';
+import { guild } from '@shardworks/nexus-core';
+import type { AnimatorApi } from '@shardworks/animator-apparatus';
+import type { BlockType, CheckResult } from '../types.ts';
+
+const conditionSchema = z.object({});
+
+const animatorPausedBlockType: BlockType = {
+  id: 'animator-paused',
+  conditionSchema,
+  pollIntervalMs: 30_000,
+  async check(_condition: unknown): Promise<CheckResult> {
+    let animatorApi: AnimatorApi;
+    try {
+      animatorApi = guild().apparatus<AnimatorApi>('animator');
+    } catch {
+      // Animator not installed — treat as cleared so the engine doesn't
+      // get stuck forever in environments without the Animator.
+      return { status: 'cleared' };
+    }
+
+    const status = await animatorApi.getStatus();
+
+    if (status.state === 'running') {
+      return { status: 'cleared' };
+    }
+
+    // Paused: check if the window has elapsed (natural probe semantic).
+    if (status.pausedUntil && new Date(status.pausedUntil).getTime() <= Date.now()) {
+      return { status: 'cleared' };
+    }
+
+    return { status: 'pending' };
+  },
+};
+
+export default animatorPausedBlockType;
