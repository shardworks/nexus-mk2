+  // ── Animator pause banner ──────────────────────────────────────────────
+
+  /**
+   * Fetch /api/animator/status and show or hide the pause banner.
+   * Called on page load and every ANIMATOR_STATUS_POLL_INTERVAL ms.
+   * Errors are silently swallowed — if the Animator apparatus is not
+   * installed the banner stays hidden.
+   */
+  function fetchAnimatorStatus() {
+    fetch('/api/animator/status')
+      .then(function (r) {
+        if (!r.ok) return null;
+        return r.json();
+      })
+      .then(function (status) {
+        updatePauseBanner(status);
+      })
+      .catch(function () {
+        // Animator not installed or network error — keep banner hidden
+        updatePauseBanner(null);
+      });
+  }
+
+  /**
+   * Show or hide the pause banner based on the Animator status doc.
+   * @param {object|null} status - AnimatorStatusDoc or null
+   */
+  function updatePauseBanner(status) {
+    var banner = document.getElementById('pause-banner');
+    if (!banner) return;
+
+    var isPaused = status &&
+      status.state === 'paused' &&
+      (!status.pausedUntil || new Date(status.pausedUntil).getTime() > Date.now());
+
+    if (!isPaused) {
+      banner.style.display = 'none';
+      return;
+    }
+
+    banner.style.display = '';
+
+    // Update "resumes at" suffix if we know when the pause lifts
+    var untilEl = document.getElementById('pause-banner__until');
+    if (untilEl) {
+      if (status.pausedUntil) {
+        untilEl.textContent = ' Resumes at: ' + formatDate(status.pausedUntil) + '.';
+      } else {
+        untilEl.textContent = '';
+      }
+    }
+  }
+
+  function stopAnimatorStatusPoll() {
+    if (animatorStatusPollTimer !== null) {
+      clearInterval(animatorStatusPollTimer);
+      animatorStatusPollTimer = null;
+    }
+  }
+
+  function startAnimatorStatusPoll() {
+    stopAnimatorStatusPoll();
+    animatorStatusPollTimer = setInterval(fetchAnimatorStatus, ANIMATOR_STATUS_POLL_INTERVAL);
+  }
