+        packageName: '@test/plugin-a',
+        type: 'petitioners',
+        value: [{ source: 'plugin-a.event', description: 'First.' }],
+      },
+      {
+        pluginId: 'plugin-a',
+        packageName: '@test/plugin-a-copy',
+        type: 'petitioners',
+        value: [{ source: 'plugin-a.event', description: 'Duplicate.' }],
+      },
