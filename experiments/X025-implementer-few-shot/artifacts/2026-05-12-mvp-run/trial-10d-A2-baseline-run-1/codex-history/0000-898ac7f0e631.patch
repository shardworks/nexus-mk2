+/**
+ * Priority helpers — default-filling and schema validation.
+ *
+ * See: docs/architecture/petitioner-registration.md §3
+ */
+
+import type { Priority, DomainTag } from './types.ts';
+
+// ── Valid value sets ───────────────────────────────────────────────────
+
+const VALID_VISION_RELATIONS = [
+  'vision-blocker',
+  'vision-violator',
+  'vision-advancer',
+  'vision-neutral',
+] as const satisfies readonly Priority['visionRelation'][];
+
+const VALID_SEVERITIES = [
+  'critical',
+  'serious',
+  'moderate',
+  'minor',
+] as const satisfies readonly Priority['severity'][];
+
+const VALID_SCOPES = [
+  'whole-product',
+  'major-area',
+  'minor-area',
+] as const satisfies readonly Priority['scope'][];
+
+const VALID_DOMAIN_TAGS: readonly DomainTag[] = [
+  'security',
+  'compliance',
+  'cost',
+  'feature',
+  'quality',
+  'infrastructure',
+  'documentation',
+  'research',
+  'ergonomics',
+];
+
+// ── Defaults ───────────────────────────────────────────────────────────
+
+/**
+ * Return the default `Priority` applied when dimensions are omitted.
+ *
+ * Defaults (per contract §3):
+ *   - visionRelation: `vision-neutral`
+ *   - severity:       `minor`
+ *   - scope:          `minor-area`
+ *   - time:           `{ decay: false, deadline: null }`
+ *   - domain:         `[]`
+ */
+export function defaultPriority(): Priority {
+  return {
+    visionRelation: 'vision-neutral',
+    severity: 'minor',
+    scope: 'minor-area',
+    time: { decay: false, deadline: null },
+    domain: [],
+  };
+}
+
+/**
+ * Return a fully-populated `Priority` by filling any omitted dimensions
+ * with the contract defaults.
+ *
+ * The `time` sub-object is treated atomically — if `partial.time` is
+ * present, it is used as-is; if absent, the default `{decay:false,
+ * deadline:null}` is applied. Partial `time` sub-objects (e.g. only
+ * `decay` specified) are not merged — pass the full `time` object to
+ * avoid surprises.
+ */
+export function applyPriorityDefaults(partial?: Partial<Priority>): Priority {
+  const defaults = defaultPriority();
+  if (!partial) return defaults;
+
+  return {
+    visionRelation: partial.visionRelation ?? defaults.visionRelation,
+    severity: partial.severity ?? defaults.severity,
+    scope: partial.scope ?? defaults.scope,
+    time: partial.time ?? defaults.time,
+    domain: partial.domain ?? defaults.domain,
+  };
+}
+
+// ── Validation ─────────────────────────────────────────────────────────
+
+/**
+ * Validate a fully-resolved `Priority` object against the schema.
+ *
+ * Throws a descriptive `[reckoner]`-prefixed error if any dimension value
+ * is outside the allowed set. Intended to be called after
+ * `applyPriorityDefaults()` so all fields are guaranteed present.
+ */
+export function validatePriority(priority: Priority): void {
+  if (!(VALID_VISION_RELATIONS as readonly string[]).includes(priority.visionRelation)) {
+    throw new Error(
+      `[reckoner] Invalid priority.visionRelation "${priority.visionRelation}". ` +
+      `Must be one of: ${VALID_VISION_RELATIONS.join(', ')}.`,
+    );
+  }
+
+  if (!(VALID_SEVERITIES as readonly string[]).includes(priority.severity)) {
+    throw new Error(
+      `[reckoner] Invalid priority.severity "${priority.severity}". ` +
+      `Must be one of: ${VALID_SEVERITIES.join(', ')}.`,
+    );
+  }
+
+  if (!(VALID_SCOPES as readonly string[]).includes(priority.scope)) {
+    throw new Error(
+      `[reckoner] Invalid priority.scope "${priority.scope}". ` +
+      `Must be one of: ${VALID_SCOPES.join(', ')}.`,
+    );
+  }
+
+  if (!priority.time || typeof priority.time.decay !== 'boolean') {
+    throw new Error(
+      `[reckoner] Invalid priority.time.decay: must be a boolean ` +
+      `(got ${JSON.stringify(priority.time?.decay)}).`,
+    );
+  }
+
+  if (priority.time.deadline !== null && typeof priority.time.deadline !== 'string') {
+    throw new Error(
+      `[reckoner] Invalid priority.time.deadline: must be an ISO date string or null ` +
+      `(got ${JSON.stringify(priority.time.deadline)}).`,
+    );
+  }
+
+  if (!Array.isArray(priority.domain)) {
+    throw new Error(
+      `[reckoner] Invalid priority.domain: must be an array ` +
+      `(got ${JSON.stringify(priority.domain)}).`,
+    );
+  }
+
+  for (const tag of priority.domain) {
+    if (!(VALID_DOMAIN_TAGS as readonly string[]).includes(tag)) {
+      throw new Error(
+        `[reckoner] Invalid priority.domain tag "${tag}". ` +
+        `Must be one of: ${VALID_DOMAIN_TAGS.join(', ')}.`,
+      );
+    }
+  }
+}
