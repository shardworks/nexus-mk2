+/**
+ * priority.ts — unit tests.
+ *
+ * Covers: `defaultPriority`, `applyPriorityDefaults`, `validatePriority`.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+import {
+  defaultPriority,
+  applyPriorityDefaults,
+  validatePriority,
+} from './priority.ts';
+import type { Priority } from './types.ts';
+
+// ── defaultPriority ───────────────────────────────────────────────────
+
+describe('defaultPriority', () => {
+  it('returns the contract-specified defaults', () => {
+    const d = defaultPriority();
+    assert.equal(d.visionRelation, 'vision-neutral');
+    assert.equal(d.severity, 'minor');
+    assert.equal(d.scope, 'minor-area');
+    assert.equal(d.time.decay, false);
+    assert.equal(d.time.deadline, null);
+    assert.deepEqual(d.domain, []);
+  });
+
+  it('returns a new object on each call (not a singleton)', () => {
+    const a = defaultPriority();
+    const b = defaultPriority();
+    assert.notEqual(a, b);
+    // Mutating one should not affect the other
+    a.domain.push('security');
+    assert.deepEqual(b.domain, []);
+  });
+});
+
+// ── applyPriorityDefaults ─────────────────────────────────────────────
+
+describe('applyPriorityDefaults', () => {
+  it('returns full defaults when called with no argument', () => {
+    const p = applyPriorityDefaults();
+    assert.deepEqual(p, defaultPriority());
+  });
+
+  it('returns full defaults when called with undefined', () => {
+    const p = applyPriorityDefaults(undefined);
+    assert.deepEqual(p, defaultPriority());
+  });
+
+  it('returns full defaults when called with empty object', () => {
+    const p = applyPriorityDefaults({});
+    assert.deepEqual(p, defaultPriority());
+  });
+
+  it('preserves a supplied visionRelation, fills the rest with defaults', () => {
+    const p = applyPriorityDefaults({ visionRelation: 'vision-violator' });
+    assert.equal(p.visionRelation, 'vision-violator');
+    assert.equal(p.severity, 'minor');
+    assert.equal(p.scope, 'minor-area');
+    assert.equal(p.time.decay, false);
+    assert.equal(p.time.deadline, null);
+    assert.deepEqual(p.domain, []);
+  });
+
+  it('preserves a supplied severity', () => {
+    const p = applyPriorityDefaults({ severity: 'critical' });
+    assert.equal(p.severity, 'critical');
+    assert.equal(p.visionRelation, 'vision-neutral');
+  });
+
+  it('preserves a supplied scope', () => {
+    const p = applyPriorityDefaults({ scope: 'whole-product' });
+    assert.equal(p.scope, 'whole-product');
+  });
+
+  it('preserves a supplied time object', () => {
+    const p = applyPriorityDefaults({ time: { decay: true, deadline: '2025-06-01' } });
+    assert.equal(p.time.decay, true);
+    assert.equal(p.time.deadline, '2025-06-01');
+  });
+
+  it('preserves a supplied domain array', () => {
+    const p = applyPriorityDefaults({ domain: ['security', 'quality'] });
+    assert.deepEqual(p.domain, ['security', 'quality']);
+  });
+
+  it('preserves all supplied dimensions (no defaults applied when all provided)', () => {
+    const full: Priority = {
+      visionRelation: 'vision-blocker',
+      severity: 'critical',
+      scope: 'whole-product',
+      time: { decay: true, deadline: '2025-12-31' },
+      domain: ['security', 'compliance'],
+    };
+    const p = applyPriorityDefaults(full);
+    assert.deepEqual(p, full);
+  });
+
+  it('matches the behavioral case from the spec: partial priority with visionRelation only', () => {
+    // From commission spec behavioral case:
+    // reckoner.petition({ priority: { visionRelation: 'vision-violator' } })
+    // → omitted dimensions fall back to defaults
+    const p = applyPriorityDefaults({ visionRelation: 'vision-violator' });
+    assert.equal(p.visionRelation, 'vision-violator');
+    assert.equal(p.severity, 'minor');
+    assert.equal(p.scope, 'minor-area');
+    assert.equal(p.time.decay, false);
+    assert.equal(p.time.deadline, null);
+    assert.deepEqual(p.domain, []);
+  });
+});
+
+// ── validatePriority ──────────────────────────────────────────────────
+
+describe('validatePriority', () => {
+  it('accepts a fully valid priority (the defaults)', () => {
+    assert.doesNotThrow(() => validatePriority(defaultPriority()));
+  });
+
+  it('accepts all valid visionRelation values', () => {
+    const values = ['vision-blocker', 'vision-violator', 'vision-advancer', 'vision-neutral'] as const;
+    for (const v of values) {
+      assert.doesNotThrow(() =>
+        validatePriority({ ...defaultPriority(), visionRelation: v }),
+      );
+    }
+  });
+
+  it('accepts all valid severity values', () => {
+    const values = ['critical', 'serious', 'moderate', 'minor'] as const;
+    for (const v of values) {
+      assert.doesNotThrow(() =>
+        validatePriority({ ...defaultPriority(), severity: v }),
+      );
+    }
+  });
+
+  it('accepts all valid scope values', () => {
+    const values = ['whole-product', 'major-area', 'minor-area'] as const;
+    for (const v of values) {
+      assert.doesNotThrow(() =>
+        validatePriority({ ...defaultPriority(), scope: v }),
+      );
+    }
+  });
+
+  it('accepts all valid domain tags', () => {
+    const tags = [
+      'security', 'compliance', 'cost', 'feature', 'quality',
+      'infrastructure', 'documentation', 'research', 'ergonomics',
+    ] as const;
+    assert.doesNotThrow(() =>
+      validatePriority({ ...defaultPriority(), domain: [...tags] }),
+    );
+  });
+
+  it('accepts time with decay: true', () => {
+    assert.doesNotThrow(() =>
+      validatePriority({ ...defaultPriority(), time: { decay: true, deadline: null } }),
+    );
+  });
+
+  it('accepts time with a deadline string', () => {
+    assert.doesNotThrow(() =>
+      validatePriority({ ...defaultPriority(), time: { decay: false, deadline: '2025-06-01' } }),
+    );
+  });
+
+  // ── Invalid values ─────────────────────────────────────────────────
+
+  it('throws for invalid visionRelation', () => {
+    assert.throws(
+      () =>
+        validatePriority({
+          ...defaultPriority(),
+          visionRelation: 'vision-unrelated' as Priority['visionRelation'],
+        }),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('visionRelation'));
+        assert.ok(err.message.includes('vision-unrelated'));
+        return true;
+      },
+    );
+  });
+
+  it('throws for invalid severity', () => {
+    assert.throws(
+      () =>
+        validatePriority({
+          ...defaultPriority(),
+          severity: 'urgent' as Priority['severity'],
+        }),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('severity'));
+        return true;
+      },
+    );
+  });
+
+  it('throws for invalid scope', () => {
+    assert.throws(
+      () =>
+        validatePriority({
+          ...defaultPriority(),
+          scope: 'everywhere' as Priority['scope'],
+        }),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('scope'));
+        return true;
+      },
+    );
+  });
+
+  it('throws for non-boolean time.decay', () => {
+    assert.throws(
+      () =>
+        validatePriority({
+          ...defaultPriority(),
+          time: { decay: 'yes' as unknown as boolean, deadline: null },
+        }),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('decay'));
+        return true;
+      },
+    );
+  });
+
+  it('throws for non-null non-string time.deadline', () => {
+    assert.throws(
+      () =>
+        validatePriority({
+          ...defaultPriority(),
+          time: { decay: false, deadline: 42 as unknown as string },
+        }),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('deadline'));
+        return true;
+      },
+    );
+  });
+
+  it('throws for a non-array domain', () => {
+    assert.throws(
+      () =>
+        validatePriority({
+          ...defaultPriority(),
+          domain: 'security' as unknown as Priority['domain'],
+        }),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('domain'));
+        return true;
+      },
+    );
+  });
+
+  it('throws for an invalid domain tag', () => {
+    assert.throws(
+      () =>
+        validatePriority({
+          ...defaultPriority(),
+          domain: ['security', 'unknown-tag'] as Priority['domain'],
+        }),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('domain'));
+        assert.ok(err.message.includes('unknown-tag'));
+        return true;
+      },
+    );
+  });
+});
