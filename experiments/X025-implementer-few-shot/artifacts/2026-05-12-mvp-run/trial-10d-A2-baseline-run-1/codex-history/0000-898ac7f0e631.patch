diff --git a/packages/plugins/reckoner/src/reckoner.ts b/packages/plugins/reckoner/src/reckoner.ts
new file mode 100644
index 0000000..38e2db5
--- /dev/null
+++ b/packages/plugins/reckoner/src/reckoner.ts
@@ -0,0 +1,141 @@
+/**
+ * The Reckoner — petition scheduler apparatus.
+ *
+ * Exposes the `reckoner.petition()` / `reckoner.withdraw()` helper APIs,
+ * builds the kit-static petitioner registry from `petitioners` kit
+ * contributions, and parses `guild.json` Reckoner configuration.
+ *
+ * The CDC handler that watches held writs and decides their fate is a
+ * separate commission that follows this one.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { Plugin, StartupContext } from '@shardworks/nexus-core';
+import { guild } from '@shardworks/nexus-core';
+import type { ClerkApi } from '@shardworks/clerk-apparatus';
+
+import type {
+  PetitionRequest,
+  ReckonerApi,
+  ReckonerConfig,
+  ReckonerExt,
+} from './types.ts';
+import { PetitionerRegistry } from './registry.ts';
+import { applyPriorityDefaults, validatePriority } from './priority.ts';
+
+/** Plugin id stamped on `writ.ext.reckoner`. Matches the apparatus's derived id. */
+export const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * Read and resolve Reckoner configuration from `guild.json`, applying
+ * defaults for any missing fields.
+ *
+ * Called lazily at petition-time so config changes written via
+ * `guild().writeConfig()` are reflected without a restart.
+ */
+function resolveConfig(): Required<ReckonerConfig> {
+  const raw = guild().config<ReckonerConfig>(RECKONER_PLUGIN_ID);
+  return {
+    enforceRegistration: raw.enforceRegistration ?? false,
+    disabledSources: raw.disabledSources ?? [],
+  };
+}
+
+/**
+ * Create the Reckoner apparatus plugin.
+ *
+ * The apparatus:
+ * - Consumes `petitioners` kit contributions to build the registry.
+ * - Seals the registry at `phase:started`.
+ * - Exposes `ReckonerApi` via `provides`.
+ */
+export function createReckoner(): Plugin {
+  const registry = new PetitionerRegistry();
+
+  const api: ReckonerApi = {
+    async petition(request: PetitionRequest) {
+      const config = resolveConfig();
+
+      // ── Step 1: Validate source against the registry ─────────────────
+      if (!registry.isRegistered(request.source)) {
+        if (config.enforceRegistration) {
+          throw new Error(
+            `[reckoner] Unregistered petitioner source "${request.source}". ` +
+            `Register the source via a kit \`petitioners\` contribution, or ` +
+            `set \`enforceRegistration: false\` in guild.json to allow unregistered sources.`,
+          );
+        }
+        // Permissive mode: warn and proceed.
+        console.warn(
+          `[reckoner] Warning: unregistered petitioner source "${request.source}". ` +
+          `Proceeding because enforceRegistration is disabled. ` +
+          `Register the source in a kit petitioners contribution to silence this warning.`,
+        );
+      }
+
+      // ── Step 2: Apply priority defaults for omitted dimensions ────────
+      const priority = applyPriorityDefaults(request.priority);
+
+      // ── Step 3: Validate dimension values against schema ──────────────
+      validatePriority(priority);
+
+      // ── Step 4: Post the writ via clerk.post() ────────────────────────
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+      const writ = await clerk.post({
+        type: request.type,
+        title: request.title,
+        body: request.body,
+        codex: request.codex,
+        parentId: request.parentId,
+      });
+
+      // ── Step 5: Write ext.reckoner via setWritExt ─────────────────────
+      const reckonerExt: ReckonerExt = {
+        source: request.source,
+        priority,
+        ...(request.complexity !== undefined
+          ? { complexity: request.complexity }
+          : {}),
+        ...(request.payload !== undefined ? { payload: request.payload } : {}),
+        ...(request.labels !== undefined ? { labels: request.labels } : {}),
+      };
+
+      return clerk.setWritExt(writ.id, RECKONER_PLUGIN_ID, reckonerExt);
+    },
+
+    async withdraw(writId: string, reason?: string) {
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+      return clerk.transition(
+        writId,
+        'cancelled',
+        reason !== undefined ? { resolution: reason } : {},
+      );
+    },
+  };
+
+  return {
+    apparatus: {
+      requires: ['clerk'],
+      consumes: ['petitioners'],
+      provides: api,
+
+      async start(ctx: StartupContext): Promise<void> {
+        // ── Consume petitioners kit contributions ─────────────────────
+        const kitEntries = ctx.kits('petitioners');
+        for (const entry of kitEntries) {
+          if (!Array.isArray(entry.value)) continue;
+          registry.register(
+            entry.pluginId,
+            entry.value as Array<{ source: string; description: string }>,
+          );
+        }
+
+        // ── Seal registry at phase:started ────────────────────────────
+        ctx.on('phase:started', () => {
+          registry.seal();
+        });
+      },
+    },
+  };
+}
