+/**
+ * @shardworks/reckoner-apparatus — The Reckoner.
+ *
+ * Petition scheduler: kit-static petitioner registry, guild.json
+ * configuration parsing, priority dimension types with default-filling,
+ * and the `reckoner.petition()` / `reckoner.withdraw()` helper APIs.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import { createReckoner } from './reckoner.ts';
+
+// ── Public types ──────────────────────────────────────────────────────
+
+export type {
+  DomainTag,
+  Priority,
+  ComplexityTier,
+  ReckonerExt,
+  PetitionerDescriptor,
+  PetitionRequest,
+  ReckonerApi,
+  ReckonerConfig,
+} from './types.ts';
+
+// ── Priority helpers ──────────────────────────────────────────────────
+
+export {
+  defaultPriority,
+  applyPriorityDefaults,
+  validatePriority,
+} from './priority.ts';
+
+// ── Registry ──────────────────────────────────────────────────────────
+
+export {
+  PetitionerRegistry,
+  buildRegistryFromKits,
+} from './registry.ts';
+
+// ── Source ID helpers ─────────────────────────────────────────────────
+
+export { isValidSourceId, validateSourceId } from './source-id.ts';
+
+// ── Apparatus factory ─────────────────────────────────────────────────
+
+export { createReckoner, RECKONER_PLUGIN_ID } from './reckoner.ts';
+
+// ── Default export: the apparatus plugin ─────────────────────────────
+
+export default createReckoner();
