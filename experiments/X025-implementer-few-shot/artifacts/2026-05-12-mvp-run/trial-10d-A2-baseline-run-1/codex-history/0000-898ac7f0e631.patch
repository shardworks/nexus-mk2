+/**
+ * source-id.ts — unit tests.
+ *
+ * Covers: `isValidSourceId`, `validateSourceId`.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { isValidSourceId, validateSourceId } from './source-id.ts';
+
+// ── isValidSourceId ───────────────────────────────────────────────────
+
+describe('isValidSourceId', () => {
+  // ── Valid IDs ───────────────────────────────────────────────────────
+
+  it('accepts two simple lowercase segments', () => {
+    assert.equal(isValidSourceId('vision.snapshot'), true);
+  });
+
+  it('accepts kebab-case plugin id with simple suffix', () => {
+    assert.equal(isValidSourceId('vision-keeper.snapshot'), true);
+  });
+
+  it('accepts kebab-case in both segments', () => {
+    assert.equal(isValidSourceId('patron-bridge.commission'), true);
+    assert.equal(isValidSourceId('tech-debt.detected'), true);
+    assert.equal(isValidSourceId('clerk.writ-posted'), true);
+  });
+
+  it('accepts segments with digits', () => {
+    assert.equal(isValidSourceId('plugin1.source2'), true);
+    assert.equal(isValidSourceId('my-plugin-v2.event-type-3'), true);
+  });
+
+  it('accepts single-word segments', () => {
+    assert.equal(isValidSourceId('clerk.mandate'), true);
+    assert.equal(isValidSourceId('stacks.update'), true);
+  });
+
+  // ── Invalid IDs ─────────────────────────────────────────────────────
+
+  it('rejects missing dot separator', () => {
+    assert.equal(isValidSourceId('visionsnapshot'), false);
+  });
+
+  it('rejects two dots (three segments)', () => {
+    assert.equal(isValidSourceId('vision.keeper.snapshot'), false);
+  });
+
+  it('rejects uppercase letters', () => {
+    assert.equal(isValidSourceId('Vision.snapshot'), false);
+    assert.equal(isValidSourceId('vision.Snapshot'), false);
+    assert.equal(isValidSourceId('VISION.SNAPSHOT'), false);
+  });
+
+  it('rejects special characters other than hyphen', () => {
+    assert.equal(isValidSourceId('wrong.format!'), false);
+    assert.equal(isValidSourceId('vision_keeper.snapshot'), false);
+    assert.equal(isValidSourceId('vision.snap@shot'), false);
+  });
+
+  it('rejects leading hyphen in segment', () => {
+    assert.equal(isValidSourceId('-vision.snapshot'), false);
+    assert.equal(isValidSourceId('vision.-snapshot'), false);
+  });
+
+  it('rejects trailing hyphen in segment', () => {
+    assert.equal(isValidSourceId('vision-.snapshot'), false);
+    assert.equal(isValidSourceId('vision.snapshot-'), false);
+  });
+
+  it('rejects consecutive hyphens', () => {
+    assert.equal(isValidSourceId('vi--sion.snapshot'), false);
+    assert.equal(isValidSourceId('vision.snap--shot'), false);
+  });
+
+  it('rejects segment starting with digit', () => {
+    assert.equal(isValidSourceId('1plugin.source'), false);
+    assert.equal(isValidSourceId('plugin.1source'), false);
+  });
+
+  it('rejects empty string', () => {
+    assert.equal(isValidSourceId(''), false);
+  });
+
+  it('rejects only-dot', () => {
+    assert.equal(isValidSourceId('.'), false);
+  });
+
+  it('rejects empty prefix segment', () => {
+    assert.equal(isValidSourceId('.snapshot'), false);
+  });
+
+  it('rejects empty suffix segment', () => {
+    assert.equal(isValidSourceId('vision.'), false);
+  });
+});
+
+// ── validateSourceId ──────────────────────────────────────────────────
+
+describe('validateSourceId', () => {
+  it('does not throw for a valid source id', () => {
+    assert.doesNotThrow(() => validateSourceId('vision-keeper.snapshot'));
+  });
+
+  it('throws with a [reckoner] prefix for a malformed id', () => {
+    assert.throws(
+      () => validateSourceId('wrong.format!'),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('wrong.format!'));
+        return true;
+      },
+    );
+  });
+
+  it('throws for an id starting with a digit', () => {
+    assert.throws(() => validateSourceId('1plugin.source'));
+  });
+
+  // ── Plugin ID prefix validation ─────────────────────────────────────
+
+  it('does not throw when prefix matches contributing plugin id', () => {
+    assert.doesNotThrow(() =>
+      validateSourceId('vision-keeper.snapshot', 'vision-keeper'),
+    );
+  });
+
+  it('throws when prefix does not match contributing plugin id', () => {
+    assert.throws(
+      () => validateSourceId('vision-keeper.snapshot', 'other-plugin'),
+      (err: Error) => {
+        assert.ok(err.message.includes('[reckoner]'));
+        assert.ok(err.message.includes('vision-keeper'));
+        assert.ok(err.message.includes('other-plugin'));
+        return true;
+      },
+    );
+  });
+
+  it('skips prefix check when contributing plugin id is omitted', () => {
+    assert.doesNotThrow(() => validateSourceId('any-prefix.suffix'));
+  });
+});
