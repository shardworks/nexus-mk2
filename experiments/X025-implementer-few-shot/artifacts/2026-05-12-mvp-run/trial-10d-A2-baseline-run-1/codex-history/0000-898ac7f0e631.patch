index 0000000..f21c508
--- /dev/null
+++ b/packages/plugins/reckoner/src/types.ts
@@ -0,0 +1,282 @@
+/**
+ * Reckoner public types.
+ *
+ * All types exported from @shardworks/reckoner-apparatus.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { WritDoc } from '@shardworks/clerk-apparatus';
+
+// ── Priority dimensions ───────────────────────────────────────────────
+
+/**
+ * Domain tags for the `priority.domain` multi-valued field.
+ * Describes the kind of work a petition represents; not a priority axis.
+ */
+export type DomainTag =
+  | 'security'
+  | 'compliance'
+  | 'cost'
+  | 'feature'
+  | 'quality'
+  | 'infrastructure'
+  | 'documentation'
+  | 'research'
+  | 'ergonomics';
+
+/**
+ * Five-dimensional priority declaration for a Reckoner petition.
+ *
+ * Designed to be inspectable and defensible rather than mechanically
+ * objective. Petitioners declare honest inputs; the Reckoner does
+ * judgment-laden contextual collapse. The shared vocabulary makes
+ * disagreements visible and resolvable in review.
+ *
+ * See: docs/architecture/petitioner-registration.md §3
+ */
+export type Priority = {
+  /**
+   * How does this petition relate to the product vision?
+   * - `vision-blocker`   — the vision is unreachable without this.
+   * - `vision-violator`  — current state actively diverges from vision.
+   * - `vision-advancer`  — pushes toward an aspirational aspect of vision.
+   * - `vision-neutral`   — operational, hygiene, internal; doesn't touch vision.
+   */
+  visionRelation:
+    | 'vision-blocker'
+    | 'vision-violator'
+    | 'vision-advancer'
+    | 'vision-neutral';
+
+  /**
+   * If this petition is not acted on, how bad is the situation?
+   * - `critical`  — production breakage, irreversible damage, agents blocked.
+   * - `serious`   — significant ongoing degradation; daily workarounds.
+   * - `moderate`  — noticeable but tolerable.
+   * - `minor`     — easy to live with; cosmetic, convenience, polish.
+   */
+  severity: 'critical' | 'serious' | 'moderate' | 'minor';
+
+  /**
+   * What fraction of the system is affected?
+   * - `whole-product` — every user / every commission / every guild.
+   * - `major-area`    — a major feature or subsystem.
+   * - `minor-area`    — a small slice, one workflow, one command.
+   */
+  scope: 'whole-product' | 'major-area' | 'minor-area';
+
+  /**
+   * Time pressure axes (independent):
+   * - `decay: true`           — urgency increases as time passes.
+   * - `deadline: <iso-date>`  — externally-committed date.
+   */
+  time: {
+    decay: boolean;
+    /** ISO date string, or null for no deadline. */
+    deadline: string | null;
+  };
+
+  /**
+   * Multi-valued tag set describing what kind of work this is.
+   * Not a priority axis — used for filtering, weighting, and reporting.
+   */
+  domain: Array<DomainTag>;
+};
+
+// ── Complexity ────────────────────────────────────────────────────────
+
+/**
+ * Petitioner-side coarse estimate of expected agent token cost.
+ * Refined by the Astrolabe at plan time.
+ *
+ * - `mechanical`   — clear path, minimal exploration. ~50K–200K tokens.
+ * - `bounded`      — clear scope, some exploration. ~200K–1M tokens.
+ * - `exploratory`  — design judgment required; multiple viable paths. ~1M–5M tokens.
+ * - `open-ended`   — research or scope likely to grow. ~5M+ tokens.
+ *
+ * Token ranges are calibration hints, not contractual. Omit rather than guess.
+ *
+ * See: docs/architecture/petitioner-registration.md §4
+ */
+export type ComplexityTier =
+  | 'mechanical'
+  | 'bounded'
+  | 'exploratory'
+  | 'open-ended';
+
+// ── ReckonerExt ───────────────────────────────────────────────────────
+
+/**
+ * The `writ.ext['reckoner']` shape — metadata attached to a Reckoner-gated writ.
+ *
+ * A writ carrying this ext in `new` phase signals to the Reckoner that
+ * it requires consideration before being dispatched by Spider.
+ *
+ * See: docs/architecture/petitioner-registration.md §2
+ */
+export interface ReckonerExt {
+  /**
+   * Identifies the petitioner. Must match a registered petitioner
+   * descriptor when `enforceRegistration` is enabled.
+   */
+  source: string;
+
+  /**
+   * Multi-dimensional priority. Fully resolved — no optional fields.
+   * The `reckoner.petition()` helper applies defaults for omitted dimensions.
+   */
+  priority: Priority;
+
+  /**
+   * Optional petitioner-side coarse cost estimate.
+   * Omit when the petitioner has no basis to claim.
+   */
+  complexity?: ComplexityTier;
+
+  /**
+   * Opaque petitioner-defined structured data.
+   * The Reckoner stores it without introspection; the rig's engine reads
+   * it if needed.
+   */
+  payload?: unknown;
+
+  /**
+   * Additive non-priority metadata.
+   * Multi-instance discrimination, observability hints, diagnostic tags.
+   * Example: `{ 'vision-keeper.io/vision-id': 'nexus' }`.
+   */
+  labels?: Record<string, string>;
+}
+
+// ── Petitioner registry ───────────────────────────────────────────────
+
+/**
+ * A petitioner source declaration contributed via a kit's `petitioners` array.
+ *
+ * Source ids must be `{pluginId}.{kebab-suffix}` — matching the
+ * contributing plugin's derived id and a kebab-case suffix.
+ *
+ * See: docs/architecture/petitioner-registration.md §5
+ */
+export interface PetitionerDescriptor {
+  /**
+   * Fully-qualified source id (e.g. `vision-keeper.snapshot`).
+   * Must be `{pluginId}.{kebab-suffix}`. Validated at startup.
+   */
+  source: string;
+  /** Human-readable description of what this source emits. */
+  description: string;
+}
+
+// ── Petition request ──────────────────────────────────────────────────
+
+/**
+ * Request shape for `reckoner.petition()`.
+ *
+ * Combines writ fields (passed to `clerk.post`) with Reckoner ext fields
+ * (stored under `writ.ext.reckoner`). The helper applies priority defaults
+ * for omitted dimensions, validates values, and validates the source.
+ *
+ * See: docs/architecture/petitioner-registration.md §1
+ */
+export interface PetitionRequest {
+  // ── Writ fields (passed through to clerk.post) ──────────────────────
+
+  /** Writ type. Defaults to the guild's configured default (usually `mandate`). */
+  type?: string;
+  /** Short human-readable title describing the work. */
+  title: string;
+  /** Detail text. */
+  body: string;
+  /** Optional target codex name. */
+  codex?: string;
+  /** Create as a child of this parent writ. */
+  parentId?: string;
+
+  // ── Reckoner ext fields ─────────────────────────────────────────────
+
+  /**
+   * Petitioner source id. Required. Must be a registered source when
+   * `enforceRegistration` is true; a warning is logged when unregistered
+   * and `enforceRegistration` is false (the default).
+   */
+  source: string;
+
+  /**
+   * Priority dimensions. Partial — omitted fields are filled with defaults:
+   * `vision-neutral / minor / minor-area / {decay:false, deadline:null} / []`.
+   */
+  priority?: Partial<Priority>;
+
+  /** Optional complexity tier. Omit when the petitioner has no basis to claim. */
+  complexity?: ComplexityTier;
+
+  /** Opaque petitioner-defined structured data for the rig's engine. */
+  payload?: unknown;
+
+  /** Additive metadata labels for multi-instance discrimination and tagging. */
+  labels?: Record<string, string>;
+}
+
+// ── API ───────────────────────────────────────────────────────────────
+
+/**
+ * The Reckoner's runtime API — retrieved via guild().apparatus<ReckonerApi>('reckoner').
+ *
+ * See: docs/architecture/petitioner-registration.md §1
+ */
+export interface ReckonerApi {
+  /**
+   * Post a writ in `new` phase with Reckoner ext set correctly.
+   *
+   * Steps:
+   * 1. Validates source against the petitioner registry (subject to
+   *    `enforceRegistration` config — throws when true and source is unknown).
+   * 2. Applies priority defaults for omitted dimensions.
+   * 3. Validates dimension values against the schema.
+   * 4. Calls `clerk.post()` with the writ payload.
+   * 5. Writes ext fields under `writ.ext.reckoner` via `setWritExt`.
+   *
+   * Returns the persisted `WritDoc` with `phase: 'new'` and `ext.reckoner` set.
+   */
+  petition(request: PetitionRequest): Promise<WritDoc>;
+
+  /**
+   * Withdraw a held writ by transitioning it to `cancelled`.
+   *
+   * Thin wrapper around `clerk.transition(writId, 'cancelled', {resolution: reason})`.
+   * Exists for ergonomic discoverability; identical effect to calling Clerk directly.
+   */
+  withdraw(writId: string, reason?: string): Promise<WritDoc>;
+}
+
+// ── Configuration ─────────────────────────────────────────────────────
+
+/**
+ * Reckoner configuration — lives under the `reckoner` key in guild.json.
+ *
+ * See: docs/architecture/petitioner-registration.md §6
+ */
+export interface ReckonerConfig {
+  /**
+   * Controls how petitions with unregistered sources are handled.
+   * - `false` (default) — log a warning and proceed with consideration.
+   * - `true` — decline: transition the writ to `cancelled`.
+   */
+  enforceRegistration?: boolean;
+
+  /**
+   * Per-source disable list. Petitions from listed sources are skipped
+   * by the Reckoner — left in `new` phase indefinitely until removed.
+   * Default: `[]`.
+   */
+  disabledSources?: string[];
+}
+
+// Augment GuildConfig so `guild().guildConfig().reckoner` is typed.
+declare module '@shardworks/nexus-core' {
+  interface GuildConfig {
+    reckoner?: ReckonerConfig;
+  }
+}
