+/**
+ * Kit-static petitioner registry.
+ *
+ * Populated from `petitioners` kit contributions at apparatus startup,
+ * sealed at `phase:started` so no new registrations are accepted after
+ * the guild is fully loaded.
+ *
+ * Duplicate-source contributions are a hard startup error naming both
+ * contributing plugin ids — matching the framework-wide collision policy
+ * applied to Clerk writ-types, Spider rig-template-mappings, and
+ * Fabricator engine designs.
+ *
+ * See: docs/architecture/petitioner-registration.md §5
+ */
+
+import type { KitEntry } from '@shardworks/nexus-core';
+import type { PetitionerDescriptor } from './types.ts';
+import { validateSourceId } from './source-id.ts';
+
+/** Internal registry entry — extends the public descriptor with the contributor's plugin id. */
+interface RegistryEntry extends PetitionerDescriptor {
+  readonly pluginId: string;
+}
+
+/**
+ * Kit-static registry of petitioner sources.
+ *
+ * Created fresh per apparatus instance. Populated via `register()` during
+ * startup, sealed via `seal()` at `phase:started`.
+ */
+export class PetitionerRegistry {
+  private readonly entries = new Map<string, RegistryEntry>();
+  private sealed = false;
+
+  /**
+   * Register an array of petitioner descriptors from a single kit contribution.
+   *
+   * Validates:
+   * - Source ID grammar (must be `{pluginId}.{kebab-suffix}`).
+   * - Source ID prefix matches the contributing plugin id.
+   * - No duplicate source across all registered entries.
+   *
+   * @throws When the registry is sealed, a source id is malformed,
+   *   the prefix doesn't match the plugin id, or a duplicate source is detected.
+   */
+  register(pluginId: string, descriptors: PetitionerDescriptor[]): void {
+    if (this.sealed) {
+      throw new Error(
+        `[reckoner] Petitioner registry is sealed after startup; ` +
+        `cannot register new petitioners (attempted by plugin "${pluginId}").`,
+      );
+    }
+
+    for (const descriptor of descriptors) {
+      // Validate source ID grammar and prefix match.
+      // Throws with a descriptive message on failure.
+      validateSourceId(descriptor.source, pluginId);
+
+      const existing = this.entries.get(descriptor.source);
+      if (existing) {
+        throw new Error(
+          `[reckoner] Duplicate petitioner source "${descriptor.source}": ` +
+          `contributed by both "${existing.pluginId}" and "${pluginId}". ` +
+          `Remove the duplicate declaration from one of these plugins.`,
+        );
+      }
+
+      this.entries.set(descriptor.source, {
+        source: descriptor.source,
+        description: descriptor.description,
+        pluginId,
+      });
+    }
+  }
+
+  /**
+   * Seal the registry. No new registrations are accepted after this call.
+   * Called at `phase:started` to finalize the kit-static registry.
+   */
+  seal(): void {
+    this.sealed = true;
+  }
+
+  /** Return `true` if the source is in the registry. */
+  isRegistered(source: string): boolean {
+    return this.entries.has(source);
+  }
+
+  /** List all registered petitioner descriptors (without internal plugin id). */
+  list(): PetitionerDescriptor[] {
+    return Array.from(this.entries.values()).map(({ source, description }) => ({
+      source,
+      description,
+    }));
+  }
+}
+
+/**
+ * Build a `PetitionerRegistry` from a set of `petitioners` kit entries.
+ *
+ * Each `KitEntry` represents one plugin's contribution array. The entry's
+ * `value` is expected to be `PetitionerDescriptor[]`.
+ *
+ * @throws On any registration validation failure (see `PetitionerRegistry.register`).
+ */
+export function buildRegistryFromKits(kitEntries: KitEntry[]): PetitionerRegistry {
+  const registry = new PetitionerRegistry();
+  for (const entry of kitEntries) {
+    if (!Array.isArray(entry.value)) continue;
+    registry.register(entry.pluginId, entry.value as PetitionerDescriptor[]);
+  }
+  return registry;
+}
