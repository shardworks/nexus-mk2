@@ -0,0 +1,68 @@
+/**
+ * Source ID grammar validation.
+ *
+ * A petitioner source id has the form `{pluginId}.{kebab-suffix}`:
+ * - Each segment is kebab-case: lowercase letters, digits, and single
+ *   hyphens. No leading or trailing hyphens. Must start with a letter.
+ * - Exactly one dot separates the two segments.
+ *
+ * Examples of valid source ids:
+ *   - `vision-keeper.snapshot`
+ *   - `patron-bridge.commission`
+ *   - `tech-debt.detected`
+ *   - `clerk.writ-posted`
+ *
+ * See: docs/architecture/petitioner-registration.md §5
+ */
+
+/**
+ * Pattern for a single kebab-case segment:
+ * - Starts with a lowercase letter
+ * - Followed by any mix of lowercase letters and digits
+ * - Optionally followed by groups of `-` + one or more lowercase letters/digits
+ */
+const SEGMENT_PATTERN = '[a-z][a-z0-9]*(?:-[a-z0-9]+)*';
+
+/** Full source ID pattern: two kebab segments separated by exactly one dot. */
+const SOURCE_ID_RE = new RegExp(`^${SEGMENT_PATTERN}\\.${SEGMENT_PATTERN}$`);
+
+/**
+ * Return `true` if `sourceId` matches the source ID grammar.
+ */
+export function isValidSourceId(sourceId: string): boolean {
+  return SOURCE_ID_RE.test(sourceId);
+}
+
+/**
+ * Validate a petitioner source ID, throwing a descriptive error if invalid.
+ *
+ * When `contributingPluginId` is supplied, also validates that the `{pluginId}`
+ * prefix of the source ID matches the contributing plugin's id.
+ *
+ * @throws When the source ID is malformed or the prefix doesn't match the plugin.
+ */
+export function validateSourceId(
+  sourceId: string,
+  contributingPluginId?: string,
+): void {
+  if (!SOURCE_ID_RE.test(sourceId)) {
+    throw new Error(
+      `[reckoner] Malformed petitioner source id "${sourceId}": ` +
+      `must be "{pluginId}.{kebab-suffix}" with kebab-case segments ` +
+      `(lowercase letters, digits, single hyphens; no leading/trailing hyphens). ` +
+      `Examples: "vision-keeper.snapshot", "clerk.writ-posted".`,
+    );
+  }
+
+  if (contributingPluginId !== undefined) {
+    const dotIdx = sourceId.indexOf('.');
+    const prefix = sourceId.slice(0, dotIdx);
+    if (prefix !== contributingPluginId) {
+      throw new Error(
+        `[reckoner] Petitioner source id "${sourceId}" has prefix "${prefix}" ` +
+        `but the contributing plugin id is "${contributingPluginId}". ` +
+        `The source id prefix must match the contributing plugin id.`,
+      );
+    }
+  }
+}
diff --git a/packages/plugins/reckoner/src/types.ts b/packages/plugins/reckoner/src/types.ts
