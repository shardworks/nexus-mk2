@@ -0,0 +1,599 @@
+/**
+ * Unit tests for detail-pane and link-dispatch logic in pages/clicks/index.html.
+ *
+ * Covers:
+ * - renderDetailHtml — field rendering, children section, links section
+ * - renderLinksHtml — outbound/inbound rendering and link-type select
+ * - statusBadge — CSS class mapping per D20
+ * - dispatchLinkTarget — already in clicks-tree.test.js; re-tested here
+ *   in the context of renderLinkRow HTML generation
+ *
+ * Re-declares the pure functions from index.html (IIFE-scoped, not exported).
+ * Follows the node:test + assert/strict + minimal-DOM-shim pattern from the
+ * Clerk writs-page companion tests.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Re-declared pure functions (mirrors index.html IIFE) ─────────────
+
+function escHtml(s) {
+  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+}
+
+function escAttr(s) {
+  return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
+}
+
+function fmtDate(iso) {
+  if (!iso) return '';
+  return new Date(iso).toLocaleString();
+}
+
+function shortId(id) {
+  const parts = id.split('-');
+  return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+}
+
+/**
+ * Maps click status to Oculus shared badge classes (D20).
+ */
+function statusBadge(status) {
+  const map = {
+    live:      'badge badge--active',
+    parked:    'badge badge--warning',
+    concluded: 'badge badge--success',
+    dropped:   'badge badge--error',
+  };
+  const cls = map[status] ?? 'badge';
+  return `<span class="${cls}">${escHtml(status)}</span>`;
+}
+
+function dispatchLinkTarget(targetId) {
+  if (targetId.startsWith('c-')) return 'click';
+  if (targetId.startsWith('w-')) return 'writ';
+  return 'plain';
+}
+
+function renderLinkRow(link, dir, peerId, _clickId, linkType) {
+  const dispatch = dispatchLinkTarget(peerId);
+  let peerHtml;
+  if (dispatch === 'click') {
+    peerHtml = '<span class="link-target" data-click-id="' + escAttr(peerId) + '">' + escHtml(peerId) + '</span>';
+  } else if (dispatch === 'writ') {
+    const writUrl = '/pages/writs/?writ=' + encodeURIComponent(peerId);
+    peerHtml = '<a class="link-target" href="' + escAttr(writUrl) + '">' + escHtml(peerId) + '</a>';
+  } else {
+    peerHtml = '<span>' + escHtml(peerId) + '</span>';
+  }
+
+  let html = '<div class="link-row" data-link-source="' + escAttr(link.sourceId) + '" data-link-target="' + escAttr(link.targetId) + '" data-link-type="' + escAttr(linkType) + '">';
+  html += '<span class="link-dir">' + dir + '</span>';
+  html += peerHtml;
+  html += ' <span class="link-meta">(' + escHtml(linkType) + ')</span>';
+  html += ' <span class="link-meta-label" data-peer-id="' + escAttr(peerId) + '"></span>';
+  html += '<button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.75rem"';
+  html += ' data-action="unlink" data-source="' + escAttr(link.sourceId) + '"';
+  html += ' data-target="' + escAttr(link.targetId) + '"';
+  html += ' data-type="' + escAttr(linkType) + '" title="Remove link">×</button>';
+  html += '</div>';
+  return html;
+}
+
+function renderLinksHtml(click) {
+  const outbound = click.links?.outbound ?? [];
+  const inbound = click.links?.inbound ?? [];
+  let html = '<h4>Links</h4>';
+
+  if (outbound.length === 0 && inbound.length === 0) {
+    html += '<p class="detail-empty">No links.</p>';
+  }
+
+  for (const l of outbound) {
+    html += renderLinkRow(l, '→', l.targetId, click.id, l.linkType);
+  }
+  for (const l of inbound) {
+    html += renderLinkRow(l, '←', l.sourceId, click.id, l.linkType);
+  }
+
+  html += '<div class="add-link-form" id="add-link-form-' + escAttr(click.id) + '">';
+  html += '<input type="text" id="link-target-' + escAttr(click.id) + '" placeholder="Target ID (c-… or w-…)" style="width:160px">';
+  html += '<select id="link-type-' + escAttr(click.id) + '">';
+  for (const lt of ['related', 'commissioned', 'supersedes', 'depends-on']) {
+    html += '<option value="' + lt + '">' + lt + '</option>';
+  }
+  html += '</select>';
+  html += '<button class="btn" data-action="addlink" data-id="' + escAttr(click.id) + '">Link</button>';
+  html += '<div class="error-msg" id="link-error-' + escAttr(click.id) + '" style="display:none"></div>';
+  html += '</div>';
+
+  return html;
+}
+
+function renderDetailHtml(click) {
+  const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+  const isLive = click.status === 'live';
+  const isParked = click.status === 'parked';
+  let html = '';
+
+  // ID + copy
+  html += '<div class="detail-section">';
+  html += '<h4>Click</h4>';
+  html += '<div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem">';
+  html += '<code style="font-size:0.875rem">' + escHtml(click.id) + '</code>';
+  html += '<button class="btn copy-btn" data-copy-id="' + escAttr(click.id) + '" title="Copy ID">📋</button>';
+  html += '</div>';
+  html += '</div>';
+
+  // Core fields
+  html += '<div class="detail-section"><h4>Details</h4><dl class="detail-grid">';
+  html += '<dt>Goal</dt><dd>' + escHtml(click.goal) + '</dd>';
+  html += '<dt>Status</dt><dd>' + statusBadge(click.status) + '</dd>';
+  if (click.parent) {
+    html += '<dt>Parent</dt><dd>';
+    html += '<a class="link-target" data-click-id="' + escAttr(click.parent.id) + '">' + escHtml(shortId(click.parent.id)) + '</a>';
+    html += ' ' + statusBadge(click.parent.status);
+    html += ' <span style="font-size:0.8rem;opacity:0.7">' + escHtml(click.parent.goal) + '</span>';
+    html += '</dd>';
+  }
+  html += '<dt>Created</dt><dd>' + escHtml(fmtDate(click.createdAt)) + '</dd>';
+  if (click.resolvedAt) html += '<dt>Resolved</dt><dd>' + escHtml(fmtDate(click.resolvedAt)) + '</dd>';
+  if (click.createdSessionId) html += '<dt>Created by</dt><dd><code>' + escHtml(click.createdSessionId) + '</code></dd>';
+  if (click.resolvedSessionId) html += '<dt>Resolved by</dt><dd><code>' + escHtml(click.resolvedSessionId) + '</code></dd>';
+  html += '</dl></div>';
+
+  // Conclusion
+  if (isTerminal && click.conclusion) {
+    html += '<div class="detail-section">';
+    html += '<h4>Conclusion <button class="btn" id="detail-conclusion-toggle" style="padding:0.1rem 0.35rem;font-size:0.75rem">▸ Show</button></h4>';
+    html += '<div id="detail-conclusion-body" style="display:none;padding:0.5rem;background:var(--bg3,#24283b);border-radius:4px;font-size:0.875rem;margin-top:0.25rem">';
+    html += escHtml(click.conclusion);
+    html += '</div></div>';
+  }
+
+  // Actions
+  if (!isTerminal) {
+    html += '<div class="detail-section"><h4>Actions</h4>';
+    html += '<div class="action-buttons" id="lifecycle-actions-' + escAttr(click.id) + '">';
+    if (isLive) {
+      html += '<button class="btn" data-action="park" data-id="' + escAttr(click.id) + '">Park</button>';
+      html += '<button class="btn btn--success" data-action="conclude" data-id="' + escAttr(click.id) + '">Conclude</button>';
+      html += '<button class="btn btn--danger" data-action="drop" data-id="' + escAttr(click.id) + '">Drop</button>';
+    } else if (isParked) {
+      html += '<button class="btn" data-action="resume" data-id="' + escAttr(click.id) + '">Resume</button>';
+      html += '<button class="btn btn--success" data-action="conclude" data-id="' + escAttr(click.id) + '">Conclude</button>';
+      html += '<button class="btn btn--danger" data-action="drop" data-id="' + escAttr(click.id) + '">Drop</button>';
+    }
+    html += '<div class="error-msg" id="action-error-' + escAttr(click.id) + '" style="display:none"></div>';
+    html += '<div id="confirm-area-' + escAttr(click.id) + '"></div>';
+    html += '</div></div>';
+  }
+
+  // Create child button
+  html += '<div class="detail-section">';
+  html += '<button class="btn" data-action="create-child" data-id="' + escAttr(click.id) + '">+ Child Click</button>';
+  html += '</div>';
+
+  // Links
+  html += '<div class="detail-section" id="links-section-' + escAttr(click.id) + '">';
+  html += renderLinksHtml(click);
+  html += '</div>';
+
+  // Children
+  const childItems = click.children?.items ?? [];
+  html += '<div class="detail-section"><h4>Children';
+  if (childItems.length > 0) html += ' <span style="font-size:0.75rem;opacity:0.6">(' + childItems.length + ')</span>';
+  html += '</h4>';
+  if (click.children?.summary && Object.keys(click.children.summary).length > 0) {
+    html += '<div style="margin-bottom:0.5rem">';
+    for (const [status, count] of Object.entries(click.children.summary)) {
+      html += statusBadge(status) + ' <span style="margin-right:0.75rem">' + count + '</span>';
+    }
+    html += '</div>';
+  }
+  if (childItems.length > 0) {
+    html += '<table class="data-table"><thead><tr>';
+    html += '<th>Status</th><th>Goal</th><th>ID</th>';
+    html += '</tr></thead><tbody>';
+    for (const child of childItems) {
+      html += '<tr class="child-click-row" data-child-id="' + escAttr(child.id) + '">';
+      html += '<td>' + statusBadge(child.status) + '</td>';
+      html += '<td>' + escHtml(child.goal) + '</td>';
+      html += '<td><code>' + escHtml(shortId(child.id)) + '</code></td>';
+      html += '</tr>';
+    }
+    html += '</tbody></table>';
+  } else {
+    html += '<p class="detail-empty">No children.</p>';
+  }
+  html += '</div>';
+
+  return html;
+}
+
+// ── Test fixtures ─────────────────────────────────────────────────────
+
+const BASE_CLICK = {
+  id: 'c-test01-aaa',
+  goal: 'Test the system',
+  status: 'live',
+  createdAt: '2025-01-15T10:00:00.000Z',
+  links: { outbound: [], inbound: [] },
+  children: { summary: {}, items: [] },
+  parent: null,
+};
+
+// ── statusBadge ───────────────────────────────────────────────────────
+
+describe('statusBadge — CSS class mapping (D20)', () => {
+  it('live → badge--active', () => {
+    const html = statusBadge('live');
+    assert.ok(html.includes('badge--active'), 'live should use badge--active');
+    assert.ok(html.includes('live'));
+  });
+
+  it('parked → badge--warning', () => {
+    const html = statusBadge('parked');
+    assert.ok(html.includes('badge--warning'));
+    assert.ok(html.includes('parked'));
+  });
+
+  it('concluded → badge--success', () => {
+    const html = statusBadge('concluded');
+    assert.ok(html.includes('badge--success'));
+    assert.ok(html.includes('concluded'));
+  });
+
+  it('dropped → badge--error', () => {
+    const html = statusBadge('dropped');
+    assert.ok(html.includes('badge--error'));
+    assert.ok(html.includes('dropped'));
+  });
+
+  it('unknown status falls back to bare badge class', () => {
+    const html = statusBadge('mystery');
+    assert.ok(html.includes('"badge"'), 'unknown status should use bare badge');
+  });
+});
+
+// ── renderDetailHtml — field coverage ─────────────────────────────────
+
+describe('renderDetailHtml — field rendering', () => {
+  it('renders the click ID in a code element', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(html.includes('<code'), 'should have a code element');
+    assert.ok(html.includes(BASE_CLICK.id), 'should include the click ID');
+  });
+
+  it('renders the goal', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(html.includes('Test the system'), 'should include goal text');
+  });
+
+  it('renders the status badge', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(html.includes('badge--active'), 'live click should show badge--active');
+  });
+
+  it('renders createdAt', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    // The date is locale-formatted; just check the section exists
+    assert.ok(html.includes('<dt>Created</dt>'), 'should have Created field');
+  });
+
+  it('omits resolvedAt when not set', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(!html.includes('<dt>Resolved</dt>'), 'should not include Resolved when not set');
+  });
+
+  it('renders resolvedAt when set', () => {
+    const click = { ...BASE_CLICK, resolvedAt: '2025-02-01T12:00:00.000Z' };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('<dt>Resolved</dt>'), 'should include Resolved field');
+  });
+
+  it('omits createdSessionId when not set', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(!html.includes('<dt>Created by</dt>'), 'should not include Created by when not set');
+  });
+
+  it('renders createdSessionId when set', () => {
+    const click = { ...BASE_CLICK, createdSessionId: 'sess-abc' };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('sess-abc'), 'should include session ID');
+    assert.ok(html.includes('<dt>Created by</dt>'));
+  });
+
+  it('renders resolvedSessionId when set', () => {
+    const click = { ...BASE_CLICK, resolvedSessionId: 'sess-xyz', status: 'concluded', resolvedAt: '2025-02-01T00:00:00.000Z' };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('sess-xyz'), 'should include resolved session ID');
+  });
+
+  it('renders parent link when parent is set', () => {
+    const click = {
+      ...BASE_CLICK,
+      parent: { id: 'c-parent-zzz', goal: 'Parent goal', status: 'live' },
+    };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('data-click-id'), 'parent should be a clickable link');
+    assert.ok(html.includes('Parent goal'), 'should show parent goal');
+  });
+
+  it('omits parent section when parent is null', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(!html.includes('<dt>Parent</dt>'), 'should not include Parent field when not set');
+  });
+});
+
+// ── renderDetailHtml — terminal click conclusion ───────────────────────
+
+describe('renderDetailHtml — conclusion section (D10)', () => {
+  it('shows conclusion toggle for concluded click', () => {
+    const click = {
+      ...BASE_CLICK,
+      status: 'concluded',
+      conclusion: 'All done successfully',
+      resolvedAt: '2025-02-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: { summary: {}, items: [] },
+    };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('detail-conclusion-toggle'), 'should have conclusion toggle');
+    assert.ok(html.includes('All done successfully'), 'should include conclusion text');
+  });
+
+  it('shows conclusion toggle for dropped click', () => {
+    const click = {
+      ...BASE_CLICK,
+      status: 'dropped',
+      conclusion: 'Abandoned this path',
+      resolvedAt: '2025-02-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: { summary: {}, items: [] },
+    };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('detail-conclusion-toggle'), 'should have conclusion toggle');
+    assert.ok(html.includes('Abandoned this path'));
+  });
+
+  it('does not show conclusion section for live click', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(!html.includes('detail-conclusion-toggle'), 'live click should not have conclusion toggle');
+  });
+});
+
+// ── renderDetailHtml — lifecycle actions ───────────────────────────────
+
+describe('renderDetailHtml — lifecycle actions (D11)', () => {
+  it('shows Park, Conclude, Drop for live click', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(html.includes('data-action="park"'), 'live: should have Park');
+    assert.ok(html.includes('data-action="conclude"'), 'live: should have Conclude');
+    assert.ok(html.includes('data-action="drop"'), 'live: should have Drop');
+    assert.ok(!html.includes('data-action="resume"'), 'live: should not have Resume');
+  });
+
+  it('shows Resume, Conclude, Drop for parked click', () => {
+    const click = { ...BASE_CLICK, status: 'parked', links: { outbound: [], inbound: [] }, children: { summary: {}, items: [] } };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('data-action="resume"'), 'parked: should have Resume');
+    assert.ok(html.includes('data-action="conclude"'), 'parked: should have Conclude');
+    assert.ok(html.includes('data-action="drop"'), 'parked: should have Drop');
+    assert.ok(!html.includes('data-action="park"'), 'parked: should not have Park');
+  });
+
+  it('shows no lifecycle actions for concluded click', () => {
+    const click = {
+      ...BASE_CLICK, status: 'concluded', conclusion: 'done',
+      resolvedAt: '2025-02-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] }, children: { summary: {}, items: [] },
+    };
+    const html = renderDetailHtml(click);
+    assert.ok(!html.includes('data-action="park"'));
+    assert.ok(!html.includes('data-action="resume"'));
+    assert.ok(!html.includes('data-action="conclude"'));
+    assert.ok(!html.includes('data-action="drop"'));
+  });
+
+  it('shows no lifecycle actions for dropped click', () => {
+    const click = {
+      ...BASE_CLICK, status: 'dropped', conclusion: 'abandoned',
+      resolvedAt: '2025-02-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] }, children: { summary: {}, items: [] },
+    };
+    const html = renderDetailHtml(click);
+    assert.ok(!html.includes('data-action="park"'));
+    assert.ok(!html.includes('data-action="resume"'));
+  });
+});
+
+// ── renderDetailHtml — children section (D22) ─────────────────────────
+
+describe('renderDetailHtml — children section (D22)', () => {
+  it('renders status-count badge strip when children present', () => {
+    const click = {
+      ...BASE_CLICK,
+      children: {
+        summary: { live: 2, parked: 1 },
+        items: [
+          { id: 'c-child1-xx', goal: 'Child 1', status: 'live' },
+          { id: 'c-child2-xx', goal: 'Child 2', status: 'live' },
+          { id: 'c-child3-xx', goal: 'Child 3', status: 'parked' },
+        ],
+      },
+    };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('badge--active'), 'should include live badge in summary');
+    assert.ok(html.includes('badge--warning'), 'should include parked badge in summary');
+    assert.ok(html.includes('(3)'), 'should show count of 3 children');
+  });
+
+  it('renders children table with clickable rows', () => {
+    const click = {
+      ...BASE_CLICK,
+      children: {
+        summary: { live: 1 },
+        items: [{ id: 'c-child1-xx', goal: 'Do the thing', status: 'live' }],
+      },
+    };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('child-click-row'), 'should have child-click-row class');
+    assert.ok(html.includes('data-child-id="c-child1-xx"'), 'should have child ID in dataset');
+    assert.ok(html.includes('Do the thing'), 'should include child goal text');
+  });
+
+  it('shows "No children" when children array is empty', () => {
+    const html = renderDetailHtml(BASE_CLICK);
+    assert.ok(html.includes('No children'), 'should show no-children message');
+  });
+
+  it('shows short ID in children table', () => {
+    const click = {
+      ...BASE_CLICK,
+      children: {
+        summary: { live: 1 },
+        items: [{ id: 'c-mo1mq8ry-abc123', goal: 'Child goal', status: 'live' }],
+      },
+    };
+    const html = renderDetailHtml(click);
+    assert.ok(html.includes('c-mo1mq8ry'), 'should show short ID in children table');
+  });
+});
+
+// ── renderLinksHtml — link type select and layout ──────────────────────
+
+describe('renderLinksHtml', () => {
+  it('shows "No links" when both outbound and inbound are empty', () => {
+    const html = renderLinksHtml(BASE_CLICK);
+    assert.ok(html.includes('No links'), 'should show no-links message');
+  });
+
+  it('renders outbound links with → direction', () => {
+    const click = {
+      ...BASE_CLICK,
+      links: {
+        outbound: [{
+          id: 'c-test01-aaa:c-other-bbb:related',
+          sourceId: 'c-test01-aaa',
+          targetId: 'c-other-bbb',
+          linkType: 'related',
+          createdAt: '2025-01-15T10:00:00.000Z',
+        }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksHtml(click);
+    assert.ok(html.includes('→'), 'should have outbound direction arrow');
+    assert.ok(html.includes('c-other-bbb'), 'should include target ID');
+    assert.ok(html.includes('(related)'), 'should include link type');
+  });
+
+  it('renders inbound links with ← direction', () => {
+    const click = {
+      ...BASE_CLICK,
+      links: {
+        outbound: [],
+        inbound: [{
+          id: 'c-source-xxx:c-test01-aaa:depends-on',
+          sourceId: 'c-source-xxx',
+          targetId: 'c-test01-aaa',
+          linkType: 'depends-on',
+          createdAt: '2025-01-15T10:00:00.000Z',
+        }],
+      },
+    };
+    const html = renderLinksHtml(click);
+    assert.ok(html.includes('←'), 'should have inbound direction arrow');
+    assert.ok(html.includes('c-source-xxx'), 'should include source ID');
+    assert.ok(html.includes('(depends-on)'), 'should include link type');
+  });
+
+  it('renders add-link form with all four link-type options (D14)', () => {
+    const html = renderLinksHtml(BASE_CLICK);
+    for (const lt of ['related', 'commissioned', 'supersedes', 'depends-on']) {
+      assert.ok(html.includes('<option value="' + lt + '"'), 'should have option for ' + lt);
+    }
+    assert.ok(html.includes('<select'), 'should use a select element (not datalist)');
+  });
+
+  it('c- target renders as in-page clickable span (not link)', () => {
+    const click = {
+      ...BASE_CLICK,
+      links: {
+        outbound: [{
+          id: 'c-test01-aaa:c-other-bbb:related',
+          sourceId: 'c-test01-aaa',
+          targetId: 'c-other-bbb',
+          linkType: 'related',
+          createdAt: '2025-01-15T10:00:00.000Z',
+        }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksHtml(click);
+    assert.ok(html.includes('data-click-id="c-other-bbb"'), 'c- target should have data-click-id');
+    // Should not be an <a href=...> to a writ page
+    assert.ok(!html.includes('/pages/writs/'), 'c- target should not link to writs page');
+  });
+
+  it('w- target renders as an href to the writs page (D15)', () => {
+    const click = {
+      ...BASE_CLICK,
+      links: {
+        outbound: [{
+          id: 'c-test01-aaa:w-mo1o65ky:commissioned',
+          sourceId: 'c-test01-aaa',
+          targetId: 'w-mo1o65ky',
+          linkType: 'commissioned',
+          createdAt: '2025-01-15T10:00:00.000Z',
+        }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksHtml(click);
+    assert.ok(html.includes('/pages/writs/?writ=w-mo1o65ky'), 'w- target should link to writs page');
+  });
+
+  it('unknown-prefix target renders as plain text (D15)', () => {
+    const click = {
+      ...BASE_CLICK,
+      links: {
+        outbound: [{
+          id: 'c-test01-aaa:ext-xyz123:related',
+          sourceId: 'c-test01-aaa',
+          targetId: 'ext-xyz123',
+          linkType: 'related',
+          createdAt: '2025-01-15T10:00:00.000Z',
+        }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksHtml(click);
+    assert.ok(html.includes('ext-xyz123'), 'should include target ID as text');
+    assert.ok(!html.includes('data-click-id'), 'should not be click link');
+    assert.ok(!html.includes('/pages/writs/'), 'should not be writ link');
+  });
+
+  it('renders unlink button for each link', () => {
+    const click = {
+      ...BASE_CLICK,
+      links: {
+        outbound: [{
+          id: 'c-test01-aaa:c-other-bbb:related',
+          sourceId: 'c-test01-aaa',
+          targetId: 'c-other-bbb',
+          linkType: 'related',
+          createdAt: '2025-01-15T10:00:00.000Z',
+        }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksHtml(click);
+    assert.ok(html.includes('data-action="unlink"'), 'should have unlink button');
+    assert.ok(html.includes('data-source="c-test01-aaa"'), 'should carry source on unlink');
+    assert.ok(html.includes('data-target="c-other-bbb"'), 'should carry target on unlink');
+    assert.ok(html.includes('data-type="related"'), 'should carry type on unlink');
+  });
+});
diff --git a/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
new file mode 100644
index 0000000..ea251a6
--- /dev/null
+++ b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
@@ -0,0 +1,305 @@
+/**
+ * Unit tests for click tree logic in pages/clicks/index.html.
+ *
+ * Covers:
+ * - pruneByStatus — prune semantics including subtree hiding
+ * - findSubtree — locate a node by ID in the forest
+ * - buildAncestorPath — derive breadcrumb path from forest root to a node
+ * - visibleForest helper — combined scope + filter
+ * - dispatchLinkTarget — link prefix dispatch (c-…, w-…, other)
+ * - shortId helper
+ *
+ * Re-declares the pure functions from index.html (IIFE-scoped, not exported).
+ * Follows the node:test + assert/strict + FakeElement DOM-shim pattern from
+ * the Clerk writs-page companion tests.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Re-declared pure functions (mirrors index.html IIFE) ─────────────
+
+function shortId(id) {
+  const parts = id.split('-');
+  return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+}
+
+/**
+ * Prune a forest by status set. Nodes whose status is not in statusSet,
+ * and their entire subtrees, are removed (prune semantics per D6).
+ */
+function pruneByStatus(nodes, statusSet) {
+  const result = [];
+  for (const node of nodes) {
+    if (!statusSet.has(node.click.status)) continue;
+    const prunedChildren = pruneByStatus(node.children, statusSet);
+    result.push({ click: node.click, children: prunedChildren });
+  }
+  return result;
+}
+
+/**
+ * Find the subtree rooted at targetId in the forest.
+ * Returns the matching ClickTree node or null.
+ */
+function findSubtree(nodes, targetId) {
+  for (const node of nodes) {
+    if (node.click.id === targetId) return node;
+    const found = findSubtree(node.children, targetId);
+    if (found) return found;
+  }
+  return null;
+}
+
+/**
+ * Build the ancestor path from forest root to targetId.
+ * Returns array of ClickDoc from root to the node (inclusive), or null if not found.
+ */
+function buildAncestorPath(nodes, targetId, path) {
+  for (const node of nodes) {
+    const candidate = [...(path ?? []), node.click];
+    if (node.click.id === targetId) return candidate;
+    const found = buildAncestorPath(node.children, targetId, candidate);
+    if (found) return found;
+  }
+  return null;
+}
+
+/**
+ * Dispatch a link target ID to its navigation type.
+ * Returns 'click', 'writ', or 'plain'.
+ */
+function dispatchLinkTarget(targetId) {
+  if (targetId.startsWith('c-')) return 'click';
+  if (targetId.startsWith('w-')) return 'writ';
+  return 'plain';
+}
+
+// ── Test fixtures ─────────────────────────────────────────────────────
+
+function makeClick(id, status, parentId) {
+  return {
+    id,
+    goal: 'Goal for ' + id,
+    status: status ?? 'live',
+    createdAt: '2025-01-01T00:00:00.000Z',
+    ...(parentId ? { parentId } : {}),
+  };
+}
+
+function makeNode(id, status, children) {
+  return { click: makeClick(id, status), children: children ?? [] };
+}
+
+// Simple three-level forest:
+//   rootA (live)
+//     childA1 (live)
+//       grandA1 (concluded)
+//     childA2 (parked)
+//   rootB (dropped)
+const grandA1 = makeNode('c-ga1', 'concluded');
+const childA1 = makeNode('c-ca1', 'live', [grandA1]);
+const childA2 = makeNode('c-ca2', 'parked');
+const rootA   = makeNode('c-ra',  'live', [childA1, childA2]);
+const rootB   = makeNode('c-rb',  'dropped');
+const sampleForest = [rootA, rootB];
+
+// ── shortId ───────────────────────────────────────────────────────────
+
+describe('shortId', () => {
+  it('returns first two hyphen-separated segments', () => {
+    assert.equal(shortId('c-mo1mq8ry-abc123'), 'c-mo1mq8ry');
+  });
+
+  it('returns unchanged id with fewer than 2 segments', () => {
+    assert.equal(shortId('nohyphen'), 'nohyphen');
+  });
+
+  it('handles exactly two segments', () => {
+    assert.equal(shortId('c-abc123'), 'c-abc123');
+  });
+});
+
+// ── pruneByStatus ─────────────────────────────────────────────────────
+
+describe('pruneByStatus', () => {
+  it('returns all nodes when all statuses are in set', () => {
+    const all = new Set(['live', 'parked', 'concluded', 'dropped']);
+    const result = pruneByStatus(sampleForest, all);
+    assert.equal(result.length, 2, 'both roots present');
+    assert.equal(result[0].children.length, 2, 'both childA children present');
+    assert.equal(result[0].children[0].children.length, 1, 'grandA1 present');
+  });
+
+  it('prunes nodes whose status is not in the set', () => {
+    const liveOnly = new Set(['live']);
+    const result = pruneByStatus(sampleForest, liveOnly);
+    // rootB (dropped) should be pruned
+    assert.equal(result.length, 1);
+    assert.equal(result[0].click.id, 'c-ra');
+  });
+
+  it('prunes the entire subtree when parent is pruned', () => {
+    const liveOnly = new Set(['live']);
+    const result = pruneByStatus(sampleForest, liveOnly);
+    // childA1 (live) is kept, childA2 (parked) is pruned, grandA1 is pruned via childA1
+    // Wait — childA1 is live so it passes. Its child grandA1 is concluded, so pruned.
+    const ra = result[0];
+    assert.equal(ra.children.length, 1, 'childA2 (parked) is pruned');
+    assert.equal(ra.children[0].click.id, 'c-ca1');
+    assert.equal(ra.children[0].children.length, 0, 'grandA1 (concluded) pruned under live filter');
+  });
+
+  it('subtree under pruned parent is removed entirely', () => {
+    // childA2 is parked, and has no children in our fixture.
+    // Build a tree where a parked node has a live child to verify
+    // that the live child is also pruned (parent prune cascades to descendants).
+    const liveChildUnderParked = makeNode('c-x', 'live');
+    const parkedWithLiveChild = makeNode('c-p', 'parked', [liveChildUnderParked]);
+    const forest = [parkedWithLiveChild];
+
+    const result = pruneByStatus(forest, new Set(['live']));
+    assert.equal(result.length, 0, 'parked root pruned, pulling live child with it');
+  });
+
+  it('empty statusSet prunes all nodes', () => {
+    const result = pruneByStatus(sampleForest, new Set());
+    assert.equal(result.length, 0);
+  });
+
+  it('returns empty array for empty forest', () => {
+    const result = pruneByStatus([], new Set(['live']));
+    assert.deepEqual(result, []);
+  });
+});
+
+// ── findSubtree ───────────────────────────────────────────────────────
+
+describe('findSubtree', () => {
+  it('finds a root node by ID', () => {
+    const found = findSubtree(sampleForest, 'c-rb');
+    assert.ok(found);
+    assert.equal(found.click.id, 'c-rb');
+  });
+
+  it('finds a deeply nested node by ID', () => {
+    const found = findSubtree(sampleForest, 'c-ga1');
+    assert.ok(found);
+    assert.equal(found.click.id, 'c-ga1');
+  });
+
+  it('returns the matching subtree including descendants', () => {
+    const found = findSubtree(sampleForest, 'c-ca1');
+    assert.ok(found);
+    assert.equal(found.children.length, 1);
+    assert.equal(found.children[0].click.id, 'c-ga1');
+  });
+
+  it('returns null when ID is not found', () => {
+    const found = findSubtree(sampleForest, 'c-zzz');
+    assert.equal(found, null);
+  });
+
+  it('returns null for empty forest', () => {
+    assert.equal(findSubtree([], 'c-ra'), null);
+  });
+});
+
+// ── buildAncestorPath ─────────────────────────────────────────────────
+
+describe('buildAncestorPath', () => {
+  it('returns single-element path for a root node', () => {
+    const path = buildAncestorPath(sampleForest, 'c-ra', []);
+    assert.ok(Array.isArray(path));
+    assert.equal(path.length, 1);
+    assert.equal(path[0].id, 'c-ra');
+  });
+
+  it('returns full path to a deeply nested node', () => {
+    const path = buildAncestorPath(sampleForest, 'c-ga1', []);
+    assert.ok(path);
+    assert.equal(path.length, 3, 'root → child → grandchild');
+    assert.equal(path[0].id, 'c-ra');
+    assert.equal(path[1].id, 'c-ca1');
+    assert.equal(path[2].id, 'c-ga1');
+  });
+
+  it('returns path to a direct child', () => {
+    const path = buildAncestorPath(sampleForest, 'c-ca2', []);
+    assert.ok(path);
+    assert.equal(path.length, 2);
+    assert.equal(path[0].id, 'c-ra');
+    assert.equal(path[1].id, 'c-ca2');
+  });
+
+  it('returns null when node is not found', () => {
+    const path = buildAncestorPath(sampleForest, 'c-zzz', []);
+    assert.equal(path, null);
+  });
+
+  it('returns null for empty forest', () => {
+    assert.equal(buildAncestorPath([], 'c-ra', []), null);
+  });
+
+  it('path entries contain the click doc', () => {
+    const path = buildAncestorPath(sampleForest, 'c-ca1', []);
+    assert.ok(path);
+    for (const click of path) {
+      assert.ok(click.id, 'each entry should have an id field');
+      assert.ok(click.goal, 'each entry should have a goal field');
+    }
+  });
+});
+
+// ── dispatchLinkTarget ────────────────────────────────────────────────
+
+describe('dispatchLinkTarget', () => {
+  it('c- prefix dispatches to "click"', () => {
+    assert.equal(dispatchLinkTarget('c-mo1mq8ry-abc123'), 'click');
+  });
+
+  it('w- prefix dispatches to "writ"', () => {
+    assert.equal(dispatchLinkTarget('w-mo1o65ky'), 'writ');
+  });
+
+  it('unknown prefix dispatches to "plain"', () => {
+    assert.equal(dispatchLinkTarget('some-other-id'), 'plain');
+  });
+
+  it('empty string dispatches to "plain"', () => {
+    assert.equal(dispatchLinkTarget(''), 'plain');
+  });
+
+  it('bare "c-" prefix (just the prefix) dispatches to "click"', () => {
+    assert.equal(dispatchLinkTarget('c-'), 'click');
+  });
+
+  it('bare "w-" prefix dispatches to "writ"', () => {
+    assert.equal(dispatchLinkTarget('w-'), 'writ');
+  });
+});
+
+// ── Combined: subtree scoping + status pruning ─────────────────────────
+
+describe('subtree scope + status filter', () => {
+  it('scopes to a subtree then prunes by status', () => {
+    // Scope to rootA (which contains live and parked children), then filter to live only
+    const sub = findSubtree(sampleForest, 'c-ra');
+    assert.ok(sub);
+    const scoped = [sub];
+    const pruned = pruneByStatus(scoped, new Set(['live']));
+    assert.equal(pruned.length, 1);
+    // childA2 (parked) pruned; childA1 (live) kept but grandA1 (concluded) pruned
+    assert.equal(pruned[0].children.length, 1);
+    assert.equal(pruned[0].children[0].click.id, 'c-ca1');
+    assert.equal(pruned[0].children[0].children.length, 0);
+  });
+
+  it('scoping to a non-existent ID yields empty forest', () => {
+    const sub = findSubtree(sampleForest, 'c-zzz');
+    const scoped = sub ? [sub] : [];
+    assert.equal(scoped.length, 0);
+    const pruned = pruneByStatus(scoped, new Set(['live', 'parked']));
+    assert.equal(pruned.length, 0);
+  });
+});
