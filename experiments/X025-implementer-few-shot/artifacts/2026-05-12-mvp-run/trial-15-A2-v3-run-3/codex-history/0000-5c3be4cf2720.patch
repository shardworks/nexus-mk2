+});
+
+// ── executeWithdraw ───────────────────────────────────────────────────
+
+describe('executeWithdraw', () => {
+  it('calls clerk.transition() with writId and "cancelled"', async () => {
+    const { clerk, calls } = makeClerkMock();
+
+    await executeWithdraw(clerk, 'w-test-0001');
+
+    const call = calls.find((c) => c.method === 'transition');
+    assert.ok(call, 'transition should have been called');
+    assert.equal(call.args[0], 'w-test-0001');
+    assert.equal(call.args[1], 'cancelled');
+  });
+
+  it('passes resolution when reason is provided', async () => {
+    const { clerk, calls } = makeClerkMock();
+    const reason = 'Snapshot superseded by newer drift.';
+
+    await executeWithdraw(clerk, 'w-test-0001', reason);
+
+    const call = calls.find((c) => c.method === 'transition')!;
+    const fields = call.args[2] as { resolution?: string } | undefined;
+    assert.ok(fields, 'fields should be present when reason is provided');
+    assert.equal(fields.resolution, reason);
