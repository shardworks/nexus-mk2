+/**
+ * @shardworks/reckoner-apparatus — The Reckoner.
+ *
+ * Kit-static petitioner registry, guild.json configuration parsing, priority
+ * dimension types with default-filling, and reckoner.petition() / reckoner.withdraw()
+ * helper APIs. The foundation that lets petitioners declare themselves and
+ * emit properly-formed held writs through an ergonomic API.
+ *
+ * The CDC handler that watches held writs and decides their fate (approve /
+ * defer / decline) is a separate commission that follows this one.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import { createReckoner } from './reckoner.ts';
+
+// ── Public types ──────────────────────────────────────────────────────
+
+export {
+  type DomainTag,
+  type Priority,
+  type ComplexityTier,
+  type ReckonerExt,
+  type PetitionRequest,
+  type PetitionerDescriptor,
+  type ReckonerConfig,
+  type ResolvedReckonerConfig,
+  type ReckonerApi,
+} from './types.ts';
+
+// ── Registry ──────────────────────────────────────────────────────────
+
+export { validateSourceId, PetitionerRegistry } from './registry.ts';
+
+// ── Defaults and validation ───────────────────────────────────────────
+
+export { defaultPriority, DEFAULT_PRIORITY } from './defaults.ts';
+export {
+  validatePriority,
+  VALID_VISION_RELATIONS,
+  VALID_SEVERITIES,
+  VALID_SCOPES,
+  VALID_DOMAIN_TAGS,
+} from './validation.ts';
+
+// ── Apparatus factory ─────────────────────────────────────────────────
+
+export { createReckoner } from './reckoner.ts';
+
+// ── Constants ─────────────────────────────────────────────────────────
+
+export { RECKONER_PLUGIN_ID } from './petition.ts';
+
+// ── Default export: the apparatus plugin ─────────────────────────────
+
+export default createReckoner();
