@@ -0,0 +1,157 @@
+/**
+ * The Reckoner apparatus — petitioner registry, guild.json configuration,
+ * and helper APIs for posting Reckoner-gated writs.
+ *
+ * This module provides the foundation that lets petitioners declare themselves
+ * and emit properly-formed held writs through an ergonomic API. The CDC
+ * handler that watches held writs and decides their fate (approve / defer /
+ * decline) is a separate commission that follows this one.
+ *
+ * Three responsibilities owned here:
+ *
+ *   1. **Kit-static petitioner registry** — consumed from kit `petitioners`
+ *      contributions at boot, sealed at `phase:started`. Duplicate-source
+ *      contributions are a hard startup error naming both plugin ids.
+ *
+ *   2. **Configuration** — reads `guild.json["reckoner"]` at startup, exposes
+ *      `enforceRegistration` (default `false`) and `disabledSources` (default
+ *      `[]`) to the CDC-handler commission via the apparatus's `provides`.
+ *
+ *   3. **Helper APIs** — `petition()` and `withdraw()` wrap `clerk.post()` /
+ *      `clerk.setWritExt()` / `clerk.transition()` with validation, defaults,
+ *      and discoverability.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { Plugin, StartupContext } from '@shardworks/nexus-core';
+import { guild } from '@shardworks/nexus-core';
+import type { ClerkApi } from '@shardworks/clerk-apparatus';
+
+import type {
+  PetitionerDescriptor,
+  PetitionRequest,
+  ReckonerApi,
+  ResolvedReckonerConfig,
+} from './types.ts';
+import { PetitionerRegistry } from './registry.ts';
+import { executePetition, executeWithdraw } from './petition.ts';
+
+/**
+ * Create the Reckoner apparatus plugin.
+ *
+ * The returned plugin registers itself as an apparatus with id `reckoner`
+ * (derived from the package name `@shardworks/reckoner-apparatus`).
+ *
+ * At startup:
+ *   - Consumes all kit `petitioners` contributions and builds the registry.
+ *   - Validates each source id and throws on duplicates or malformed ids.
+ *   - Seals the registry so no further registrations are accepted.
+ *   - Reads `guild.json["reckoner"]` and resolves defaults.
+ *   - Exposes the `ReckonerApi` via `provides` so petitioners can call
+ *     `guild().apparatus<ReckonerApi>('reckoner').petition(...)`.
+ *
+ * Requires the `clerk` apparatus (used by `petition()` and `withdraw()`).
+ * Consumes the `petitioners` kit contribution type.
+ */
+export function createReckoner(): Plugin {
+  const registry = new PetitionerRegistry();
+
+  // These are initialised in `start()` and accessed only after the apparatus
+  // has started, so non-null assertions in the api closures are safe.
+  let clerk: ClerkApi;
+  let config: ResolvedReckonerConfig;
+
+  const api: ReckonerApi = {
+    async petition(request: PetitionRequest) {
+      return executePetition(clerk, registry, config, request);
+    },
+
+    async withdraw(writId: string, reason?: string) {
+      return executeWithdraw(clerk, writId, reason);
+    },
+
+    getRegisteredSources(): ReadonlyArray<PetitionerDescriptor> {
+      return registry.getAll();
+    },
+  };
+
+  return {
+    apparatus: {
+      /**
+       * `clerk` must be started before the Reckoner because `petition()` and
+       * `withdraw()` call Clerk APIs synchronously after startup.
+       */
+      requires: ['clerk'],
+
+      /**
+       * The `petitioners` contribution type — kit plugins declare their
+       * sources here; the Reckoner consumes them in `start()`.
+       */
+      consumes: ['petitioners'],
+
+      /**
+       * The runtime API exposed to other apparatuses and kit plugins.
+       * Retrieved via `guild().apparatus<ReckonerApi>('reckoner')`.
+       */
+      provides: api,
+
+      async start(ctx: StartupContext): Promise<void> {
+        // ── 1. Build the petitioner registry from kit contributions ──────
+
+        const petitionerEntries = ctx.kits('petitioners');
+
+        for (const entry of petitionerEntries) {
+          // Each kit entry's value is the array declared in the kit:
+          //   kit: { petitioners: [{ source, description }, ...] }
+          // Validate the shape defensively — a badly-shaped contribution
+          // should fail loudly at startup rather than produce silent drops.
+          const value = entry.value;
+          if (!Array.isArray(value)) {
+            throw new Error(
+              `[reckoner] Plugin '${entry.pluginId}' contributed an invalid ` +
+                `'petitioners' value: expected an array of PetitionerDescriptor ` +
+                `objects, got ${typeof value}.`,
+            );
+          }
+
+          for (const item of value as PetitionerDescriptor[]) {
+            if (
+              typeof item !== 'object' ||
+              item === null ||
+              typeof item.source !== 'string' ||
+              typeof item.description !== 'string'
+            ) {
+              throw new Error(
+                `[reckoner] Plugin '${entry.pluginId}' contributed a malformed ` +
+                  `petitioner entry: each entry must have { source: string, ` +
+                  `description: string }.`,
+              );
+            }
+            // register() validates source-id grammar and prefix match; it
+            // throws a descriptive error on any violation.
+            registry.register(entry.pluginId, item);
+          }
+        }
+
+        // Seal the registry — no further registrations are accepted after
+        // `phase:started`. Any attempt throws immediately.
+        registry.seal();
+
+        // ── 2. Read configuration from guild.json ────────────────────────
+
+        const rawConfig = guild().guildConfig().reckoner ?? {};
+        config = {
+          enforceRegistration: rawConfig.enforceRegistration ?? false,
+          disabledSources: rawConfig.disabledSources ?? [],
+        };
+
+        // ── 3. Capture the Clerk API handle ──────────────────────────────
+
+        // guild().apparatus() throws if 'clerk' is not started; `requires`
+        // guarantees it is started before us, so this is always safe.
+        clerk = guild().apparatus<ClerkApi>('clerk');
+      },
+    },
+  };
+}
diff --git a/packages/plugins/reckoner/src/registry.test.ts b/packages/plugins/reckoner/src/registry.test.ts
