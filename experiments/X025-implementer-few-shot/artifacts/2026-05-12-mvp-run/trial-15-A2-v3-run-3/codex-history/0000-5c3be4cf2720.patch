+/**
+ * Core petition and withdrawal helpers — exported as standalone functions so
+ * tests can call them directly with mocked dependencies without needing to
+ * exercise the apparatus startup machinery.
+ *
+ * The apparatus's `ReckonerApi.petition()` and `ReckonerApi.withdraw()`
+ * implementations delegate directly to `executePetition()` and
+ * `executeWithdraw()`.
+ *
+ * See: docs/architecture/petitioner-registration.md §1
+ */
+
+import type { ClerkApi, WritDoc, WritPhase } from '@shardworks/clerk-apparatus';
+
+import type {
+  PetitionRequest,
+  ReckonerExt,
+  ResolvedReckonerConfig,
+} from './types.ts';
+import type { PetitionerRegistry } from './registry.ts';
+import { defaultPriority } from './defaults.ts';
+import { validatePriority } from './validation.ts';
+
+/** Plugin id stamped on `writ.ext` sub-slots written by the Reckoner. */
+export const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * Execute a petition — the full Workflow 2 path.
+ *
+ * Steps (per the contract §1):
+ * 1. Validate `request.source` against `registry` (subject to
+ *    `config.enforceRegistration`).
+ * 2. Apply priority defaults for any omitted dimensions.
+ * 3. Validate all five priority dimension values against their enums.
+ * 4. Call `clerk.post()` to create the writ in its `initial` state.
+ * 5. Write `ext.reckoner` via `clerk.setWritExt()`.
+ * 6. Return the final `WritDoc` (with `ext.reckoner` populated).
+ *
+ * Throws on:
+ * - Unregistered source when `enforceRegistration` is `true`.
+ * - Invalid priority dimension values.
+ * - Any error propagated from `clerk.post()` or `clerk.setWritExt()`.
+ *
+ * @param clerk     - The Clerk apparatus API.
+ * @param registry  - The sealed petitioner registry.
+ * @param config    - Resolved Reckoner configuration (with defaults applied).
+ * @param request   - The petition request from the caller.
+ */
+export async function executePetition(
+  clerk: ClerkApi,
+  registry: PetitionerRegistry,
+  config: ResolvedReckonerConfig,
+  request: PetitionRequest,
+): Promise<WritDoc> {
+  const { source } = request;
+
+  // Step 1 — source validation
+  if (!registry.isRegistered(source)) {
+    if (config.enforceRegistration) {
+      throw new Error(
+        `[reckoner] Unregistered petitioner source '${source}'. ` +
+          `Register the source via a 'petitioners' kit contribution, or set ` +
+          `enforceRegistration: false in guild.json to allow unregistered sources.`,
+      );
+    }
+    // enforceRegistration === false: warn and proceed
+    console.warn(
+      `[reckoner] Warning: petitioner source '${source}' is not registered. ` +
+        `The writ will be created but the Reckoner cannot attribute it to a ` +
+        `known source. Add a petitioners kit entry to suppress this warning.`,
+    );
+  }
+
+  // Step 2 — apply priority defaults
+  const priority = defaultPriority(request.priority);
+
+  // Step 3 — validate dimension values
+  validatePriority(priority);
+
+  // Build the ext.reckoner payload
+  const reckonerExt: ReckonerExt = {
+    source,
+    priority,
+    ...(request.complexity !== undefined ? { complexity: request.complexity } : {}),
+    ...(request.payload !== undefined ? { payload: request.payload } : {}),
+    ...(request.labels !== undefined ? { labels: request.labels } : {}),
+  };
+
+  // Step 4 — create the writ via clerk.post()
+  const writ = await clerk.post({
+    type: request.type,
+    title: request.title,
+    body: request.body,
+    codex: request.codex,
+    ...(request.parentId !== undefined ? { parentId: request.parentId } : {}),
+  });
+
+  // Step 5 — write ext.reckoner via setWritExt()
+  return clerk.setWritExt(writ.id, RECKONER_PLUGIN_ID, reckonerExt);
+}
+
+/**
+ * Execute a withdrawal — transition a held writ to `cancelled`.
+ *
+ * Thin wrapper around `clerk.transition(writId, 'cancelled', ...)`. The
+ * `reason`, when provided, is stored in the writ's `resolution` field.
+ *
+ * No source-check is performed — any caller may withdraw any writ via this
+ * helper. The purpose is ergonomic discoverability, not enforcement.
+ *
+ * @param clerk   - The Clerk apparatus API.
+ * @param writId  - Id of the writ to cancel.
+ * @param reason  - Optional human-readable reason, stored in `writ.resolution`.
+ */
+export async function executeWithdraw(
+  clerk: ClerkApi,
+  writId: string,
+  reason?: string,
+): Promise<WritDoc> {
+  const to: WritPhase = 'cancelled';
+  return clerk.transition(
+    writId,
+    to,
+    reason !== undefined ? { resolution: reason } : undefined,
+  );
+}
