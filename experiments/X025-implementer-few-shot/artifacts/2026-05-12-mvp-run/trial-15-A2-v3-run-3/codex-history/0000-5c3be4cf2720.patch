+
+    it('uses the plugin id "reckoner" as the setWritExt slot key', async () => {
+      const { clerk, calls } = makeClerkMock();
+      const reg = makeRegistry([
+        { pluginId: 'vision-keeper', source: 'vision-keeper.snapshot' },
+      ]);
+      const config = makeConfig();
+
+      await executePetition(clerk, reg, config, {
+        type: 'mandate',
+        title: 'T',
+        body: 'B',
+        codex: 'nexus',
+        source: 'vision-keeper.snapshot',
+        priority: {},
+      });
+
+      const extCall = calls.find((c) => c.method === 'setWritExt')!;
+      assert.equal(extCall.args[1], 'reckoner');
