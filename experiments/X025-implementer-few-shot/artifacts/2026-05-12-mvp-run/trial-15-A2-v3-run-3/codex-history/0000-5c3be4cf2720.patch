+++ b/packages/plugins/reckoner/src/registry.ts
@@ -0,0 +1,150 @@
+/**
+ * Kit-static petitioner registry.
+ *
+ * Consumed by the Reckoner apparatus at boot — `createReckoner()` calls
+ * `ctx.kits('petitioners')`, registers each declared source, then seals the
+ * registry at `phase:started`. Post-seal registration attempts are a hard
+ * error.
+ *
+ * See: docs/architecture/petitioner-registration.md §5
+ */
+
+import type { PetitionerDescriptor } from './types.ts';
+
+// ── Source-id grammar ─────────────────────────────────────────────────
+
+/**
+ * Regex for the source-id grammar: `{pluginId}.{kebab-suffix}`.
+ *
+ * Both segments are kebab-case identifiers:
+ *   - Start with a lowercase letter.
+ *   - Followed by zero or more lowercase letters, digits, or single hyphens.
+ *   - No leading or trailing hyphens; no consecutive hyphens.
+ *
+ * Examples that match: `vision-keeper.snapshot`, `patron-bridge.commission`,
+ *   `tech-debt.detected`, `my-plugin.my-event-type`.
+ * Examples that don't: `no-dot`, `.prefix-missing`, `suffix.`, `UPPER.case`,
+ *   `bad!.chars`, `double..dot`, `-leading.hyphen`, `trailing-.hyphen`.
+ */
+const SOURCE_ID_REGEX =
+  /^[a-z][a-z0-9]*(-[a-z0-9]+)*\.[a-z][a-z0-9]*(-[a-z0-9]+)*$/;
+
+/**
+ * Return `true` when `source` satisfies the `{pluginId}.{kebab-suffix}`
+ * grammar, `false` otherwise.
+ */
+export function validateSourceId(source: string): boolean {
+  return SOURCE_ID_REGEX.test(source);
+}
+
+/**
+ * Extract the pluginId prefix from a source id (the part before the first
+ * `.`). Returns the empty string for ids that contain no `.`.
+ */
+function pluginIdPrefix(source: string): string {
+  const dot = source.indexOf('.');
+  return dot === -1 ? '' : source.slice(0, dot);
+}
+
+// ── PetitionerRegistry ────────────────────────────────────────────────
+
+/**
+ * Maintains the kit-static map of registered petitioner sources.
+ *
+ * The registry is built during apparatus startup via `register()` calls, one
+ * per kit entry, then sealed via `seal()` before the apparatus signals
+ * ready. After sealing, any `register()` call throws immediately.
+ *
+ * Duplicate-source collision policy: two entries with the same `source` id
+ * — regardless of which plugin contributed them — throw a hard error naming
+ * both contributing plugin ids. The winner is never resolved by load order.
+ * This mirrors the framework-wide collision rule for writ-types,
+ * rig-template-mappings, and engine designs.
+ */
+export class PetitionerRegistry {
+  private readonly _entries = new Map<
+    string,
+    { readonly pluginId: string; readonly descriptor: PetitionerDescriptor }
+  >();
+  private _sealed = false;
+
+  /** Whether `seal()` has been called. Post-seal registration throws. */
+  get isSealed(): boolean {
+    return this._sealed;
+  }
+
+  /**
+   * Register a petitioner source declared by `pluginId`.
+   *
+   * Validates:
+   * 1. Registry is not yet sealed.
+   * 2. `descriptor.source` matches the source-id grammar.
+   * 3. `descriptor.source` is prefixed with `pluginId.`.
+   * 4. No other kit has already registered the same `descriptor.source`.
+   *
+   * Throws on any violation — all validation failures are startup errors.
+   */
+  register(pluginId: string, descriptor: PetitionerDescriptor): void {
+    if (this._sealed) {
+      throw new Error(
+        `[reckoner] Registry is sealed; cannot register petitioner source ` +
+          `'${descriptor.source}' from plugin '${pluginId}' after startup.`,
+      );
+    }
+
+    if (!validateSourceId(descriptor.source)) {
+      throw new Error(
+        `[reckoner] Malformed source id '${descriptor.source}' from plugin '${pluginId}': ` +
+          `source ids must match the pattern '{pluginId}.{kebab-suffix}' ` +
+          `(e.g. 'vision-keeper.snapshot').`,
+      );
+    }
+
+    const prefix = pluginIdPrefix(descriptor.source);
+    if (prefix !== pluginId) {
+      throw new Error(
+        `[reckoner] Source id '${descriptor.source}' from plugin '${pluginId}' ` +
+          `must be prefixed with the contributing plugin id followed by '.': ` +
+          `expected prefix '${pluginId}.' but got '${prefix}.'.`,
+      );
+    }
+
+    const existing = this._entries.get(descriptor.source);
+    if (existing !== undefined) {
+      throw new Error(
+        `[reckoner] Duplicate petitioner source '${descriptor.source}': ` +
+          `contributed by both '${existing.pluginId}' and '${pluginId}'. ` +
+          `Each source id must be unique across all plugins.`,
+      );
+    }
+
+    this._entries.set(descriptor.source, { pluginId, descriptor });
+  }
+
+  /**
+   * Seal the registry, preventing any further `register()` calls.
+   *
+   * Called by the Reckoner apparatus immediately after consuming all
+   * kit `petitioners` contributions, before the apparatus signals ready.
+   * Idempotent — calling `seal()` on an already-sealed registry is a no-op.
+   */
+  seal(): void {
+    this._sealed = true;
+  }
+
+  /**
+   * Return `true` when `source` has been registered, `false` otherwise.
+   */
+  isRegistered(source: string): boolean {
+    return this._entries.has(source);
+  }
+
+  /**
+   * Return all registered petitioner descriptors in registration order.
+   * The returned array is a snapshot — mutations to the registry after this
+   * call are not reflected in the returned value.
+   */
+  getAll(): ReadonlyArray<PetitionerDescriptor> {
+    return Array.from(this._entries.values()).map((e) => e.descriptor);
+  }
+}
diff --git a/packages/plugins/reckoner/src/types.ts b/packages/plugins/reckoner/src/types.ts
new file mode 100644
index 0000000..ba9fa5e
--- /dev/null
+++ b/packages/plugins/reckoner/src/types.ts
@@ -0,0 +1,322 @@
+/**
+ * Reckoner public types.
+ *
+ * Covers the petition data shape (priority dimensions, complexity, payload,
+ * labels), the petitioner registry descriptor, the configuration schema, and
+ * the ReckonerApi interface.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { WritDoc } from '@shardworks/clerk-apparatus';
+
+// ── Priority dimensions (§3) ──────────────────────────────────────────
+
+/**
+ * Domain tags — multi-valued classification axis on a petition's priority.
+ *
+ * Not a priority axis itself; describes what *kind* of work the petition is.
+ * Used by the Reckoner for filtering, patron-tunable weighting, and reporting.
+ */
+export type DomainTag =
+  | 'security'
+  | 'compliance'
+  | 'cost'
+  | 'feature'
+  | 'quality'
+  | 'infrastructure'
+  | 'documentation'
+  | 'research'
+  | 'ergonomics';
+
+/**
+ * Five-axis priority schema for a petition.
+ *
+ * Designed to be inspectable and defensible rather than mechanically
+ * objective — petitioners declare honest inputs; the Reckoner does
+ * judgment-laden contextual collapse. The shared vocabulary makes
+ * disagreements visible and resolvable in review.
+ *
+ * Use `defaultPriority()` to obtain an instance with defaults applied for
+ * any omitted dimensions.
+ */
+export type Priority = {
+  /**
+   * How this petition relates to the product vision.
+   *
+   * - `vision-blocker`  — the vision is unreachable without this.
+   * - `vision-violator` — the current state actively diverges from the vision.
+   * - `vision-advancer` — pushes toward an aspirational, not-yet-realised aspect.
+   * - `vision-neutral`  — operational, hygiene, internal tooling, research.
+   */
+  visionRelation:
+    | 'vision-blocker'
+    | 'vision-violator'
+    | 'vision-advancer'
+    | 'vision-neutral';
+
+  /**
+   * How bad is the situation if this petition is not acted on?
+   *
+   * - `critical`  — production breakage, irreversible damage, agents blocked.
+   * - `serious`   — significant ongoing degradation; daily workarounds.
+   * - `moderate`  — noticeable but tolerable.
+   * - `minor`     — easy to live with; cosmetic, convenience, polish.
+   */
+  severity: 'critical' | 'serious' | 'moderate' | 'minor';
+
+  /**
+   * What fraction of the system is affected?
+   *
+   * - `whole-product` — every user / every commission / every guild.
+   * - `major-area`    — a major feature or subsystem.
+   * - `minor-area`    — a small slice, one workflow, one command.
+   */
+  scope: 'whole-product' | 'major-area' | 'minor-area';
+
+  /**
+   * Time-pressure dimensions — two genuinely independent axes.
+   *
+   * - `decay: true`          — urgency grows over time (drift, accruing debt).
+   * - `deadline: <iso-date>` — pledged external commitment.
+   * Neither — defer-friendly work.
+   */
+  time: {
+    decay: boolean;
+    /** ISO date string (e.g. "2025-06-01") or null when no hard deadline. */
+    deadline: string | null;
+  };
+
+  /**
+   * Multi-valued domain classification. An empty array is valid and common.
+   * See `DomainTag` for valid values.
+   */
+  domain: Array<DomainTag>;
+};
+
+// ── Complexity (§4) ───────────────────────────────────────────────────
+
+/**
+ * Petitioner-side coarse cost estimate.
+ *
+ * Refined by the Astrolabe at plan time; present at petition time only for
+ * early-stage trade-offs before plans exist.
+ *
+ * - `mechanical`  — clear path, minimal exploration. ~50K–200K tokens.
+ * - `bounded`     — clear scope, some exploration. ~200K–1M tokens.
+ * - `exploratory` — design judgment required; multiple viable paths. ~1M–5M.
+ * - `open-ended`  — research/prototyping; scope likely to grow. 5M+ tokens.
+ *
+ * Petitioners are encouraged to omit rather than guess — omission is honest.
+ */
+export type ComplexityTier =
+  | 'mechanical'
+  | 'bounded'
+  | 'exploratory'
+  | 'open-ended';
+
+// ── Petition shape (§2) ───────────────────────────────────────────────
+
+/**
+ * Full `writ.ext['reckoner']` shape.
+ *
+ * Set by the Reckoner apparatus on every held writ, either via
+ * `reckoner.petition()` (Workflow 2) or manually via `clerk.post()` +
+ * `clerk.setWritExt()` (Workflow 1).
+ */
+export interface ReckonerExt {
+  /**
+   * Required. Identifies the petitioner. Must match a registered petitioner
+   * descriptor (§5) when `enforceRegistration` is true.
+   */
+  source: string;
+
+  /** Required. Multi-dimensional priority; see §3. */
+  priority: Priority;
+
+  /**
+   * Optional petitioner-side coarse cost estimate. Refined by the Astrolabe
+   * at plan time. See §4.
+   */
+  complexity?: ComplexityTier;
+
+  /**
+   * Opaque petitioner-defined structured data. The Reckoner stores it but
+   * does not introspect; the rig's implementation engine reads it if needed.
+   */
+  payload?: unknown;
+
+  /**
+   * Additive non-priority metadata. Multi-instance discrimination,
+   * observability hints, diagnostic tags.
+   *
+   * @example { 'vision-keeper.io/vision-id': 'nexus' }
+   */
+  labels?: Record<string, string>;
+}
+
+// ── PetitionRequest (§1 Workflow 2) ──────────────────────────────────
+
+/**
+ * Input to `reckoner.petition()`.
+ *
+ * Combines writ fields (passed through to `clerk.post()`) with the
+ * `ext.reckoner` fields (source, priority, complexity, payload, labels).
+ * The `priority` is accepted as `Partial<Priority>`; `reckoner.petition()`
+ * applies defaults for any omitted dimensions before posting.
+ */
+export interface PetitionRequest {
+  // ── Writ fields ────────────────────────────────────────────────
+  /** Writ type — must be registered with the Clerk. */
+  type: string;
+  /** Short human-readable title describing the work. */
+  title: string;
+  /** Detail text. */
+  body: string;
+  /** Target codex name. */
+  codex: string;
+  /** Create as a child of this parent writ. */
+  parentId?: string;
+
+  // ── ext.reckoner fields ────────────────────────────────────────
+  /** Required. Identifies the petitioner source. Format: `{pluginId}.{kebab-suffix}`. */
+  source: string;
+  /**
+   * Priority dimensions. Any omitted dimension receives its default:
+   * `vision-neutral / minor / minor-area / {decay: false, deadline: null} / []`.
+   */
+  priority: Partial<Priority>;
+  /** Optional petitioner-side coarse cost estimate. */
+  complexity?: ComplexityTier;
+  /** Opaque petitioner-defined structured data. */
+  payload?: unknown;
+  /** Additive non-priority metadata. */
+  labels?: Record<string, string>;
+}
+
+// ── Petitioner registry (§5) ──────────────────────────────────────────
+
+/**
+ * A petitioner source declaration — contributed via the `petitioners` kit
+ * contribution type.
+ *
+ * Kit declaration example:
+ * ```typescript
+ * export default {
+ *   kit: {
+ *     requires: ['reckoner'],
+ *     petitioners: [{
+ *       source: 'vision-keeper.snapshot',
+ *       description: 'Vision-vs-reality snapshots emitted on drift.',
+ *     }],
+ *   },
+ * };
+ * ```
+ */
+export interface PetitionerDescriptor {
+  /**
+   * Unique source id. Format: `{pluginId}.{kebab-suffix}`.
+   * Validated against the contributing plugin's id at registry build time.
+   */
+  source: string;
+  /** Human-readable one-liner describing this source for operators. */
+  description: string;
+}
+
+// ── Configuration (§6) ───────────────────────────────────────────────
+
+/**
+ * Reckoner configuration — read from `guild.json` under the `reckoner` key.
+ *
+ * ```json
+ * {
+ *   "reckoner": {
+ *     "enforceRegistration": false,
+ *     "disabledSources": []
+ *   }
+ * }
+ * ```
+ */
+export interface ReckonerConfig {
+  /**
+   * Controls how the Reckoner handles petitions from unregistered sources.
+   *
+   * - `false` (default) — log a warning and proceed with normal consideration.
+   * - `true` — decline the petition (transition `new` → `cancelled`) with a
+   *   reason naming the unknown source.
+   */
+  enforceRegistration?: boolean;
+
+  /**
+   * Per-source disable list. Petitions from any source in this array are
+   * skipped by the Reckoner — left in `new` phase with no reckoning entry.
+   * Removing a source from this list resumes normal consideration of any
+   * pending writs from that source.
+   *
+   * Default: `[]`.
+   */
+  disabledSources?: string[];
+}
+
+// Augment GuildConfig so `guild().guildConfig().reckoner` is typed without
+// requiring a manual type parameter at the call site.
+declare module '@shardworks/nexus-core' {
+  interface GuildConfig {
+    reckoner?: ReckonerConfig;
+  }
+}
+
+// ── Resolved config (internal) ────────────────────────────────────────
+
+/**
+ * Reckoner config with all defaults applied. Used internally by the apparatus.
+ */
+export interface ResolvedReckonerConfig {
+  readonly enforceRegistration: boolean;
+  readonly disabledSources: readonly string[];
+}
+
+// ── ReckonerApi (§1 Workflow 2) ───────────────────────────────────────
+
+/**
+ * The Reckoner's runtime API — retrieved via `guild().apparatus<ReckonerApi>('reckoner')`.
+ *
+ * Petitioners typically interact only with `petition()` and `withdraw()`.
+ * `getRegisteredSources()` is for operator/observability tooling.
+ */
+export interface ReckonerApi {
+  /**
+   * Post a writ in `new` phase with Reckoner ext set correctly.
+   *
+   * Validates dimension values against the schema, applies defaults for
+   * omitted dimensions, validates source against the registry (subject to
+   * `enforceRegistration` config), calls `clerk.post()`, and then writes
+   * the ext fields under `writ.ext.reckoner` via `setWritExt`.
+   *
+   * Returns the persisted `WritDoc` with `phase: 'new'` and
+   * `ext.reckoner` populated.
+   *
+   * Equivalent in effect to calling `clerk.post()` with manual ext
+   * construction (Workflow 1); this helper exists for type checking,
+   * default handling, and discoverability.
+   */
+  petition(request: PetitionRequest): Promise<WritDoc>;
+
+  /**
+   * Withdraw a held writ by transitioning it to `cancelled`.
+   *
+   * Convenience wrapper around `clerk.transition(writId, 'cancelled', ...)`.
+   * The `reason`, when provided, is recorded in the writ's `resolution` field.
+   * No source-check is performed — any caller may withdraw any writ.
+   */
+  withdraw(writId: string, reason?: string): Promise<WritDoc>;
+
+  /**
+   * Return all registered petitioner sources.
+   *
+   * Useful for operator / observability tooling that wants to enumerate known
+   * sources without aggregating from observed petition history.
+   * Reflects the registry state at the time of the call — sealed after startup.
+   */
+  getRegisteredSources(): ReadonlyArray<PetitionerDescriptor>;
+}
diff --git a/packages/plugins/reckoner/src/validation.ts b/packages/plugins/reckoner/src/validation.ts
new file mode 100644
index 0000000..272d0d2
--- /dev/null
+++ b/packages/plugins/reckoner/src/validation.ts
@@ -0,0 +1,109 @@
+/**
+ * Priority dimension validation.
+ *
+ * Validates that all fields on a fully-resolved `Priority` object are
+ * members of their respective enum sets. Called by `executePetition()` after
+ * defaults have been applied.
+ *
+ * See: docs/architecture/petitioner-registration.md §3
+ */
+
+import type { DomainTag, Priority } from './types.ts';
+
+// ── Valid value sets (as frozen Sets for O(1) membership checks) ──────
+
+export const VALID_VISION_RELATIONS: ReadonlySet<Priority['visionRelation']> =
+  new Set([
+    'vision-blocker',
+    'vision-violator',
+    'vision-advancer',
+    'vision-neutral',
+  ]);
+
+export const VALID_SEVERITIES: ReadonlySet<Priority['severity']> = new Set([
+  'critical',
+  'serious',
+  'moderate',
+  'minor',
+]);
+
+export const VALID_SCOPES: ReadonlySet<Priority['scope']> = new Set([
+  'whole-product',
+  'major-area',
+  'minor-area',
+]);
+
+export const VALID_DOMAIN_TAGS: ReadonlySet<DomainTag> = new Set([
+  'security',
+  'compliance',
+  'cost',
+  'feature',
+  'quality',
+  'infrastructure',
+  'documentation',
+  'research',
+  'ergonomics',
+]);
+
+// ── Validator ─────────────────────────────────────────────────────────
+
+/**
+ * Validate that all five dimensions of `priority` are well-formed.
+ *
+ * Throws a descriptive error on the first invalid field found. This is
+ * intentionally fail-loud at petition-emit time so mis-configured sources
+ * are caught immediately rather than silently accepted and misfiled.
+ *
+ * After `defaultPriority()` has been applied all fields will be present;
+ * this function validates their *values*, not their presence.
+ */
+export function validatePriority(priority: Priority): void {
+  if (
+    !VALID_VISION_RELATIONS.has(priority.visionRelation)
+  ) {
+    throw new Error(
+      `[reckoner] Invalid priority.visionRelation: '${priority.visionRelation}'. ` +
+        `Valid values: ${[...VALID_VISION_RELATIONS].map((v) => `'${v}'`).join(', ')}.`,
+    );
+  }
+
+  if (!VALID_SEVERITIES.has(priority.severity)) {
+    throw new Error(
+      `[reckoner] Invalid priority.severity: '${priority.severity}'. ` +
+        `Valid values: ${[...VALID_SEVERITIES].map((v) => `'${v}'`).join(', ')}.`,
+    );
+  }
+
+  if (!VALID_SCOPES.has(priority.scope)) {
+    throw new Error(
+      `[reckoner] Invalid priority.scope: '${priority.scope}'. ` +
+        `Valid values: ${[...VALID_SCOPES].map((v) => `'${v}'`).join(', ')}.`,
+    );
+  }
+
+  if (typeof priority.time.decay !== 'boolean') {
+    throw new Error(
+      `[reckoner] Invalid priority.time.decay: expected boolean, ` +
+        `got ${typeof priority.time.decay}.`,
+    );
+  }
+
+  if (
+    priority.time.deadline !== null &&
+    typeof priority.time.deadline !== 'string'
+  ) {
+    throw new Error(
+      `[reckoner] Invalid priority.time.deadline: expected ISO date string or null, ` +
+        `got ${typeof priority.time.deadline}.`,
+    );
+  }
+
+  for (const tag of priority.domain) {
+    if (!VALID_DOMAIN_TAGS.has(tag as DomainTag)) {
+      throw new Error(
+        `[reckoner] Invalid priority.domain tag: '${tag}'. ` +
+          `Valid values: ${[...VALID_DOMAIN_TAGS].map((v) => `'${v}'`).join(', ')}.`,
+      );
+    }
+  }
+}
