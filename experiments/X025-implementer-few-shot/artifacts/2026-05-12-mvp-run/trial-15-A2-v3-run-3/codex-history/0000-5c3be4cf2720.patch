+
+  it('returns the WritDoc from clerk.transition()', async () => {
+    const expectedWrit = makeWrit({ id: 'w-test-0001', phase: 'cancelled' });
+    const { clerk } = makeClerkMock({
+      transition: async () => expectedWrit,
