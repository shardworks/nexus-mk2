+/**
+ * Tests for executePetition() and executeWithdraw().
+ *
+ * Covers the behavioural cases from the commission brief:
+ *
+ * - petition() with unregistered source + enforceRegistration=false → succeeds
+ *   (warning logged).
+ * - petition() with unregistered source + enforceRegistration=true → throws
+ *   fail-loud, no writ posted.
+ * - petition() with registered source → posts writ, sets ext.reckoner.
+ * - petition() with partial priority → defaults applied before writing ext.
+ * - petition() with invalid priority dimension → throws, no writ posted.
+ * - The resulting writ carries ext.reckoner = { source, priority,
+ *   complexity?, payload?, labels? }.
+ * - withdraw() calls clerk.transition() with 'cancelled' + resolution.
+ * - withdraw() without reason calls clerk.transition() without fields.
+ */
+
+import { describe, it, beforeEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { executePetition, executeWithdraw } from './petition.ts';
+import { PetitionerRegistry } from './registry.ts';
+import type { ClerkApi, WritDoc } from '@shardworks/clerk-apparatus';
+import type { ResolvedReckonerConfig, ReckonerExt } from './types.ts';
+
+// ── Minimal WritDoc factory ───────────────────────────────────────────
+
+function makeWrit(overrides: Partial<WritDoc> = {}): WritDoc {
+  return {
+    id: 'w-test-0001',
+    type: 'mandate',
+    phase: 'new',
+    title: 'Test writ',
+    body: 'Test body',
+    codex: 'nexus',
+    createdAt: '2025-01-01T00:00:00.000Z',
+    updatedAt: '2025-01-01T00:00:00.000Z',
+    ...overrides,
+  };
+}
+
+// ── Mock ClerkApi ─────────────────────────────────────────────────────
+
+interface ClerkCall {
+  method: 'post' | 'setWritExt' | 'transition';
+  args: unknown[];
+}
+
+function makeClerkMock(overrides: {
+  post?: (req: unknown) => Promise<WritDoc>;
+  setWritExt?: (writId: string, pluginId: string, value: unknown) => Promise<WritDoc>;
+  transition?: (id: string, to: string, fields?: unknown) => Promise<WritDoc>;
+} = {}): { clerk: ClerkApi; calls: ClerkCall[] } {
+  const calls: ClerkCall[] = [];
+  const baseWrit = makeWrit();
+
+  const clerk = {
+    async post(req: unknown): Promise<WritDoc> {
+      calls.push({ method: 'post', args: [req] });
+      return overrides.post ? overrides.post(req) : baseWrit;
+    },
+    async setWritExt(writId: string, pluginId: string, value: unknown): Promise<WritDoc> {
+      calls.push({ method: 'setWritExt', args: [writId, pluginId, value] });
+      if (overrides.setWritExt) return overrides.setWritExt(writId, pluginId, value);
+      return makeWrit({ id: writId, ext: { [pluginId]: value } });
+    },
+    async transition(id: string, to: string, fields?: unknown): Promise<WritDoc> {
+      calls.push({ method: 'transition', args: [id, to, fields] });
+      if (overrides.transition) return overrides.transition(id, to, fields);
+      return makeWrit({ id, phase: to });
+    },
+    // Stub out the rest of the interface to satisfy the type
+    async show() { return baseWrit; },
+    async resolveId(prefix: string) { return prefix; },
+    async list() { return []; },
+    async count() { return 0; },
+    async countActive() { return 0; },
+    async tree() { return []; },
+    async countDescendantsByPhase() { return {} as never; },
+    async link() { return {} as never; },
+    async links() { return { outbound: [], inbound: [] }; },
+    async unlink() { return; },
+    async edit() { return baseWrit; },
+    listWritTypes() { return []; },
+    async listKinds() { return []; },
+    registerWritType() { return; },
+    getWritTypeConfig() { return undefined; },
+    isInitial() { return true; },
+    isActive() { return false; },
+    isTerminal() { return false; },
+    setWritStatus: async (writId: string, pluginId: string, value: unknown) => {
+      return makeWrit({ id: writId, status: { [pluginId]: value } });
+    },
+  } satisfies ClerkApi;
+
+  return { clerk, calls };
+}
+
+// ── Helpers ───────────────────────────────────────────────────────────
+
+function makeRegistry(sources: Array<{ pluginId: string; source: string }> = []) {
+  const reg = new PetitionerRegistry();
+  for (const { pluginId, source } of sources) {
+    reg.register(pluginId, { source, description: `${source} test source` });
+  }
+  reg.seal();
+  return reg;
+}
+
+function makeConfig(overrides: Partial<ResolvedReckonerConfig> = {}): ResolvedReckonerConfig {
+  return {
+    enforceRegistration: false,
+    disabledSources: [],
+    ...overrides,
+  };
+}
+
+// ── executePetition ───────────────────────────────────────────────────
+
+describe('executePetition', () => {
+  describe('source registration checks', () => {
+    it('succeeds with warning when source is unregistered and enforceRegistration is false', async () => {
+      const { clerk, calls } = makeClerkMock();
+      const reg = makeRegistry(); // empty registry
+      const config = makeConfig({ enforceRegistration: false });
+      const warnCalls: unknown[] = [];
+      const origWarn = console.warn;
+      console.warn = (...args: unknown[]) => { warnCalls.push(args); };
+      try {
+        await executePetition(clerk, reg, config, {
+          type: 'mandate',
+          title: 'Test',
+          body: 'body',
+          codex: 'nexus',
+          source: 'unknown.source',
+          priority: {},
+        });
+      } finally {
+        console.warn = origWarn;
+      }
+      // Should have called post and setWritExt
+      assert.ok(calls.some((c) => c.method === 'post'));
+      assert.ok(calls.some((c) => c.method === 'setWritExt'));
+      // Should have logged a warning
+      assert.ok(warnCalls.length > 0);
+      assert.ok(
+        warnCalls.some((args) =>
+          (args as string[]).some((a) => String(a).includes('not registered')),
+        ),
+      );
+    });
+
+    it('throws fail-loud when source is unregistered and enforceRegistration is true', async () => {
+      const { clerk, calls } = makeClerkMock();
