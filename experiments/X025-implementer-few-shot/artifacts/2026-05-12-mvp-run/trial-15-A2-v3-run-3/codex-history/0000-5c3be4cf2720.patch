+++ b/packages/plugins/reckoner/src/registry.test.ts
@@ -0,0 +1,300 @@
+/**
+ * Tests for validateSourceId and PetitionerRegistry.
+ *
+ * Covers:
+ * - Source-id grammar validation (§5 "Source-id grammar").
+ * - Successful registration of valid petitioner sources.
+ * - Hard-error cases: duplicate source, malformed id, wrong prefix, post-seal.
+ * - Registry sealing.
+ * - isRegistered() and getAll() query methods.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { validateSourceId, PetitionerRegistry } from './registry.ts';
+
+// ── validateSourceId ──────────────────────────────────────────────────
+
+describe('validateSourceId', () => {
+  describe('valid ids', () => {
+    const valid = [
+      'vision-keeper.snapshot',
+      'patron-bridge.commission',
+      'tech-debt.detected',
+      'my-plugin.my-event',
+      'simple.source',
+      'a.b',
+      'abc.def',
+      'ab1.cd2',
+      'multi-part-plugin.multi-part-suffix',
+      'plugin1.source2',
+    ];
+
+    for (const id of valid) {
+      it(`accepts '${id}'`, () => {
+        assert.equal(validateSourceId(id), true);
+      });
+    }
+  });
+
+  describe('invalid ids', () => {
+    const invalid = [
+      // Missing dot separator
+      { id: 'nodot', reason: 'no dot separator' },
+      // Missing prefix
+      { id: '.no-prefix', reason: 'empty prefix' },
+      // Missing suffix
+      { id: 'no-suffix.', reason: 'empty suffix' },
+      // Uppercase letters
+      { id: 'Upper.Case', reason: 'uppercase letter in prefix' },
+      { id: 'plugin.Upper', reason: 'uppercase letter in suffix' },
+      // Special characters
+      { id: 'bad!.source', reason: 'bang in prefix' },
+      { id: 'plugin.bad!', reason: 'bang in suffix' },
+      // Leading/trailing hyphens in prefix
+      { id: '-leading.suffix', reason: 'leading hyphen in prefix' },
+      { id: 'trailing-.suffix', reason: 'trailing hyphen in prefix' },
+      // Leading/trailing hyphens in suffix
+      { id: 'plugin.-leading', reason: 'leading hyphen in suffix' },
+      { id: 'plugin.trailing-', reason: 'trailing hyphen in suffix' },
+      // Double dots
+      { id: 'double..dot', reason: 'double dot' },
+      // Empty string
+      { id: '', reason: 'empty string' },
+      // Only spaces
+      { id: '   ', reason: 'whitespace only' },
+      // Consecutive hyphens
+      { id: 'double--hyphen.suffix', reason: 'consecutive hyphens in prefix' },
+      { id: 'prefix.double--hyphen', reason: 'consecutive hyphens in suffix' },
+    ];
+
+    for (const { id, reason } of invalid) {
+      it(`rejects '${id}' (${reason})`, () => {
+        assert.equal(validateSourceId(id), false);
+      });
+    }
+  });
+});
+
+// ── PetitionerRegistry ────────────────────────────────────────────────
+
+describe('PetitionerRegistry', () => {
+  describe('register — success path', () => {
+    it('registers a valid petitioner source', () => {
+      const reg = new PetitionerRegistry();
+      reg.register('vision-keeper', {
+        source: 'vision-keeper.snapshot',
+        description: 'Vision snapshots.',
+      });
+      assert.equal(reg.isRegistered('vision-keeper.snapshot'), true);
+    });
+
+    it('registers multiple distinct sources from different plugins', () => {
+      const reg = new PetitionerRegistry();
+      reg.register('vision-keeper', {
+        source: 'vision-keeper.snapshot',
+        description: 'Vision snapshots.',
+      });
+      reg.register('patron-bridge', {
+        source: 'patron-bridge.commission',
+        description: 'Patron commissions.',
+      });
+      assert.equal(reg.isRegistered('vision-keeper.snapshot'), true);
+      assert.equal(reg.isRegistered('patron-bridge.commission'), true);
+    });
+
+    it('registers multiple sources from the same plugin', () => {
+      const reg = new PetitionerRegistry();
+      reg.register('my-plugin', {
+        source: 'my-plugin.first',
+        description: 'First source.',
+      });
+      reg.register('my-plugin', {
+        source: 'my-plugin.second',
+        description: 'Second source.',
+      });
+      assert.equal(reg.isRegistered('my-plugin.first'), true);
+      assert.equal(reg.isRegistered('my-plugin.second'), true);
+    });
+  });
+
+  describe('register — error: duplicate source', () => {
+    it('throws naming both plugin ids when the same source is contributed twice from different plugins', () => {
+      const reg = new PetitionerRegistry();
+      reg.register('vision-keeper', {
+        source: 'vision-keeper.snapshot',
+        description: 'First.',
+      });
+      // Attempt to register the same source from a different plugin
+      // (prefix check would fail first for 'other-plugin', so use a source
+      // that matches both validation criteria to reach the duplicate check)
+      assert.throws(
+        () =>
+          reg.register('vision-keeper', {
+            source: 'vision-keeper.snapshot',
+            description: 'Second.',
+          }),
+        (err: Error) => {
+          assert.match(err.message, /Duplicate petitioner source/);
+          assert.match(err.message, /vision-keeper\.snapshot/);
+          return true;
+        },
+      );
+    });
+
+    it('error message names both contributing plugin ids', () => {
+      const reg = new PetitionerRegistry();
+      // Register from plugin-a
+      reg.register('plugin-a', {
+        source: 'plugin-a.source',
+        description: 'Plugin A source.',
+      });
+      // Attempt duplicate from same plugin-a (only same plugin can share prefix)
+      let caught: Error | undefined;
+      try {
+        reg.register('plugin-a', {
+          source: 'plugin-a.source',
+          description: 'Duplicate.',
+        });
+      } catch (e) {
+        caught = e as Error;
+      }
+      assert.ok(caught, 'expected an error to be thrown');
+      assert.match(caught.message, /plugin-a/);
+    });
+  });
+
+  describe('register — error: malformed source id', () => {
+    it('throws on source id without a dot', () => {
+      const reg = new PetitionerRegistry();
+      assert.throws(
+        () => reg.register('bad', { source: 'nodot', description: 'test' }),
+        /Malformed source id/,
+      );
+    });
+
+    it('throws on source id with uppercase', () => {
+      const reg = new PetitionerRegistry();
+      assert.throws(
+        () => reg.register('bad', { source: 'Bad.source', description: 'test' }),
+        /Malformed source id/,
+      );
+    });
+
+    it('throws on source id with special characters', () => {
+      const reg = new PetitionerRegistry();
+      assert.throws(
+        () => reg.register('bad', { source: 'bad!.source', description: 'test' }),
+        /Malformed source id/,
+      );
+    });
+  });
+
+  describe('register — error: wrong prefix', () => {
+    it('throws when the source id prefix does not match the contributing plugin id', () => {
+      const reg = new PetitionerRegistry();
+      assert.throws(
+        () =>
+          reg.register('other-plugin', {
+            source: 'vision-keeper.snapshot',
+            description: 'test',
+          }),
+        (err: Error) => {
+          assert.match(err.message, /must be prefixed with the contributing plugin id/);
+          assert.match(err.message, /other-plugin/);
+          return true;
+        },
+      );
+    });
+  });
+
+  describe('register — error: post-seal registration', () => {
+    it('throws when register() is called after seal()', () => {
+      const reg = new PetitionerRegistry();
+      reg.seal();
+      assert.throws(
+        () =>
+          reg.register('vision-keeper', {
+            source: 'vision-keeper.snapshot',
+            description: 'test',
+          }),
+        /Registry is sealed/,
+      );
+    });
+
+    it('pre-seal registrations are preserved after sealing', () => {
+      const reg = new PetitionerRegistry();
+      reg.register('vision-keeper', {
+        source: 'vision-keeper.snapshot',
+        description: 'Snapshot.',
+      });
+      reg.seal();
+      assert.equal(reg.isRegistered('vision-keeper.snapshot'), true);
+    });
+  });
+
+  describe('isRegistered', () => {
+    it('returns false for an unregistered source', () => {
+      const reg = new PetitionerRegistry();
+      assert.equal(reg.isRegistered('unknown.source'), false);
+    });
+
+    it('returns false for an empty string', () => {
+      const reg = new PetitionerRegistry();
+      assert.equal(reg.isRegistered(''), false);
+    });
+  });
+
+  describe('isSealed', () => {
+    it('is false before seal()', () => {
+      const reg = new PetitionerRegistry();
+      assert.equal(reg.isSealed, false);
+    });
+
+    it('is true after seal()', () => {
+      const reg = new PetitionerRegistry();
+      reg.seal();
+      assert.equal(reg.isSealed, true);
+    });
+
+    it('seal() is idempotent', () => {
+      const reg = new PetitionerRegistry();
+      reg.seal();
+      reg.seal(); // should not throw
+      assert.equal(reg.isSealed, true);
+    });
+  });
+
+  describe('getAll', () => {
+    it('returns empty array when no sources are registered', () => {
+      const reg = new PetitionerRegistry();
+      assert.deepEqual(reg.getAll(), []);
+    });
+
+    it('returns all registered descriptors', () => {
+      const reg = new PetitionerRegistry();
+      const d1 = { source: 'vision-keeper.snapshot', description: 'A' };
+      const d2 = { source: 'patron-bridge.commission', description: 'B' };
+      reg.register('vision-keeper', d1);
+      reg.register('patron-bridge', d2);
+      const all = reg.getAll();
+      assert.equal(all.length, 2);
+      assert.ok(all.some((d) => d.source === d1.source && d.description === d1.description));
+      assert.ok(all.some((d) => d.source === d2.source && d.description === d2.description));
+    });
+
+    it('returns a snapshot — mutations to the registry afterwards are not reflected', () => {
+      const reg = new PetitionerRegistry();
+      reg.register('plugin-a', { source: 'plugin-a.first', description: 'first' });
+      const snapshot1 = reg.getAll();
+      assert.equal(snapshot1.length, 1);
+
+      reg.register('plugin-b', { source: 'plugin-b.second', description: 'second' });
+      const snapshot2 = reg.getAll();
+      assert.equal(snapshot2.length, 2);
+      // snapshot1 is frozen in time
+      assert.equal(snapshot1.length, 1);
+    });
+  });
+});
