+/**
+ * Priority default-filling helper.
+ *
+ * See: docs/architecture/petitioner-registration.md §3 "Defaults when omitted"
+ */
+
+import type { Priority } from './types.ts';
+
+/**
+ * The contract-specified defaults for omitted priority dimensions.
+ *
+ * vision-neutral / minor / minor-area / {decay: false, deadline: null} / []
+ */
+export const DEFAULT_PRIORITY: Readonly<Priority> = Object.freeze({
+  visionRelation: 'vision-neutral' as const,
+  severity: 'minor' as const,
+  scope: 'minor-area' as const,
+  time: Object.freeze({ decay: false, deadline: null }) as {
+    readonly decay: boolean;
+    readonly deadline: string | null;
+  },
+  domain: [] as Priority['domain'],
+});
+
+/**
+ * Apply the contract's default values for any omitted priority dimensions.
+ *
+ * The `reckoner.petition()` helper calls this before validation so callers
+ * never need to supply the full five-dimension object. Direct `clerk.post()`
+ * callers (Workflow 1) are responsible for supplying priority values, though
+ * omitted dimension fields on the writ's ext fall back to these same defaults
+ * at CDC consideration time.
+ *
+ * Returns a fresh `Priority` object — the original `partial` is not mutated.
+ *
+ * @example
+ * // Only overriding visionRelation; other dimensions get defaults.
+ * const p = defaultPriority({ visionRelation: 'vision-violator' });
+ * // p.severity === 'minor', p.scope === 'minor-area', ...
+ */
+export function defaultPriority(partial?: Partial<Priority>): Priority {
+  if (!partial) {
+    return {
+      visionRelation: DEFAULT_PRIORITY.visionRelation,
+      severity: DEFAULT_PRIORITY.severity,
+      scope: DEFAULT_PRIORITY.scope,
+      time: { decay: DEFAULT_PRIORITY.time.decay, deadline: DEFAULT_PRIORITY.time.deadline },
+      domain: [],
+    };
+  }
+
+  return {
+    visionRelation: partial.visionRelation ?? DEFAULT_PRIORITY.visionRelation,
+    severity: partial.severity ?? DEFAULT_PRIORITY.severity,
+    scope: partial.scope ?? DEFAULT_PRIORITY.scope,
+    time: {
+      decay: partial.time?.decay ?? DEFAULT_PRIORITY.time.decay,
+      deadline: partial.time?.deadline ?? DEFAULT_PRIORITY.time.deadline,
+    },
+    domain: partial.domain !== undefined ? [...partial.domain] : [],
+  };
+}
