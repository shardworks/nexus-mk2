+/**
+ * Tests for defaultPriority().
+ *
+ * Covers:
+ * - No-arg call returns full defaults.
+ * - Empty-object call returns full defaults.
+ * - Each dimension can be overridden independently.
+ * - The time sub-object is merged field by field, not replaced wholesale.
+ * - The returned object is a new value (not a reference to DEFAULT_PRIORITY).
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { defaultPriority, DEFAULT_PRIORITY } from './defaults.ts';
+import type { Priority } from './types.ts';
+
+describe('defaultPriority', () => {
+  describe('called with no argument', () => {
+    it('returns the contract-specified defaults', () => {
+      const p = defaultPriority();
+      assert.equal(p.visionRelation, 'vision-neutral');
+      assert.equal(p.severity, 'minor');
+      assert.equal(p.scope, 'minor-area');
+      assert.equal(p.time.decay, false);
+      assert.equal(p.time.deadline, null);
+      assert.deepEqual(p.domain, []);
+    });
+
+    it('matches DEFAULT_PRIORITY', () => {
+      const p = defaultPriority();
+      assert.equal(p.visionRelation, DEFAULT_PRIORITY.visionRelation);
+      assert.equal(p.severity, DEFAULT_PRIORITY.severity);
+      assert.equal(p.scope, DEFAULT_PRIORITY.scope);
+      assert.equal(p.time.decay, DEFAULT_PRIORITY.time.decay);
+      assert.equal(p.time.deadline, DEFAULT_PRIORITY.time.deadline);
+      assert.deepEqual(p.domain, DEFAULT_PRIORITY.domain);
+    });
+  });
+
+  describe('called with an empty object', () => {
+    it('returns the same defaults as a no-arg call', () => {
+      const p = defaultPriority({});
+      assert.equal(p.visionRelation, 'vision-neutral');
+      assert.equal(p.severity, 'minor');
+      assert.equal(p.scope, 'minor-area');
+      assert.equal(p.time.decay, false);
+      assert.equal(p.time.deadline, null);
+      assert.deepEqual(p.domain, []);
+    });
+  });
+
+  describe('overriding individual dimensions', () => {
+    it('overrides visionRelation only', () => {
+      const p = defaultPriority({ visionRelation: 'vision-violator' });
+      assert.equal(p.visionRelation, 'vision-violator');
+      assert.equal(p.severity, 'minor');
+      assert.equal(p.scope, 'minor-area');
+    });
+
+    it('overrides severity only', () => {
+      const p = defaultPriority({ severity: 'critical' });
+      assert.equal(p.visionRelation, 'vision-neutral');
+      assert.equal(p.severity, 'critical');
+      assert.equal(p.scope, 'minor-area');
+    });
+
+    it('overrides scope only', () => {
+      const p = defaultPriority({ scope: 'whole-product' });
+      assert.equal(p.scope, 'whole-product');
+      assert.equal(p.visionRelation, 'vision-neutral');
+      assert.equal(p.severity, 'minor');
+    });
+
+    it('overrides time.decay only', () => {
+      const p = defaultPriority({ time: { decay: true, deadline: null } });
+      assert.equal(p.time.decay, true);
+      assert.equal(p.time.deadline, null);
+    });
+
+    it('overrides time.deadline only', () => {
+      const p = defaultPriority({ time: { decay: false, deadline: '2025-06-01' } });
+      assert.equal(p.time.decay, false);
+      assert.equal(p.time.deadline, '2025-06-01');
+    });
+
+    it('overrides both time fields', () => {
+      const p = defaultPriority({ time: { decay: true, deadline: '2025-12-31' } });
+      assert.equal(p.time.decay, true);
+      assert.equal(p.time.deadline, '2025-12-31');
+    });
+
+    it('overrides domain', () => {
+      const p = defaultPriority({ domain: ['security', 'quality'] });
+      assert.deepEqual(p.domain, ['security', 'quality']);
+    });
+
+    it('preserves empty domain array when explicitly provided', () => {
+      const p = defaultPriority({ domain: [] });
+      assert.deepEqual(p.domain, []);
+    });
+  });
+
+  describe('full override', () => {
+    it('preserves all provided values when all dimensions are given', () => {
+      const input: Partial<Priority> = {
+        visionRelation: 'vision-blocker',
+        severity: 'critical',
+        scope: 'whole-product',
+        time: { decay: true, deadline: '2025-03-15' },
+        domain: ['security', 'compliance'],
+      };
+      const p = defaultPriority(input);
+      assert.equal(p.visionRelation, 'vision-blocker');
+      assert.equal(p.severity, 'critical');
+      assert.equal(p.scope, 'whole-product');
+      assert.equal(p.time.decay, true);
+      assert.equal(p.time.deadline, '2025-03-15');
+      assert.deepEqual(p.domain, ['security', 'compliance']);
+    });
+  });
+
+  describe('returned value is independent of DEFAULT_PRIORITY', () => {
+    it('mutations to the returned object do not affect DEFAULT_PRIORITY', () => {
+      const p = defaultPriority() as Priority & { time: { decay: boolean } };
+      p.time.decay = true;
+      // DEFAULT_PRIORITY is frozen — this also verifies the returned `time`
+      // is a new object, not a reference to the frozen DEFAULT_PRIORITY.time.
+      assert.equal(DEFAULT_PRIORITY.time.decay, false);
+    });
+  });
+});
