+      const config = makeConfig({ enforceRegistration: true });
+
+      await assert.rejects(
+        () =>
+          executePetition(clerk, reg, config, {
+            type: 'mandate',
+            title: 'Test',
+            body: 'body',
+            codex: 'nexus',
+            source: 'unknown.source',
+            priority: {},
+          }),
+        /Unregistered petitioner source/,
+      );
+
+      // No writ should have been posted
+      assert.equal(calls.filter((c) => c.method === 'post').length, 0);
+    });
+
+    it('succeeds when source is registered and enforceRegistration is true', async () => {
+      const { clerk, calls } = makeClerkMock();
+      const reg = makeRegistry([
+        { pluginId: 'vision-keeper', source: 'vision-keeper.snapshot' },
+      ]);
+      const config = makeConfig({ enforceRegistration: true });
