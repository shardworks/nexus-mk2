+      font-family: var(--font-mono, monospace);
+    }
+    .action-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
+    tr.click-child-row { cursor: pointer; }
+    tr.click-child-row:hover { opacity: 0.85; }
+    .empty-pane {
+      color: var(--text-dim, #565f89);
+      font-size: 0.875rem;
+      padding: 32px 16px;
+      text-align: center;
+    }
+    .detail-header { margin-bottom: 16px; }
+    .detail-header h2 { margin: 0 0 4px; font-size: 1rem; word-break: break-word; }
+    .detail-id-row { font-size: 0.8rem; opacity: 0.6; display: flex; align-items: center; gap: 6px; }
+  </style>
+</head>
+<body>
+<main style="padding: 24px;">
+  <h1>Clicks</h1>
+
+  <div class="page-layout">
+    <!-- ── Tree area ──────────────────────────────────────────────── -->
+    <div class="tree-area" id="tree-area">
+
+      <!-- Toolbar -->
+      <div class="card">
+        <div class="toolbar" id="toolbar">
+          <button class="btn btn--primary" id="btn-new-click">New Click</button>
+          <button class="btn" id="btn-refresh">Refresh</button>
+          <span style="display:inline-flex;gap:0.4rem;flex-wrap:wrap;align-items:center">
+            <span style="font-size:0.875rem;opacity:0.6">Status:</span>
+            <button class="btn filter-btn active-filter" data-status="">All</button>
+            <button class="btn filter-btn active-filter" data-status="live">live</button>
+            <button class="btn filter-btn active-filter" data-status="parked">parked</button>
+            <button class="btn filter-btn active-filter" data-status="concluded">concluded</button>
+            <button class="btn filter-btn active-filter" data-status="dropped">dropped</button>
+          </span>
+        </div>
+      </div>
+
+      <!-- Create form (toggleable) -->
+      <div id="create-section" class="card">
+        <h3 style="margin:0 0 0.75rem">New Click</h3>
+        <div class="form-row">
+          <label for="create-goal-input">Goal <span style="color:var(--red,#f7768e)">*</span></label>
+          <input type="text" id="create-goal-input" placeholder="Short description of the task or goal">
+        </div>
+        <div class="form-row">
+          <label for="create-parent-input">Parent ID (optional)</label>
+          <input type="text" id="create-parent-input" placeholder="c-… (leave blank for root click)">
+        </div>
+        <div style="display:flex;gap:0.5rem;align-items:center">
+          <button class="btn btn--primary" id="create-submit-btn">Create Click</button>
+          <button class="btn" id="create-cancel-btn">Cancel</button>
+        </div>
+        <div id="create-error" class="error-msg" style="display:none"></div>
+      </div>
+
+      <!-- Breadcrumb (shown when subtree-scoped) -->
+      <div id="breadcrumb-area" style="display:none"></div>
+
+      <!-- Tree container -->
+      <div class="card" id="tree-container" style="flex:1;min-height:0;overflow-y:auto">
+        <div id="tree-root"></div>
+      </div>
+    </div>
+
+    <!-- ── Detail pane ────────────────────────────────────────────── -->
+    <div class="detail-pane" id="detail-pane">
+      <div class="empty-pane" id="detail-empty">Select a click to view its details.</div>
+      <div id="detail-content" style="display:none"></div>
+    </div>
+  </div>
+</main>
+
+<script>
+(() => {
+  // ── Constants ──────────────────────────────────────────────────────
+  const ALL_STATUSES = ['live', 'parked', 'concluded', 'dropped'];
+  const LINK_TYPES = ['related', 'commissioned', 'supersedes', 'depends-on'];
+
+  // ── State ──────────────────────────────────────────────────────────
+  let fullForest = [];         // ClickTree[] — full unfiltered forest from API
+  let selectedId = null;       // string | null — currently selected click ID
+  let scopeId = null;          // string | null — subtree scope root ID
+  let statusFilter = new Set(ALL_STATUSES); // active status filters
+  let expandedNodes = new Set(); // IDs of expanded nodes
+  let metadataCache = {};      // { [id]: { goal, status } } — lazy link-target metadata
+
+  // ── URL helpers ────────────────────────────────────────────────────
+
+  function getUrlParams() {
+    const p = new URLSearchParams(window.location.search);
+    return { click: p.get('click'), root: p.get('root') };
+  }
+
+  function pushUrlState(click, root) {
+    const p = new URLSearchParams();
+    if (root) p.set('root', root);
+    if (click) p.set('click', click);
+    const qs = p.toString();
+    history.pushState({}, '', qs ? '?' + qs : window.location.pathname);
+  }
+
+  // ── Utility helpers ────────────────────────────────────────────────
+
+  async function api(method, path, body) {
+    const opts = { method, headers: { 'Content-Type': 'application/json' } };
+    if (body !== undefined) opts.body = JSON.stringify(body);
+    const res = await fetch(path, opts);
+    const json = await res.json();
+    if (!res.ok) throw new Error(json.error ?? `HTTP ${res.status}`);
+    return json;
+  }
+
+  function statusBadge(status) {
+    const map = {
+      live:      'badge badge--active',
+      parked:    'badge badge--warning',
+      concluded: 'badge badge--success',
+      dropped:   'badge badge--error',
+    };
+    const cls = map[status] ?? 'badge';
+    return `<span class="${cls}">${status}</span>`;
+  }
+
+  function fmtDate(iso) {
+    if (!iso) return '';
+    return new Date(iso).toLocaleString();
+  }
+
+  function escHtml(s) {
+    return String(s ?? '')
+      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
+      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+  }
+
+  function escAttr(s) {
+    return String(s ?? '')
+      .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
+      .replace(/</g, '&lt;').replace(/>/g, '&gt;');
+  }
+
+  function showError(el, msg) { el.textContent = msg; el.style.display = 'block'; }
+  function clearError(el) { el.textContent = ''; el.style.display = 'none'; }
+
+  async function copyToClipboard(text, btn) {
+    try {
+      await navigator.clipboard.writeText(text);
+      const orig = btn.textContent;
+      btn.textContent = '✓';
+      setTimeout(() => { btn.textContent = orig; }, 1500);
+    } catch (e) { console.error('Copy failed:', e); }
+  }
+
+  // ── Pure tree logic (also used by companion tests) ─────────────────
+
+  /**
+   * Prune the forest by status set.
+   * Non-matching nodes and their entire subtrees are removed.
+   */
+  function pruneByStatus(forest, statusSet) {
+    function pruneNode(node) {
+      if (!statusSet.has(node.click.status)) return null;
+      const children = node.children.map(pruneNode).filter(Boolean);
+      return { click: node.click, children };
+    }
+    return forest.map(pruneNode).filter(Boolean);
+  }
+
+  /**
+   * Find the subtree rooted at rootId within the forest.
+   * Returns a single-element ClickTree[] if found, null otherwise.
+   */
+  function findSubtree(forest, rootId) {
+    for (const node of forest) {
+      if (node.click.id === rootId) return [node];
+      const found = findSubtree(node.children, rootId);
+      if (found) return found;
+    }
+    return null;
+  }
+
+  /**
+   * Build breadcrumb path from forest root down to targetId.
+   * Returns array of { id, goal } from outermost ancestor to target,
+   * or null if targetId is not found.
+   */
+  function buildBreadcrumb(forest, targetId, path) {
+    path = path || [];
+    for (const node of forest) {
+      const newPath = path.concat({ id: node.click.id, goal: node.click.goal });
+      if (node.click.id === targetId) return newPath;
+      const found = buildBreadcrumb(node.children, targetId, newPath);
+      if (found) return found;
+    }
+    return null;
+  }
+
+  /**
+   * Collect all click IDs from the forest recursively.
+   */
+  function collectAllIds(forest) {
+    const ids = [];
+    function walk(nodes) {
+      for (const n of nodes) {
+        ids.push(n.click.id);
+        walk(n.children);
+      }
+    }
+    walk(forest);
+    return ids;
+  }
+
+  /**
+   * Return short ID form: first two hyphen-delimited segments (e.g. c-mo1mq8ry).
+   */
+  function shortClickId(id) {
+    const parts = id.split('-');
+    return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+  }
+
+  /**
+   * Render a link target as HTML based on its ID prefix.
+   * c-… → clickable to open click detail in-page
+   * w-… → link navigating to /pages/writs/?writ=<id>
+   * other → plain escaped text
+   */
+  function renderLinkTarget(targetId) {
+    const esc = escHtml(targetId);
+    const attr = escAttr(targetId);
+    if (targetId.startsWith('c-')) {
+      return `<a class="link-target" data-action="open-click" data-id="${attr}">${esc}</a>`;
+    }
+    if (targetId.startsWith('w-')) {
+      const url = `/pages/writs/?writ=${encodeURIComponent(targetId)}`;
+      return `<a class="link-target" href="${url}">${esc}</a>`;
+    }
+    return esc;
+  }
+
+  // ── Data loading ────────────────────────────────────────────────────
+
+  async function loadTree() {
+    // Always fetch the full unfiltered forest; apply scope + status client-side.
+    try {
+      fullForest = await api('GET', '/api/click/tree?format=json');
+    } catch (e) {
+      console.error('Failed to load click tree:', e);
+      fullForest = [];
+    }
+
+    // Expand any newly-seen node by default (D8: all nodes expanded by default).
+    for (const id of collectAllIds(fullForest)) {
+      if (!expandedNodes.has(id)) expandedNodes.add(id);
+    }
+
+    renderTree();
+    renderBreadcrumb();
+  }
+
+  // ── Tree rendering ──────────────────────────────────────────────────
+
+  function renderTree() {
+    const container = document.getElementById('tree-root');
+
+    // Determine the display forest: scope first, then prune by status.
+    let displayForest = fullForest;
+    if (scopeId) {
+      displayForest = findSubtree(fullForest, scopeId) || [];
+    }
+    const allSelected = ALL_STATUSES.every(s => statusFilter.has(s));
+    if (!allSelected) {
+      displayForest = pruneByStatus(displayForest, statusFilter);
+    }
+
+    if (displayForest.length === 0) {
+      container.innerHTML = '<div class="empty-state">No clicks match the current filters.</div>';
+      return;
+    }
+
+    container.innerHTML = '';
+    for (const node of displayForest) {
+      container.appendChild(buildNodeEl(node));
+    }
+  }
+
+  function buildNodeEl(node) {
+    const click = node.click;
+    const hasChildren = node.children.length > 0;
+    const isExpanded = expandedNodes.has(click.id);
+    const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+    const shortId = shortClickId(click.id);
+
+    const wrapper = document.createElement('div');
+    wrapper.className = 'click-node';
+
+    // ── Node row ──
+    const row = document.createElement('div');
+    row.className = 'node-row' + (selectedId === click.id ? ' selected' : '');
+    row.dataset.id = click.id;
+
+    // Expand/collapse toggle for children
+    const toggle = document.createElement('button');
+    toggle.className = 'toggle-btn';
+    if (hasChildren) {
+      toggle.textContent = isExpanded ? '▾' : '▸';
+      toggle.title = isExpanded ? 'Collapse' : 'Expand';
+    } else {
+      toggle.textContent = ' ';
+      toggle.disabled = true;
+    }
+
+    // Status badge
+    const badgeWrap = document.createElement('span');
+    badgeWrap.innerHTML = statusBadge(click.status);
+
+    // Short ID (click to copy full ID)
+    const idSpan = document.createElement('span');
+    idSpan.className = 'node-id';
+    idSpan.textContent = shortId;
+    idSpan.title = 'Copy: ' + click.id;
+
+    // Goal label (click to open in detail pane)
+    const label = document.createElement('span');
+    label.className = 'node-label';
+    label.textContent = click.goal;
+    label.title = click.goal;
+
+    // Focus button (scope tree to this subtree)
+    const focusBtn = document.createElement('button');
+    focusBtn.className = 'focus-btn';
+    focusBtn.textContent = 'focus';
+    focusBtn.title = 'Scope tree to this subtree';
+
+    row.appendChild(toggle);
+    row.appendChild(badgeWrap);
+    row.appendChild(idSpan);
+    row.appendChild(label);
+    row.appendChild(focusBtn);
+    wrapper.appendChild(row);
+
+    // ── Inline conclusion disclosure (D10) ──
+    if (isTerminal && click.conclusion) {
+      const details = document.createElement('details');
+      details.className = 'inline-conclusion';
+      const summary = document.createElement('summary');
+      summary.textContent = '▸ Conclusion';
+      const body = document.createElement('div');
+      body.className = 'conc-body';
+      body.textContent = click.conclusion;
+      details.appendChild(summary);
+      details.appendChild(body);
+      wrapper.appendChild(details);
+    }
+
+    // ── Children container ──
+    if (hasChildren) {
+      const childrenDiv = document.createElement('div');
+      childrenDiv.className = 'node-children';
+      childrenDiv.dataset.parentId = click.id;
+      childrenDiv.style.display = isExpanded ? '' : 'none';
+      for (const child of node.children) {
+        childrenDiv.appendChild(buildNodeEl(child));
+      }
+      wrapper.appendChild(childrenDiv);
+    }
+
+    // ── Wire node events ──
+    toggle.addEventListener('click', (e) => {
+      e.stopPropagation();
+      const childrenDiv = wrapper.querySelector(`.node-children[data-parent-id="${click.id}"]`);
+      if (expandedNodes.has(click.id)) {
+        expandedNodes.delete(click.id);
+        toggle.textContent = '▸';
+        toggle.title = 'Expand';
+        if (childrenDiv) childrenDiv.style.display = 'none';
+      } else {
+        expandedNodes.add(click.id);
+        toggle.textContent = '▾';
+        toggle.title = 'Collapse';
+        if (childrenDiv) childrenDiv.style.display = '';
+      }
+    });
+
+    idSpan.addEventListener('click', (e) => {
+      e.stopPropagation();
+      copyToClipboard(click.id, idSpan);
+    });
+
+    label.addEventListener('click', () => selectClick(click.id));
+
+    focusBtn.addEventListener('click', (e) => {
+      e.stopPropagation();
+      setScopeId(click.id);
+    });
+
+    return wrapper;
+  }
+
+  // ── Breadcrumb rendering ────────────────────────────────────────────
+
+  function renderBreadcrumb() {
+    const area = document.getElementById('breadcrumb-area');
+    if (!scopeId) {
+      area.style.display = 'none';
+      area.innerHTML = '';
+      return;
+    }
+
+    const crumb = buildBreadcrumb(fullForest, scopeId) || [];
+    let html = '<div class="breadcrumb">';
+    html += `<a class="breadcrumb-link" data-action="show-all">Show all</a>`;
+    for (let i = 0; i < crumb.length; i++) {
+      html += `<span class="breadcrumb-sep">›</span>`;
+      const seg = crumb[i];
+      if (i === crumb.length - 1) {
+        html += `<span>${escHtml(seg.goal)}</span>`;
+      } else {
+        html += `<a class="breadcrumb-link" data-action="scope-to" data-id="${escAttr(seg.id)}">${escHtml(seg.goal)}</a>`;
+      }
+    }
+    html += '</div>';
+    area.innerHTML = html;
+    area.style.display = 'block';
+
+    area.querySelector('[data-action="show-all"]')?.addEventListener('click', () => setScopeId(null));
+    area.querySelectorAll('[data-action="scope-to"]').forEach(a => {
+      a.addEventListener('click', () => setScopeId(a.dataset.id));
+    });
+  }
+
+  // ── Scope management ────────────────────────────────────────────────
+
+  function setScopeId(id) {
+    scopeId = id;
+    const params = getUrlParams();
+    pushUrlState(params.click, id);
+    renderTree();
+    renderBreadcrumb();
+  }
+
+  // ── Node selection ──────────────────────────────────────────────────
+
+  async function selectClick(id) {
+    selectedId = id;
+    const params = getUrlParams();
+    pushUrlState(id, params.root);
+
+    // Update selection styling
+    document.querySelectorAll('.node-row.selected').forEach(el => el.classList.remove('selected'));
+    document.querySelectorAll(`.node-row[data-id="${id}"]`).forEach(el => el.classList.add('selected'));
+
+    await loadDetail(id);
+  }
+
+  // ── Detail pane ─────────────────────────────────────────────────────
+
+  async function loadDetail(id) {
+    const content = document.getElementById('detail-content');
+    const empty = document.getElementById('detail-empty');
+
+    empty.style.display = 'none';
+    content.style.display = '';
+    content.innerHTML = '<div style="opacity:0.5;padding:16px">Loading…</div>';
+
+    try {
+      // click-show returns the click enriched with links, parent, and children.
+      const clickData = await api('GET', `/api/click/show?id=${encodeURIComponent(id)}`);
+      renderDetail(clickData);
+      // Lazily fetch metadata for link targets that are clicks.
+      fetchLinkMetadata(clickData);
+    } catch (e) {
+      content.innerHTML = `<div class="error-msg" style="padding:16px">Failed to load: ${escHtml(e.message)}</div>`;
+    }
+  }
+
+  // ── Detail pane rendering ───────────────────────────────────────────
+
+  function renderLinksSection(clickData) {
+    const outbound = clickData.links?.outbound ?? [];
+    const inbound = clickData.links?.inbound ?? [];
+    let html = '<h4>Links</h4>';
+
+    if (outbound.length === 0 && inbound.length === 0) {
+      html += '<p style="font-size:0.875rem;opacity:0.5">No links.</p>';
+    }
+
+    for (const l of outbound) {
+      const metaId = escAttr(l.targetId);
+      html += `<div class="link-row">
+        <span class="link-dir">→</span>
+        ${renderLinkTarget(l.targetId)}
+        <span class="link-meta" data-link-meta-id="${metaId}"></span>
+        <span style="font-size:0.8rem;opacity:0.6">(${escHtml(l.linkType)})</span>
+        <button class="btn btn--danger" style="padding:0.1rem 0.5rem;font-size:0.75rem"
+          data-action="unlink"
+          data-source="${escAttr(l.sourceId)}"
+          data-target="${escAttr(l.targetId)}"
+          data-link-type="${escAttr(l.linkType)}">×</button>
+      </div>`;
+    }
+    for (const l of inbound) {
+      const metaId = escAttr(l.sourceId);
+      html += `<div class="link-row">
+        <span class="link-dir">←</span>
+        ${renderLinkTarget(l.sourceId)}
+        <span class="link-meta" data-link-meta-id="${metaId}"></span>
+        <span style="font-size:0.8rem;opacity:0.6">(${escHtml(l.linkType)})</span>
+        <button class="btn btn--danger" style="padding:0.1rem 0.5rem;font-size:0.75rem"
+          data-action="unlink"
+          data-source="${escAttr(l.sourceId)}"
+          data-target="${escAttr(l.targetId)}"
+          data-link-type="${escAttr(l.linkType)}">×</button>
+      </div>`;
+    }
+
+    // Add-link form with select dropdown for link type (D14)
+    html += `<div class="add-link-form" id="add-link-form">
+      <input type="text" id="link-target-input" placeholder="Target ID (c-…, w-…)" style="width:160px">
+      <select id="link-type-select">`;
+    for (const lt of LINK_TYPES) {
+      html += `<option value="${lt}">${lt}</option>`;
+    }
+    html += `</select>
+      <button class="btn" data-action="addlink">Link</button>
+      <div class="error-msg" id="link-error" style="display:none"></div>
+    </div>`;
+
+    return html;
+  }
+
+  function renderActionsSection(clickData) {
+    const { status, id } = clickData;
+    let html = '<h4>Actions</h4>';
+
+    if (status === 'live') {
+      html += `<div class="action-buttons">
+        <button class="btn" data-action="park" data-id="${escAttr(id)}">Park</button>
+        <button class="btn btn--success" data-action="conclude" data-id="${escAttr(id)}">Conclude</button>
+        <button class="btn btn--danger" data-action="drop" data-id="${escAttr(id)}">Drop</button>
+      </div>`;
+    } else if (status === 'parked') {
+      html += `<div class="action-buttons">
+        <button class="btn btn--primary" data-action="resume" data-id="${escAttr(id)}">Resume</button>
+        <button class="btn btn--success" data-action="conclude" data-id="${escAttr(id)}">Conclude</button>
+        <button class="btn btn--danger" data-action="drop" data-id="${escAttr(id)}">Drop</button>
+      </div>`;
+    } else {
+      html += '<p style="font-size:0.875rem;opacity:0.5">Terminal — no lifecycle actions available.</p>';
+    }
+
+    html += '<div id="action-error" class="error-msg" style="display:none"></div>';
+    html += '<div id="confirm-area"></div>';
+
+    return html;
+  }
+
+  function renderDetail(clickData) {
+    const content = document.getElementById('detail-content');
+    const isTerminal = clickData.status === 'concluded' || clickData.status === 'dropped';
+
+    // ── Header ──
+    let html = `<div class="detail-header">
+      <h2>${escHtml(clickData.goal)}</h2>
+      <div class="detail-id-row">
+        <code>${escHtml(clickData.id)}</code>
+        <button class="btn" id="copy-id-btn" data-copy="${escAttr(clickData.id)}"
+          style="padding:0.1rem 0.3rem;font-size:0.7rem">📋</button>
+      </div>
+    </div>`;
+
+    // ── Fields (D24: all populated fields) ──
+    html += '<div class="detail-section"><h4>Details</h4><dl class="detail-grid">';
+    html += `<dt>ID</dt><dd><code>${escHtml(clickData.id)}</code></dd>`;
+    html += `<dt>Status</dt><dd>${statusBadge(clickData.status)}</dd>`;
+    if (clickData.parent) {
+      html += `<dt>Parent</dt><dd>
+        <a class="link-target" data-action="open-click" data-id="${escAttr(clickData.parent.id)}">
+          ${escHtml(clickData.parent.goal ?? clickData.parent.id)}</a>
+        ${statusBadge(clickData.parent.status)}
+      </dd>`;
+    }
+    html += `<dt>Created</dt><dd>${fmtDate(clickData.createdAt)}</dd>`;
+    if (clickData.resolvedAt) html += `<dt>Resolved</dt><dd>${fmtDate(clickData.resolvedAt)}</dd>`;
+    if (clickData.createdSessionId) html += `<dt>Session (created)</dt><dd><code>${escHtml(clickData.createdSessionId)}</code></dd>`;
+    if (clickData.resolvedSessionId) html += `<dt>Session (resolved)</dt><dd><code>${escHtml(clickData.resolvedSessionId)}</code></dd>`;
+    html += '</dl></div>';
+
+    // ── Conclusion (terminal clicks, expandable per D10 in detail pane) ──
+    if (isTerminal && clickData.conclusion) {
+      html += `<div class="detail-section"><h4>Conclusion</h4>
+        <details>
+          <summary style="cursor:pointer;font-size:0.875rem;color:var(--text-dim,#565f89)">▸ Show conclusion</summary>
+          <div style="margin-top:6px;padding:8px;background:var(--surface,#24283b);border-radius:4px;
+            font-size:0.875rem;white-space:pre-wrap;word-break:break-word">
+            ${escHtml(clickData.conclusion)}
+          </div>
+        </details>
+      </div>`;
+    }
+
+    // ── Children (D22: status-count badge strip + table) ──
+    const childItems = clickData.children?.items ?? [];
+    const summary = clickData.children?.summary ?? {};
+    if (childItems.length > 0 || Object.keys(summary).length > 0) {
+      html += '<div class="detail-section"><h4>Children</h4>';
+
+      if (Object.keys(summary).length > 0) {
+        html += '<div style="margin-bottom:0.5rem">';
+        for (const [st, count] of Object.entries(summary)) {
+          html += statusBadge(st) + ` <span style="margin-right:0.75rem">${count}</span>`;
+        }
+        html += '</div>';
+      }
+
+      if (childItems.length > 0) {
+        html += '<table class="data-table"><thead><tr>';
+        html += '<th>Status</th><th>Goal</th><th>ID</th>';
+        html += '</tr></thead><tbody>';
+        for (const child of childItems) {
+          html += `<tr class="click-child-row" data-child-id="${escAttr(child.id)}">`;
+          html += `<td>${statusBadge(child.status)}</td>`;
+          html += `<td>${escHtml(child.goal ?? '')}</td>`;
+          html += `<td><code>${escHtml(child.id)}</code></td>`;
+          html += '</tr>';
+        }
+        html += '</tbody></table>';
+      }
+      html += '</div>';
+    }
+
+    // ── Links ──
+    html += `<div class="detail-section" id="links-section">
+      ${renderLinksSection(clickData)}
+    </div>`;
+
+    // ── Lifecycle actions (D11: detail pane only) ──
+    html += `<div class="detail-section" id="actions-section">
+      ${renderActionsSection(clickData)}
+    </div>`;
+
+    content.innerHTML = html;
+    wireDetailEvents(content, clickData);
+  }
+
+  function wireDetailEvents(container, clickData) {
+    // Copy ID button
+    container.querySelector('#copy-id-btn')?.addEventListener('click', (e) => {
+      copyToClipboard(e.currentTarget.dataset.copy, e.currentTarget);
+    });
+
+    // In-page link target clicks (c- prefix)
+    container.querySelectorAll('.link-target[data-action="open-click"]').forEach(a => {
+      a.addEventListener('click', (e) => {
+        e.preventDefault();
+        e.stopPropagation();
+        selectClick(a.dataset.id);
+      });
+    });
+
+    // Child row clicks
+    container.querySelectorAll('.click-child-row').forEach(row => {
+      row.addEventListener('click', () => selectClick(row.dataset.childId));
+    });
+
+    // data-action buttons
+    container.querySelectorAll('[data-action]').forEach(btn => {
+      // Skip link-target anchors already wired above
+      if (btn.tagName === 'A') return;
+      btn.addEventListener('click', (e) => {
+        e.stopPropagation();
+        handleDetailAction(btn.dataset.action, btn.dataset.id ?? clickData.id, btn, container, clickData);
+      });
+    });
+  }
+
+  // ── Lazy metadata fetch for link targets (D16) ─────────────────────
+
+  async function fetchLinkMetadata(clickData) {
+    const outbound = clickData.links?.outbound ?? [];
+    const inbound = clickData.links?.inbound ?? [];
+    // Collect all c- prefixed target/source IDs not yet cached.
+    const ids = new Set([
+      ...outbound.map(l => l.targetId),
+      ...inbound.map(l => l.sourceId),
+    ].filter(id => id && id.startsWith('c-') && !metadataCache[id]));
+
+    for (const id of ids) {
+      try {
+        const data = await api('GET', `/api/click/show?id=${encodeURIComponent(id)}`);
+        metadataCache[id] = { goal: data.goal, status: data.status };
+        // Update any visible metadata spans for this ID.
+        document.querySelectorAll(`[data-link-meta-id="${escAttr(id)}"]`).forEach(el => {
+          el.textContent = data.goal ? `(${data.goal})` : '';
+        });
+      } catch (e) {
+        // Silently skip failed metadata fetches.
+      }
+    }
+  }
+
+  // ── Lifecycle action handlers ───────────────────────────────────────
+
+  function handleDetailAction(action, id, btn, container, clickData) {
+    if (action === 'park') {
+      doSimpleLifecycle('park', id, btn, container);
+    } else if (action === 'resume') {
+      doSimpleLifecycle('resume', id, btn, container);
+    } else if (action === 'conclude') {
+      showConfirm(id, 'conclude', container);
+    } else if (action === 'drop') {
+      showConfirm(id, 'drop', container);
+    } else if (action === 'unlink') {
+      doUnlink(btn.dataset.source, btn.dataset.target, btn.dataset.linkType, btn, id);
+    } else if (action === 'addlink') {
+      const targetInput = container.querySelector('#link-target-input');
+      const typeSelect = container.querySelector('#link-type-select');
+      const errEl = container.querySelector('#link-error');
+      doAddLink(id, targetInput?.value?.trim() ?? '', typeSelect?.value ?? '', btn, errEl, targetInput, typeSelect);
+    }
+  }
+
+  async function doSimpleLifecycle(action, id, btn, container) {
+    const errEl = container.querySelector('#action-error');
+    if (errEl) clearError(errEl);
+    const orig = btn.textContent;
+    btn.disabled = true;
+    btn.textContent = '…';
+    try {
+      await api('POST', `/api/click/${action}`, { id });
+      await refreshAfterMutation(id);
+    } catch (e) {
+      if (errEl) showError(errEl, e.message);
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  function showConfirm(id, action, container) {
+    const area = container.querySelector('#confirm-area');
+    const errEl = container.querySelector('#action-error');
+    if (errEl) clearError(errEl);
+    if (!area) return;
+
+    const isConclude = action === 'conclude';
+    const label = isConclude ? 'Conclusion (required)' : 'Conclusion / reason (required)';
+    const confirmText = isConclude ? 'Confirm Conclude' : 'Confirm Drop';
+    const btnCls = isConclude ? 'btn--success' : 'btn--danger';
+
+    area.innerHTML = `<div class="confirm-section">
+      <label>${label}</label>
+      <input type="text" id="confirm-text" placeholder="${label}">
+      <button class="btn ${btnCls}" id="confirm-btn" disabled>${confirmText}</button>
+      <div class="error-msg" id="confirm-error" style="display:none"></div>
+    </div>`;
+
+    const textInput = area.querySelector('#confirm-text');
+    const confirmBtn = area.querySelector('#confirm-btn');
+    const confirmErr = area.querySelector('#confirm-error');
+
+    textInput.addEventListener('input', () => {
+      confirmBtn.disabled = !textInput.value.trim();
+      clearError(confirmErr);
+    });
+
+    confirmBtn.addEventListener('click', async () => {
+      const conclusion = textInput.value.trim();
+      clearError(confirmErr);
+      confirmBtn.disabled = true;
+      confirmBtn.textContent = isConclude ? 'Concluding…' : 'Dropping…';
+      try {
+        await api('POST', `/api/click/${action}`, { id, conclusion });
+        area.innerHTML = '';
+        await refreshAfterMutation(id);
+      } catch (e) {
+        showError(confirmErr, e.message);
+        confirmBtn.disabled = false;
+        confirmBtn.textContent = confirmText;
+      }
+    });
+  }
+
+  async function doUnlink(sourceId, targetId, linkType, btn, clickId) {
+    const orig = btn.textContent;
+    btn.disabled = true;
+    try {
+      await api('POST', '/api/click/unlink', { sourceId, targetId, linkType });
+      await refreshAfterMutation(clickId);
+    } catch (e) {
+      alert(`Unlink failed: ${e.message}`);
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  async function doAddLink(clickId, targetId, linkType, btn, errEl, targetInput, typeSelect) {
+    if (errEl) clearError(errEl);
+    if (!targetId) {
+      if (errEl) showError(errEl, 'Target ID is required.');
+      return;
+    }
+    const orig = btn.textContent;
+    btn.disabled = true;
+    btn.textContent = 'Linking…';
+    try {
+      await api('POST', '/api/click/link', { sourceId: clickId, targetId, linkType });
+      if (targetInput) targetInput.value = '';
+      await refreshAfterMutation(clickId);
+    } catch (e) {
+      if (errEl) showError(errEl, e.message);
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  /**
+   * Full refetch after any mutation (D17): reload the tree and re-open the detail.
+   */
+  async function refreshAfterMutation(clickId) {
+    await loadTree();
+    if (clickId) await loadDetail(clickId);
+  }
+
+  // ── Status filter ───────────────────────────────────────────────────
+
+  function setStatusFilter(status) {
+    if (status === '') {
+      // "All" clicked → select all statuses
+      statusFilter = new Set(ALL_STATUSES);
+    } else {
+      const allActive = ALL_STATUSES.every(s => statusFilter.has(s));
+      if (allActive) {
+        // Break "all" state — select only the clicked status
+        statusFilter = new Set([status]);
+      } else {
+        if (statusFilter.has(status)) {
+          statusFilter.delete(status);
+        } else {
+          statusFilter.add(status);
+        }
+      }
+    }
+
+    // Update button visual state
+    const nowAll = ALL_STATUSES.every(s => statusFilter.has(s));
+    document.querySelector('.filter-btn[data-status=""]')
+      ?.classList.toggle('active-filter', nowAll);
+    ALL_STATUSES.forEach(s => {
+      document.querySelector(`.filter-btn[data-status="${s}"]`)
+        ?.classList.toggle('active-filter', statusFilter.has(s));
+    });
+
+    renderTree();
+  }
+
+  // ── Create form ─────────────────────────────────────────────────────
+
+  function openCreateForm(prefilledParentId) {
+    const section = document.getElementById('create-section');
+    section.classList.add('open');
+    if (prefilledParentId) {
+      document.getElementById('create-parent-input').value = prefilledParentId;
+    }
+    document.getElementById('create-goal-input').focus();
+  }
+
+  function closeCreateForm() {
+    const section = document.getElementById('create-section');
+    section.classList.remove('open');
+    document.getElementById('create-goal-input').value = '';
+    document.getElementById('create-parent-input').value = '';
+    clearError(document.getElementById('create-error'));
+  }
+
+  async function submitCreateForm() {
+    const goalInput = document.getElementById('create-goal-input');
+    const parentInput = document.getElementById('create-parent-input');
+    const errEl = document.getElementById('create-error');
+    const btn = document.getElementById('create-submit-btn');
+
+    clearError(errEl);
+    const goal = goalInput.value.trim();
+    const parentId = parentInput.value.trim() || undefined;
+
+    if (!goal) { showError(errEl, 'Goal is required.'); return; }
+
+    btn.disabled = true;
+    btn.textContent = 'Creating…';
+    try {
+      const newClick = await api('POST', '/api/click/create', { goal, parentId });
+      closeCreateForm();
+      // Expand the parent so the new child is visible.
+      if (newClick.parentId) expandedNodes.add(newClick.parentId);
+      await refreshAfterMutation(null);
+      await selectClick(newClick.id);
+    } catch (e) {
+      showError(errEl, e.message);
+    } finally {
+      btn.disabled = false;
+      btn.textContent = 'Create Click';
+    }
+  }
+
+  // ── Event wiring ────────────────────────────────────────────────────
+
+  document.getElementById('btn-new-click').addEventListener('click', () => {
+    const section = document.getElementById('create-section');
+    if (section.classList.contains('open')) {
+      closeCreateForm();
+    } else {
+      // Pre-fill parent if a click is selected (D12)
+      openCreateForm(selectedId || undefined);
+    }
+  });
+
+  document.getElementById('btn-refresh').addEventListener('click', async () => {
+    await loadTree();
+    if (selectedId) await loadDetail(selectedId);
+  });
+
+  document.getElementById('create-submit-btn').addEventListener('click', submitCreateForm);
+  document.getElementById('create-cancel-btn').addEventListener('click', closeCreateForm);
+
+  document.querySelectorAll('.filter-btn').forEach(btn => {
+    btn.addEventListener('click', () => setStatusFilter(btn.dataset.status));
+  });
+
+  // popstate: sync state when browser back/forward is used
+  window.addEventListener('popstate', async () => {
+    const params = getUrlParams();
+    scopeId = params.root || null;
+    renderTree();
+    renderBreadcrumb();
+    if (params.click) await loadDetail(params.click);
+  });
+
+  // ── Init ─────────────────────────────────────────────────────────────
+
+  (async () => {
+    const params = getUrlParams();
+    scopeId = params.root || null;
+
+    await loadTree();
+
+    // Deep-link: ?click=<id> auto-opens detail pane (D19)
+    if (params.click) {
+      selectedId = params.click;
+      document.querySelectorAll(`.node-row[data-id="${params.click}"]`)
+        .forEach(el => el.classList.add('selected'));
+      await loadDetail(params.click);
+    }
+  })();
+})();
+</script>
+</body>
+</html>
