+/**
+ * Companion tests for pages/clicks/index.html — detail pane rendering and link dispatch.
+ *
+ * Covers:
+ * - statusBadge: correct CSS classes for each click status
+ * - renderLinkTarget: link prefix dispatch (c- in-page, w- writs page, other plain text)
+ * - renderLinksSection: links HTML (outbound, inbound, add-link form)
+ * - renderDetail: full detail pane rendering (fields, children, conclusion disclosure)
+ *
+ * Pattern: re-declare pure functions from index.html (IIFE-scoped, not exported)
+ * and test them directly. Uses node:test + assert/strict — no browser runtime.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Re-declared pure functions (must stay in sync with index.html) ─────
+
+const LINK_TYPES = ['related', 'commissioned', 'supersedes', 'depends-on'];
+
+function escHtml(s) {
+  return String(s ?? '')
+    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+}
+
+function escAttr(s) {
+  return String(s ?? '')
+    .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
+    .replace(/</g, '&lt;').replace(/>/g, '&gt;');
+}
+
+function fmtDate(iso) {
+  if (!iso) return '';
+  return new Date(iso).toLocaleString();
+}
+
+function statusBadge(status) {
+  const map = {
+    live:      'badge badge--active',
+    parked:    'badge badge--warning',
+    concluded: 'badge badge--success',
+    dropped:   'badge badge--error',
+  };
+  const cls = map[status] ?? 'badge';
+  return `<span class="${cls}">${status}</span>`;
+}
+
+/**
+ * Render a link target as HTML based on its ID prefix.
+ * c-… → clickable to open click detail in-page
+ * w-… → link navigating to /pages/writs/?writ=<id>
+ * other → plain escaped text
+ */
+function renderLinkTarget(targetId) {
+  const esc = escHtml(targetId);
+  const attr = escAttr(targetId);
+  if (targetId.startsWith('c-')) {
+    return `<a class="link-target" data-action="open-click" data-id="${attr}">${esc}</a>`;
+  }
+  if (targetId.startsWith('w-')) {
+    const url = `/pages/writs/?writ=${encodeURIComponent(targetId)}`;
+    return `<a class="link-target" href="${url}">${esc}</a>`;
+  }
+  return esc;
+}
+
+function renderLinksSection(clickData) {
+  const outbound = clickData.links?.outbound ?? [];
+  const inbound = clickData.links?.inbound ?? [];
+  let html = '<h4>Links</h4>';
+
+  if (outbound.length === 0 && inbound.length === 0) {
+    html += '<p style="font-size:0.875rem;opacity:0.5">No links.</p>';
+  }
+
+  for (const l of outbound) {
+    const metaId = escAttr(l.targetId);
+    html += `<div class="link-row">
+      <span class="link-dir">→</span>
+      ${renderLinkTarget(l.targetId)}
+      <span class="link-meta" data-link-meta-id="${metaId}"></span>
+      <span style="font-size:0.8rem;opacity:0.6">(${escHtml(l.linkType)})</span>
+      <button class="btn btn--danger" style="padding:0.1rem 0.5rem;font-size:0.75rem"
+        data-action="unlink"
+        data-source="${escAttr(l.sourceId)}"
+        data-target="${escAttr(l.targetId)}"
+        data-link-type="${escAttr(l.linkType)}">×</button>
+    </div>`;
+  }
+  for (const l of inbound) {
+    const metaId = escAttr(l.sourceId);
+    html += `<div class="link-row">
+      <span class="link-dir">←</span>
+      ${renderLinkTarget(l.sourceId)}
+      <span class="link-meta" data-link-meta-id="${metaId}"></span>
+      <span style="font-size:0.8rem;opacity:0.6">(${escHtml(l.linkType)})</span>
+      <button class="btn btn--danger" style="padding:0.1rem 0.5rem;font-size:0.75rem"
+        data-action="unlink"
+        data-source="${escAttr(l.sourceId)}"
+        data-target="${escAttr(l.targetId)}"
+        data-link-type="${escAttr(l.linkType)}">×</button>
+    </div>`;
+  }
+
+  // Add-link form
+  html += `<div class="add-link-form" id="add-link-form">
+    <input type="text" id="link-target-input" placeholder="Target ID (c-…, w-…)" style="width:160px">
+    <select id="link-type-select">`;
+  for (const lt of LINK_TYPES) {
+    html += `<option value="${lt}">${lt}</option>`;
+  }
+  html += `</select>
+    <button class="btn" data-action="addlink">Link</button>
+    <div class="error-msg" id="link-error" style="display:none"></div>
+  </div>`;
+
+  return html;
+}
+
+function renderDetail(clickData) {
+  const isTerminal = clickData.status === 'concluded' || clickData.status === 'dropped';
+  let html = '';
+
+  // Header
+  html += `<div class="detail-header">
+    <h2>${escHtml(clickData.goal)}</h2>
+    <div class="detail-id-row">
+      <code>${escHtml(clickData.id)}</code>
+      <button class="btn" id="copy-id-btn" data-copy="${escAttr(clickData.id)}"
+        style="padding:0.1rem 0.3rem;font-size:0.7rem">📋</button>
+    </div>
+  </div>`;
+
+  // Fields
+  html += '<div class="detail-section"><h4>Details</h4><dl class="detail-grid">';
+  html += `<dt>ID</dt><dd><code>${escHtml(clickData.id)}</code></dd>`;
+  html += `<dt>Status</dt><dd>${statusBadge(clickData.status)}</dd>`;
+  if (clickData.parent) {
+    html += `<dt>Parent</dt><dd>
+      <a class="link-target" data-action="open-click" data-id="${escAttr(clickData.parent.id)}">
+        ${escHtml(clickData.parent.goal ?? clickData.parent.id)}</a>
+      ${statusBadge(clickData.parent.status)}
+    </dd>`;
+  }
+  html += `<dt>Created</dt><dd>${fmtDate(clickData.createdAt)}</dd>`;
+  if (clickData.resolvedAt) html += `<dt>Resolved</dt><dd>${fmtDate(clickData.resolvedAt)}</dd>`;
+  if (clickData.createdSessionId) html += `<dt>Session (created)</dt><dd><code>${escHtml(clickData.createdSessionId)}</code></dd>`;
+  if (clickData.resolvedSessionId) html += `<dt>Session (resolved)</dt><dd><code>${escHtml(clickData.resolvedSessionId)}</code></dd>`;
+  html += '</dl></div>';
+
+  // Conclusion
+  if (isTerminal && clickData.conclusion) {
+    html += `<div class="detail-section"><h4>Conclusion</h4>
+      <details>
+        <summary style="cursor:pointer">▸ Show conclusion</summary>
+        <div>${escHtml(clickData.conclusion)}</div>
+      </details>
+    </div>`;
+  }
+
+  // Children
+  const childItems = clickData.children?.items ?? [];
+  const summary = clickData.children?.summary ?? {};
+  if (childItems.length > 0 || Object.keys(summary).length > 0) {
+    html += '<div class="detail-section"><h4>Children</h4>';
+
+    if (Object.keys(summary).length > 0) {
+      html += '<div style="margin-bottom:0.5rem">';
+      for (const [st, count] of Object.entries(summary)) {
+        html += statusBadge(st) + ` <span style="margin-right:0.75rem">${count}</span>`;
+      }
+      html += '</div>';
+    }
+
+    if (childItems.length > 0) {
+      html += '<table class="data-table"><thead><tr>';
+      html += '<th>Status</th><th>Goal</th><th>ID</th>';
+      html += '</tr></thead><tbody>';
+      for (const child of childItems) {
+        html += `<tr class="click-child-row" data-child-id="${escAttr(child.id)}">`;
+        html += `<td>${statusBadge(child.status)}</td>`;
+        html += `<td>${escHtml(child.goal ?? '')}</td>`;
+        html += `<td><code>${escHtml(child.id)}</code></td>`;
+        html += '</tr>';
+      }
+      html += '</tbody></table>';
+    }
+    html += '</div>';
+  }
+
+  // Links
+  html += `<div class="detail-section" id="links-section">
+    ${renderLinksSection(clickData)}
+  </div>`;
+
+  // Actions (simplified for testing — just presence check)
+  html += '<div class="detail-section" id="actions-section"></div>';
+
+  return html;
+}
+
+// ── Tests: statusBadge ─────────────────────────────────────────────────────
+
+describe('statusBadge()', () => {
+  it('live maps to badge--active', () => {
+    const result = statusBadge('live');
+    assert.equal(result, '<span class="badge badge--active">live</span>');
+  });
+
+  it('parked maps to badge--warning', () => {
+    const result = statusBadge('parked');
+    assert.equal(result, '<span class="badge badge--warning">parked</span>');
+  });
+
+  it('concluded maps to badge--success', () => {
+    const result = statusBadge('concluded');
+    assert.equal(result, '<span class="badge badge--success">concluded</span>');
+  });
+
+  it('dropped maps to badge--error', () => {
+    const result = statusBadge('dropped');
+    assert.equal(result, '<span class="badge badge--error">dropped</span>');
+  });
+
+  it('unknown status falls back to plain badge', () => {
+    const result = statusBadge('unknown');
+    assert.equal(result, '<span class="badge">unknown</span>');
+  });
+});
+
+// ── Tests: renderLinkTarget (link prefix dispatch) ─────────────────────────
+
+describe('renderLinkTarget() — prefix dispatch', () => {
+  it('c- prefix renders an in-page clickable anchor with data-action="open-click"', () => {
+    const html = renderLinkTarget('c-mo1mq8ry-abc123');
+    assert.ok(html.includes('data-action="open-click"'), 'should have open-click action');
+    assert.ok(html.includes('data-id="c-mo1mq8ry-abc123"'), 'should set data-id to full ID');
+    assert.ok(html.includes('class="link-target"'), 'should have link-target class');
+    assert.ok(html.includes('>c-mo1mq8ry-abc123<'), 'should show the ID as text');
+    assert.ok(!html.includes('href='), 'should not have an href for in-page navigation');
+  });
+
+  it('w- prefix renders an href to the writs page', () => {
+    const html = renderLinkTarget('w-abc123');
+    assert.ok(html.includes('href="/pages/writs/?writ=w-abc123"'), 'should link to writs page');
+    assert.ok(html.includes('class="link-target"'), 'should have link-target class');
+    assert.ok(!html.includes('data-action='), 'should not have data-action for external links');
+  });
+
+  it('w- prefix URL-encodes the writ ID', () => {
+    const html = renderLinkTarget('w-special id');
+    assert.ok(html.includes('writ=w-special%20id'), 'should URL-encode the writ ID');
+  });
+
+  it('unknown prefix renders as plain escaped text', () => {
+    const html = renderLinkTarget('other-id-xyz');
+    assert.equal(html, 'other-id-xyz');
+    assert.ok(!html.includes('<a'), 'should not be a link');
+  });
+
+  it('escapes HTML special characters in plain text IDs', () => {
+    const html = renderLinkTarget('<script>');
+    assert.ok(!html.includes('<script>'), 'should escape <');
+    assert.ok(html.includes('&lt;script&gt;'), 'should have escaped version');
+  });
+
+  it('c- link escapes HTML special characters in the ID', () => {
+    // IDs won't normally contain <>, but verify defensive escaping
+    const html = renderLinkTarget('c-abc');
+    assert.ok(html.includes('>c-abc<'), 'text content should be the ID');
+  });
+});
+
+// ── Tests: renderLinksSection ─────────────────────────────────────────────
+
+describe('renderLinksSection()', () => {
+  it('shows "No links." when no outbound or inbound links', () => {
+    const click = { id: 'c-1', links: { outbound: [], inbound: [] } };
+    const html = renderLinksSection(click);
+    assert.ok(html.includes('No links.'));
+  });
+
+  it('renders outbound link with → direction indicator', () => {
+    const click = {
+      id: 'c-1',
+      links: {
+        outbound: [{ sourceId: 'c-1', targetId: 'c-2', linkType: 'related' }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksSection(click);
+    assert.ok(html.includes('→'), 'should show outbound arrow');
+    assert.ok(html.includes('c-2'), 'should show target ID');
+    assert.ok(html.includes('(related)'), 'should show link type');
+    assert.ok(html.includes('data-action="unlink"'), 'should have unlink button');
+  });
+
+  it('renders inbound link with ← direction indicator', () => {
+    const click = {
+      id: 'c-2',
+      links: {
+        outbound: [],
+        inbound: [{ sourceId: 'c-1', targetId: 'c-2', linkType: 'commissioned' }],
+      },
+    };
+    const html = renderLinksSection(click);
+    assert.ok(html.includes('←'), 'should show inbound arrow');
+    assert.ok(html.includes('c-1'), 'should show source ID');
+    assert.ok(html.includes('(commissioned)'), 'should show link type');
+  });
+
+  it('renders outbound c- link as in-page open-click anchor', () => {
+    const click = {
+      id: 'c-1',
+      links: {
+        outbound: [{ sourceId: 'c-1', targetId: 'c-2', linkType: 'depends-on' }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksSection(click);
+    assert.ok(html.includes('data-action="open-click"'), 'c- target should be open-click');
+  });
+
+  it('renders outbound w- link as href to writs page', () => {
+    const click = {
+      id: 'c-1',
+      links: {
+        outbound: [{ sourceId: 'c-1', targetId: 'w-abc', linkType: 'supersedes' }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksSection(click);
+    assert.ok(html.includes('href="/pages/writs/?writ=w-abc"'), 'w- target should link to writs');
+  });
+
+  it('includes add-link form with select dropdown containing all four link types', () => {
+    const click = { id: 'c-1', links: { outbound: [], inbound: [] } };
+    const html = renderLinksSection(click);
+    for (const lt of LINK_TYPES) {
+      assert.ok(html.includes(`<option value="${lt}">${lt}</option>`), `missing option for ${lt}`);
+    }
+    assert.ok(html.includes('id="link-type-select"'), 'should have link-type select');
+    assert.ok(html.includes('id="link-target-input"'), 'should have target input');
+  });
+
+  it('includes data-link-meta-id attribute for lazy metadata display', () => {
+    const click = {
+      id: 'c-1',
+      links: {
+        outbound: [{ sourceId: 'c-1', targetId: 'c-2', linkType: 'related' }],
+        inbound: [],
+      },
+    };
+    const html = renderLinksSection(click);
+    assert.ok(html.includes('data-link-meta-id="c-2"'), 'should have metadata placeholder span');
+  });
+});
+
+// ── Tests: renderDetail ────────────────────────────────────────────────────
+
+describe('renderDetail() — fields', () => {
+  const baseClick = {
+    id: 'c-mo1o65ky-abc123',
+    goal: 'Ship the feature',
+    status: 'live',
+    createdAt: '2025-01-15T10:00:00.000Z',
+    links: { outbound: [], inbound: [] },
+    children: { summary: {}, items: [] },
+  };
+
+  it('renders the goal in h2', () => {
+    const html = renderDetail(baseClick);
+    assert.ok(html.includes('<h2>Ship the feature</h2>'), 'goal should appear in h2');
+  });
+
+  it('renders the full ID in a code element', () => {
+    const html = renderDetail(baseClick);
+    assert.ok(html.includes('<code>c-mo1o65ky-abc123</code>'), 'full ID in code');
+  });
+
+  it('renders status badge', () => {
+    const html = renderDetail(baseClick);
+    assert.ok(html.includes('badge--active'), 'live status → badge--active');
+    assert.ok(html.includes('>live<'), 'badge text should be "live"');
+  });
+
+  it('renders createdAt as formatted date', () => {
+    const html = renderDetail(baseClick);
+    // fmtDate returns toLocaleString() which varies by locale, so just check the dt exists
+    assert.ok(html.includes('<dt>Created</dt>'), 'should have Created dt');
+  });
+
+  it('renders parent link when parent is set', () => {
+    const click = {
+      ...baseClick,
+      parent: { id: 'c-parent-abc', goal: 'Parent goal', status: 'live' },
+    };
+    const html = renderDetail(click);
+    assert.ok(html.includes('<dt>Parent</dt>'), 'Parent dt should exist');
+    assert.ok(html.includes('Parent goal'), 'Parent goal should appear');
+    assert.ok(html.includes('data-action="open-click"'), 'parent link should be open-click');
+    assert.ok(html.includes(`data-id="${click.parent.id}"`), 'parent link data-id should be set');
+  });
+
+  it('does not render parent section when parent is null', () => {
+    const click = { ...baseClick, parent: null };
+    const html = renderDetail(click);
+    assert.ok(!html.includes('<dt>Parent</dt>'), 'Parent dt should not exist when no parent');
+  });
+
+  it('does not render parent section when parent is undefined', () => {
+    const click = { ...baseClick };
+    delete click.parent;
+    const html = renderDetail(click);
+    assert.ok(!html.includes('<dt>Parent</dt>'), 'Parent dt should not exist when undefined');
+  });
+
+  it('renders resolvedAt when set', () => {
+    const click = { ...baseClick, resolvedAt: '2025-01-20T12:00:00.000Z' };
+    const html = renderDetail(click);
+    assert.ok(html.includes('<dt>Resolved</dt>'), 'Resolved dt should appear');
+  });
+
+  it('does not render resolvedAt when absent', () => {
+    const html = renderDetail(baseClick);
+    assert.ok(!html.includes('<dt>Resolved</dt>'), 'Resolved dt should not appear');
+  });
+
+  it('renders createdSessionId when set', () => {
+    const click = { ...baseClick, createdSessionId: 'sess-abc' };
+    const html = renderDetail(click);
+    assert.ok(html.includes('<dt>Session (created)</dt>'), 'should show session created');
+    assert.ok(html.includes('sess-abc'), 'should show session ID');
+  });
+
+  it('renders resolvedSessionId when set', () => {
+    const click = { ...baseClick, resolvedSessionId: 'sess-xyz' };
+    const html = renderDetail(click);
+    assert.ok(html.includes('<dt>Session (resolved)</dt>'), 'should show session resolved');
+    assert.ok(html.includes('sess-xyz'), 'should show resolved session ID');
+  });
+
+  it('escapes HTML in goal text', () => {
+    const click = { ...baseClick, goal: '<b>Bold & Dangerous</b>' };
+    const html = renderDetail(click);
+    assert.ok(!html.includes('<b>Bold'), 'should not have unescaped HTML in goal');
+    assert.ok(html.includes('&lt;b&gt;Bold &amp; Dangerous'), 'should have escaped version');
+  });
+});
+
+describe('renderDetail() — conclusion disclosure (terminal clicks)', () => {
+  it('concluded click shows conclusion in expandable details element', () => {
+    const click = {
+      id: 'c-1',
+      goal: 'A task',
+      status: 'concluded',
+      conclusion: 'Successfully shipped.',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: { summary: {}, items: [] },
+    };
+    const html = renderDetail(click);
+    assert.ok(html.includes('<h4>Conclusion</h4>'), 'Conclusion heading should appear');
+    assert.ok(html.includes('<details>'), 'should use details element');
+    assert.ok(html.includes('Successfully shipped.'), 'conclusion text should appear');
+  });
+
+  it('dropped click shows conclusion section', () => {
+    const click = {
+      id: 'c-2',
+      goal: 'Abandoned',
+      status: 'dropped',
+      conclusion: 'No longer needed.',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: { summary: {}, items: [] },
+    };
+    const html = renderDetail(click);
+    assert.ok(html.includes('<h4>Conclusion</h4>'));
+    assert.ok(html.includes('No longer needed.'));
+  });
+
+  it('live click does not show conclusion section', () => {
+    const click = {
+      id: 'c-3',
+      goal: 'In progress',
+      status: 'live',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: { summary: {}, items: [] },
+    };
+    const html = renderDetail(click);
+    assert.ok(!html.includes('<h4>Conclusion</h4>'), 'no conclusion section for live click');
+  });
+
+  it('terminal click without conclusion does not show conclusion section', () => {
+    const click = {
+      id: 'c-4',
+      goal: 'Done',
+      status: 'concluded',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: { summary: {}, items: [] },
+    };
+    const html = renderDetail(click);
+    assert.ok(!html.includes('<h4>Conclusion</h4>'), 'no conclusion section when conclusion is absent');
+  });
+
+  it('conclusion text is escaped', () => {
+    const click = {
+      id: 'c-5',
+      goal: 'Done',
+      status: 'concluded',
+      conclusion: '<script>alert("xss")</script>',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: { summary: {}, items: [] },
+    };
+    const html = renderDetail(click);
+    assert.ok(!html.includes('<script>alert'), 'should not have unescaped script tag');
+    assert.ok(html.includes('&lt;script&gt;'), 'should have escaped version');
+  });
+});
+
+describe('renderDetail() — children section (D22)', () => {
+  it('renders children table with status, goal, ID columns', () => {
+    const click = {
+      id: 'c-parent',
+      goal: 'Parent',
+      status: 'live',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: {
+        summary: { live: 2, parked: 1 },
+        items: [
+          { id: 'c-child-1', goal: 'Child one', status: 'live' },
+          { id: 'c-child-2', goal: 'Child two', status: 'parked' },
+          { id: 'c-child-3', goal: 'Child three', status: 'live' },
+        ],
+      },
+    };
+    const html = renderDetail(click);
+
+    assert.ok(html.includes('<h4>Children</h4>'), 'Children heading');
+    assert.ok(html.includes('<th>Status</th><th>Goal</th><th>ID</th>'), 'Table headers');
+
+    // All 3 children rendered
+    const rowCount = (html.match(/class="click-child-row"/g) || []).length;
+    assert.equal(rowCount, 3, 'should have 3 child rows');
+
+    assert.ok(html.includes('Child one'));
+    assert.ok(html.includes('Child two'));
+    assert.ok(html.includes('Child three'));
+
+    // data-child-id attributes for click navigation
+    assert.ok(html.includes('data-child-id="c-child-1"'));
+    assert.ok(html.includes('data-child-id="c-child-2"'));
+  });
+
+  it('renders summary badge strip', () => {
+    const click = {
+      id: 'c-parent',
+      goal: 'Parent',
+      status: 'live',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: {
+        summary: { live: 3, concluded: 1 },
+        items: [],
+      },
+    };
+    const html = renderDetail(click);
+    // Badge strip should contain status badges from summary
+    assert.ok(html.includes('badge--active'), 'live badge in summary');
+    assert.ok(html.includes('badge--success'), 'concluded badge in summary');
+  });
+
+  it('does not render children section when no children', () => {
+    const click = {
+      id: 'c-leaf',
+      goal: 'Leaf',
+      status: 'live',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: { summary: {}, items: [] },
+    };
+    const html = renderDetail(click);
+    assert.ok(!html.includes('<h4>Children</h4>'), 'no children section for leaf');
+  });
+
+  it('children ordering is preserved as-is from the data', () => {
+    const click = {
+      id: 'c-parent',
+      goal: 'Parent',
+      status: 'live',
+      createdAt: '2025-01-01T00:00:00.000Z',
+      links: { outbound: [], inbound: [] },
+      children: {
+        summary: { live: 2 },
+        items: [
+          { id: 'c-early', goal: 'Early', status: 'live' },
+          { id: 'c-late', goal: 'Late', status: 'live' },
+        ],
+      },
+    };
+    const html = renderDetail(click);
+    const earlyIdx = html.indexOf('c-early');
+    const lateIdx = html.indexOf('c-late');
+    assert.ok(earlyIdx < lateIdx, 'Early should appear before Late in rendered order');
+  });
+});
diff --git a/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
new file mode 100644
index 0000000..ab12e12
--- /dev/null
+++ b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
@@ -0,0 +1,338 @@
+/**
+ * Companion tests for pages/clicks/index.html — tree logic.
+ *
+ * Covers:
+ * - pruneByStatus: status-filter pruning with subtree-hiding semantics
+ * - findSubtree: subtree scoping by ID
+ * - buildBreadcrumb: ancestor path derivation
+ * - collectAllIds: ID collection for expansion state
+ * - shortClickId: short-ID derivation
+ *
+ * Pattern: re-declare pure functions from index.html (IIFE-scoped, not exported)
+ * and test them directly. Uses node:test + assert/strict — no browser runtime.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Re-declared pure functions (must stay in sync with index.html) ─────
+
+/**
+ * Prune the forest by status set.
+ * Non-matching nodes and their entire subtrees are removed.
+ */
+function pruneByStatus(forest, statusSet) {
+  function pruneNode(node) {
+    if (!statusSet.has(node.click.status)) return null;
+    const children = node.children.map(pruneNode).filter(Boolean);
+    return { click: node.click, children };
+  }
+  return forest.map(pruneNode).filter(Boolean);
+}
+
+/**
+ * Find the subtree rooted at rootId within the forest.
+ * Returns a single-element ClickTree[] if found, null otherwise.
+ */
+function findSubtree(forest, rootId) {
+  for (const node of forest) {
+    if (node.click.id === rootId) return [node];
+    const found = findSubtree(node.children, rootId);
+    if (found) return found;
+  }
+  return null;
+}
+
+/**
+ * Build breadcrumb path from forest root down to targetId.
+ * Returns array of { id, goal } from outermost ancestor to target,
+ * or null if targetId is not found.
+ */
+function buildBreadcrumb(forest, targetId, path) {
+  path = path || [];
+  for (const node of forest) {
+    const newPath = path.concat({ id: node.click.id, goal: node.click.goal });
+    if (node.click.id === targetId) return newPath;
+    const found = buildBreadcrumb(node.children, targetId, newPath);
+    if (found) return found;
+  }
+  return null;
+}
+
+/**
+ * Collect all click IDs from the forest recursively.
+ */
+function collectAllIds(forest) {
+  const ids = [];
+  function walk(nodes) {
+    for (const n of nodes) {
+      ids.push(n.click.id);
+      walk(n.children);
+    }
+  }
+  walk(forest);
+  return ids;
+}
+
+/**
+ * Return short ID form: first two hyphen-delimited segments.
+ */
+function shortClickId(id) {
+  const parts = id.split('-');
+  return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+}
+
+// ── Fixtures ─────────────────────────────────────────────────────────────
+
+function makeClick(id, status, goal, parentId) {
+  return {
+    id,
+    status,
+    goal: goal ?? id,
+    parentId,
+    createdAt: '2025-01-01T00:00:00.000Z',
+  };
+}
+
+function makeNode(click, children = []) {
+  return { click, children };
+}
+
+// Simple two-level forest:
+//   root-a (live)
+//     child-a1 (live)
+//     child-a2 (parked)
+//       grandchild-a2a (concluded)
+//   root-b (dropped)
+const grandchild = makeNode(makeClick('grandchild-a2a', 'concluded', 'Grandchild A2A'));
+const childA1 = makeNode(makeClick('child-a1', 'live', 'Child A1'));
+const childA2 = makeNode(makeClick('child-a2', 'parked', 'Child A2'), [grandchild]);
+const rootA = makeNode(makeClick('root-a', 'live', 'Root A'), [childA1, childA2]);
+const rootB = makeNode(makeClick('root-b', 'dropped', 'Root B'));
+const sampleForest = [rootA, rootB];
+
+// ── pruneByStatus ─────────────────────────────────────────────────────────
+
+describe('pruneByStatus()', () => {
+  it('all statuses selected — returns forest unchanged', () => {
+    const result = pruneByStatus(sampleForest, new Set(['live', 'parked', 'concluded', 'dropped']));
+    assert.equal(result.length, 2);
+    assert.equal(result[0].children.length, 2);
+    assert.equal(result[0].children[1].children.length, 1);
+  });
+
+  it('single status: live — keeps only live nodes', () => {
+    const result = pruneByStatus(sampleForest, new Set(['live']));
+    // root-a is live → kept
+    assert.equal(result.length, 1);
+    assert.equal(result[0].click.id, 'root-a');
+    // child-a1 is live → kept
+    assert.equal(result[0].children.length, 1);
+    assert.equal(result[0].children[0].click.id, 'child-a1');
+    // child-a2 is parked → pruned (and grandchild with it)
+  });
+
+  it('parked status — child-a2 kept, grandchild-a2a pruned', () => {
+    const result = pruneByStatus(sampleForest, new Set(['parked']));
+    // root-a is live → pruned entirely (its children too)
+    assert.equal(result.length, 0);
+  });
+
+  it('concluded status — only grandchild, but pruned because ancestors do not match', () => {
+    // grandchild-a2a is concluded; however root-a (live) and child-a2 (parked) don't match
+    // so the whole path is pruned
+    const result = pruneByStatus(sampleForest, new Set(['concluded']));
+    assert.equal(result.length, 0);
+  });
+
+  it('live + parked — root-a kept with both children; root-b pruned', () => {
+    const result = pruneByStatus(sampleForest, new Set(['live', 'parked']));
+    assert.equal(result.length, 1);
+    assert.equal(result[0].click.id, 'root-a');
+    // child-a1 (live) and child-a2 (parked) both kept
+    assert.equal(result[0].children.length, 2);
+    // grandchild-a2a (concluded) is pruned
+    assert.equal(result[0].children[1].children.length, 0);
+  });
+
+  it('dropped status — only root-b', () => {
+    const result = pruneByStatus(sampleForest, new Set(['dropped']));
+    assert.equal(result.length, 1);
+    assert.equal(result[0].click.id, 'root-b');
+  });
+
+  it('subtree pruning is total — if parent does not match, children are hidden even if they would match', () => {
+    // child-a2 (parked) has grandchild-a2a (concluded).
+    // If we filter only concluded, grandchild-a2a would match but parent chain does not.
+    const result = pruneByStatus(sampleForest, new Set(['concluded']));
+    assert.equal(result.length, 0, 'nothing survives because all ancestors fail the filter');
+  });
+
+  it('empty statusSet — prunes everything', () => {
+    const result = pruneByStatus(sampleForest, new Set());
+    assert.equal(result.length, 0);
+  });
+
+  it('empty forest — returns empty array', () => {
+    const result = pruneByStatus([], new Set(['live']));
+    assert.deepEqual(result, []);
+  });
+
+  it('leaf node matching — kept as leaf with no children', () => {
+    // A forest with a single root that has no children and matches the filter
+    const solo = [makeNode(makeClick('solo', 'concluded', 'Solo'))];
+    const result = pruneByStatus(solo, new Set(['concluded']));
+    assert.equal(result.length, 1);
+    assert.equal(result[0].click.id, 'solo');
+    assert.deepEqual(result[0].children, []);
+  });
+});
+
+// ── findSubtree ───────────────────────────────────────────────────────────
+
+describe('findSubtree()', () => {
+  it('finds a root node — returns it as single-element array', () => {
+    const result = findSubtree(sampleForest, 'root-a');
+    assert.ok(result, 'should return non-null');
+    assert.equal(result.length, 1);
+    assert.equal(result[0].click.id, 'root-a');
+    // Children should be intact
+    assert.equal(result[0].children.length, 2);
+  });
+
+  it('finds a child node — returns it as single-element array', () => {
+    const result = findSubtree(sampleForest, 'child-a2');
+    assert.ok(result);
+    assert.equal(result.length, 1);
+    assert.equal(result[0].click.id, 'child-a2');
+    // Its own child should be present
+    assert.equal(result[0].children.length, 1);
+    assert.equal(result[0].children[0].click.id, 'grandchild-a2a');
+  });
+
+  it('finds a grandchild node — returns leaf', () => {
+    const result = findSubtree(sampleForest, 'grandchild-a2a');
+    assert.ok(result);
+    assert.equal(result[0].click.id, 'grandchild-a2a');
+    assert.deepEqual(result[0].children, []);
+  });
+
+  it('finds root-b', () => {
+    const result = findSubtree(sampleForest, 'root-b');
+    assert.ok(result);
+    assert.equal(result[0].click.id, 'root-b');
+  });
+
+  it('returns null when ID not found', () => {
+    const result = findSubtree(sampleForest, 'nonexistent');
+    assert.equal(result, null);
+  });
+
+  it('returns null on empty forest', () => {
+    const result = findSubtree([], 'root-a');
+    assert.equal(result, null);
+  });
+});
+
+// ── buildBreadcrumb ───────────────────────────────────────────────────────
+
+describe('buildBreadcrumb()', () => {
+  it('target is a root — returns single-element path', () => {
+    const crumb = buildBreadcrumb(sampleForest, 'root-a');
+    assert.ok(crumb);
+    assert.equal(crumb.length, 1);
+    assert.equal(crumb[0].id, 'root-a');
+    assert.equal(crumb[0].goal, 'Root A');
+  });
+
+  it('target is a direct child — path has 2 segments', () => {
+    const crumb = buildBreadcrumb(sampleForest, 'child-a2');
+    assert.ok(crumb);
+    assert.equal(crumb.length, 2);
+    assert.equal(crumb[0].id, 'root-a');
+    assert.equal(crumb[1].id, 'child-a2');
+  });
+
+  it('target is a grandchild — path has 3 segments in order', () => {
+    const crumb = buildBreadcrumb(sampleForest, 'grandchild-a2a');
+    assert.ok(crumb);
+    assert.equal(crumb.length, 3);
+    assert.equal(crumb[0].id, 'root-a');
+    assert.equal(crumb[1].id, 'child-a2');
+    assert.equal(crumb[2].id, 'grandchild-a2a');
+  });
+
+  it('target is root-b — single-element path from different root', () => {
+    const crumb = buildBreadcrumb(sampleForest, 'root-b');
+    assert.ok(crumb);
+    assert.equal(crumb.length, 1);
+    assert.equal(crumb[0].id, 'root-b');
+  });
+
+  it('returns null when target not in forest', () => {
+    const crumb = buildBreadcrumb(sampleForest, 'ghost');
+    assert.equal(crumb, null);
+  });
+
+  it('returns null on empty forest', () => {
+    const crumb = buildBreadcrumb([], 'root-a');
+    assert.equal(crumb, null);
+  });
+
+  it('path contains correct goal text for each segment', () => {
+    const crumb = buildBreadcrumb(sampleForest, 'grandchild-a2a');
+    assert.equal(crumb[0].goal, 'Root A');
+    assert.equal(crumb[1].goal, 'Child A2');
+    assert.equal(crumb[2].goal, 'Grandchild A2A');
+  });
+});
+
+// ── collectAllIds ─────────────────────────────────────────────────────────
+
+describe('collectAllIds()', () => {
+  it('collects IDs from a full forest in DFS order', () => {
+    const ids = collectAllIds(sampleForest);
+    // Should include all 5 nodes
+    assert.equal(ids.length, 5);
+    assert.ok(ids.includes('root-a'));
+    assert.ok(ids.includes('child-a1'));
+    assert.ok(ids.includes('child-a2'));
+    assert.ok(ids.includes('grandchild-a2a'));
+    assert.ok(ids.includes('root-b'));
+  });
+
+  it('returns empty array for empty forest', () => {
+    assert.deepEqual(collectAllIds([]), []);
+  });
+
+  it('returns single ID for single-node forest', () => {
+    const ids = collectAllIds([makeNode(makeClick('solo', 'live', 'Solo'))]);
+    assert.deepEqual(ids, ['solo']);
+  });
+
+  it('does not duplicate IDs', () => {
+    const ids = collectAllIds(sampleForest);
+    const unique = new Set(ids);
+    assert.equal(unique.size, ids.length, 'all IDs should be unique');
+  });
+});
+
+// ── shortClickId ──────────────────────────────────────────────────────────
+
+describe('shortClickId()', () => {
+  it('returns first two segments of a standard click ID', () => {
+    assert.equal(shortClickId('c-mo1mq8ry-abc123'), 'c-mo1mq8ry');
+  });
+
+  it('handles IDs with exactly two segments', () => {
+    assert.equal(shortClickId('c-mo1mq8ry'), 'c-mo1mq8ry');
+  });
+
+  it('returns the full string when there are no hyphens', () => {
+    assert.equal(shortClickId('nohyphen'), 'nohyphen');
+  });
+
+  it('handles longer IDs with many segments', () => {
+    assert.equal(shortClickId('c-abc-def-ghi-jkl'), 'c-abc');
+  });
+});
