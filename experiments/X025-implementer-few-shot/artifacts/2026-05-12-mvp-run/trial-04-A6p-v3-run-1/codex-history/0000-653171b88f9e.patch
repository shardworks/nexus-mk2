+      btn.addEventListener('click', e => {
+        e.stopPropagation();
+        handleDetailAction(btn.dataset.action, btn.dataset.id, btn, container, click);
+      });
+    });
+  }
+
+  function handleDetailAction(action, id, btn, container, click) {
+    if (action === 'park') {
+      doSimpleAction('POST', '/api/click/park', { id }, btn, id, container);
+    } else if (action === 'resume') {
+      doSimpleAction('POST', '/api/click/resume', { id }, btn, id, container);
+    } else if (action === 'conclude') {
+      showConclusionConfirm(id, 'conclude', container);
+    } else if (action === 'drop') {
+      showConclusionConfirm(id, 'drop', container);
+    } else if (action === 'unlink') {
+      doUnlink(btn.dataset.source, btn.dataset.target, btn.dataset.linkType, btn, id);
+    } else if (action === 'addlink') {
+      const targetInput = document.getElementById(`link-target-input-${id}`);
+      const typeSelect  = document.getElementById(`link-type-select-${id}`);
+      const errEl       = document.getElementById(`link-error-${id}`);
+      doAddLink(id, targetInput?.value.trim() ?? '', typeSelect?.value ?? '', btn, errEl, targetInput);
+    }
+  }
+
+  async function doSimpleAction(method, path, body, btn, clickId, container) {
+    const errEl = document.getElementById(`action-error-${clickId}`);
+    if (errEl) clearError(errEl);
+    btn.disabled = true;
+    const orig = btn.textContent;
+    btn.textContent = '…';
+    try {
+      await api(method, path, body);
+      await refreshAfterMutation(clickId);
+    } catch (e) {
+      if (errEl) showError(errEl, e.message);
+    } finally {
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  function showConclusionConfirm(id, action, container) {
+    const area = document.getElementById(`confirm-area-${id}`);
+    const errEl = document.getElementById(`action-error-${id}`);
+    if (!area) return;
+    if (errEl) clearError(errEl);
+
+    const label = action === 'conclude' ? 'Conclude' : 'Drop';
+    const btnClass = action === 'conclude' ? 'btn--success' : 'btn--danger';
+    const path = `/api/click/${action}`;
+
+    area.innerHTML = `
+      <div class="confirm-section">
+        <label>Conclusion (required)</label>
+        <input type="text" id="confirm-conclusion-${id}" placeholder="What was the outcome?">
+        <button class="btn ${btnClass}" id="confirm-btn-${id}" disabled>Confirm ${label}</button>
+        <div class="error-msg" id="confirm-error-${id}" style="display:none"></div>
+      </div>`;
+
+    const input = document.getElementById(`confirm-conclusion-${id}`);
+    const confirmBtn = document.getElementById(`confirm-btn-${id}`);
+    const confirmErr = document.getElementById(`confirm-error-${id}`);
+
+    input.addEventListener('input', () => {
+      confirmBtn.disabled = !input.value.trim();
+      clearError(confirmErr);
+    });
+
+    confirmBtn.addEventListener('click', async () => {
+      const conclusion = input.value.trim();
+      if (!conclusion) return;
+      clearError(confirmErr);
+      confirmBtn.disabled = true;
+      confirmBtn.textContent = `${label}ing…`;
+      try {
+        await api('POST', path, { id, conclusion });
+        area.innerHTML = '';
+        await refreshAfterMutation(id);
+      } catch (e) {
+        showError(confirmErr, e.message);
+        confirmBtn.disabled = false;
+        confirmBtn.textContent = `Confirm ${label}`;
+      }
+    });
+  }
+
+  async function doUnlink(sourceId, targetId, linkType, btn, clickId) {
+    btn.disabled = true;
+    const orig = btn.textContent;
+    btn.textContent = '…';
+    try {
+      await api('POST', '/api/click/unlink', { sourceId, targetId, linkType });
+      await refreshAfterMutation(clickId ?? selectedId);
+    } catch (e) {
+      alert(`Unlink failed: ${e.message}`);
+    } finally {
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  async function doAddLink(clickId, targetId, linkType, btn, errEl, targetInput) {
+    if (errEl) clearError(errEl);
+    if (!targetId || !linkType) {
+      if (errEl) showError(errEl, 'Target ID and link type are required.');
+      return;
+    }
+    btn.disabled = true;
+    const orig = btn.textContent;
+    btn.textContent = '…';
+    try {
+      await api('POST', '/api/click/link', { sourceId: clickId, targetId, linkType });
+      if (targetInput) targetInput.value = '';
+      await refreshAfterMutation(clickId);
+    } catch (e) {
+      if (errEl) showError(errEl, e.message);
+    } finally {
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  /**
+   * After any mutation: re-fetch full tree, re-render, re-open detail pane
+   * for the current click (D17).
+   */
+  async function refreshAfterMutation(clickId) {
+    await loadData();
+    if (clickId ?? selectedId) {
+      await openDetail(clickId ?? selectedId);
+    }
+  }
+
+  /**
+   * Lazily fetch metadata for link targets and update the DOM (D16).
+   */
+  async function fetchLinkMetadata(click) {
+    const links = click.links ?? {};
+    const all = [...(links.outbound ?? []), ...(links.inbound ?? [])];
+    const seen = new Set();
+
+    for (const l of all) {
+      const targetId = l.targetId !== click.id ? l.targetId : l.sourceId;
+      if (seen.has(targetId)) continue;
+      seen.add(targetId);
+
+      const dispatch = dispatchLinkTarget(targetId);
+      let endpoint = null;
+      if (dispatch.type === 'click') endpoint = `/api/click/show?id=${encodeURIComponent(targetId)}`;
+      else if (dispatch.type === 'writ') endpoint = `/api/writ/show?id=${encodeURIComponent(targetId)}`;
+      if (!endpoint) continue;
+
+      (async () => {
+        try {
+          const data = await api('GET', endpoint);
+          const metaEls = document.querySelectorAll(`[data-meta-id="${CSS.escape(targetId)}"]`);
+          const meta = dispatch.type === 'click' ? data.goal : data.title;
+          metaEls.forEach(el => { if (meta) el.textContent = `— ${meta}`; });
+        } catch { /* ignore — metadata is optional */ }
+      })();
+    }
+  }
+
+  // ── Create click ──────────────────────────────────────────────────────
+
+  async function createClick() {
+    const goalInput  = document.getElementById('create-goal-input');
+    const parentInput = document.getElementById('create-parent-input');
+    const errEl = document.getElementById('create-error');
+    const btn = document.getElementById('create-submit-btn');
+    clearError(errEl);
+
+    const goal = goalInput.value.trim();
+    if (!goal) { showError(errEl, 'Goal is required.'); return; }
+
+    const parentId = parentInput.value.trim() || undefined;
+
+    btn.disabled = true;
+    const orig = btn.textContent;
+    btn.textContent = 'Creating…';
+    try {
+      const newClick = await api('POST', '/api/click/create', { goal, parentId });
+      goalInput.value = '';
+      parentInput.value = '';
+      // Close the form
+      document.getElementById('create-section').classList.remove('open');
+      // Refresh and select the new click
+      await loadData();
+      await openDetail(newClick.id);
+    } catch (e) {
+      showError(errEl, e.message);
+    } finally {
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  // ── Data loading ──────────────────────────────────────────────────────
+
+  async function loadData() {
+    try {
+      forest = await api('GET', '/api/click/tree?format=json');
+    } catch (e) {
+      document.getElementById('tree-empty-state').textContent = `Error loading tree: ${e.message}`;
+      document.getElementById('tree-empty-state').style.display = '';
+      return;
+    }
+    renderTree();
+  }
+
+  // ── Init ──────────────────────────────────────────────────────────────
+
+  // Wire toolbar buttons
+  document.getElementById('btn-new-click').addEventListener('click', () => {
+    const section = document.getElementById('create-section');
+    section.classList.toggle('open');
+    // Pre-fill parent ID from selected click (D12 additive pre-fill)
+    if (section.classList.contains('open') && selectedId) {
+      const parentInput = document.getElementById('create-parent-input');
+      if (!parentInput.value) parentInput.value = selectedId;
+    }
+  });
+
+  document.getElementById('btn-refresh').addEventListener('click', async () => {
+    await loadData();
+    if (selectedId) await openDetail(selectedId);
+  });
+
+  document.getElementById('create-submit-btn').addEventListener('click', createClick);
+
+  // Wire create form: submit on Enter in goal input
+  document.getElementById('create-goal-input').addEventListener('keydown', e => {
+    if (e.key === 'Enter') createClick();
+  });
+
+  // Wire filter buttons
+  document.querySelectorAll('.filter-btn').forEach(btn => {
+    btn.addEventListener('click', () => handleStatusFilter(btn.dataset.status));
+  });
+
+  // Initial load
+  loadData().then(async () => {
+    // D19: auto-open detail pane if ?click= is set
+    if (initClickId) {
+      await openDetail(initClickId);
+    }
+  });
+
+})();
+</script>
+</body>
+</html>
