@@ -0,0 +1,309 @@
+/**
+ * Unit tests for the Clicks page tree logic.
+ *
+ * Covers: pruneByStatus, getSubtreeById, getBreadcrumbPath.
+ *
+ * Pure functions are re-declared here (they are IIFE-scoped in index.html)
+ * following the same pattern as writs-hierarchy.test.js.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Re-declared pure functions (mirrors index.html) ──────────────────
+
+/**
+ * Prune a ClickTree forest to only nodes (and their subtrees) whose status
+ * is in the given Set. Non-matching nodes AND their descendants are removed.
+ */
+function pruneByStatus(nodes, statuses) {
+  const result = [];
+  for (const node of nodes) {
+    if (!statuses.has(node.click.status)) continue;
+    const prunedChildren = pruneByStatus(node.children, statuses);
+    result.push({ click: node.click, children: prunedChildren });
+  }
+  return result;
+}
+
+/**
+ * Find and return the ClickTree node (and its subtree) rooted at the given ID.
+ * Returns an array containing that single node, or null if not found.
+ */
+function getSubtreeById(nodes, rootId) {
+  for (const node of nodes) {
+    if (node.click.id === rootId) return [node];
+    const found = getSubtreeById(node.children, rootId);
+    if (found) return found;
+  }
+  return null;
+}
+
+/**
+ * Build the breadcrumb path from the forest root to the node with targetId.
+ * Returns an array of { id, goal } objects from topmost ancestor to targetId.
+ * Returns null if targetId is not found.
+ */
+function getBreadcrumbPath(nodes, targetId, path) {
+  path = path ?? [];
+  for (const node of nodes) {
+    const next = [...path, { id: node.click.id, goal: node.click.goal }];
+    if (node.click.id === targetId) return next;
+    const found = getBreadcrumbPath(node.children, targetId, next);
+    if (found) return found;
+  }
+  return null;
+}
+
+// ── Fixtures ─────────────────────────────────────────────────────────
+
+/** Build a minimal ClickTree node. */
+function node(id, status, goal, children = []) {
+  return { click: { id, status, goal }, children };
+}
+
+// ── pruneByStatus ─────────────────────────────────────────────────────
+
+describe('pruneByStatus', () => {
+  it('returns all nodes when all statuses are in the set', () => {
+    const forest = [
+      node('a', 'live', 'Root', [
+        node('b', 'parked', 'Child B'),
+        node('c', 'concluded', 'Child C'),
+      ]),
+    ];
+    const result = pruneByStatus(forest, new Set(['live', 'parked', 'concluded', 'dropped']));
+    assert.equal(result.length, 1);
+    assert.equal(result[0].children.length, 2);
+  });
+
+  it('prunes nodes whose status is not in the set', () => {
+    const forest = [
+      node('a', 'live', 'Root', [
+        node('b', 'parked', 'Parked child'),
+        node('c', 'live', 'Live child'),
+      ]),
+    ];
+    const result = pruneByStatus(forest, new Set(['live']));
+    assert.equal(result.length, 1);
+    assert.equal(result[0].children.length, 1);
+    assert.equal(result[0].children[0].click.id, 'c');
+  });
+
+  it('prunes entire subtree when parent does not match — D6', () => {
+    const forest = [
+      node('a', 'live', 'Root', [
+        node('b', 'parked', 'Parked parent', [
+          node('c', 'live', 'Live grandchild'),
+        ]),
+      ]),
+    ];
+    // Only 'live' selected: b is pruned, so c (child of b) is also pruned
+    const result = pruneByStatus(forest, new Set(['live']));
+    assert.equal(result.length, 1);
+    assert.equal(result[0].children.length, 0, 'parked node and its live child should both be pruned');
+  });
+
+  it('returns empty forest when root does not match', () => {
+    const forest = [node('a', 'parked', 'Root')];
+    const result = pruneByStatus(forest, new Set(['live']));
+    assert.equal(result.length, 0);
+  });
+
+  it('handles empty forest', () => {
+    const result = pruneByStatus([], new Set(['live']));
+    assert.deepEqual(result, []);
+  });
+
+  it('handles forest with no matching nodes across all statuses', () => {
+    const forest = [
+      node('a', 'concluded', 'Root A'),
+      node('b', 'dropped', 'Root B'),
+    ];
+    const result = pruneByStatus(forest, new Set(['live', 'parked']));
+    assert.deepEqual(result, []);
+  });
+
+  it('prunes with a multi-status filter — matching nodes survive', () => {
+    const forest = [
+      node('r', 'live', 'Root', [
+        node('c1', 'parked', 'Parked'),
+        node('c2', 'concluded', 'Concluded'),
+        node('c3', 'dropped', 'Dropped'),
+      ]),
+    ];
+    const result = pruneByStatus(forest, new Set(['live', 'parked']));
+    assert.equal(result.length, 1);
+    assert.equal(result[0].children.length, 1);
+    assert.equal(result[0].children[0].click.id, 'c1');
+  });
+
+  it('does not mutate the original forest nodes', () => {
+    const child = node('b', 'parked', 'Child');
+    const forest = [node('a', 'live', 'Root', [child])];
+    pruneByStatus(forest, new Set(['live']));
+    // Original forest still has the parked child
+    assert.equal(forest[0].children.length, 1);
+  });
+});
+
+// ── getSubtreeById ────────────────────────────────────────────────────
+
+describe('getSubtreeById', () => {
+  const forest = [
+    node('root-a', 'live', 'Root A', [
+      node('child-a1', 'live', 'Child A1', [
+        node('grand-a1a', 'live', 'Grandchild A1a'),
+      ]),
+      node('child-a2', 'parked', 'Child A2'),
+    ]),
+    node('root-b', 'live', 'Root B'),
+  ];
+
+  it('finds a root-level node', () => {
+    const result = getSubtreeById(forest, 'root-b');
+    assert.ok(result !== null);
+    assert.equal(result.length, 1);
+    assert.equal(result[0].click.id, 'root-b');
+  });
+
+  it('finds a first-generation child', () => {
+    const result = getSubtreeById(forest, 'child-a1');
+    assert.ok(result !== null);
+    assert.equal(result[0].click.id, 'child-a1');
+    assert.equal(result[0].children.length, 1);
+  });
+
+  it('finds a grandchild and returns its subtree', () => {
+    const result = getSubtreeById(forest, 'grand-a1a');
+    assert.ok(result !== null);
+    assert.equal(result[0].click.id, 'grand-a1a');
+    assert.equal(result[0].children.length, 0);
+  });
+
+  it('returns null when ID is not found', () => {
+    const result = getSubtreeById(forest, 'nonexistent');
+    assert.equal(result, null);
+  });
+
+  it('returns null on empty forest', () => {
+    const result = getSubtreeById([], 'any');
+    assert.equal(result, null);
+  });
+
+  it('returned subtree preserves full descendant tree', () => {
+    const result = getSubtreeById(forest, 'child-a1');
+    assert.equal(result[0].children[0].click.id, 'grand-a1a');
+  });
+});
+
+// ── getBreadcrumbPath ─────────────────────────────────────────────────
+
+describe('getBreadcrumbPath', () => {
+  const forest = [
+    node('r', 'live', 'Root', [
+      node('a', 'live', 'Node A', [
+        node('b', 'live', 'Node B', [
+          node('c', 'live', 'Node C'),
+        ]),
+      ]),
+      node('d', 'live', 'Node D'),
+    ]),
+  ];
+
+  it('returns single-element path for a root node', () => {
+    const path = getBreadcrumbPath(forest, 'r', null);
+    assert.deepEqual(path, [{ id: 'r', goal: 'Root' }]);
+  });
+
+  it('returns two-element path for a first-generation child', () => {
+    const path = getBreadcrumbPath(forest, 'a', null);
+    assert.deepEqual(path, [
+      { id: 'r', goal: 'Root' },
+      { id: 'a', goal: 'Node A' },
+    ]);
+  });
+
+  it('returns three-element path for a grandchild', () => {
+    const path = getBreadcrumbPath(forest, 'b', null);
+    assert.deepEqual(path, [
+      { id: 'r', goal: 'Root' },
+      { id: 'a', goal: 'Node A' },
+      { id: 'b', goal: 'Node B' },
+    ]);
+  });
+
+  it('returns four-element path for a great-grandchild', () => {
+    const path = getBreadcrumbPath(forest, 'c', null);
+    assert.deepEqual(path, [
+      { id: 'r', goal: 'Root' },
+      { id: 'a', goal: 'Node A' },
+      { id: 'b', goal: 'Node B' },
+      { id: 'c', goal: 'Node C' },
+    ]);
+  });
+
+  it('returns correct path for a sibling branch (Node D)', () => {
+    const path = getBreadcrumbPath(forest, 'd', null);
+    assert.deepEqual(path, [
+      { id: 'r', goal: 'Root' },
+      { id: 'd', goal: 'Node D' },
+    ]);
+  });
+
+  it('returns null for a node that does not exist', () => {
+    const path = getBreadcrumbPath(forest, 'missing', null);
+    assert.equal(path, null);
+  });
+
+  it('handles multiple root trees — finds node in second root', () => {
+    const twoRootForest = [
+      node('r1', 'live', 'Root 1'),
+      node('r2', 'live', 'Root 2', [
+        node('r2c', 'live', 'Root 2 child'),
+      ]),
+    ];
+    const path = getBreadcrumbPath(twoRootForest, 'r2c', null);
+    assert.deepEqual(path, [
+      { id: 'r2', goal: 'Root 2' },
+      { id: 'r2c', goal: 'Root 2 child' },
+    ]);
+  });
+
+  it('handles empty forest', () => {
+    const path = getBreadcrumbPath([], 'any', null);
+    assert.equal(path, null);
+  });
+});
+
+// ── Subtree scoping integration ───────────────────────────────────────
+
+describe('subtree scoping (combined pruneByStatus + getSubtreeById)', () => {
+  const forest = [
+    node('root', 'live', 'Root', [
+      node('live-child', 'live', 'Live child', [
+        node('live-grand', 'live', 'Live grandchild'),
+        node('parked-grand', 'parked', 'Parked grandchild'),
+      ]),
+      node('parked-child', 'parked', 'Parked child'),
+    ]),
+  ];
+
+  it('scoping to a subtree then pruning only affects nodes in that subtree', () => {
+    const subtree = getSubtreeById(forest, 'live-child');
+    assert.ok(subtree, 'subtree should be found');
+
+    const pruned = pruneByStatus(subtree, new Set(['live']));
+    assert.equal(pruned.length, 1);
+    assert.equal(pruned[0].click.id, 'live-child');
+    assert.equal(pruned[0].children.length, 1);
+    assert.equal(pruned[0].children[0].click.id, 'live-grand');
+  });
+
+  it('scoping to a parked node with live-only filter returns empty', () => {
+    const subtree = getSubtreeById(forest, 'parked-child');
+    assert.ok(subtree, 'subtree should be found');
+    const pruned = pruneByStatus(subtree, new Set(['live']));
+    assert.deepEqual(pruned, []);
+  });
+});
