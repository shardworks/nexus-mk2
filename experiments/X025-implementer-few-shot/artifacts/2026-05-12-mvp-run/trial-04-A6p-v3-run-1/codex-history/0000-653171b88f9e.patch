diff --git a/packages/plugins/ratchet/pages/clicks/clicks-detail.test.js b/packages/plugins/ratchet/pages/clicks/clicks-detail.test.js
new file mode 100644
index 0000000..2ddbf48
--- /dev/null
+++ b/packages/plugins/ratchet/pages/clicks/clicks-detail.test.js
@@ -0,0 +1,488 @@
+/**
+ * Unit tests for the Clicks page detail pane and link-dispatch logic.
+ *
+ * Covers: statusBadgeHtml, renderDetailFields, renderChildrenSection,
+ *         renderLinksSection, dispatchLinkTarget.
+ *
+ * Pure functions are re-declared here (IIFE-scoped in index.html)
+ * following the same pattern as writs-hierarchy.test.js.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Re-declared pure functions (mirrors index.html) ──────────────────
+
+function escHtml(s) {
+  return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+}
+
+function fmtDate(iso) {
+  if (!iso) return '';
+  try { return new Date(iso).toLocaleString(); } catch { return iso; }
+}
+
+function statusBadgeHtml(status) {
+  const map = {
+    live:      'badge badge--active',
+    parked:    'badge badge--warning',
+    concluded: 'badge badge--success',
+    dropped:   'badge badge--error',
+  };
+  const cls = map[status] ?? 'badge';
+  return `<span class="${cls}">${escHtml(status)}</span>`;
+}
+
+function dispatchLinkTarget(targetId) {
+  if (targetId.startsWith('c-')) {
+    return { type: 'click', href: null };
+  }
+  if (targetId.startsWith('w-')) {
+    return { type: 'writ', href: `/pages/writs/?writ=${encodeURIComponent(targetId)}` };
+  }
+  return { type: 'plain', href: null };
+}
+
+function renderDetailFields(click) {
+  const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+  let html = '';
+
+  html += `<div class="detail-section"><h4>Details</h4>`;
+  html += `<dl class="detail-grid">`;
+  html += `<dt>ID</dt><dd><code>${escHtml(click.id)}</code>`;
+  html += ` <button class="copy-btn" data-copy="${escHtml(click.id)}">copy</button></dd>`;
+  html += `<dt>Goal</dt><dd>${escHtml(click.goal)}</dd>`;
+  html += `<dt>Status</dt><dd>${statusBadgeHtml(click.status)}</dd>`;
+  if (click.parent) {
+    html += `<dt>Parent</dt><dd>`;
+    html += `<a class="link-id parent-link" data-click-id="${escHtml(click.parent.id)}" href="#">`;
+    html += `${escHtml(click.parent.id)}</a>`;
+    html += ` — ${escHtml(click.parent.goal)} ${statusBadgeHtml(click.parent.status)}`;
+    html += `</dd>`;
+  }
+  html += `<dt>Created</dt><dd>${fmtDate(click.createdAt)}</dd>`;
+  if (click.resolvedAt) html += `<dt>Resolved</dt><dd>${fmtDate(click.resolvedAt)}</dd>`;
+  if (click.createdSessionId) html += `<dt>Created by</dt><dd>${escHtml(click.createdSessionId)}</dd>`;
+  if (click.resolvedSessionId) html += `<dt>Resolved by</dt><dd>${escHtml(click.resolvedSessionId)}</dd>`;
+  html += `</dl>`;
+
+  if (isTerminal && click.conclusion) {
+    html += `<details class="conclusion-expandable">`;
+    html += `<summary>▸ Conclusion</summary>`;
+    html += `<div class="conclusion-body">${escHtml(click.conclusion)}</div>`;
+    html += `</details>`;
+  }
+
+  html += `</div>`;
+  return html;
+}
+
+function renderChildrenSection(children) {
+  const items = children?.items ?? [];
+  if (items.length === 0) return '';
+
+  let html = `<div class="detail-section"><h4>Children</h4>`;
+
+  const summary = children?.summary ?? {};
+  if (Object.keys(summary).length > 0) {
+    html += `<div style="margin-bottom:0.5rem;display:flex;flex-wrap:wrap;gap:0.4rem">`;
+    for (const [status, count] of Object.entries(summary)) {
+      html += `${statusBadgeHtml(status)} <span style="margin-right:0.5rem;font-size:0.8rem">${count}</span>`;
+    }
+    html += `</div>`;
+  }
+
+  html += `<table class="data-table"><thead><tr>`;
+  html += `<th>Status</th><th>Goal</th><th>ID</th>`;
+  html += `</tr></thead><tbody>`;
+  for (const child of items) {
+    html += `<tr class="click-child-row" data-child-id="${escHtml(child.id)}">`;
+    html += `<td>${statusBadgeHtml(child.status)}</td>`;
+    html += `<td>${escHtml(child.goal)}</td>`;
+    html += `<td><code>${escHtml(child.id)}</code></td>`;
+    html += `</tr>`;
+  }
+  html += `</tbody></table></div>`;
+  return html;
+}
+
+function renderLinksSection(links, clickId) {
+  const outbound = links?.outbound ?? [];
+  const inbound  = links?.inbound  ?? [];
+  let html = `<div class="detail-section" id="links-section-${escHtml(clickId)}"><h4>Links</h4>`;
+
+  if (outbound.length === 0 && inbound.length === 0) {
+    html += `<p style="font-size:0.8rem;opacity:0.5">No links.</p>`;
+  }
+
+  for (const l of outbound) {
+    const dispatch = dispatchLinkTarget(l.targetId);
+    html += `<div class="link-row">`;
+    html += `<span class="link-dir">→</span>`;
+    if (dispatch.type === 'click') {
+      html += `<a class="link-id" data-dispatch="click" data-target-id="${escHtml(l.targetId)}">${escHtml(l.targetId)}</a>`;
+    } else if (dispatch.type === 'writ') {
+      html += `<a class="link-id" href="${escHtml(dispatch.href)}">${escHtml(l.targetId)}</a>`;
+    } else {
+      html += `<span class="link-id" style="cursor:default;text-decoration:none">${escHtml(l.targetId)}</span>`;
+    }
+    html += ` <span class="link-meta" data-meta-id="${escHtml(l.targetId)}"></span>`;
+    html += ` <span class="link-type-badge">(${escHtml(l.linkType)})</span>`;
+    html += ` <button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.7rem"`;
+    html += ` data-action="unlink" data-source="${escHtml(l.sourceId)}" data-target="${escHtml(l.targetId)}" data-link-type="${escHtml(l.linkType)}">×</button>`;
+    html += `</div>`;
+  }
+  for (const l of inbound) {
+    const dispatch = dispatchLinkTarget(l.sourceId);
+    html += `<div class="link-row">`;
+    html += `<span class="link-dir">←</span>`;
+    if (dispatch.type === 'click') {
+      html += `<a class="link-id" data-dispatch="click" data-target-id="${escHtml(l.sourceId)}">${escHtml(l.sourceId)}</a>`;
+    } else if (dispatch.type === 'writ') {
+      html += `<a class="link-id" href="${escHtml(dispatch.href)}">${escHtml(l.sourceId)}</a>`;
+    } else {
+      html += `<span class="link-id" style="cursor:default;text-decoration:none">${escHtml(l.sourceId)}</span>`;
+    }
+    html += ` <span class="link-meta" data-meta-id="${escHtml(l.sourceId)}"></span>`;
+    html += ` <span class="link-type-badge">(${escHtml(l.linkType)})</span>`;
+    html += ` <button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.7rem"`;
+    html += ` data-action="unlink" data-source="${escHtml(l.sourceId)}" data-target="${escHtml(l.targetId)}" data-link-type="${escHtml(l.linkType)}">×</button>`;
+    html += `</div>`;
+  }
+
+  html += `<div class="add-link-form" id="add-link-form-${escHtml(clickId)}">`;
+  html += `<input type="text" id="link-target-input-${escHtml(clickId)}" placeholder="Target ID" style="width:130px">`;
+  html += `<select id="link-type-select-${escHtml(clickId)}">`;
+  html += `<option value="related">related</option>`;
+  html += `<option value="commissioned">commissioned</option>`;
+  html += `<option value="supersedes">supersedes</option>`;
+  html += `<option value="depends-on">depends-on</option>`;
+  html += `</select>`;
+  html += `<button class="btn" data-action="addlink" data-id="${escHtml(clickId)}">Add Link</button>`;
+  html += `<div class="error-msg" id="link-error-${escHtml(clickId)}" style="display:none"></div>`;
+  html += `</div>`;
+
+  html += `</div>`;
+  return html;
+}
+
+// ── statusBadgeHtml ───────────────────────────────────────────────────
+
+describe('statusBadgeHtml', () => {
+  it('maps live to badge--active (D20)', () => {
+    const html = statusBadgeHtml('live');
+    assert.ok(html.includes('badge--active'), 'live → badge--active');
+    assert.ok(html.includes('>live<'), 'should include status text');
+  });
+
+  it('maps parked to badge--warning (D20)', () => {
+    const html = statusBadgeHtml('parked');
+    assert.ok(html.includes('badge--warning'), 'parked → badge--warning');
+  });
+
+  it('maps concluded to badge--success (D20)', () => {
+    const html = statusBadgeHtml('concluded');
+    assert.ok(html.includes('badge--success'), 'concluded → badge--success');
+  });
+
+  it('maps dropped to badge--error (D20)', () => {
+    const html = statusBadgeHtml('dropped');
+    assert.ok(html.includes('badge--error'), 'dropped → badge--error');
+  });
+
+  it('falls back to plain badge for unknown status', () => {
+    const html = statusBadgeHtml('unknown');
+    assert.ok(html.includes('<span class="badge">unknown</span>'));
+  });
+});
+
+// ── dispatchLinkTarget ────────────────────────────────────────────────
+
+describe('dispatchLinkTarget (D15)', () => {
+  it('c- prefix → type:click, href:null', () => {
+    const result = dispatchLinkTarget('c-mo1mq8ry-abc123');
+    assert.equal(result.type, 'click');
+    assert.equal(result.href, null);
+  });
+
+  it('w- prefix → type:writ, href to writs page', () => {
+    const result = dispatchLinkTarget('w-abc123');
+    assert.equal(result.type, 'writ');
+    assert.ok(result.href.includes('/pages/writs/'), 'should link to writs page');
+    assert.ok(result.href.includes(encodeURIComponent('w-abc123')), 'writ id should be encoded in URL');
+  });
+
+  it('unknown prefix → type:plain, href:null', () => {
+    const result = dispatchLinkTarget('other-thing-123');
+    assert.equal(result.type, 'plain');
+    assert.equal(result.href, null);
+  });
+
+  it('plain string with no prefix → type:plain', () => {
+    const result = dispatchLinkTarget('some-external-ref');
+    assert.equal(result.type, 'plain');
+  });
+
+  it('w- prefix href encodes the full ID including hyphens', () => {
+    const result = dispatchLinkTarget('w-some-long-id');
+    assert.ok(result.href.includes(encodeURIComponent('w-some-long-id')));
+  });
+
+  it('c- short ID → type:click', () => {
+    const result = dispatchLinkTarget('c-mo1o65ky');
+    assert.equal(result.type, 'click');
+  });
+});
+
+// ── renderDetailFields ────────────────────────────────────────────────
+
+describe('renderDetailFields', () => {
+  const baseClick = {
+    id: 'c-abc123-def456',
+    goal: 'Test goal',
+    status: 'live',
+    createdAt: '2025-01-01T00:00:00.000Z',
+  };
+
+  it('renders ID, goal, and status', () => {
+    const html = renderDetailFields(baseClick);
+    assert.ok(html.includes('c-abc123-def456'), 'should include ID');
+    assert.ok(html.includes('Test goal'), 'should include goal');
+    assert.ok(html.includes('badge--active'), 'should include live status badge');
+  });
+
+  it('includes copy button for ID', () => {
+    const html = renderDetailFields(baseClick);
+    assert.ok(html.includes('class="copy-btn"'), 'should include copy button');
+    assert.ok(html.includes(`data-copy="${baseClick.id}"`), 'copy button should have ID');
+  });
+
+  it('renders parent link when parent is set', () => {
+    const click = { ...baseClick, parent: { id: 'c-parent-000', goal: 'Parent goal', status: 'live' } };
+    const html = renderDetailFields(click);
+    assert.ok(html.includes('<dt>Parent</dt>'), 'should have Parent label');
+    assert.ok(html.includes('c-parent-000'), 'should include parent ID');
+    assert.ok(html.includes('Parent goal'), 'should include parent goal');
+  });
+
+  it('does not render parent row when parent is null', () => {
+    const click = { ...baseClick, parent: null };
+    const html = renderDetailFields(click);
+    assert.ok(!html.includes('<dt>Parent</dt>'), 'should not have Parent label');
+  });
+
+  it('does not render parent row when parent is undefined', () => {
+    const html = renderDetailFields(baseClick);
+    assert.ok(!html.includes('<dt>Parent</dt>'), 'should not have Parent label');
+  });
+
+  it('renders resolvedAt when set', () => {
+    const click = { ...baseClick, resolvedAt: '2025-06-01T00:00:00.000Z' };
+    const html = renderDetailFields(click);
+    assert.ok(html.includes('<dt>Resolved</dt>'), 'should have Resolved label');
+  });
+
+  it('omits resolvedAt when not set', () => {
+    const html = renderDetailFields(baseClick);
+    assert.ok(!html.includes('<dt>Resolved</dt>'));
+  });
+
+  it('renders createdSessionId when set', () => {
+    const click = { ...baseClick, createdSessionId: 'sess-001' };
+    const html = renderDetailFields(click);
+    assert.ok(html.includes('sess-001'), 'should include session ID');
+    assert.ok(html.includes('Created by'), 'should have Created by label');
+  });
+
+  it('renders resolvedSessionId when set', () => {
+    const click = { ...baseClick, resolvedSessionId: 'sess-002' };
+    const html = renderDetailFields(click);
+    assert.ok(html.includes('sess-002'), 'should include resolved session ID');
+    assert.ok(html.includes('Resolved by'), 'should have Resolved by label');
+  });
+
+  it('does not render expandable conclusion for non-terminal click', () => {
+    const html = renderDetailFields(baseClick);
+    assert.ok(!html.includes('conclusion-expandable'), 'live click should not have expandable conclusion');
+  });
+
+  it('renders expandable conclusion for concluded click (D10)', () => {
+    const click = { ...baseClick, status: 'concluded', conclusion: 'All done!' };
+    const html = renderDetailFields(click);
+    assert.ok(html.includes('conclusion-expandable'), 'concluded should have expandable conclusion');
+    assert.ok(html.includes('All done!'), 'conclusion text should be present');
+    assert.ok(html.includes('▸ Conclusion'), 'summary should have disclosure triangle');
+  });
+
+  it('renders expandable conclusion for dropped click', () => {
+    const click = { ...baseClick, status: 'dropped', conclusion: 'Not needed.' };
+    const html = renderDetailFields(click);
+    assert.ok(html.includes('conclusion-expandable'), 'dropped should have expandable conclusion');
+    assert.ok(html.includes('Not needed.'), 'conclusion text should be present');
+  });
+
+  it('does not render conclusion section when terminal but no conclusion', () => {
+    const click = { ...baseClick, status: 'concluded' };
+    const html = renderDetailFields(click);
+    assert.ok(!html.includes('conclusion-expandable'), 'no conclusion section without conclusion text');
+  });
+
+  it('HTML-escapes goal text', () => {
+    const click = { ...baseClick, goal: '<script>alert(1)</script>' };
+    const html = renderDetailFields(click);
+    assert.ok(!html.includes('<script>'), 'should escape HTML in goal');
+    assert.ok(html.includes('&lt;script&gt;'), 'should encode script tag');
+  });
+});
+
+// ── renderChildrenSection ─────────────────────────────────────────────
+
+describe('renderChildrenSection', () => {
+  it('returns empty string when no children', () => {
+    const result = renderChildrenSection({ items: [], summary: {} });
+    assert.equal(result, '', 'should return empty string for no children');
+  });
+
+  it('returns empty string for undefined children', () => {
+    assert.equal(renderChildrenSection(undefined), '');
+    assert.equal(renderChildrenSection(null), '');
+  });
+
+  it('renders a table with children rows (D22)', () => {
+    const children = {
+      summary: { live: 2 },
+      items: [
+        { id: 'c-child1', goal: 'First child', status: 'live' },
+        { id: 'c-child2', goal: 'Second child', status: 'live' },
+      ],
+    };
+    const html = renderChildrenSection(children);
+    assert.ok(html.includes('<h4>Children</h4>'), 'should have Children header');
+    assert.ok(html.includes('c-child1'), 'should include first child ID');
+    assert.ok(html.includes('c-child2'), 'should include second child ID');
+    assert.ok(html.includes('First child'), 'should include first child goal');
+    assert.ok(html.includes('Second child'), 'should include second child goal');
+    // Children rows should be clickable
+    assert.ok(html.includes('click-child-row'), 'should have clickable rows');
+    assert.ok(html.includes(`data-child-id="c-child1"`), 'row should have child ID');
+  });
+
+  it('renders status-count badge strip (D22)', () => {
+    const children = {
+      summary: { live: 3, parked: 1 },
+      items: [
+        { id: 'c-1', goal: 'a', status: 'live' },
+      ],
+    };
+    const html = renderChildrenSection(children);
+    assert.ok(html.includes('badge--active'), 'live badge in summary strip');
+    assert.ok(html.includes('badge--warning'), 'parked badge in summary strip');
+  });
+
+  it('renders table columns: Status, Goal, ID', () => {
+    const children = {
+      summary: {},
+      items: [{ id: 'c-x', goal: 'x', status: 'live' }],
+    };
+    const html = renderChildrenSection(children);
+    assert.ok(html.includes('<th>Status</th>'), 'Status column header');
+    assert.ok(html.includes('<th>Goal</th>'), 'Goal column header');
+    assert.ok(html.includes('<th>ID</th>'), 'ID column header');
+  });
+
+  it('HTML-escapes child goal text', () => {
+    const children = {
+      summary: {},
+      items: [{ id: 'c-1', goal: '<bad>', status: 'live' }],
+    };
+    const html = renderChildrenSection(children);
+    assert.ok(!html.includes('<bad>'), 'should escape HTML in goal');
+    assert.ok(html.includes('&lt;bad&gt;'));
+  });
+});
+
+// ── renderLinksSection ────────────────────────────────────────────────
+
+describe('renderLinksSection', () => {
+  it('renders "No links." when both outbound and inbound are empty', () => {
+    const html = renderLinksSection({ outbound: [], inbound: [] }, 'c-src');
+    assert.ok(html.includes('No links.'), 'should show empty state');
+  });
+
+  it('renders outbound link with → direction', () => {
+    const links = {
+      outbound: [{
+        sourceId: 'c-src', targetId: 'c-tgt', linkType: 'related',
+      }],
+      inbound: [],
+    };
+    const html = renderLinksSection(links, 'c-src');
+    assert.ok(html.includes('→'), 'outbound should use → arrow');
+    assert.ok(html.includes('c-tgt'), 'should show target ID');
+    assert.ok(html.includes('(related)'), 'should show link type');
+  });
+
+  it('renders inbound link with ← direction', () => {
+    const links = {
+      outbound: [],
+      inbound: [{
+        sourceId: 'c-other', targetId: 'c-src', linkType: 'depends-on',
+      }],
+    };
+    const html = renderLinksSection(links, 'c-src');
+    assert.ok(html.includes('←'), 'inbound should use ← arrow');
+    assert.ok(html.includes('c-other'), 'should show source ID');
+    assert.ok(html.includes('(depends-on)'), 'should show link type');
+  });
+
+  it('c- outbound target renders as clickable dispatch link', () => {
+    const links = {
+      outbound: [{ sourceId: 'c-me', targetId: 'c-other', linkType: 'related' }],
+      inbound: [],
+    };
+    const html = renderLinksSection(links, 'c-me');
+    assert.ok(html.includes('data-dispatch="click"'), 'c- target should use click dispatch');
+    assert.ok(html.includes(`data-target-id="c-other"`), 'should have target ID on element');
+  });
+
+  it('w- outbound target renders as external href link', () => {
+    const links = {
+      outbound: [{ sourceId: 'c-me', targetId: 'w-abc', linkType: 'commissioned' }],
+      inbound: [],
+    };
+    const html = renderLinksSection(links, 'c-me');
+    assert.ok(html.includes('/pages/writs/'), 'w- target should link to writs page');
+    assert.ok(!html.includes('data-dispatch="click"'), 'w- target should not use click dispatch');
+  });
+
+  it('unknown prefix renders as plain text (no link)', () => {
+    const links = {
+      outbound: [{ sourceId: 'c-me', targetId: 'external-ref', linkType: 'related' }],
+      inbound: [],
+    };
+    const html = renderLinksSection(links, 'c-me');
+    // Should not be a clickable link
+    assert.ok(!html.includes('data-dispatch="click"'), 'should not use click dispatch');
+    assert.ok(!html.includes('href='), 'plain text should not have href');
+    assert.ok(html.includes('external-ref'), 'should still show the ID');
+  });
+
+  it('renders unlink button for each link', () => {
+    const links = {
+      outbound: [{ sourceId: 'c-me', targetId: 'c-other', linkType: 'related' }],
+      inbound: [],
+    };
+    const html = renderLinksSection(links, 'c-me');
+    assert.ok(html.includes('data-action="unlink"'), 'should have unlink button');
+    assert.ok(html.includes(`data-link-type="related"`), 'unlink button should have link type');
+  });
+
+  it('renders add-link form with enum select dropdown (D14)', () => {
+    const html = renderLinksSection({ outbound: [], inbound: [] }, 'c-me');
+    assert.ok(html.includes('id="link-type-select-c-me"'), 'should have link type select');
+    assert.ok(html.includes('<option value="related">'), 'should have related option');
+    assert.ok(html.includes('<option value="commissioned">'), 'should have commissioned option');
+    assert.ok(html.includes('<option value="supersedes">'), 'should have supersedes option');
+    assert.ok(html.includes('<option value="depends-on">'), 'should have depends-on option');
+  });
+});
diff --git a/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
