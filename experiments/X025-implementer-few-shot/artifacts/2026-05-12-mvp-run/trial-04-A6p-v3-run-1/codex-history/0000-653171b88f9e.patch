+  let scopeRootId = null;    // current subtree scope (from ?root= URL param)
+  let collapsedIds = new Set(); // IDs the user has explicitly collapsed
+  let activeStatuses = new Set(['live', 'parked', 'concluded', 'dropped']); // all on by default
+
+  // Parse URL params on load
+  const urlParams = new URLSearchParams(window.location.search);
+  const initClickId = urlParams.get('click') || null;
+  const initRootId  = urlParams.get('root')  || null;
+  if (initRootId) scopeRootId = initRootId;
+
+  // ── API helper ────────────────────────────────────────────────────────
+  async function api(method, path, body) {
+    const opts = { method, headers: { 'Content-Type': 'application/json' } };
+    if (body !== undefined) opts.body = JSON.stringify(body);
+    const res = await fetch(path, opts);
+    const json = await res.json();
+    if (!res.ok) throw new Error(json.error ?? `HTTP ${res.status}`);
+    return json;
+  }
+
