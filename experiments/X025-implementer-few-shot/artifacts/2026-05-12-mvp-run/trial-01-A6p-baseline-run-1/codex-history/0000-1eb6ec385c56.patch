+    .add-link-form { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: flex-end; margin-top: 0.5rem; }
+    .add-link-form input, .add-link-form select {
+      padding: 0.3rem 0.5rem; background: var(--bg3, #24283b);
+      border: 1px solid var(--border, #414868); border-radius: 4px;
+      color: inherit; font-size: 0.875rem;
+    }
+    .confirm-section {
+      display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: flex-end;
+      margin-top: 0.5rem; padding: 0.75rem; background: var(--bg3, #24283b); border-radius: 6px;
+    }
+    .confirm-section label { font-size: 0.875rem; opacity: 0.8; }
+    .confirm-section input {
+      padding: 0.3rem 0.5rem; background: var(--bg, #1a1b26);
+      border: 1px solid var(--border, #414868); border-radius: 4px;
+      color: inherit; min-width: 200px;
+    }
