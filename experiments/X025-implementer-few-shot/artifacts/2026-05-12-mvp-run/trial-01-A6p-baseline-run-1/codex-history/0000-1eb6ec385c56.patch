diff --git a/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
new file mode 100644
index 0000000..7db6880
--- /dev/null
+++ b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
@@ -0,0 +1,437 @@
+/**
+ * Unit tests for the pure tree logic in pages/clicks/index.html.
+ *
+ * Re-declares the functions under test since they are IIFE-scoped in the page.
+ * Uses node:test + assert/strict + a minimal FakeElement DOM shim, following
+ * the clerk pages/writs/writs-hierarchy.test.js pattern.
+ *
+ * Covers (per D21):
+ *   - tree-build from a ClickTree[] forest
+ *   - prune-by-status with subtree-hiding semantics (D6)
+ *   - subtree scoping and breadcrumb derivation (D23)
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Minimal DOM shim ────────────────────────────────────────────────
+
+class FakeElement {
+  constructor(tag) {
+    this.tagName = tag.toUpperCase();
+    this.className = '';
+    this.textContent = '';
+    this.title = '';
+    this.innerHTML = '';
+    this.dataset = {};
+    this.children = [];
+    this.style = {};
+    this._listeners = {};
+  }
+  appendChild(child) { this.children.push(child); return child; }
+  querySelectorAll(selector) {
+    if (selector.startsWith('.')) {
+      const cls = selector.slice(1);
+      return this.children.filter(c => (c.className ?? '').includes(cls));
+    }
+    return [];
+  }
+  addEventListener(event, fn) {
+    if (!this._listeners[event]) this._listeners[event] = [];
+    this._listeners[event].push(fn);
+  }
+  get classList() {
+    const self = this;
+    return {
+      toggle(cls, force) {
+        const parts = self.className.split(/\s+/).filter(Boolean);
+        const idx = parts.indexOf(cls);
+        if (force === true  && idx === -1) parts.push(cls);
+        if (force === false && idx !== -1) parts.splice(idx, 1);
+        if (force === undefined) {
+          if (idx === -1) parts.push(cls); else parts.splice(idx, 1);
+        }
+        self.className = parts.join(' ');
+      },
+      add(cls)    { if (!self.className.split(/\s+/).includes(cls)) self.className = (self.className + ' ' + cls).trim(); },
+      remove(cls) { self.className = self.className.split(/\s+/).filter(c => c !== cls).join(' '); },
+      contains(cls) { return self.className.split(/\s+/).includes(cls); },
+    };
+  }
+}
+
+// ── Re-declared pure functions (mirrors pages/clicks/index.html) ────
+
+function statusBadge(status) {
+  const map = {
+    live:      'badge badge--active',
+    parked:    'badge badge--warning',
+    concluded: 'badge badge--success',
+    dropped:   'badge badge--error',
+  };
+  return `<span class="${map[status] ?? 'badge'}">${escHtml(status)}</span>`;
+}
+
+function escHtml(s) {
+  return String(s ?? '')
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;');
+}
+
+function shortId(id) {
+  const parts = id.split('-');
+  return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+}
+
+/** Prune a ClickTree by a Set<string> of allowed statuses. */
+function pruneByStatus(tree, activeStatuses) {
+  if (!activeStatuses.has(tree.click.status)) return null;
+  const children = tree.children.map(c => pruneByStatus(c, activeStatuses)).filter(c => c !== null);
+  return { click: tree.click, children };
+}
+
+/** Apply scoping and status pruning to a forest. */
+function getVisibleForest(forest, scopedRootId, activeStatuses) {
+  let roots;
+  if (scopedRootId) {
+    const sub = findTree(forest, scopedRootId);
+    roots = sub ? [sub] : [];
+  } else {
+    roots = forest;
+  }
+  return roots.map(t => pruneByStatus(t, activeStatuses)).filter(t => t !== null);
+}
+
+function findTree(trees, id) {
+  for (const t of trees) {
+    if (t.click.id === id) return t;
+    const found = findTree(t.children, id);
+    if (found) return found;
+  }
+  return null;
+}
+
+/** Return the ancestor path of ClickDocs from forest root to the target ID. */
+function ancestorPath(forest, id) {
+  function walk(trees, target, acc) {
+    for (const t of trees) {
+      const path = [...acc, t.click];
+      if (t.click.id === target) return path;
+      const found = walk(t.children, target, path);
+      if (found) return found;
+    }
+    return null;
+  }
+  return walk(forest, id, []) ?? [];
+}
+
+/**
+ * Dispatch link target display by ID prefix (D15):
+ * c-… → in-page click anchor
+ * w-… → writs-page anchor
+ * other → plain text
+ */
+function linkTargetHtml(targetId) {
+  if (targetId.startsWith('c-')) {
+    return `<a class="link-target" data-click-id="${escHtml(targetId)}">${escHtml(targetId)}</a>`;
+  }
+  if (targetId.startsWith('w-')) {
+    return `<a class="link-target" href="/pages/writs/?writ=${encodeURIComponent(targetId)}">${escHtml(targetId)}</a>`;
+  }
+  return `<span>${escHtml(targetId)}</span>`;
+}
+
+// ── Test helpers ────────────────────────────────────────────────────
+
+function makeClick(id, status = 'live', opts = {}) {
+  return {
+    id,
+    goal:      opts.goal      ?? `Goal of ${id}`,
+    status,
+    createdAt: opts.createdAt ?? '2024-01-01T00:00:00.000Z',
+    conclusion: opts.conclusion,
+    parentId:   opts.parentId,
+  };
+}
+
+function makeTree(click, children = []) {
+  return { click, children };
+}
+
+// ── Tests: tree-build ───────────────────────────────────────────────
+
+describe('tree-build (pruneByStatus + getVisibleForest)', () => {
+  const ALL = new Set(['live', 'parked', 'concluded', 'dropped']);
+
+  it('returns forest unchanged when all statuses active', () => {
+    const root = makeTree(makeClick('c-1', 'live'), [
+      makeTree(makeClick('c-2', 'parked')),
+      makeTree(makeClick('c-3', 'concluded')),
+    ]);
+    const result = getVisibleForest([root], null, ALL);
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].children.length, 2);
+  });
+
+  it('returns an empty array for an empty forest', () => {
+    const result = getVisibleForest([], null, ALL);
+    assert.strictEqual(result.length, 0);
+  });
+
+  it('preserves tree structure when nothing is pruned', () => {
+    const grandchild = makeTree(makeClick('c-3', 'live'));
+    const child = makeTree(makeClick('c-2', 'live'), [grandchild]);
+    const root  = makeTree(makeClick('c-1', 'live'), [child]);
+    const result = getVisibleForest([root], null, ALL);
+    assert.strictEqual(result[0].children[0].children[0].click.id, 'c-3');
+  });
+});
+
+// ── Tests: prune-by-status ──────────────────────────────────────────
+
+describe('prune-by-status (D6)', () => {
+  it('prunes a root node whose status is not in the active set', () => {
+    const root = makeTree(makeClick('c-1', 'parked'));
+    const result = pruneByStatus(root, new Set(['live']));
+    assert.strictEqual(result, null);
+  });
+
+  it('prunes a root and its entire subtree when root status is filtered', () => {
+    const child = makeTree(makeClick('c-2', 'live'));
+    const root  = makeTree(makeClick('c-1', 'parked'), [child]);
+    const result = pruneByStatus(root, new Set(['live']));
+    // Root is parked → pruned, even though child is live
+    assert.strictEqual(result, null);
+  });
+
+  it('prunes non-matching children but keeps matching root', () => {
+    const liveChild   = makeTree(makeClick('c-2', 'live'));
+    const parkedChild = makeTree(makeClick('c-3', 'parked'));
+    const root        = makeTree(makeClick('c-1', 'live'), [liveChild, parkedChild]);
+    const result = pruneByStatus(root, new Set(['live']));
+    assert.ok(result, 'root should survive');
+    assert.strictEqual(result.children.length, 1);
+    assert.strictEqual(result.children[0].click.id, 'c-2');
+  });
+
+  it('preserves a grandchild when all ancestors match', () => {
+    const grandchild = makeTree(makeClick('c-3', 'live'));
+    const child = makeTree(makeClick('c-2', 'live'), [grandchild]);
+    const root  = makeTree(makeClick('c-1', 'live'), [child]);
+    const result = pruneByStatus(root, new Set(['live']));
+    assert.strictEqual(result.children[0].children[0].click.id, 'c-3');
+  });
+
+  it('prunes grandchild when parent does not match', () => {
+    const grandchild = makeTree(makeClick('c-3', 'live'));
+    const child      = makeTree(makeClick('c-2', 'parked'), [grandchild]);
+    const root       = makeTree(makeClick('c-1', 'live'), [child]);
+    const result = pruneByStatus(root, new Set(['live']));
+    assert.strictEqual(result.children.length, 0, 'parked child (with live grandchild) must be removed');
+  });
+
+  it('getVisibleForest prunes root-level nodes', () => {
+    const forest = [
+      makeTree(makeClick('c-1', 'live')),
+      makeTree(makeClick('c-2', 'dropped')),
+    ];
+    const result = getVisibleForest(forest, null, new Set(['live']));
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].click.id, 'c-1');
+  });
+
+  it('returns empty array when no nodes match filters', () => {
+    const forest = [makeTree(makeClick('c-1', 'live'))];
+    const result = getVisibleForest(forest, null, new Set(['parked']));
+    assert.strictEqual(result.length, 0);
+  });
+
+  it('filters by multiple statuses', () => {
+    const forest = [
+      makeTree(makeClick('c-1', 'live')),
+      makeTree(makeClick('c-2', 'parked')),
+      makeTree(makeClick('c-3', 'dropped')),
+    ];
+    const result = getVisibleForest(forest, null, new Set(['live', 'parked']));
+    assert.strictEqual(result.length, 2);
+    const ids = result.map(t => t.click.id);
+    assert.ok(ids.includes('c-1'));
+    assert.ok(ids.includes('c-2'));
+  });
+});
+
+// ── Tests: subtree scoping ──────────────────────────────────────────
+
+describe('subtree scoping (D23)', () => {
+  const ALL = new Set(['live', 'parked', 'concluded', 'dropped']);
+
+  it('returns full forest when scopedRootId is null', () => {
+    const forest = [
+      makeTree(makeClick('c-1', 'live')),
+      makeTree(makeClick('c-2', 'live')),
+    ];
+    const result = getVisibleForest(forest, null, ALL);
+    assert.strictEqual(result.length, 2);
+  });
+
+  it('returns only the scoped subtree when rootId is set', () => {
+    const child = makeTree(makeClick('c-2', 'live'));
+    const forest = [
+      makeTree(makeClick('c-1', 'live'), [child]),
+      makeTree(makeClick('c-3', 'live')),
+    ];
+    const result = getVisibleForest(forest, 'c-1', ALL);
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].click.id, 'c-1');
+    assert.strictEqual(result[0].children.length, 1);
+    assert.strictEqual(result[0].children[0].click.id, 'c-2');
+  });
+
+  it('returns empty when scopedRootId does not exist in forest', () => {
+    const forest = [makeTree(makeClick('c-1', 'live'))];
+    const result = getVisibleForest(forest, 'c-ghost', ALL);
+    assert.strictEqual(result.length, 0);
+  });
+
+  it('scoping to a deep node returns that node as root', () => {
+    const deep = makeTree(makeClick('c-3', 'live'));
+    const mid  = makeTree(makeClick('c-2', 'live'), [deep]);
+    const root = makeTree(makeClick('c-1', 'live'), [mid]);
+    const result = getVisibleForest([root], 'c-3', ALL);
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].click.id, 'c-3');
+    assert.strictEqual(result[0].children.length, 0);
+  });
+
+  // Breadcrumb derivation
+  it('ancestorPath returns empty array for unknown id', () => {
+    const forest = [makeTree(makeClick('c-1', 'live'))];
+    assert.deepStrictEqual(ancestorPath(forest, 'c-ghost'), []);
+  });
+
+  it('ancestorPath returns single-element array for a root node', () => {
+    const click = makeClick('c-1', 'live');
+    const forest = [makeTree(click)];
+    const path = ancestorPath(forest, 'c-1');
+    assert.strictEqual(path.length, 1);
+    assert.strictEqual(path[0].id, 'c-1');
+  });
+
+  it('ancestorPath returns full chain for a nested node', () => {
+    const gc   = makeClick('c-3', 'live');
+    const mid  = makeClick('c-2', 'live');
+    const root = makeClick('c-1', 'live');
+    const forest = [makeTree(root, [makeTree(mid, [makeTree(gc)])])];
+    const path = ancestorPath(forest, 'c-3');
+    assert.strictEqual(path.length, 3);
+    assert.strictEqual(path[0].id, 'c-1');
+    assert.strictEqual(path[1].id, 'c-2');
+    assert.strictEqual(path[2].id, 'c-3');
+  });
+
+  it('ancestorPath works across multiple forest roots', () => {
+    const target = makeClick('c-5', 'live');
+    const forest = [
+      makeTree(makeClick('c-1', 'live')),
+      makeTree(makeClick('c-2', 'live'), [makeTree(target)]),
+    ];
+    const path = ancestorPath(forest, 'c-5');
+    assert.strictEqual(path.length, 2);
+    assert.strictEqual(path[0].id, 'c-2');
+    assert.strictEqual(path[1].id, 'c-5');
+  });
+});
+
+// ── Tests: detail-pane rendering ────────────────────────────────────
+
+describe('detail-pane rendering', () => {
+  it('statusBadge maps live to badge--active', () => {
+    const html = statusBadge('live');
+    assert.ok(html.includes('badge--active'));
+    assert.ok(html.includes('live'));
+  });
+
+  it('statusBadge maps parked to badge--warning', () => {
+    const html = statusBadge('parked');
+    assert.ok(html.includes('badge--warning'));
+  });
+
+  it('statusBadge maps concluded to badge--success', () => {
+    const html = statusBadge('concluded');
+    assert.ok(html.includes('badge--success'));
+  });
+
+  it('statusBadge maps dropped to badge--error', () => {
+    const html = statusBadge('dropped');
+    assert.ok(html.includes('badge--error'));
+  });
+
+  it('shortId returns c-<base36ts> prefix', () => {
+    const full  = 'c-mo1mq8ry-abc123';
+    const short = shortId(full);
+    assert.strictEqual(short, 'c-mo1mq8ry');
+  });
+
+  it('shortId returns the ID unchanged when it has fewer than 2 parts', () => {
+    assert.strictEqual(shortId('single'), 'single');
+  });
+
+  it('escHtml encodes HTML special characters', () => {
+    assert.strictEqual(escHtml('<script>'), '&lt;script&gt;');
+    assert.strictEqual(escHtml('"quoted"'), '&quot;quoted&quot;');
+    assert.strictEqual(escHtml('a & b'), 'a &amp; b');
+  });
+
+  it('escHtml handles null/undefined safely', () => {
+    assert.strictEqual(escHtml(null),      '');
+    assert.strictEqual(escHtml(undefined), '');
+  });
+});
+
+// ── Tests: link dispatch (D15) ──────────────────────────────────────
+
+describe('link prefix dispatch (D15)', () => {
+  it('c-… prefix renders an in-page anchor with data-click-id', () => {
+    const html = linkTargetHtml('c-abc123');
+    assert.ok(html.includes('data-click-id="c-abc123"'));
+    assert.ok(html.includes('<a '));
+    assert.ok(!html.includes('/pages/writs/'));
+  });
+
+  it('w-… prefix renders a link to the writs page', () => {
+    const html = linkTargetHtml('w-xyz789');
+    assert.ok(html.includes('/pages/writs/'));
+    assert.ok(html.includes('w-xyz789'));
+    assert.ok(html.includes('<a '));
+  });
+
+  it('w-… prefix encodes the ID in the href', () => {
+    const html = linkTargetHtml('w-abc/def');
+    assert.ok(html.includes(encodeURIComponent('w-abc/def')));
+  });
+
+  it('unknown prefix renders as plain text without a link', () => {
+    const html = linkTargetHtml('github:org/repo');
+    assert.ok(html.includes('<span>'));
+    assert.ok(!html.includes('<a '));
+    assert.ok(html.includes('github:org/repo'));
+  });
+
+  it('c-… prefix does not link to writs page', () => {
+    const html = linkTargetHtml('c-mo1mq8ry');
+    assert.ok(!html.includes('/pages/writs/'));
+  });
+
+  it('w-… prefix does not carry data-click-id', () => {
+    const html = linkTargetHtml('w-mo1mq8ry');
+    assert.ok(!html.includes('data-click-id'));
+  });
+
+  it('escapes HTML in target IDs', () => {
+    const html = linkTargetHtml('c-<evil>');
+    assert.ok(!html.includes('<evil>'));
+    assert.ok(html.includes('&lt;evil&gt;'));
+  });
+});
