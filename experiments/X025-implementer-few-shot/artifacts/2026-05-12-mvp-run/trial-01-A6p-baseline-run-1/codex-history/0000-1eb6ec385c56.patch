+<!DOCTYPE html>
+<html lang="en">
+<head>
+  <meta charset="UTF-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1.0">
+  <title>Clicks</title>
+  <style>
+    /* ── Page-specific styles ───────────────────────────────────── */
+    .error-msg { color: var(--red, #f7768e); font-size: 0.875rem; margin-top: 0.25rem; }
+    .split-layout { display: flex; gap: 1rem; align-items: flex-start; }
+    .tree-area { flex: 0 0 55%; min-width: 0; }
+    .detail-area { flex: 1; min-width: 0; }
+    .tree-node-row {
+      display: flex; align-items: center; gap: 0.4rem;
+      padding: 0.2rem 0.35rem; cursor: pointer; border-radius: 4px;
+      border-left: 2px solid transparent;
+    }
+    .tree-node-row:hover { background: var(--bg3, #24283b); }
+    .tree-node-row.selected {
+      background: var(--bg3, #24283b);
+      border-left-color: var(--blue, #7aa2f7);
+    }
+    .tree-children {
+      padding-left: 1.25rem;
+      border-left: 1px solid var(--border, #414868);
+      margin-left: 0.6rem;
+    }
+    .expand-btn {
+      background: none; border: none; color: inherit; cursor: pointer;
+      width: 1rem; min-width: 1rem; text-align: center;
+      font-size: 0.75rem; padding: 0; opacity: 0.6;
+    }
+    .node-goal { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.9rem; }
+    .node-id-code { font-size: 0.72rem; opacity: 0.55; white-space: nowrap; }
+    .node-actions { display: flex; gap: 0.25rem; opacity: 0; transition: opacity 0.1s; flex-shrink: 0; }
+    .tree-node-row:hover .node-actions { opacity: 1; }
+    .conclusion-disclosure { padding-left: 1.6rem; }
+    .conclusion-text {
+      font-size: 0.8rem; opacity: 0.8;
+      padding: 0.25rem 0.5rem; background: var(--bg3, #24283b);
+      border-radius: 4px; margin-top: 0.15rem;
+      white-space: pre-wrap; word-break: break-word;
+    }
+    .breadcrumb { font-size: 0.875rem; display: flex; flex-wrap: wrap; align-items: center; gap: 0.2rem; }
+    .breadcrumb-sep { opacity: 0.4; }
+    .breadcrumb-link { cursor: pointer; color: var(--blue, #7aa2f7); text-decoration: underline; background: none; border: none; font: inherit; padding: 0; }
+    .breadcrumb-link:hover { opacity: 0.8; }
+    #create-section { margin-bottom: 16px; display: none; }
+    #create-section.open { display: block; }
+    #create-section h3 { margin: 0 0 0.75rem; }
+    .form-row { margin-bottom: 0.75rem; display: flex; flex-direction: column; gap: 0.3rem; }
+    .form-row label { font-size: 0.875rem; opacity: 0.7; }
+    .form-row input, .form-row textarea, .form-row select {
