+    .children-table { width: 100%; }
+    .children-table tbody tr { cursor: pointer; }
+    .children-table tbody tr:hover { opacity: 0.85; }
+    .detail-placeholder-text { font-size: 0.875rem; opacity: 0.5; text-align: center; padding: 2rem 1rem; }
+    #breadcrumb-bar { margin-bottom: 8px; }
+  </style>
+</head>
+<body>
+<main style="padding: 24px;">
+  <h1>Clicks</h1>
+
+  <!-- Toolbar -->
+  <div class="card" style="margin-bottom: 16px;">
+    <div class="toolbar" id="toolbar">
+      <button class="btn btn--primary" id="btn-new-click">New Click</button>
+      <button class="btn" id="btn-refresh">Refresh</button>
+      <span style="display:inline-flex;gap:0.4rem;flex-wrap:wrap;align-items:center">
+        <span style="font-size:0.875rem;opacity:0.6">Status:</span>
+        <button class="btn filter-btn active-filter" data-status="">All</button>
+        <button class="btn filter-btn active-filter" data-status="live">live</button>
+        <button class="btn filter-btn active-filter" data-status="parked">parked</button>
+        <button class="btn filter-btn active-filter" data-status="concluded">concluded</button>
+        <button class="btn filter-btn active-filter" data-status="dropped">dropped</button>
+      </span>
+    </div>
+  </div>
+
+  <!-- Create-click card (toggleable, per D13) -->
+  <div id="create-section" class="card">
+    <h3 id="create-form-title">New Click</h3>
+    <div class="form-row">
+      <label for="create-goal-input">Goal</label>
+      <input type="text" id="create-goal-input" placeholder="Click goal" required>
+    </div>
+    <div class="form-row">
+      <label for="create-parent-input">Parent ID (optional)</label>
+      <input type="text" id="create-parent-input" placeholder="Parent click ID or short prefix">
+    </div>
+    <button class="btn btn--primary" id="create-submit-btn">Create Click</button>
+    <div id="create-error" class="error-msg" style="display:none"></div>
+  </div>
+
+  <!-- Breadcrumb (shown when scoped, per D23) -->
+  <div id="breadcrumb-bar" class="card" style="display:none">
+    <div id="breadcrumb-content" class="breadcrumb"></div>
+  </div>
+
+  <!-- Split layout: tree area (left) + detail pane (right), per D4 -->
+  <div class="split-layout">
+    <div class="tree-area">
+      <div class="card" id="tree-card">
+        <div id="tree-container">
+          <div class="empty-state">Loading…</div>
+        </div>
+      </div>
+    </div>
+    <div class="detail-area">
+      <div id="detail-card" class="card" style="display:none">
+        <div id="detail-content"></div>
+      </div>
+      <div id="detail-placeholder" class="card">
+        <p class="detail-placeholder-text">Select a click to view its details.</p>
+      </div>
+    </div>
+  </div>
+
+</main>
+
+  <script>
+  (() => {
+    // ── State ────────────────────────────────────────────────────────
+    let forest = [];            // Full ClickTree[] from server
+    let selectedClickId = null; // Currently shown in detail pane
+    let scopedRootId = null;    // ?root= URL param
+    let collapsedNodes = new Set(); // node IDs the user has collapsed
+
+    // All four statuses active by default (D7)
+    let activeStatuses = new Set(['live', 'parked', 'concluded', 'dropped']);
+
+    // Parse URL params on load (D19, D23)
+    const _urlParams = new URLSearchParams(window.location.search);
+    selectedClickId = _urlParams.get('click');
+    scopedRootId    = _urlParams.get('root');
+
+    // ── Helpers ──────────────────────────────────────────────────────
+
+    async function api(method, path, body) {
+      const opts = { method, headers: { 'Content-Type': 'application/json' } };
+      if (body !== undefined) opts.body = JSON.stringify(body);
+      const res = await fetch(path, opts);
+      const json = await res.json();
+      if (!res.ok) throw new Error(json.error ?? `HTTP ${res.status}`);
+      return json;
+    }
+
+    /** Map click status to shared Oculus badge class (D9/D20). */
+    function statusBadge(status) {
+      const map = {
+        live:      'badge badge--active',
+        parked:    'badge badge--warning',
+        concluded: 'badge badge--success',
+        dropped:   'badge badge--error',
+      };
+      return `<span class="${map[status] ?? 'badge'}">${escHtml(status)}</span>`;
+    }
+
+    function fmtDate(iso) {
+      if (!iso) return '';
+      return new Date(iso).toLocaleString();
+    }
+
+    function escHtml(s) {
+      return String(s ?? '')
+        .replace(/&/g, '&amp;')
+        .replace(/</g, '&lt;')
+        .replace(/>/g, '&gt;')
+        .replace(/"/g, '&quot;');
+    }
+
+    function showError(el, msg) { el.textContent = msg; el.style.display = 'block'; }
+    function clearError(el) { el.textContent = ''; el.style.display = 'none'; }
+
+    async function copyToClipboard(text, btn) {
+      try {
+        await navigator.clipboard.writeText(text);
+        const orig = btn.textContent;
+        btn.textContent = '✓';
+        setTimeout(() => { btn.textContent = orig; }, 1500);
+      } catch (e) { console.error('Copy failed', e); }
+    }
+
+    /** Shorten `c-<base36ts>-<hex>` to `c-<base36ts>` (the resolvable prefix form). */
+    function shortId(id) {
+      const parts = id.split('-');
+      return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+    }
+
+    // ── Prune helpers (D6) ───────────────────────────────────────────
+
+    /**
+     * Prune a ClickTree by the active status set.
+     * Returns null when the node itself is filtered out.
+     */
+    function pruneByStatus(tree) {
+      if (!activeStatuses.has(tree.click.status)) return null;
+      const children = tree.children.map(pruneByStatus).filter(c => c !== null);
+      return { click: tree.click, children };
+    }
+
+    /** Return the pruned, scoped forest for rendering. */
+    function getVisibleForest() {
+      let roots;
+      if (scopedRootId) {
+        const sub = findTree(forest, scopedRootId);
+        roots = sub ? [sub] : [];
+      } else {
+        roots = forest;
+      }
+      return roots.map(pruneByStatus).filter(t => t !== null);
+    }
+
+    /** Find a ClickTree node anywhere in the forest by ID. */
+    function findTree(trees, id) {
+      for (const t of trees) {
+        if (t.click.id === id) return t;
+        const found = findTree(t.children, id);
+        if (found) return found;
+      }
+      return null;
+    }
+
+    /** Find the ClickDoc for a given ID anywhere in the forest. */
+    function findClick(id) {
+      const t = findTree(forest, id);
+      return t ? t.click : null;
+    }
+
+    // ── Breadcrumb (D23) ─────────────────────────────────────────────
+
+    /** Return the path of ClickDocs from the forest root to `id`. */
+    function ancestorPath(id) {
+      function walk(trees, target, acc) {
+        for (const t of trees) {
+          const path = [...acc, t.click];
+          if (t.click.id === target) return path;
+          const found = walk(t.children, target, path);
+          if (found) return found;
+        }
+        return null;
+      }
+      return walk(forest, id, []) ?? [];
+    }
+
+    function renderBreadcrumb() {
+      const bar = document.getElementById('breadcrumb-bar');
+      const content = document.getElementById('breadcrumb-content');
+
+      if (!scopedRootId) { bar.style.display = 'none'; return; }
+
+      bar.style.display = '';
+      const path = ancestorPath(scopedRootId);
+
+      let html = '<button class="breadcrumb-link" id="bc-show-all">Show all</button>';
+      for (const click of path) {
+        const label = click.goal.length > 40 ? click.goal.substring(0, 39) + '…' : click.goal;
+        html += `<span class="breadcrumb-sep">›</span>`;
+        html += `<button class="breadcrumb-link" data-bc-id="${click.id}">${escHtml(label)}</button>`;
+      }
+      content.innerHTML = html;
+
+      document.getElementById('bc-show-all').addEventListener('click', () => setScopedRoot(null));
+      content.querySelectorAll('[data-bc-id]').forEach(btn => {
+        btn.addEventListener('click', () => setScopedRoot(btn.dataset.bcId));
+      });
+    }
+
+    function setScopedRoot(id) {
+      scopedRootId = id;
+      const p = new URLSearchParams(window.location.search);
+      if (id) { p.set('root', id); } else { p.delete('root'); }
+      if (selectedClickId) { p.set('click', selectedClickId); } else { p.delete('click'); }
+      const qs = p.toString();
+      history.pushState({}, '', qs ? '?' + qs : location.pathname);
+      renderAll();
+    }
+
+    // ── Tree rendering ────────────────────────────────────────────────
+
+    function renderTree() {
+      const container = document.getElementById('tree-container');
+      const visible = getVisibleForest();
+
+      if (visible.length === 0) {
+        if (forest.length === 0) {
+          container.innerHTML = '<div class="empty-state">No clicks found. Create one with "New Click".</div>';
+        } else {
+          container.innerHTML = '<div class="empty-state">No clicks match the current filters.</div>';
+        }
+        return;
+      }
+
+      container.innerHTML = '';
+      for (const tree of visible) {
+        container.appendChild(buildNodeEl(tree));
+      }
+    }
+
+    function buildNodeEl(tree) {
+      const click  = tree.click;
+      const isSelected  = click.id === selectedClickId;
+      const isCollapsed = collapsedNodes.has(click.id);
+      const hasChildren = tree.children.length > 0;
+      const isTerminal  = click.status === 'concluded' || click.status === 'dropped';
+      const hasConclusion = isTerminal && click.conclusion;
+
+      const wrapper = document.createElement('div');
+      wrapper.dataset.nodeId = click.id;
+
+      // ── Row ──────────────────────────────────────────────────────
+      const row = document.createElement('div');
+      row.className = 'tree-node-row' + (isSelected ? ' selected' : '');
+      row.dataset.id = click.id;
+
+      // Expand/collapse button (for children) or conclusion toggle (for terminal leaf)
+      const expandBtn = document.createElement('button');
+      expandBtn.className = 'expand-btn';
+      if (hasChildren) {
+        expandBtn.textContent = isCollapsed ? '▸' : '▾';
+        expandBtn.title = isCollapsed ? 'Expand' : 'Collapse';
+        expandBtn.addEventListener('click', e => { e.stopPropagation(); toggleExpand(click.id); });
+      } else if (hasConclusion) {
+        // D10: disclosure triangle for terminal-node conclusion
+        expandBtn.textContent = '▸';
+        expandBtn.title = 'Show conclusion';
+        expandBtn.dataset.conclusionFor = click.id;
+        expandBtn.addEventListener('click', e => { e.stopPropagation(); toggleConclusion(click.id, expandBtn); });
+      }
+      row.appendChild(expandBtn);
+
+      // Status badge (D9)
+      const badgeWrapper = document.createElement('span');
+      badgeWrapper.innerHTML = statusBadge(click.status);
+      row.appendChild(badgeWrapper);
+
+      // Short ID
+      const idCode = document.createElement('code');
+      idCode.className = 'node-id-code';
+      idCode.textContent = shortId(click.id);
+      row.appendChild(idCode);
+
+      // Goal text
+      const goalSpan = document.createElement('span');
+      goalSpan.className = 'node-goal';
+      goalSpan.textContent = click.goal;
+      goalSpan.title = click.goal;
+      row.appendChild(goalSpan);
+
+      // Action buttons (visible on hover)
+      const actions = document.createElement('span');
+      actions.className = 'node-actions';
+
+      const copyBtn = document.createElement('button');
+      copyBtn.className = 'btn';
+      copyBtn.textContent = 'ID';
+      copyBtn.title = 'Copy full ID to clipboard';
+      copyBtn.style.cssText = 'padding:0.1rem 0.3rem;font-size:0.7rem';
+      copyBtn.addEventListener('click', e => { e.stopPropagation(); copyToClipboard(click.id, copyBtn); });
+      actions.appendChild(copyBtn);
+
+      const focusBtn = document.createElement('button');
+      focusBtn.className = 'btn';
+      focusBtn.textContent = 'Focus';
+      focusBtn.title = 'Scope tree to this subtree';
+      focusBtn.style.cssText = 'padding:0.1rem 0.3rem;font-size:0.7rem';
+      focusBtn.addEventListener('click', e => { e.stopPropagation(); setScopedRoot(click.id); });
+      actions.appendChild(focusBtn);
+
+      row.appendChild(actions);
+
+      // Select the click and show detail when the row label is clicked (D5)
+      row.addEventListener('click', () => selectClick(click.id));
+
+      wrapper.appendChild(row);
+
+      // ── Conclusion disclosure (D10) ──────────────────────────────
+      if (hasConclusion) {
+        const discDiv = document.createElement('div');
+        discDiv.className = 'conclusion-disclosure';
+        discDiv.id = 'node-conclusion-' + click.id;
+        discDiv.style.display = 'none';
+        const discText = document.createElement('div');
+        discText.className = 'conclusion-text';
+        discText.textContent = click.conclusion;
+        discDiv.appendChild(discText);
+        wrapper.appendChild(discDiv);
+      }
+
+      // ── Children (D8: all expanded by default) ───────────────────
+      if (hasChildren) {
+        const childrenDiv = document.createElement('div');
+        childrenDiv.className = 'tree-children';
+        childrenDiv.id = 'children-' + click.id;
+        if (isCollapsed) childrenDiv.style.display = 'none';
+        for (const child of tree.children) {
+          childrenDiv.appendChild(buildNodeEl(child));
+        }
+        wrapper.appendChild(childrenDiv);
+      }
+
+      return wrapper;
+    }
+
+    function toggleExpand(id) {
+      if (collapsedNodes.has(id)) {
+        collapsedNodes.delete(id);
+      } else {
+        collapsedNodes.add(id);
+      }
+      renderAll();
+    }
+
+    function toggleConclusion(id, btn) {
+      const discDiv = document.getElementById('node-conclusion-' + id);
+      if (!discDiv) return;
+      const show = discDiv.style.display === 'none';
+      discDiv.style.display = show ? '' : 'none';
+      btn.textContent = show ? '▾' : '▸';
+    }
+
+    // ── Data loading ─────────────────────────────────────────────────
+
+    async function loadForest() {
+      try {
+        const data = await api('GET', '/api/click/tree?format=json');
+        forest = Array.isArray(data) ? data : [];
+      } catch (e) {
+        console.error('Failed to load click tree:', e);
+        forest = [];
+      }
+    }
+
+    // ── Render all ───────────────────────────────────────────────────
+
+    function renderAll() {
+      renderBreadcrumb();
+      renderTree();
+    }
+
+    // ── Status filter (D6/D7) ────────────────────────────────────────
+
+    function setStatusFilter(status) {
+      const allStatuses = ['live', 'parked', 'concluded', 'dropped'];
+      if (status === '') {
+        // "All" button: activate all
+        activeStatuses = new Set(allStatuses);
+      } else {
+        const allActive = allStatuses.every(s => activeStatuses.has(s));
+        if (allActive) {
+          // Collapse to just the clicked status
+          activeStatuses = new Set([status]);
+        } else if (activeStatuses.has(status)) {
+          activeStatuses.delete(status);
+        } else {
+          activeStatuses.add(status);
+        }
+      }
+      // Re-sync button visual state
+      const nowAll = allStatuses.every(s => activeStatuses.has(s));
+      document.querySelectorAll('.filter-btn').forEach(btn => {
+        const s = btn.dataset.status;
+        btn.classList.toggle('active-filter', s === '' ? nowAll : activeStatuses.has(s));
+      });
+      renderAll();
+    }
+
+    // ── Select click → detail pane ────────────────────────────────────
+
+    async function selectClick(id) {
+      selectedClickId = id;
+
+      // Update URL ?click= param (D19)
+      const p = new URLSearchParams(window.location.search);
+      p.set('click', id);
+      if (scopedRootId) { p.set('root', scopedRootId); }
+      history.pushState({}, '', '?' + p.toString());
+
+      // Highlight selected row
+      document.querySelectorAll('.tree-node-row').forEach(row => {
+        row.classList.toggle('selected', row.dataset.id === id);
+      });
+
+      await showDetailPane(id);
+    }
+
+    async function showDetailPane(id) {
+      let clickData;
+      try {
+        clickData = await api('GET', '/api/click/show?id=' + encodeURIComponent(id));
+      } catch (e) {
+        console.error('Failed to load click detail:', e);
+        return;
+      }
+
+      document.getElementById('detail-placeholder').style.display = 'none';
+      document.getElementById('detail-card').style.display = '';
+
+      const content = document.getElementById('detail-content');
+      content.innerHTML = renderDetail(clickData);
+      wireDetailEvents(content, clickData);
+      fetchLinkMetadata(clickData);
+    }
+
+    function hideDetailPane() {
+      document.getElementById('detail-card').style.display = 'none';
+      document.getElementById('detail-placeholder').style.display = '';
+      selectedClickId = null;
+    }
+
+    // ── Detail pane rendering (D24) ──────────────────────────────────
+
+    function renderDetail(clickData) {
+      // click-show returns the ClickDoc fields spread + links + parent + children
+      const click    = clickData;
+      const links    = clickData.links    ?? { outbound: [], inbound: [] };
+      const children = clickData.children ?? { summary: {}, items: [] };
+      const parent   = clickData.parent;
+
+      const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+      let html = '';
+
+      // ── ID header with copy affordance ──────────────────────────
+      html += `<div class="detail-section" style="margin-bottom:0.5rem">`;
+      html += `<div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap">`;
+      html += `<code id="detail-id-${click.id}">${escHtml(click.id)}</code>`;
+      html += `<button class="btn copy-id-btn" data-copy="${escHtml(click.id)}" `;
+      html += `style="padding:0.1rem 0.3rem;font-size:0.7rem;cursor:pointer">📋</button>`;
+      html += `</div></div>`;
+
+      // ── Fields (D24) ─────────────────────────────────────────────
+      html += `<div class="detail-section"><dl class="detail-grid">`;
+      html += `<dt>Goal</dt><dd>${escHtml(click.goal)}</dd>`;
+      html += `<dt>Status</dt><dd>${statusBadge(click.status)}</dd>`;
+      if (parent) {
+        html += `<dt>Parent</dt><dd>`;
+        html += `<a class="link-target" data-click-id="${parent.id}">${escHtml(parent.goal ?? parent.id)}</a>`;
+        html += ` ${statusBadge(parent.status)}`;
+        html += `</dd>`;
+      }
+      html += `<dt>Created</dt><dd>${escHtml(fmtDate(click.createdAt))}</dd>`;
+      if (click.createdSessionId) {
+        html += `<dt>Created by</dt><dd><code>${escHtml(click.createdSessionId)}</code></dd>`;
+      }
+      if (click.resolvedAt) {
+        html += `<dt>Resolved</dt><dd>${escHtml(fmtDate(click.resolvedAt))}</dd>`;
+      }
+      if (click.resolvedSessionId) {
+        html += `<dt>Resolved by</dt><dd><code>${escHtml(click.resolvedSessionId)}</code></dd>`;
+      }
+      html += `</dl></div>`;
+
+      // ── Conclusion (terminal only, expandable per D10) ────────────
+      if (isTerminal && click.conclusion) {
+        html += `<div class="detail-section">`;
+        html += `<h4>Conclusion `;
+        html += `<button class="btn" id="concl-toggle-${click.id}" `;
+        html += `style="padding:0.1rem 0.3rem;font-size:0.7rem" title="Toggle conclusion">▸</button>`;
+        html += `</h4>`;
+        html += `<div id="concl-text-${click.id}" style="display:none;padding:0.5rem;`;
+        html += `background:var(--bg3,#24283b);border-radius:4px;font-size:0.875rem;`;
+        html += `white-space:pre-wrap;word-break:break-word">${escHtml(click.conclusion)}</div>`;
+        html += `</div>`;
+      }
+
+      // ── Children (D22) ────────────────────────────────────────────
+      const childItems = children.items ?? [];
+      if (childItems.length > 0 || Object.keys(children.summary ?? {}).length > 0) {
+        html += `<div class="detail-section"><h4>Children</h4>`;
+
+        // Status-count badge strip
+        if (children.summary && Object.keys(children.summary).length > 0) {
+          html += `<div style="margin-bottom:0.5rem">`;
+          for (const [st, cnt] of Object.entries(children.summary)) {
+            html += statusBadge(st) + ` <span style="margin-right:0.6rem">${cnt}</span>`;
+          }
+          html += `</div>`;
+        }
+
+        // Table of first-generation children with clickable rows
+        if (childItems.length > 0) {
+          html += `<table class="data-table children-table"><thead><tr>`;
+          html += `<th>Status</th><th>Goal</th><th>ID</th>`;
+          html += `</tr></thead><tbody>`;
+          for (const child of childItems) {
+            html += `<tr class="child-row" data-child-id="${escHtml(child.id)}">`;
+            html += `<td>${statusBadge(child.status)}</td>`;
+            html += `<td>${escHtml(child.goal ?? '')}</td>`;
+            html += `<td><code>${escHtml(child.id)}</code></td>`;
+            html += `</tr>`;
+          }
+          html += `</tbody></table>`;
+        }
+        html += `</div>`;
+      }
+
+      // ── Links (D15/D16) ───────────────────────────────────────────
+      html += `<div class="detail-section" id="links-section-${click.id}">`;
+      html += renderLinksSection(click, links);
+      html += `</div>`;
+
+      // ── Lifecycle actions (D11) ───────────────────────────────────
+      if (!isTerminal) {
+        html += `<div class="detail-section"><h4>Actions</h4>`;
+        html += `<div class="action-buttons" id="actions-${click.id}">`;
+        if (click.status === 'live') {
+          html += `<button class="btn" data-action="park" data-id="${click.id}">Park</button>`;
+          html += `<button class="btn btn--success" data-action="conclude" data-id="${click.id}">Conclude</button>`;
+          html += `<button class="btn btn--danger"  data-action="drop"     data-id="${click.id}">Drop</button>`;
+        } else if (click.status === 'parked') {
+          html += `<button class="btn btn--primary" data-action="resume"   data-id="${click.id}">Resume</button>`;
+          html += `<button class="btn btn--success" data-action="conclude" data-id="${click.id}">Conclude</button>`;
+          html += `<button class="btn btn--danger"  data-action="drop"     data-id="${click.id}">Drop</button>`;
+        }
+        html += `<div class="error-msg" id="action-error-${click.id}" style="display:none"></div>`;
+        html += `<div id="confirm-area-${click.id}"></div>`;
+        html += `</div></div>`;
+      }
+
+      return html;
+    }
+
+    /** Render the links section HTML for a click. */
+    function renderLinksSection(click, links) {
+      const outbound = links.outbound ?? [];
+      const inbound  = links.inbound  ?? [];
+      let html = '<h4>Links</h4>';
+
+      if (outbound.length === 0 && inbound.length === 0) {
+        html += '<p style="font-size:0.875rem;opacity:0.5">No links.</p>';
+      }
+
+      for (const l of outbound) {
+        html += `<div class="link-row">`;
+        html += `<span class="link-dir">→</span>`;
+        html += linkTargetHtml(l.targetId);
+        html += `<span class="badge" style="font-size:0.7rem;padding:0.1rem 0.35rem">${escHtml(l.linkType)}</span>`;
+        html += `<button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.75rem"`;
+        html += ` data-action="unlink" data-source="${l.sourceId}" data-target="${l.targetId}" data-link-type="${l.linkType}">×</button>`;
+        html += `<span class="link-meta" id="link-meta-${l.targetId}"></span>`;
+        html += `</div>`;
+      }
+      for (const l of inbound) {
+        html += `<div class="link-row">`;
+        html += `<span class="link-dir">←</span>`;
+        html += linkTargetHtml(l.sourceId);
+        html += `<span class="badge" style="font-size:0.7rem;padding:0.1rem 0.35rem">${escHtml(l.linkType)}</span>`;
+        html += `<button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.75rem"`;
+        html += ` data-action="unlink" data-source="${l.sourceId}" data-target="${l.targetId}" data-link-type="${l.linkType}">×</button>`;
+        html += `<span class="link-meta" id="link-meta-${l.sourceId}"></span>`;
+        html += `</div>`;
+      }
+
+      // Add-link form with enum dropdown (D14)
+      html += `<div class="add-link-form">`;
+      html += `<input type="text" id="link-target-${click.id}" placeholder="Target ID" style="width:160px">`;
+      html += `<select id="link-type-${click.id}">`;
+      html += `<option value="related">related</option>`;
+      html += `<option value="commissioned">commissioned</option>`;
+      html += `<option value="supersedes">supersedes</option>`;
+      html += `<option value="depends-on">depends-on</option>`;
+      html += `</select>`;
+      html += `<button class="btn" data-action="addlink" data-id="${click.id}">Link</button>`;
+      html += `<div class="error-msg" id="link-error-${click.id}" style="display:none"></div>`;
+      html += `</div>`;
+
+      return html;
+    }
+
+    /**
+     * Dispatch link target display by ID prefix (D15):
+     * c-… → anchor that opens click detail in-page
+     * w-… → anchor that navigates to the writs page
+     * other → plain text
+     */
+    function linkTargetHtml(targetId) {
+      if (targetId.startsWith('c-')) {
+        return `<a class="link-target" data-click-id="${escHtml(targetId)}">${escHtml(targetId)}</a>`;
+      }
+      if (targetId.startsWith('w-')) {
+        return `<a class="link-target" href="/pages/writs/?writ=${encodeURIComponent(targetId)}">${escHtml(targetId)}</a>`;
+      }
+      return `<span>${escHtml(targetId)}</span>`;
+    }
+
+    /**
+     * Lazily fetch metadata for each link target and populate the
+     * `.link-meta` spans in the detail pane (D16).
+     */
+    async function fetchLinkMetadata(clickData) {
+      const links   = clickData.links ?? { outbound: [], inbound: [] };
+      const targets = [
+        ...links.outbound.map(l => l.targetId),
+        ...links.inbound .map(l => l.sourceId),
+      ];
+
+      for (const id of targets) {
+        const metaEl = document.getElementById('link-meta-' + id);
+        if (!metaEl) continue;
+        try {
+          if (id.startsWith('c-')) {
+            const data = await api('GET', '/api/click/show?id=' + encodeURIComponent(id));
+            const goal = data.goal ?? '';
+            metaEl.textContent = goal ? '— ' + goal.substring(0, 50) : '';
+          } else if (id.startsWith('w-')) {
+            const data = await api('GET', '/api/writ/show?id=' + encodeURIComponent(id));
+            const title = data.title ?? '';
+            metaEl.textContent = title ? '— ' + title.substring(0, 50) : '';
+          }
+        } catch (_) { /* silently ignore — metadata is best-effort */ }
+      }
+    }
+
+    // ── Detail event wiring ──────────────────────────────────────────
+
+    function wireDetailEvents(container, clickData) {
+      const click = clickData;
+
+      // Copy-ID button
+      container.querySelectorAll('.copy-id-btn').forEach(btn => {
+        btn.addEventListener('click', () => copyToClipboard(btn.dataset.copy, btn));
+      });
+
+      // Conclusion toggle (D10)
+      const conclToggle = document.getElementById('concl-toggle-' + click.id);
+      if (conclToggle) {
+        conclToggle.addEventListener('click', () => {
+          const conclText = document.getElementById('concl-text-' + click.id);
+          if (!conclText) return;
+          const show = conclText.style.display === 'none';
+          conclText.style.display = show ? '' : 'none';
+          conclToggle.textContent = show ? '▾' : '▸';
+        });
+      }
+
+      // Child-row clicks → navigate to child detail (D22)
+      container.querySelectorAll('.child-row').forEach(row => {
+        row.addEventListener('click', () => selectClick(row.dataset.childId));
+      });
+
+      // Parent link click (c-… prefix)
+      container.querySelectorAll('.link-target[data-click-id]').forEach(a => {
+        a.addEventListener('click', e => {
+          e.preventDefault();
+          selectClick(a.dataset.clickId);
+        });
+      });
+
+      // Generic data-action buttons
+      container.querySelectorAll('[data-action]').forEach(btn => {
+        btn.addEventListener('click', e => {
+          e.stopPropagation();
+          handleDetailAction(btn.dataset.action, btn.dataset.id ?? click.id, btn, container, click);
+        });
+      });
+    }
+
+    function handleDetailAction(action, id, btn, container, click) {
+      if      (action === 'park')    doSimpleTransition(id, 'park',    btn);
+      else if (action === 'resume')  doSimpleTransition(id, 'resume',  btn);
+      else if (action === 'conclude') showConfirm(id, 'conclude', btn, container);
+      else if (action === 'drop')     showConfirm(id, 'drop',     btn, container);
+      else if (action === 'unlink') {
+        doUnlink(btn.dataset.source, btn.dataset.target, btn.dataset.linkType, btn, id);
+      }
+      else if (action === 'addlink') {
+        const targetInput = document.getElementById('link-target-' + id);
+        const typeSelect  = document.getElementById('link-type-'   + id);
+        const errEl       = document.getElementById('link-error-'  + id);
+        doAddLink(id, targetInput.value.trim(), typeSelect.value, btn, errEl, targetInput);
+      }
+    }
+
+    async function doSimpleTransition(id, action, btn) {
+      const orig = btn.textContent;
+      btn.disabled = true; btn.textContent = '…';
+      try {
+        await api('POST', '/api/click/' + action, { id });
+        await refreshAfterMutation(id);
+      } catch (e) {
+        alert(`Failed to ${action}: ${e.message}`);
+      } finally {
+        btn.disabled = false; btn.textContent = orig;
+      }
+    }
+
+    /** Show the conclude/drop confirm section with a required conclusion input. */
+    function showConfirm(id, action, btn, container) {
+      const area   = document.getElementById('confirm-area-' + id);
+      const errEl  = container.querySelector('#action-error-' + id);
+      if (errEl) clearError(errEl);
+      if (!area) return;
+
+      const confirmLabel = action === 'conclude' ? 'Confirm Conclude' : 'Confirm Drop';
+      const btnClass     = action === 'conclude' ? 'btn--success' : 'btn--danger';
+
+      area.innerHTML = `
+        <div class="confirm-section">
+          <label>Conclusion (required)</label>
+          <input type="text" id="confirm-concl-${id}" placeholder="Conclusion text">
+          <button class="btn ${btnClass}" id="confirm-btn-${id}" disabled>${escHtml(confirmLabel)}</button>
+          <div class="error-msg" id="confirm-error-${id}" style="display:none"></div>
+        </div>`;
+
+      const input      = document.getElementById('confirm-concl-'  + id);
+      const confirmBtn = document.getElementById('confirm-btn-'    + id);
+      const confirmErr = document.getElementById('confirm-error-'  + id);
+
+      input.addEventListener('input', () => {
+        confirmBtn.disabled = !input.value.trim();
+        clearError(confirmErr);
+      });
+
+      confirmBtn.addEventListener('click', async () => {
+        const conclusion = input.value.trim();
+        clearError(confirmErr);
+        confirmBtn.disabled = true; confirmBtn.textContent = '…';
+        try {
+          await api('POST', '/api/click/' + action, { id, conclusion });
+          await refreshAfterMutation(id);
+          area.innerHTML = '';
+        } catch (e) {
+          showError(confirmErr, e.message);
+          confirmBtn.disabled = false; confirmBtn.textContent = confirmLabel;
+        }
+      });
+    }
+
+    async function doUnlink(sourceId, targetId, linkType, btn, clickId) {
+      const orig = btn.textContent;
+      btn.disabled = true;
+      try {
+        await api('POST', '/api/click/unlink', { sourceId, targetId, linkType });
+        await refreshAfterMutation(clickId);
+      } catch (e) {
+        alert('Unlink failed: ' + e.message);
+      } finally {
+        btn.disabled = false; btn.textContent = orig;
+      }
+    }
+
+    async function doAddLink(clickId, targetId, linkType, btn, errEl, targetInput) {
+      clearError(errEl);
+      if (!targetId) { showError(errEl, 'Target ID is required.'); return; }
+      const orig = btn.textContent;
+      btn.disabled = true; btn.textContent = '…';
+      try {
+        await api('POST', '/api/click/link', { sourceId: clickId, targetId, linkType });
+        targetInput.value = '';
+        await refreshAfterMutation(clickId);
+      } catch (e) {
+        showError(errEl, e.message);
+      } finally {
+        btn.disabled = false; btn.textContent = orig;
+      }
+    }
+
+    // ── Post-mutation refresh (D17) ──────────────────────────────────
+
+    async function refreshAfterMutation(keepSelectedId) {
+      await loadForest();
+      renderAll();
+      // Re-select the same click so the detail pane stays coherent
+      if (keepSelectedId) {
+        // Re-highlight selected row
+        document.querySelectorAll('.tree-node-row').forEach(row => {
+          row.classList.toggle('selected', row.dataset.id === keepSelectedId);
+        });
+        await showDetailPane(keepSelectedId);
+      }
+    }
+
+    // ── Create-click form ────────────────────────────────────────────
+
+    function openCreateForm(prefillParentId) {
+      const section = document.getElementById('create-section');
+      section.classList.add('open');
+      if (prefillParentId) {
+        document.getElementById('create-parent-input').value = prefillParentId;
+      }
+      document.getElementById('create-goal-input').focus();
+    }
+
+    function closeCreateForm() {
+      document.getElementById('create-section').classList.remove('open');
+      document.getElementById('create-goal-input').value = '';
+      document.getElementById('create-parent-input').value = '';
+      clearError(document.getElementById('create-error'));
+    }
+
+    async function submitCreateForm() {
+      const goalInput   = document.getElementById('create-goal-input');
+      const parentInput = document.getElementById('create-parent-input');
+      const submitBtn   = document.getElementById('create-submit-btn');
+      const errEl       = document.getElementById('create-error');
+
+      clearError(errEl);
+      const goal     = goalInput.value.trim();
+      const parentId = parentInput.value.trim() || undefined;
+
+      if (!goal) { showError(errEl, 'Goal is required.'); return; }
+
+      submitBtn.disabled = true; submitBtn.textContent = 'Creating…';
+      try {
+        const newClick = await api('POST', '/api/click/create', { goal, ...(parentId ? { parentId } : {}) });
+        closeCreateForm();
+        await loadForest();
+        renderAll();
+        // Auto-select the new click
+        await selectClick(newClick.id);
+      } catch (e) {
+        showError(errEl, e.message);
+      } finally {
+        submitBtn.disabled = false; submitBtn.textContent = 'Create Click';
+      }
+    }
+
+    // ── Event wiring ─────────────────────────────────────────────────
+
+    document.getElementById('btn-new-click').addEventListener('click', () => {
+      const section = document.getElementById('create-section');
+      if (section.classList.contains('open')) {
+        closeCreateForm();
+      } else {
+        // Pre-fill parent with currently selected click, if any (D12)
+        openCreateForm(selectedClickId || '');
+      }
+    });
+
+    document.getElementById('btn-refresh').addEventListener('click', async () => {
+      await loadForest();
+      renderAll();
+      if (selectedClickId) await showDetailPane(selectedClickId);
+    });
+
+    document.getElementById('create-submit-btn').addEventListener('click', submitCreateForm);
+
+    document.getElementById('create-goal-input').addEventListener('keydown', e => {
+      if (e.key === 'Enter') submitCreateForm();
+    });
+
+    document.querySelectorAll('.filter-btn').forEach(btn => {
+      btn.addEventListener('click', () => setStatusFilter(btn.dataset.status));
+    });
+
+    // ── Init ─────────────────────────────────────────────────────────
+    (async () => {
+      await loadForest();
+      renderAll();
+
+      // Deep-link: ?click=<id> auto-opens detail pane (D19)
+      if (selectedClickId) {
+        await showDetailPane(selectedClickId);
+        // Highlight in tree
+        document.querySelectorAll('.tree-node-row').forEach(row => {
+          row.classList.toggle('selected', row.dataset.id === selectedClickId);
+        });
+      }
+    })();
+
+  })();
+  </script>
+</body>
+</html>
