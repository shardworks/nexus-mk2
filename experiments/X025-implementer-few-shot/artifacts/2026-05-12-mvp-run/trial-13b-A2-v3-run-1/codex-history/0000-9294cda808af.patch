+/**
+ * Reckoner apparatus — unit and integration tests.
+ *
+ * Covers the behavioral cases from the commission brief:
+ *
+ *   - Kit with duplicate source → hard startup error naming both plugin ids.
+ *   - Kit with malformed source id → hard startup error.
+ *   - petition() with unknown source + enforceRegistration=false → succeeds
+ *     (warning logged, writ created).
+ *   - petition() with unknown source + enforceRegistration=true → throws;
+ *     no writ posted.
+ *   - petition() with partial priority → defaults fill omitted dimensions.
+ *   - Resulting writ has phase:'new' and ext.reckoner populated.
+ *   - withdraw(writId, reason) → writ transitions to 'cancelled'.
+ *   - After phase:started, registry is sealed — add() throws.
+ *   - fillPriorityDefaults: each omitted field uses the contract default.
+ *   - validatePriority: throws on invalid dimension values.
+ *   - readReckonerConfig: applies defaults for absent fields.
+ */
+
+import { describe, it, beforeEach, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritDoc } from '@shardworks/clerk-apparatus';
+
+import {
+  createReckoner,
+  fillPriorityDefaults,
+  validatePriority,
+  readReckonerConfig,
+} from './reckoner.ts';
+import type { ReckonerApi } from './types.ts';
+
+// ── Fixture helpers ──────────────────────────────────────────────────
+
+const FRAMEWORK_KIT_FIELDS = new Set(['requires', 'recommends']);
+
+function buildKitEntries(
+  kits: LoadedKit[] = [],
+  apparatuses: LoadedApparatus[] = [],
+): KitEntry[] {
+  const entries: KitEntry[] = [];
+  for (const kit of kits) {
+    for (const [type, value] of Object.entries(kit.kit)) {
+      if (FRAMEWORK_KIT_FIELDS.has(type)) continue;
+      entries.push({ pluginId: kit.id, packageName: kit.packageName, type, value });
+    }
+  }
+  for (const app of apparatuses) {
+    const bag = app.apparatus.supportKit;
+    if (!bag || typeof bag !== 'object') continue;
+    for (const [type, value] of Object.entries(bag)) {
+      if (FRAMEWORK_KIT_FIELDS.has(type)) continue;
+      entries.push({ pluginId: app.id, packageName: app.packageName, type, value });
+    }
+  }
+  return entries;
+}
+
+function buildCtx(kitEntries: KitEntry[] = [], phaseStartedHandlers: (() => void)[] = []): StartupContext {
+  return {
+    on(event: string, handler: (...args: unknown[]) => void | Promise<void>): void {
+      if (event === 'phase:started') {
+        phaseStartedHandlers.push(handler as () => void);
+      }
+    },
+    kits(type: string): KitEntry[] {
+      return [...kitEntries.filter((e) => e.type === type)];
+    },
+  };
+}
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  guildConfig: GuildConfig;
+  /** Fire the phase:started event — seals the Reckoner registry. */
+  firePhaseStarted: () => void;
+  /** Post a writ and stay in 'new' phase (do NOT publish). */
+  postNew: (title?: string) => Promise<WritDoc>;
+}
+
+async function buildFixture(options: {
+  kits?: LoadedKit[];
+  guildConfig?: Partial<GuildConfig>;
+} = {}): Promise<Fixture> {
+  const backend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(backend);
+  const clerkPlugin = createClerk();
+  const reckonerPlugin = createReckoner();
+
+  if (!('apparatus' in stacksPlugin)) throw new Error('stacks must be apparatus');
+  if (!('apparatus' in clerkPlugin)) throw new Error('clerk must be apparatus');
+  if (!('apparatus' in reckonerPlugin)) throw new Error('reckoner must be apparatus');
+
+  const apparatusMap = new Map<string, unknown>();
+  const phaseStartedHandlers: (() => void)[] = [];
+
+  const guildConfig: GuildConfig = {
+    name: 'test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...options.guildConfig,
+  };
+
+  const fakeGuild: Guild = {
+    home: '/tmp/test-guild',
+    apparatus<T>(name: string): T {
+      const api = apparatusMap.get(name);
+      if (!api) throw new Error(`Apparatus "${name}" not installed`);
+      return api as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return guildConfig;
+    },
+    kits(): LoadedKit[] { return []; },
+    apparatuses(): LoadedApparatus[] { return []; },
+    failedPlugins() { return []; },
+    startupWarnings() { return []; },
+  };
+
+  setGuild(fakeGuild);
+
+  // Start stacks.
+  stacksPlugin.apparatus.start(buildCtx());
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // Ensure books the Clerk needs.
+  backend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    { indexes: ['phase', 'type', 'createdAt', 'parentId'] },
+  );
+  backend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    { indexes: ['sourceId', 'targetId'] },
+  );
+
+  // Start clerk.
+  await clerkPlugin.apparatus.start(buildCtx());
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  // Build kit entries from provided kits.
+  const kitEntries = buildKitEntries(options.kits ?? []);
+
+  // Start Reckoner.
+  const reckonerCtx = buildCtx(kitEntries, phaseStartedHandlers);
+  await reckonerPlugin.apparatus.start(reckonerCtx);
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    guildConfig,
+    firePhaseStarted: () => {
+      for (const h of phaseStartedHandlers) h();
+    },
+    postNew: async (title = 'Test petition') => {
+      return clerk.post({ title, body: 'Test body.', codex: 'nexus' });
+    },
+  };
+}
+
+// ── fillPriorityDefaults ─────────────────────────────────────────────
+
+describe('fillPriorityDefaults', () => {
+  it('returns contract defaults when called with no argument', () => {
+    const p = fillPriorityDefaults();
+    assert.equal(p.visionRelation, 'vision-neutral');
+    assert.equal(p.severity, 'minor');
+    assert.equal(p.scope, 'minor-area');
+    assert.equal(p.time.decay, false);
+    assert.equal(p.time.deadline, null);
+    assert.deepEqual(p.domain, []);
+  });
+
+  it('returns contract defaults when called with empty object', () => {
+    const p = fillPriorityDefaults({});
+    assert.equal(p.visionRelation, 'vision-neutral');
+    assert.equal(p.severity, 'minor');
+    assert.equal(p.scope, 'minor-area');
+    assert.equal(p.time.decay, false);
+    assert.equal(p.time.deadline, null);
+    assert.deepEqual(p.domain, []);
+  });
+
+  it('preserves explicitly provided visionRelation', () => {
+    const p = fillPriorityDefaults({ visionRelation: 'vision-violator' });
+    assert.equal(p.visionRelation, 'vision-violator');
+    // All others remain at defaults.
+    assert.equal(p.severity, 'minor');
+    assert.equal(p.scope, 'minor-area');
+  });
+
+  it('preserves explicitly provided severity', () => {
+    const p = fillPriorityDefaults({ severity: 'critical' });
+    assert.equal(p.severity, 'critical');
+    assert.equal(p.visionRelation, 'vision-neutral');
+  });
+
+  it('preserves explicitly provided scope', () => {
+    const p = fillPriorityDefaults({ scope: 'whole-product' });
+    assert.equal(p.scope, 'whole-product');
+  });
+
+  it('preserves explicitly provided time fields', () => {
+    const p = fillPriorityDefaults({ time: { decay: true, deadline: '2025-12-31' } });
+    assert.equal(p.time.decay, true);
+    assert.equal(p.time.deadline, '2025-12-31');
+  });
+
+  it('merges partial time — decay only', () => {
+    const p = fillPriorityDefaults({ time: { decay: true, deadline: null } });
+    assert.equal(p.time.decay, true);
+    assert.equal(p.time.deadline, null);
+  });
+
+  it('preserves explicitly provided domain', () => {
+    const p = fillPriorityDefaults({ domain: ['security', 'quality'] });
+    assert.deepEqual(p.domain, ['security', 'quality']);
+  });
+
+  it('fills a fully specified priority unchanged', () => {
+    const full = {
+      visionRelation: 'vision-blocker' as const,
+      severity: 'critical' as const,
+      scope: 'whole-product' as const,
+      time: { decay: true, deadline: '2026-01-01' },
+      domain: ['security' as const],
+    };
+    const p = fillPriorityDefaults(full);
+    assert.deepEqual(p, full);
+  });
+});
+
+// ── validatePriority ─────────────────────────────────────────────────
+
+describe('validatePriority', () => {
+  const validPriority = {
+    visionRelation: 'vision-neutral' as const,
+    severity: 'minor' as const,
+    scope: 'minor-area' as const,
+    time: { decay: false, deadline: null },
+    domain: [],
+  };
+
+  it('accepts a fully valid priority without throwing', () => {
+    assert.doesNotThrow(() => validatePriority(validPriority));
+  });
+
+  it('throws on invalid visionRelation', () => {
+    assert.throws(
+      () => validatePriority({ ...validPriority, visionRelation: 'unknown' as never }),
+      /visionRelation/,
+    );
+  });
+
+  it('throws on invalid severity', () => {
+    assert.throws(
+      () => validatePriority({ ...validPriority, severity: 'ultra' as never }),
+      /severity/,
+    );
+  });
+
+  it('throws on invalid scope', () => {
+    assert.throws(
+      () => validatePriority({ ...validPriority, scope: 'everything' as never }),
+      /scope/,
+    );
+  });
+
+  it('throws on invalid domain tag', () => {
+    assert.throws(
+      () => validatePriority({ ...validPriority, domain: ['unknown-tag' as never] }),
+      /domain/,
+    );
+  });
+
+  it('accepts all valid visionRelation values', () => {
+    for (const vr of ['vision-blocker', 'vision-violator', 'vision-advancer', 'vision-neutral'] as const) {
+      assert.doesNotThrow(() => validatePriority({ ...validPriority, visionRelation: vr }));
+    }
+  });
+
+  it('accepts all valid severity values', () => {
+    for (const s of ['critical', 'serious', 'moderate', 'minor'] as const) {
+      assert.doesNotThrow(() => validatePriority({ ...validPriority, severity: s }));
+    }
+  });
+
+  it('accepts all valid scope values', () => {
+    for (const sc of ['whole-product', 'major-area', 'minor-area'] as const) {
+      assert.doesNotThrow(() => validatePriority({ ...validPriority, scope: sc }));
+    }
+  });
+
+  it('accepts all valid domain tags', () => {
+    const tags = [
+      'security', 'compliance', 'cost', 'feature', 'quality',
+      'infrastructure', 'documentation', 'research', 'ergonomics',
+    ] as const;
+    assert.doesNotThrow(() => validatePriority({ ...validPriority, domain: [...tags] }));
+  });
+});
+
+// ── readReckonerConfig ────────────────────────────────────────────────
+
+describe('readReckonerConfig', () => {
+  afterEach(() => clearGuild());
+
+  it('returns permissive defaults when reckoner key is absent from guild.json', async () => {
+    // Use buildFixture to set up a guild with no reckoner config.
