index 0000000..f9d20d3
--- /dev/null
+++ b/packages/plugins/reckoner/src/registry.ts
@@ -0,0 +1,179 @@
+/**
+ * Petitioner registry — kit-static registry of declared petitioner sources.
+ *
+ * The registry is built once during apparatus start() from kit `petitioners`
+ * contributions and sealed at `phase:started`. After sealing, no new entries
+ * can be added.
+ *
+ * Validation rules:
+ * - Source ids must match `{pluginId}.{kebab-suffix}` grammar.
+ * - The `{pluginId}.` prefix is validated against the contributing plugin id
+ *   where derivable (i.e. at kit-scan time when `pluginId` is known).
+ * - Duplicate source ids across contributing plugins are a hard startup error
+ *   naming both contributing plugin ids.
+ *
+ * See: docs/architecture/petitioner-registration.md §5
+ */
+
+import type { PetitionerDescriptor } from './types.ts';
+
+// ── Source ID grammar ────────────────────────────────────────────────
+
+/**
+ * Regex for a single kebab-case segment: starts with a lowercase letter,
+ * followed by zero or more lowercase letters / digits / hyphen-then-alphanumeric
+ * sequences. No leading or trailing hyphens; no consecutive hyphens.
+ *
+ * Examples of valid segments: `vision-keeper`, `snapshot`, `tech-debt2`
+ */
+const KEBAB_SEGMENT = '[a-z][a-z0-9]*(?:-[a-z0-9]+)*';
+
+/**
+ * Full source-id pattern: `{kebab-pluginId}.{kebab-suffix}`
+ *
+ * Both halves follow the same kebab grammar. A literal `.` separates them.
+ */
+const SOURCE_ID_REGEX = new RegExp(`^${KEBAB_SEGMENT}\\.${KEBAB_SEGMENT}$`);
+
+/**
+ * Return true when `source` conforms to the `{pluginId}.{kebab-suffix}` grammar.
+ */
+export function isValidSourceId(source: string): boolean {
+  return SOURCE_ID_REGEX.test(source);
+}
+
+/**
+ * Return true when `source` has the expected `{pluginId}.` prefix.
+ *
+ * Used during kit scanning to validate that a petitioner's source id
+ * begins with the contributing plugin's id — a cheap consistency check
+ * that catches obvious mis-labelling at startup.
+ */
+export function hasValidPrefix(source: string, pluginId: string): boolean {
+  return source.startsWith(`${pluginId}.`);
+}
+
+// ── Registry ─────────────────────────────────────────────────────────
+
+/** Stored entry in the registry — descriptor plus owning plugin id. */
+interface RegistryEntry {
+  readonly pluginId: string;
+  readonly descriptor: PetitionerDescriptor;
+}
+
+/**
+ * Kit-static registry of petitioner sources.
+ *
+ * Built during apparatus `start()` by scanning kit `petitioners`
+ * contributions. Sealed at `phase:started` — after that, `add()` throws.
+ *
+ * @example
+ * ```typescript
+ * const registry = new PetitionerRegistry();
+ * registry.add('vision-keeper', {
+ *   source:      'vision-keeper.snapshot',
+ *   description: 'Snapshot emitted when drift is observed.',
+ * });
+ * registry.seal();
+ * registry.has('vision-keeper.snapshot'); // true
+ * ```
+ */
+export class PetitionerRegistry {
+  private readonly _entries = new Map<string, RegistryEntry>();
+  private _sealed = false;
+
+  /** Whether the registry has been sealed (no further additions allowed). */
+  get sealed(): boolean {
+    return this._sealed;
+  }
+
+  /**
+   * Seal the registry. Called at `phase:started`.
+   *
+   * After sealing, calls to `add()` throw. Idempotent — sealing an already-
+   * sealed registry is a no-op.
+   */
+  seal(): void {
+    this._sealed = true;
+  }
+
+  /**
+   * Add a petitioner descriptor contributed by `pluginId`.
+   *
+   * Validation performed:
+   * 1. Registry must not be sealed (throws if sealed).
+   * 2. `descriptor.source` must conform to the `{pluginId}.{kebab-suffix}`
+   *    grammar (throws on malformed id).
+   * 3. `descriptor.source` must begin with `{pluginId}.` (throws on prefix
+   *    mismatch — the contributing plugin's id must prefix the source).
+   * 4. No existing entry with the same source (throws on collision, naming
+   *    both contributing plugin ids).
+   *
+   * @throws Error on any validation failure — registry errors are hard
+   *   startup errors that halt guild boot.
+   */
+  add(pluginId: string, descriptor: PetitionerDescriptor): void {
+    if (this._sealed) {
+      throw new Error(
+        `[reckoner] Registry is sealed — cannot register source "${descriptor.source}" ` +
+          `from plugin "${pluginId}" after phase:started.`,
+      );
+    }
+
+    if (!isValidSourceId(descriptor.source)) {
+      throw new Error(
+        `[reckoner] Plugin "${pluginId}" contributed petitioner with malformed source id ` +
+          `"${descriptor.source}". Source ids must match the grammar ` +
+          `{pluginId}.{kebab-suffix} — e.g. "vision-keeper.snapshot", "tech-debt.detected".`,
+      );
+    }
+
+    if (!hasValidPrefix(descriptor.source, pluginId)) {
+      throw new Error(
+        `[reckoner] Plugin "${pluginId}" contributed petitioner source "${descriptor.source}" ` +
+          `whose prefix does not match the contributing plugin id. ` +
+          `Expected prefix: "${pluginId}.".`,
+      );
+    }
+
+    const existing = this._entries.get(descriptor.source);
+    if (existing) {
+      throw new Error(
+        `[reckoner] Duplicate petitioner source "${descriptor.source}": ` +
+          `contributed by both "${existing.pluginId}" and "${pluginId}". ` +
+          `Each source id must be unique across all contributing plugins.`,
+      );
+    }
+
+    this._entries.set(descriptor.source, { pluginId, descriptor });
+  }
+
+  /**
+   * Return true when `source` is in the registry.
+   */
+  has(source: string): boolean {
+    return this._entries.has(source);
+  }
+
+  /**
+   * Return the descriptor for `source`, or `undefined` when not registered.
+   */
+  get(source: string): PetitionerDescriptor | undefined {
+    return this._entries.get(source)?.descriptor;
+  }
+
+  /**
+   * Return all registered petitioner descriptors, in insertion order.
+   */
+  list(): PetitionerDescriptor[] {
+    return [...this._entries.values()].map((e) => e.descriptor);
+  }
+
+  /**
+   * Return the contributing plugin id for `source`, or `undefined` when
+   * the source is not registered.
+   */
+  ownerOf(source: string): string | undefined {
+    return this._entries.get(source)?.pluginId;
+  }
+}
diff --git a/packages/plugins/reckoner/src/types.ts b/packages/plugins/reckoner/src/types.ts
new file mode 100644
index 0000000..8ba9224
--- /dev/null
+++ b/packages/plugins/reckoner/src/types.ts
@@ -0,0 +1,351 @@
+/**
+ * Reckoner public types.
+ *
+ * Types for: priority dimensions, complexity tier, petitioner ext shape,
+ * petitioner registry descriptors, petition request, Reckoner API, and
+ * guild.json configuration.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { WritDoc } from '@shardworks/clerk-apparatus';
+
+// ── Domain tags ──────────────────────────────────────────────────────
+
+/**
+ * Multi-valued domain classification tag. Not a priority axis — describes
+ * what *kind* of work a petition is. Used by the Reckoner for filtering,
+ * patron-tunable weighting, and reporting.
+ */
+export type DomainTag =
+  | 'security'
+  | 'compliance'
+  | 'cost'
+  | 'feature'
+  | 'quality'
+  | 'infrastructure'
+  | 'documentation'
+  | 'research'
+  | 'ergonomics';
+
+// ── Priority ─────────────────────────────────────────────────────────
+
+/**
+ * Multi-dimensional priority schema for Reckoner-gated writs.
+ *
+ * Dimensions are designed to be **inspectable and defensible** rather than
+ * mechanically objective — petitioners declare honest inputs and the
+ * Reckoner does judgment-laden contextual collapse.
+ *
+ * See: docs/architecture/petitioner-registration.md §3
+ */
+export type Priority = {
+  /**
+   * How does this petition relate to the product vision?
+   *
+   * - `vision-blocker`  — the vision is unreachable without this.
+   * - `vision-violator` — the current product state actively diverges.
+   * - `vision-advancer` — pushes toward an aspirational aspect of the vision.
+   * - `vision-neutral`  — doesn't touch the product vision (ops, hygiene, etc.).
+   */
+  visionRelation:
+    | 'vision-blocker'
+    | 'vision-violator'
+    | 'vision-advancer'
+    | 'vision-neutral';
+  /**
+   * If this petition is not acted on, how bad is the situation?
+   *
+   * - `critical`  — production breakage, security incident, irreversible damage.
+   * - `serious`   — significant ongoing degradation; daily workarounds.
+   * - `moderate`  — noticeable but tolerable.
+   * - `minor`     — easy to live with; cosmetic, convenience, polish.
+   */
+  severity: 'critical' | 'serious' | 'moderate' | 'minor';
+  /**
+   * What fraction of the system is affected?
+   *
+   * - `whole-product` — every user / every commission / every guild.
+   * - `major-area`    — a major feature or subsystem.
+   * - `minor-area`    — a small slice, one workflow, one command.
+   */
+  scope: 'whole-product' | 'major-area' | 'minor-area';
+  /**
+   * Time urgency on two independent axes.
+   *
+   * - `decay: true`         — value is degrading over time.
+   * - `deadline: <iso-date>` — pledged or externally-committed deadline.
+   */
+  time: {
+    /** Whether the value of acting is actively decaying over time. */
+    decay: boolean;
+    /** ISO date deadline, or null if not deadline-constrained. */
+    deadline: string | null;
+  };
+  /**
+   * Multi-valued domain classification. Not a priority axis — used for
+   * filtering, reporting, and patron-tunable weighting. Empty array means
+   * no classification.
+   */
+  domain: Array<DomainTag>;
+};
+
+// ── Complexity ───────────────────────────────────────────────────────
+
+/**
+ * Petitioner-side coarse estimate of expected agent token cost.
+ *
+ * Peer to `Priority` — complexity answers "what does it cost?" while
+ * priority answers "how much does this matter?". Both feed scheduling but
+ * are conceptually distinct. Omit rather than guess.
+ *
+ * - `mechanical`   — clear path, minimal exploration (~50K–200K tokens).
+ * - `bounded`      — clear scope, some exploration (~200K–1M tokens).
+ * - `exploratory`  — design judgment required; cross-cutting (~1M–5M tokens).
+ * - `open-ended`   — research, prototyping, scope likely to grow (~5M+ tokens).
+ *
+ * See: docs/architecture/petitioner-registration.md §4
+ */
+export type ComplexityTier =
+  | 'mechanical'
+  | 'bounded'
+  | 'exploratory'
+  | 'open-ended';
+
+// ── ReckonerExt ──────────────────────────────────────────────────────
+
+/**
+ * The `writ.ext['reckoner']` sub-slot shape — the metadata the Reckoner
+ * attaches to a Reckoner-gated writ at petition time.
+ *
+ * Written by `reckoner.petition()` via `clerk.setWritExt`. Readable by
+ * any plugin via `writ.ext?.['reckoner']`.
+ *
+ * See: docs/architecture/petitioner-registration.md §2
+ */
+export interface ReckonerExt {
+  /**
+   * Identifies the petitioner. Must match a registered petitioner
+   * descriptor (see §5) when `enforceRegistration` is enabled.
+   *
+   * Format: `{pluginId}.{kebab-suffix}` — same grammar as Lattice
+   * trigger-types and Clerk link-kinds.
+   */
+  source: string;
+
+  /** Multi-dimensional priority. Defaults applied for any omitted dimension. */
+  priority: Priority;
+
+  /**
+   * Optional petitioner-side coarse cost estimate. Omit rather than guess.
+   * Refined by the Astrolabe at plan time.
+   */
+  complexity?: ComplexityTier;
+
+  /**
+   * Opaque petitioner-defined structured data. The Reckoner stores it but
+   * does not introspect; the rig's engine reads it if needed.
+   */
+  payload?: unknown;
+
+  /**
+   * Additive non-priority metadata. Multi-instance discrimination
+   * (e.g. `'vision-keeper.io/vision-id': 'nexus'`), observability hints,
+   * diagnostic tags.
+   */
+  labels?: Record<string, string>;
+}
+
+// ── Petitioner registry ──────────────────────────────────────────────
+
+/**
+ * A petitioner descriptor contributed by a kit's `petitioners` array.
+ *
+ * Kit authors use this shape when populating `ReckonerKit.petitioners`.
+ * Source ids must follow the `{pluginId}.{kebab-suffix}` grammar.
+ */
+export interface PetitionerDescriptor {
+  /**
+   * Fully-qualified source id. Must follow `{pluginId}.{kebab-suffix}` —
+   * e.g. `vision-keeper.snapshot`, `patron-bridge.commission`.
+   */
+  source: string;
+  /** Human-readable one-liner describing this petitioner source. */
+  description: string;
+}
+
+// ── Request types ────────────────────────────────────────────────────
+
+/**
+ * Request shape for `ReckonerApi.petition()`.
+ *
+ * Combines writ fields (passed to `clerk.post()`) and ext.reckoner fields
+ * (written via `clerk.setWritExt`). Omitted priority dimensions receive the
+ * contract defaults applied by the helper.
+ *
+ * See: docs/architecture/petitioner-registration.md §1
+ */
+export interface PetitionRequest {
+  // ── Writ fields (passed through to clerk.post) ──────────────────
+
+  /** Writ type. Defaults to the guild's configured defaultType when omitted. */
+  type?: string;
+  /** Short human-readable title. */
+  title: string;
+  /** Detail text. */
+  body: string;
+  /** Target codex name. */
+  codex?: string;
+  /** Parent writ id. Absent on root petitions. */
+  parentId?: string;
+
+  // ── ext.reckoner fields ─────────────────────────────────────────
+
+  /**
+   * Petitioner source id. Must be a registered petitioner when
+   * `enforceRegistration` is enabled. Format: `{pluginId}.{kebab-suffix}`.
+   */
+  source: string;
+
+  /**
+   * Multi-dimensional priority. Omitted dimensions receive the contract
+   * defaults (`vision-neutral / minor / minor-area / {decay:false, deadline:null} / []`).
+   */
+  priority?: Partial<Priority>;
+
+  /** Optional petitioner-side coarse cost estimate. Omit rather than guess. */
+  complexity?: ComplexityTier;
+
+  /** Opaque petitioner-defined structured data. */
+  payload?: unknown;
+
+  /** Additive non-priority metadata. */
+  labels?: Record<string, string>;
+}
+
+// ── API ──────────────────────────────────────────────────────────────
+
+/**
+ * The Reckoner's runtime API — retrieved via
+ * `guild().apparatus<ReckonerApi>('reckoner')`.
+ *
+ * See: docs/architecture/petitioner-registration.md §1
+ */
+export interface ReckonerApi {
+  /**
+   * Post a writ in `new` phase with Reckoner ext set correctly.
+   *
+   * Validates dimension values against the schema, applies defaults for
+   * omitted priority dimensions, validates source against the registry
+   * (per `enforceRegistration` config), and calls `clerk.post()` followed
+   * by `clerk.setWritExt` under the hood.
+   *
+   * Returns the persisted `WritDoc` with `phase: 'new'` and
+   * `ext['reckoner']` populated.
+   *
+   * Equivalent in effect to Workflow 1 (manual `clerk.post()` with ext
+   * construction); this helper exists for type-checking, default-handling,
+   * and discoverability.
+   */
+  petition(request: PetitionRequest): Promise<WritDoc>;
+
+  /**
+   * Withdraw a held writ by transitioning it to `cancelled`.
+   *
+   * Thin wrapper around `clerk.transition(writId, 'cancelled', {reason})`.
+   * Identical in effect to calling Clerk directly; exists for ergonomic
+   * discoverability.
+   */
+  withdraw(writId: string, reason?: string): Promise<WritDoc>;
+}
+
+// ── Configuration ────────────────────────────────────────────────────
+
+/**
+ * Reckoner apparatus configuration — lives under the `reckoner` key in
+ * `guild.json`.
+ *
+ * See: docs/architecture/petitioner-registration.md §6
+ */
+export interface ReckonerConfig {
+  /**
+   * Controls how unregistered petition sources are handled.
+   *
+   * - `false` (default) — log a warning and proceed. Permissive: emergent
+   *   petitioners that haven't registered yet still get scheduled.
+   * - `true` — throw fail-loud with an unregistered-source error; no writ
+   *   is posted.
+   */
+  enforceRegistration: boolean;
+
+  /**
+   * Per-source disable list. Petitions from any source in this array are
+   * rejected by `petition()` (throws) and left in `new` by the CDC handler.
+   *
+   * Default: `[]`.
+   */
+  disabledSources: string[];
+}
+
+// ── Kit contribution interface ───────────────────────────────────────
+
+/**
+ * Kit contribution interface for plugins that register petitioner sources
+ * with the Reckoner.
+ *
+ * Plugins declare themselves as petitioners by exporting a kit (or
+ * including a `supportKit`) with a `petitioners` array. The Reckoner
+ * consumes this at boot and builds the registry from it.
+ *
+ * Source ids must follow the `{pluginId}.{kebab-suffix}` grammar.
+ * Duplicate sources across kits are a hard startup error.
+ *
+ * @example
+ * ```typescript
+ * export default {
+ *   kit: {
+ *     requires: ['reckoner'],
+ *     petitioners: [{
+ *       source:      'vision-keeper.snapshot',
+ *       description: 'Vision-vs-reality snapshots when drift is observed.',
+ *     }],
+ *   },
+ * };
+ * ```
+ */
+export interface ReckonerKit {
+  /**
+   * Petitioner source descriptors to register with the Reckoner registry.
+   */
+  petitioners?: PetitionerDescriptor[];
+}
+
+// ── Defaults helper ──────────────────────────────────────────────────
+
+/**
+ * Return the default `Priority` object.
+ *
+ * Applies the contract defaults from §3:
+ * `vision-neutral / minor / minor-area / {decay:false, deadline:null} / []`.
+ *
+ * Used by `reckoner.petition()` to fill omitted dimension fields. Also
+ * useful as a starting point for petitioners that want to override a
+ * subset of dimensions.
+ */
+export function defaultPriority(): Priority {
+  return {
+    visionRelation: 'vision-neutral',
+    severity: 'minor',
+    scope: 'minor-area',
+    time: { decay: false, deadline: null },
+    domain: [],
+  };
+}
+
+// Augment GuildConfig so `guild().guildConfig().reckoner` is typed without
+// requiring a manual type parameter at the call site.
+declare module '@shardworks/nexus-core' {
+  interface GuildConfig {
+    reckoner?: Partial<ReckonerConfig>;
+  }
+}
