+/**
+ * @shardworks/reckoner-apparatus — The Reckoner.
+ *
+ * Kit-static petitioner registry, guild.json configuration parsing, priority
+ * dimension types with default-filling, and the petition()/withdraw() helper
+ * APIs for Reckoner-gated writs.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+// ── Public types ─────────────────────────────────────────────────────
+
+export {
+  type ComplexityTier,
+  type DomainTag,
+  type PetitionRequest,
+  type PetitionerDescriptor,
+  type Priority,
+  type ReckonerApi,
+  type ReckonerConfig,
+  type ReckonerExt,
+  type ReckonerKit,
+  defaultPriority,
+} from './types.ts';
+
+// ── Registry ─────────────────────────────────────────────────────────
+
+export {
+  PetitionerRegistry,
+  isValidSourceId,
+  hasValidPrefix,
+} from './registry.ts';
+
+// ── Plugin ───────────────────────────────────────────────────────────
+
+export {
+  RECKONER_PLUGIN_ID,
+  createReckoner,
+  fillPriorityDefaults,
+  validatePriority,
+  validateComplexity,
+  readReckonerConfig,
+} from './reckoner.ts';
+
+// ── Default export: apparatus plugin ─────────────────────────────────
+
+import { createReckoner } from './reckoner.ts';
+export default createReckoner();
