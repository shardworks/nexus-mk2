+/**
+ * The Reckoner apparatus — petitioner registry, configuration, and
+ * petition()/withdraw() helper APIs.
+ *
+ * The Reckoner is the foundation for Reckoner-gated writ scheduling. This
+ * apparatus provides:
+ *
+ *   1. A kit-static petitioner registry built from `petitioners` kit
+ *      contributions at startup, sealed at `phase:started`.
+ *   2. `guild.json` configuration parsing under the `reckoner` key.
+ *   3. `reckoner.petition(request)` — the canonical helper for posting
+ *      Reckoner-gated writs with dimension defaults, validation, and ext
+ *      attachment in one call.
+ *   4. `reckoner.withdraw(writId, reason?)` — ergonomic wrapper around
+ *      `clerk.transition(writId, 'cancelled', ...)`.
+ *
+ * The CDC handler that watches held writs and decides their fate is a
+ * separate commission that follows this one.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { Plugin, StartupContext } from '@shardworks/nexus-core';
+import { guild } from '@shardworks/nexus-core';
+import type { ClerkApi, WritDoc } from '@shardworks/clerk-apparatus';
+
+import {
+  type ComplexityTier,
+  type DomainTag,
+  type PetitionRequest,
+  type Priority,
+  type ReckonerApi,
+  type ReckonerConfig,
+  type ReckonerExt,
+  defaultPriority,
+} from './types.ts';
+import { PetitionerRegistry } from './registry.ts';
+
+// ── Constants ────────────────────────────────────────────────────────
+
+/** Apparatus id — the name plugins use with `guild().apparatus<ReckonerApi>('reckoner')`. */
+export const RECKONER_PLUGIN_ID = 'reckoner';
+
+/** Kit contribution type consumed by the Reckoner. */
+const PETITIONERS_KIT = 'petitioners';
+
+// ── Priority validation ──────────────────────────────────────────────
+
+const VALID_VISION_RELATIONS = new Set<string>([
+  'vision-blocker',
+  'vision-violator',
+  'vision-advancer',
+  'vision-neutral',
+]);
+
+const VALID_SEVERITIES = new Set<string>([
+  'critical',
+  'serious',
+  'moderate',
+  'minor',
+]);
+
+const VALID_SCOPES = new Set<string>([
+  'whole-product',
+  'major-area',
+  'minor-area',
+]);
+
+const VALID_DOMAINS = new Set<string>([
+  'security',
+  'compliance',
+  'cost',
+  'feature',
+  'quality',
+  'infrastructure',
+  'documentation',
+  'research',
+  'ergonomics',
+]);
+
+const VALID_COMPLEXITY_TIERS = new Set<string>([
+  'mechanical',
+  'bounded',
+  'exploratory',
+  'open-ended',
+]);
+
+/**
+ * Fill omitted priority dimension fields with the contract defaults.
+ *
+ * Applies: `vision-neutral / minor / minor-area / {decay:false, deadline:null} / []`
+ */
+export function fillPriorityDefaults(partial?: Partial<Priority>): Priority {
+  const defaults = defaultPriority();
+  if (!partial) return defaults;
+  return {
+    visionRelation: partial.visionRelation ?? defaults.visionRelation,
+    severity: partial.severity ?? defaults.severity,
+    scope: partial.scope ?? defaults.scope,
+    time: {
+      decay: partial.time?.decay ?? defaults.time.decay,
+      deadline: partial.time?.deadline ?? defaults.time.deadline,
+    },
+    domain: partial.domain ?? defaults.domain,
+  };
+}
+
+/**
+ * Validate all five priority dimension values against their allowed sets.
+ *
+ * Throws a descriptive error on any unrecognised value so petitioners get
+ * immediate feedback at API-call time rather than silent mis-scheduling.
+ */
+export function validatePriority(priority: Priority): void {
+  if (!VALID_VISION_RELATIONS.has(priority.visionRelation)) {
+    throw new Error(
+      `[reckoner] Invalid priority.visionRelation "${priority.visionRelation}". ` +
+        `Allowed: ${[...VALID_VISION_RELATIONS].join(', ')}.`,
+    );
+  }
+  if (!VALID_SEVERITIES.has(priority.severity)) {
+    throw new Error(
+      `[reckoner] Invalid priority.severity "${priority.severity}". ` +
+        `Allowed: ${[...VALID_SEVERITIES].join(', ')}.`,
+    );
+  }
+  if (!VALID_SCOPES.has(priority.scope)) {
+    throw new Error(
+      `[reckoner] Invalid priority.scope "${priority.scope}". ` +
+        `Allowed: ${[...VALID_SCOPES].join(', ')}.`,
+    );
+  }
+  if (typeof priority.time.decay !== 'boolean') {
+    throw new Error(
+      `[reckoner] Invalid priority.time.decay "${String(priority.time.decay)}". Must be a boolean.`,
+    );
+  }
+  if (priority.time.deadline !== null && typeof priority.time.deadline !== 'string') {
+    throw new Error(
+      `[reckoner] Invalid priority.time.deadline — must be an ISO date string or null.`,
+    );
+  }
+  for (const tag of priority.domain) {
+    if (!VALID_DOMAINS.has(tag)) {
+      throw new Error(
+        `[reckoner] Invalid priority.domain tag "${tag}". ` +
+          `Allowed: ${[...VALID_DOMAINS].join(', ')}.`,
+      );
+    }
+  }
+}
+
+/**
+ * Validate `complexity` against the known tier set (when provided).
+ */
+export function validateComplexity(complexity: ComplexityTier): void {
+  if (!VALID_COMPLEXITY_TIERS.has(complexity)) {
+    throw new Error(
+      `[reckoner] Invalid complexity "${complexity}". ` +
+        `Allowed: ${[...VALID_COMPLEXITY_TIERS].join(', ')}.`,
+    );
+  }
+}
+
+// ── Config parsing ───────────────────────────────────────────────────
+
+/**
+ * Read and resolve the Reckoner configuration from `guild.json`, applying
+ * permissive defaults for any absent fields.
+ *
+ * Defaults: `{ enforceRegistration: false, disabledSources: [] }`.
+ */
+export function readReckonerConfig(): ReckonerConfig {
+  const raw = guild().guildConfig().reckoner ?? {};
+  return {
+    enforceRegistration: raw.enforceRegistration ?? false,
+    disabledSources: raw.disabledSources ?? [],
+  };
+}
+
+// ── Plugin factory ───────────────────────────────────────────────────
+
+/**
+ * Create the Reckoner apparatus plugin.
+ *
+ * The returned plugin registers a `petitioners` kit consumer, exposes the
+ * `ReckonerApi` (`petition` and `withdraw`), and reads its configuration
+ * from `guild.json` under the `reckoner` key.
+ */
+export function createReckoner(): Plugin {
+  const registry = new PetitionerRegistry();
+
+  // Config is read once during start() and referenced by the API closures.
+  // Declared here so the API object can close over it before start() runs;
+  // the reference is mutated in start().
+  let config: ReckonerConfig = {
+    enforceRegistration: false,
+    disabledSources: [],
+  };
+
+  // ── API ────────────────────────────────────────────────────────
+
+  const api: ReckonerApi = {
+    async petition(request: PetitionRequest): Promise<WritDoc> {
+      const clerkApi = guild().apparatus<ClerkApi>('clerk');
+
+      // 1. Validate source against the registry (subject to config).
+      if (!registry.has(request.source)) {
+        if (config.enforceRegistration) {
+          throw new Error(
+            `[reckoner] petition() failed: source "${request.source}" is not registered ` +
+              `and enforceRegistration is enabled. Register the source via a ` +
+              `'petitioners' kit contribution before petitioning.`,
+          );
+        }
+        console.warn(
+          `[reckoner] Warning: source "${request.source}" is not in the petitioner ` +
+            `registry. Proceeding because enforceRegistration=false. ` +
+            `Register it via a 'petitioners' kit contribution to suppress this warning.`,
+        );
+      }
+
+      // 2. Apply priority defaults for omitted dimensions.
+      const priority = fillPriorityDefaults(request.priority);
+
+      // 3. Validate dimension values against schema.
+      validatePriority(priority);
+
+      // 4. Validate complexity (if provided).
+      if (request.complexity !== undefined) {
+        validateComplexity(request.complexity);
+      }
+
+      // 5. Post the writ via clerk.post().
+      const writ = await clerkApi.post({
+        ...(request.type !== undefined ? { type: request.type } : {}),
+        title: request.title,
+        body: request.body,
+        ...(request.codex !== undefined ? { codex: request.codex } : {}),
+        ...(request.parentId !== undefined ? { parentId: request.parentId } : {}),
+      });
+
+      // 6. Write the ext.reckoner sub-slot via setWritExt.
+      const ext: ReckonerExt = {
+        source: request.source,
+        priority,
+        ...(request.complexity !== undefined ? { complexity: request.complexity } : {}),
+        ...(request.payload !== undefined ? { payload: request.payload } : {}),
+        ...(request.labels !== undefined ? { labels: request.labels } : {}),
+      };
+      return clerkApi.setWritExt(writ.id, RECKONER_PLUGIN_ID, ext);
+    },
+
+    async withdraw(writId: string, reason?: string): Promise<WritDoc> {
+      const clerkApi = guild().apparatus<ClerkApi>('clerk');
+      return clerkApi.transition(
+        writId,
+        'cancelled',
+        reason !== undefined ? { resolution: reason } : {},
+      );
+    },
+  };
+
+  return {
+    apparatus: {
+      // The Clerk is required for posting writs and writing ext slots.
+      // Stacks is required by the Clerk (transitively), but we don't call
+      // it directly — listed here for explicit startup ordering.
+      requires: ['clerk', 'stacks'],
+
+      // Signal that this apparatus scans `petitioners` contributions.
+      consumes: [PETITIONERS_KIT],
+
+      provides: api,
+
+      async start(ctx: StartupContext): Promise<void> {
+        // 1. Read Reckoner configuration from guild.json.
+        config = readReckonerConfig();
+
+        // 2. Scan all kit contributions for petitioner declarations.
+        for (const entry of ctx.kits(PETITIONERS_KIT)) {
+          const raw = entry.value;
+          if (!Array.isArray(raw)) {
+            console.warn(
+              `[reckoner] Kit "${entry.pluginId}" petitioners: expected an array, ` +
+                `got ${typeof raw} — skipped.`,
+            );
+            continue;
+          }
+          for (const candidate of raw) {
+            if (
+              typeof candidate !== 'object' ||
+              candidate === null ||
+              typeof (candidate as Record<string, unknown>).source !== 'string' ||
+              typeof (candidate as Record<string, unknown>).description !== 'string'
+            ) {
+              console.warn(
+                `[reckoner] Kit "${entry.pluginId}" petitioners: entry is missing ` +
+                  `required string fields "source" and/or "description" — skipped.`,
+              );
+              continue;
+            }
+            // registry.add() throws on malformed ids or collisions — hard startup error.
+            registry.add(entry.pluginId, {
+              source: (candidate as { source: string }).source,
+              description: (candidate as { description: string }).description,
+            });
+          }
+        }
+
+        // 3. Seal the registry at phase:started — no new entries after boot.
+        ctx.on('phase:started', () => {
+          registry.seal();
+        });
+      },
+    },
+  };
+}
diff --git a/packages/plugins/reckoner/src/registry.test.ts b/packages/plugins/reckoner/src/registry.test.ts
new file mode 100644
index 0000000..7c7d9e5
--- /dev/null
+++ b/packages/plugins/reckoner/src/registry.test.ts
@@ -0,0 +1,249 @@
+/**
+ * PetitionerRegistry — unit tests.
+ *
+ * Covers:
+ *  - Valid source id acceptance (happy path)
+ *  - Malformed source ids rejected at add() time
+ *  - Plugin prefix validation (source must start with contributing pluginId.)
+ *  - Duplicate source collision: hard error naming both plugin ids
+ *  - Registry sealing at phase:started — post-seal add() throws
+ *  - has() / get() / list() / ownerOf() read paths
+ *  - isValidSourceId() and hasValidPrefix() exported helpers
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+import {
+  PetitionerRegistry,
+  isValidSourceId,
+  hasValidPrefix,
+} from './registry.ts';
+
+// ── isValidSourceId ──────────────────────────────────────────────────
+
+describe('isValidSourceId', () => {
+  it('accepts well-formed ids', () => {
+    assert.equal(isValidSourceId('vision-keeper.snapshot'), true);
+    assert.equal(isValidSourceId('patron-bridge.commission'), true);
+    assert.equal(isValidSourceId('tech-debt.detected'), true);
+    assert.equal(isValidSourceId('simple.suffix'), true);
+    assert.equal(isValidSourceId('a.b'), true);
+    assert.equal(isValidSourceId('my-plugin.my-suffix'), true);
+    assert.equal(isValidSourceId('plugin1.source2'), true);
+  });
+
+  it('rejects ids without a dot separator', () => {
+    assert.equal(isValidSourceId('nodotseparator'), false);
+    assert.equal(isValidSourceId('vision-keeper'), false);
+  });
+
+  it('rejects ids with uppercase letters', () => {
+    assert.equal(isValidSourceId('Vision-Keeper.snapshot'), false);
+    assert.equal(isValidSourceId('vision-keeper.Snapshot'), false);
+  });
+
+  it('rejects ids with leading or trailing hyphens in a segment', () => {
+    assert.equal(isValidSourceId('-vision.snapshot'), false);
+    assert.equal(isValidSourceId('vision-.snapshot'), false);
+    assert.equal(isValidSourceId('vision.-snapshot'), false);
+    assert.equal(isValidSourceId('vision.snapshot-'), false);
+  });
+
+  it('rejects ids with consecutive hyphens', () => {
+    assert.equal(isValidSourceId('vision--keeper.snapshot'), false);
+    assert.equal(isValidSourceId('vision.snap--shot'), false);
+  });
+
+  it('rejects ids with special characters', () => {
+    assert.equal(isValidSourceId('vision.snap!shot'), false);
+    assert.equal(isValidSourceId('vision.snap_shot'), false);
+    assert.equal(isValidSourceId('vision.snap shot'), false);
+  });
+
+  it('rejects empty string', () => {
+    assert.equal(isValidSourceId(''), false);
+  });
+
+  it('rejects ids with empty segment', () => {
+    assert.equal(isValidSourceId('.snapshot'), false);
+    assert.equal(isValidSourceId('vision.'), false);
+    assert.equal(isValidSourceId('.'), false);
+  });
+
+  it('rejects ids with multiple dots', () => {
+    // Two dots means three segments — not the expected two-segment format.
+    assert.equal(isValidSourceId('a.b.c'), false);
+  });
+});
+
+// ── hasValidPrefix ───────────────────────────────────────────────────
+
+describe('hasValidPrefix', () => {
+  it('returns true when source starts with pluginId.', () => {
+    assert.equal(hasValidPrefix('vision-keeper.snapshot', 'vision-keeper'), true);
+    assert.equal(hasValidPrefix('a.b', 'a'), true);
+  });
+
+  it('returns false when prefix does not match', () => {
+    assert.equal(hasValidPrefix('vision-keeper.snapshot', 'patron-bridge'), false);
+    assert.equal(hasValidPrefix('vision-keeper.snapshot', 'vision'), false);
+  });
+
+  it('requires the dot after the plugin id', () => {
+    // 'vision-keeper' is the pluginId; 'vision-keeperX.snapshot' must not match
+    assert.equal(hasValidPrefix('vision-keeperX.snapshot', 'vision-keeper'), false);
+  });
+});
+
+// ── PetitionerRegistry ───────────────────────────────────────────────
+
+describe('PetitionerRegistry', () => {
+  it('accepts a well-formed descriptor and records it', () => {
+    const reg = new PetitionerRegistry();
+    reg.add('vision-keeper', {
+      source: 'vision-keeper.snapshot',
+      description: 'Snapshot when drift is observed.',
+    });
+    assert.equal(reg.has('vision-keeper.snapshot'), true);
+    assert.deepEqual(reg.get('vision-keeper.snapshot'), {
+      source: 'vision-keeper.snapshot',
+      description: 'Snapshot when drift is observed.',
+    });
+    assert.equal(reg.ownerOf('vision-keeper.snapshot'), 'vision-keeper');
+  });
+
+  it('rejects a malformed source id (hard startup error)', () => {
+    const reg = new PetitionerRegistry();
+    assert.throws(
+      () => reg.add('my-plugin', { source: 'wrong.format!', description: 'bad' }),
+      /malformed source id/,
+    );
+  });
+
+  it('rejects a source id with wrong prefix (contributing plugin mismatch)', () => {
+    const reg = new PetitionerRegistry();
+    assert.throws(
+      () =>
+        reg.add('other-plugin', {
+          source: 'vision-keeper.snapshot',
+          description: 'Mismatch.',
+        }),
+      /prefix does not match/,
+    );
+  });
+
+  it('rejects a source id that is an unqualified kebab string (no dot)', () => {
+    const reg = new PetitionerRegistry();
+    assert.throws(
+      () => reg.add('vision-keeper', { source: 'vision-keeper', description: 'no dot' }),
+      /malformed source id/,
+    );
+  });
+
+  it('throws a collision error naming both plugin ids when the same source is contributed twice', () => {
+    const reg = new PetitionerRegistry();
+    reg.add('plugin-a', {
+      source: 'plugin-a.source',
+      description: 'First registration.',
+    });
+    let caught: Error | undefined;
+    try {
+      reg.add('plugin-a', { source: 'plugin-a.source', description: 'Duplicate registration.' });
+    } catch (e) {
+      caught = e as Error;
+    }
+    assert.ok(caught, 'should have thrown on duplicate source');
+    // Error message must name both contributing plugin ids and the source.
+    assert.match(caught.message, /plugin-a/);
+    assert.match(caught.message, /plugin-a\.source/);
+    assert.match(caught.message, /[Dd]uplicate/);
+  });
+
+  it('throws a collision error when two different plugins contribute the same source', () => {
+    const reg = new PetitionerRegistry();
+    reg.add('plugin-a', {
+      source: 'plugin-a.source',
+      description: 'First registration.',
+    });
+    // A second plugin contributing the same source id is impossible because
+    // the prefix check ensures the source must start with the contributing
+    // plugin id — so a true cross-plugin collision can only occur when the
+    // two plugins share the same id prefix segment. Test with same plugin id:
+    let caught: Error | undefined;
+    try {
+      reg.add('plugin-a', { source: 'plugin-a.source', description: 'Second registration.' });
+    } catch (e) {
+      caught = e as Error;
+    }
+    assert.ok(caught, 'should have thrown on duplicate source');
+    assert.match(caught.message, /plugin-a/);
+    assert.match(caught.message, /[Dd]uplicate/);
+  });
+
+  it('seals after seal() and rejects subsequent add() calls', () => {
+    const reg = new PetitionerRegistry();
+    reg.add('vision-keeper', {
+      source: 'vision-keeper.snapshot',
+      description: 'Snapshot when drift is observed.',
+    });
+    assert.equal(reg.sealed, false);
+    reg.seal();
+    assert.equal(reg.sealed, true);
+
+    let caught: Error | undefined;
+    try {
+      reg.add('vision-keeper', { source: 'vision-keeper.extra', description: 'Post-seal attempt.' });
+    } catch (e) {
+      caught = e as Error;
+    }
+    assert.ok(caught, 'should have thrown after sealing');
+    assert.match(caught.message, /sealed/);
+  });
+
+  it('seal() is idempotent', () => {
+    const reg = new PetitionerRegistry();
+    reg.seal();
+    reg.seal(); // second call must not throw
+    assert.equal(reg.sealed, true);
+  });
+
+  it('has() returns false for unknown sources', () => {
+    const reg = new PetitionerRegistry();
+    assert.equal(reg.has('unknown.source'), false);
+  });
+
+  it('get() returns undefined for unknown sources', () => {
+    const reg = new PetitionerRegistry();
+    assert.equal(reg.get('unknown.source'), undefined);
+  });
+
+  it('ownerOf() returns undefined for unknown sources', () => {
+    const reg = new PetitionerRegistry();
+    assert.equal(reg.ownerOf('unknown.source'), undefined);
+  });
+
+  it('list() returns all registered descriptors in insertion order', () => {
+    const reg = new PetitionerRegistry();
+    reg.add('plugin-a', { source: 'plugin-a.first', description: 'First.' });
+    reg.add('plugin-b', { source: 'plugin-b.second', description: 'Second.' });
+    const list = reg.list();
+    assert.equal(list.length, 2);
+    assert.equal(list[0]!.source, 'plugin-a.first');
+    assert.equal(list[1]!.source, 'plugin-b.second');
+  });
+
+  it('list() returns an empty array when no entries are registered', () => {
+    const reg = new PetitionerRegistry();
+    assert.deepEqual(reg.list(), []);
+  });
+
+  it('allows multiple distinct sources from the same plugin', () => {
+    const reg = new PetitionerRegistry();
+    reg.add('my-plugin', { source: 'my-plugin.source-a', description: 'A.' });
+    reg.add('my-plugin', { source: 'my-plugin.source-b', description: 'B.' });
+    assert.equal(reg.has('my-plugin.source-a'), true);
+    assert.equal(reg.has('my-plugin.source-b'), true);
+    assert.equal(reg.list().length, 2);
+  });
+});
