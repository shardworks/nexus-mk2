@@ -0,0 +1,493 @@
+"use client";
+
+/**
+ * Characters list-detail page (/characters).
+ * Layout: 30% left list · 70% right detail per visual-spec.md §15.1.
+ */
+
+import { useEffect, useState, useCallback } from "react";
+import { useRouter } from "next/navigation";
+import { Plus, User } from "lucide-react";
+import type { Build, Character } from "@/lib/types";
+import { CharacterForm } from "@/components/d4/editors/CharacterForm";
+import { BuildDetailView } from "@/components/d4/BuildDetailView";
+import { BuildEditor } from "@/components/d4/editors/BuildEditor";
+import { Dialog, DialogContent } from "@/components/ui/dialog";
+
+function generateId() {
+  return `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`;
+}
+
+function makeEmptyBuild(characterId: string): Build {
+  const now = new Date().toISOString();
+  return {
+    id: generateId(),
+    characterId,
+    name: "Build 1",
+    skills: [],
+    equippedItems: {},
+    targetItems: {},
+    paragonLevel: 0,
+    paragonAllocation: { boardNames: [], glyphs: [], notes: "" },
+    constraints: [],
+    uptimes: {},
+    createdAt: now,
+    updatedAt: now,
+  };
+}
+
+export default function CharactersPage() {
+  const router = useRouter();
+  const [characters, setCharacters] = useState<Character[]>([]);
+  const [buildsMap, setBuildsMap] = useState<Record<string, Build[]>>({});
+  const [selected, setSelected] = useState<Character | null>(null);
+  const [activeBuild, setActiveBuild] = useState<Build | null>(null);
+  const [loading, setLoading] = useState(true);
+  const [error, setError] = useState<string | null>(null);
+
+  // Modal state
+  const [showNewCharacter, setShowNewCharacter] = useState(false);
+  const [showEditCharacter, setShowEditCharacter] = useState(false);
+  const [editingBuild, setEditingBuild] = useState(false);
+  const [saving, setSaving] = useState(false);
+
+  // ── Data fetching ──────────────────────────────────────────────
+
+  const fetchCharacters = useCallback(async () => {
+    try {
+      const res = await fetch("/api/characters");
+      if (!res.ok) throw new Error(await res.text());
+      const data = (await res.json()) as Character[];
+      setCharacters(data);
+      // Auto-select first if none selected
+      if (data.length > 0 && !selected) {
+        setSelected(data[0]);
+      }
+    } catch (e) {
+      setError(String(e));
+    } finally {
+      setLoading(false);
+    }
+  }, [selected]);
+
+  const fetchBuildsForCharacter = useCallback(async (characterId: string) => {
+    try {
+      const res = await fetch(`/api/builds?characterId=${encodeURIComponent(characterId)}`);
+      if (!res.ok) throw new Error(await res.text());
+      const data = (await res.json()) as Build[];
+      setBuildsMap((prev) => ({ ...prev, [characterId]: data }));
+      return data;
+    } catch {
+      return [];
+    }
+  }, []);
+
+  useEffect(() => {
+    fetchCharacters();
+  }, [fetchCharacters]);
+
+  useEffect(() => {
+    if (selected) {
+      fetchBuildsForCharacter(selected.id).then((builds) => {
+        setActiveBuild(builds[0] ?? null);
+      });
+    }
+  }, [selected, fetchBuildsForCharacter]);
+
+  // ── Actions ────────────────────────────────────────────────────
+
+  async function createCharacter(data: Pick<Character, "name" | "class" | "level">) {
+    setSaving(true);
+    try {
+      const now = new Date().toISOString();
+      const char: Character = {
+        id: generateId(),
+        ...data,
+        createdAt: now,
+        updatedAt: now,
+      };
+      const res = await fetch("/api/characters", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(char),
+      });
+      if (!res.ok) throw new Error(await res.text());
+      const created = (await res.json()) as Character;
+
+      // Create a default build for the new character
+      const build = makeEmptyBuild(created.id);
+      await fetch("/api/builds", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(build),
+      });
+
+      await fetchCharacters();
+      setSelected(created);
+      setActiveBuild(build);
+      setShowNewCharacter(false);
+    } catch (e) {
+      alert(`Failed to create character: ${e}`);
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  async function updateCharacter(data: Pick<Character, "name" | "class" | "level">) {
+    if (!selected) return;
+    setSaving(true);
+    try {
+      const res = await fetch(`/api/characters/${selected.id}`, {
+        method: "PUT",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(data),
+      });
+      if (!res.ok) throw new Error(await res.text());
+      const updated = (await res.json()) as Character;
+      setCharacters((prev) => prev.map((c) => (c.id === updated.id ? updated : c)));
+      setSelected(updated);
+      setShowEditCharacter(false);
+    } catch (e) {
+      alert(`Failed to update character: ${e}`);
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  async function deleteCharacter(id: string) {
+    if (!confirm("Delete this character and all its builds?")) return;
+    try {
+      await fetch(`/api/characters/${id}`, { method: "DELETE" });
+      setCharacters((prev) => prev.filter((c) => c.id !== id));
+      if (selected?.id === id) {
+        setSelected(null);
+        setActiveBuild(null);
+      }
+    } catch (e) {
+      alert(`Failed to delete character: ${e}`);
+    }
+  }
+
+  async function saveBuild(build: Build) {
+    setSaving(true);
+    try {
+      const exists = activeBuild && activeBuild.id === build.id;
+      const method = exists ? "PUT" : "POST";
+      const url = exists ? `/api/builds/${build.id}` : "/api/builds";
+      const res = await fetch(url, {
+        method,
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(build),
+      });
+      if (!res.ok) throw new Error(await res.text());
+      const saved = (await res.json()) as Build;
+      setActiveBuild(saved);
+      if (selected) {
+        setBuildsMap((prev) => ({
+          ...prev,
+          [selected.id]: [saved],
+        }));
+      }
+      setEditingBuild(false);
+    } catch (e) {
+      alert(`Failed to save build: ${e}`);
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  // ── Render ─────────────────────────────────────────────────────
+
+  if (loading) {
+    return (
+      <div style={{ padding: "24px", color: "var(--stone-500)", fontSize: "14px" }}>
+        Loading characters…
+      </div>
+    );
+  }
+
+  if (error) {
+    return (
+      <div style={{ padding: "24px" }}>
+        <div style={{ color: "var(--danger)", fontSize: "13px", marginBottom: "8px" }}>
+          Error loading characters
+        </div>
+        <pre style={{ color: "var(--stone-400)", fontSize: "12px" }}>{error}</pre>
+      </div>
+    );
+  }
+
+  return (
+    <div style={{
+      display: "flex",
+      height: "100%",
+      gap: "0",
+      overflow: "hidden",
+    }}>
+      {/* Left: character list (30%) */}
+      <div style={{
+        width: "30%",
+        minWidth: "200px",
+        maxWidth: "280px",
+        flexShrink: 0,
+        borderRight: "1px solid var(--stone-800)",
+        display: "flex",
+        flexDirection: "column",
+        overflow: "hidden",
+      }}>
+        {/* List header */}
+        <div style={{
+          display: "flex",
+          alignItems: "center",
+          justifyContent: "space-between",
+          padding: "10px 12px",
+          borderBottom: "1px solid var(--stone-800)",
+          flexShrink: 0,
+        }}>
+          <span style={{ fontSize: "11px", fontWeight: 600, color: "var(--stone-500)", textTransform: "uppercase", letterSpacing: "0.06em" }}>
+            Characters
+          </span>
+          <button
+            onClick={() => setShowNewCharacter(true)}
+            style={{
+              display: "flex",
+              alignItems: "center",
+              gap: "4px",
+              padding: "3px 8px",
+              background: "var(--accent)",
+              border: "none",
+              borderRadius: "var(--radius-card)",
+              cursor: "pointer",
