+/**
+ * File-based persistence layer.
+ *
+ * Reads and writes JSON files in DATA_DIR (default ./data/).
+ * Characters and builds each get their own subdirectory so diffs
+ * are Git-friendly and files don't bloat over time.
+ *
+ * Directory layout:
+ *   data/
+ *     characters/<id>.json
+ *     builds/<id>.json
+ */
+
 import * as fs from "fs/promises";
 import * as path from "path";
 
@@ -12,6 +25,8 @@ function getDataDir(): string {
   return dataDir;
 }
 
+// ── Low-level helpers ────────────────────────────────────────────
+
 export async function readJsonFile<T>(filename: string): Promise<T | null> {
   const dataDir = getDataDir();
   const filePath = path.join(dataDir, filename);
@@ -26,7 +41,95 @@ export async function readJsonFile<T>(filename: string): Promise<T | null> {
 
 export async function writeJsonFile<T>(filename: string, data: T): Promise<void> {
   const dataDir = getDataDir();
-  await fs.mkdir(dataDir, { recursive: true });
   const filePath = path.join(dataDir, filename);
+  await fs.mkdir(path.dirname(filePath), { recursive: true });
   await fs.writeFile(filePath, JSON.stringify(data, null, 2), "utf-8");
 }
+
+export async function deleteJsonFile(filename: string): Promise<void> {
+  const dataDir = getDataDir();
+  const filePath = path.join(dataDir, filename);
+  try {
+    await fs.unlink(filePath);
+  } catch (err) {
+    if ((err as NodeJS.ErrnoException).code === "ENOENT") return;
+    throw err;
+  }
+}
+
+/**
+ * Lists all JSON files in a subdirectory, reads each, and returns
+ * an array of the parsed objects. Silently skips malformed files.
+ */
+export async function listJsonDirectory<T>(subdir: string): Promise<T[]> {
+  const dataDir = getDataDir();
+  const dirPath = path.join(dataDir, subdir);
+  try {
+    const entries = await fs.readdir(dirPath);
+    const results: T[] = [];
+    for (const entry of entries) {
+      if (!entry.endsWith(".json")) continue;
+      try {
+        const content = await fs.readFile(path.join(dirPath, entry), "utf-8");
+        results.push(JSON.parse(content) as T);
+      } catch {
+        // Skip malformed files silently
+      }
+    }
+    return results;
+  } catch (err) {
+    if ((err as NodeJS.ErrnoException).code === "ENOENT") return [];
+    throw err;
+  }
+}
+
+// ── Character persistence ────────────────────────────────────────
+
+import type { Character } from "@/lib/types";
+
+export async function listCharacters(): Promise<Character[]> {
+  const chars = await listJsonDirectory<Character>("characters");
+  return chars.sort(
+    (a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime(),
+  );
+}
+
+export async function readCharacter(id: string): Promise<Character | null> {
+  return readJsonFile<Character>(`characters/${id}.json`);
+}
+
+export async function writeCharacter(char: Character): Promise<void> {
+  return writeJsonFile(`characters/${char.id}.json`, char);
+}
+
+export async function deleteCharacter(id: string): Promise<void> {
+  return deleteJsonFile(`characters/${id}.json`);
+}
+
+// ── Build persistence ────────────────────────────────────────────
+
+import type { Build } from "@/lib/types";
+
+export async function listBuilds(): Promise<Build[]> {
+  const builds = await listJsonDirectory<Build>("builds");
+  return builds.sort(
+    (a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime(),
+  );
+}
+
+export async function listBuildsForCharacter(characterId: string): Promise<Build[]> {
+  const all = await listBuilds();
+  return all.filter((b) => b.characterId === characterId);
+}
+
+export async function readBuild(id: string): Promise<Build | null> {
+  return readJsonFile<Build>(`builds/${id}.json`);
+}
+
+export async function writeBuild(build: Build): Promise<void> {
+  return writeJsonFile(`builds/${build.id}.json`, build);
+}
+
+export async function deleteBuild(id: string): Promise<void> {
+  return deleteJsonFile(`builds/${id}.json`);
+}
