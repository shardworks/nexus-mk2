+/**
+ * Catalog data integrity tests.
+ *
+ * Verifies that the catalog data is internally consistent:
+ * - No duplicate IDs
+ * - All slot references are valid ItemSlotIds
+ * - All class references are valid D4Classes
+ * - Value ranges are valid (min <= max)
+ * - Required fields are present
+ */
+
+import { describe, it, expect } from "vitest";
+import { AFFIXES } from "@/lib/catalog/affixes";
+import { ASPECTS } from "@/lib/catalog/aspects";
+import { SKILLS, getSkillsForClass, getSkillDef } from "@/lib/catalog/skills";
+import { CLASSES, getClassDef, getWeaponSlots } from "@/lib/catalog/classes";
+import { SLOTS, getSlotsForClass, getSlotDef } from "@/lib/catalog/slots";
+import {
+  getAffixDef,
+  getAffixesForSlot,
+  getAspectDef,
+  getAspectsForClass,
+} from "@/lib/catalog";
+import { ITEM_SLOT_IDS, D4_CLASSES, isD4Class, isItemSlotId } from "@/lib/types";
+
+// ── Affix catalog ──────────────────────────────────────────────────
+
+describe("AFFIXES catalog", () => {
+  it("has at least 100 entries", () => {
+    expect(AFFIXES.length).toBeGreaterThanOrEqual(100);
+  });
+
+  it("has no duplicate IDs", () => {
+    const ids = AFFIXES.map((a) => a.id);
+    const unique = new Set(ids);
+    const dupes = ids.filter((id, i) => ids.indexOf(id) !== i);
+    expect(dupes).toEqual([]);
+  });
+
+  it("all affix IDs are non-empty strings", () => {
+    for (const a of AFFIXES) {
+      expect(typeof a.id).toBe("string");
+      expect(a.id.length).toBeGreaterThan(0);
+    }
+  });
+
+  it("all affixes have valid slot IDs", () => {
+    for (const affix of AFFIXES) {
+      for (const slot of affix.slots) {
+        expect(isItemSlotId(slot), `Affix ${affix.id} has invalid slot: ${slot}`).toBe(true);
+      }
+    }
+  });
+
+  it("all affix class arrays contain valid D4Classes", () => {
+    for (const affix of AFFIXES) {
+      if (!affix.classes) continue;
+      for (const cls of affix.classes) {
+        expect(isD4Class(cls), `Affix ${affix.id} has invalid class: ${cls}`).toBe(true);
+      }
+    }
+  });
+
+  it("all affixes have minValue <= maxValue", () => {
+    for (const a of AFFIXES) {
+      expect(a.minValue, `Affix ${a.id}: minValue (${a.minValue}) > maxValue (${a.maxValue})`).toBeLessThanOrEqual(a.maxValue);
+    }
+  });
+
+  it("all affixes have valid units", () => {
+    const validUnits = new Set(["flat", "percent", "x-multiplier"]);
+    for (const a of AFFIXES) {
+      expect(validUnits.has(a.unit), `Affix ${a.id} has invalid unit: ${a.unit}`).toBe(true);
+    }
+  });
+
+  it("all affixes have valid categories", () => {
+    const validCats = new Set(["offensive", "defensive", "utility", "class-specific"]);
+    for (const a of AFFIXES) {
+      expect(validCats.has(a.category), `Affix ${a.id} has invalid category: ${a.category}`).toBe(true);
+    }
+  });
+
+  it("class-specific affixes have a classes array", () => {
+    for (const a of AFFIXES) {
+      if (a.category === "class-specific") {
+        expect(a.classes, `Affix ${a.id} is class-specific but has no classes array`).toBeDefined();
+        expect(a.classes!.length, `Affix ${a.id} has empty classes array`).toBeGreaterThan(0);
+      }
+    }
+  });
+
+  it("getAffixDef returns correct affix", () => {
+    const a = AFFIXES[0];
+    expect(getAffixDef(a.id)).toEqual(a);
+    expect(getAffixDef("nonexistent-id")).toBeUndefined();
+  });
+
+  it("getAffixesForSlot filters by slot", () => {
+    const helmAffixes = getAffixesForSlot("helm");
+    for (const a of helmAffixes) {
+      expect(a.slots).toContain("helm");
+    }
+    expect(helmAffixes.length).toBeGreaterThan(0);
+  });
+
+  it("getAffixesForSlot filters by class", () => {
+    const sorcAffixes = getAffixesForSlot("helm", "Sorcerer");
+    for (const a of sorcAffixes) {
+      if (a.classes) {
+        expect(a.classes).toContain("Sorcerer");
+      }
+    }
+  });
+
+  it("class-specific affix does not appear for another class", () => {
+    const barbAffixes = getAffixesForSlot("helm", "Barbarian");
+    const sorcSpecific = barbAffixes.filter(
+      (a) => a.classes && a.classes.includes("Sorcerer") && !a.classes.includes("Barbarian"),
+    );
+    expect(sorcSpecific).toHaveLength(0);
+  });
+
+  it("has skill-rank affixes for each of the 8 classes", () => {
+    for (const cls of D4_CLASSES) {
+      const classAffixes = AFFIXES.filter(
+        (a) => a.category === "class-specific" && a.classes?.includes(cls),
+      );
+      expect(classAffixes.length, `No class-specific affixes for ${cls}`).toBeGreaterThan(0);
+    }
+  });
+});
+
+// ── Aspect catalog ─────────────────────────────────────────────────
+
+describe("ASPECTS catalog", () => {
+  it("has at least 60 entries", () => {
+    expect(ASPECTS.length).toBeGreaterThanOrEqual(60);
+  });
+
+  it("has no duplicate IDs", () => {
+    const ids = ASPECTS.map((a) => a.id);
+    const dupes = ids.filter((id, i) => ids.indexOf(id) !== i);
+    expect(dupes).toEqual([]);
+  });
+
+  it("all aspects have valid preferredSlots", () => {
+    for (const aspect of ASPECTS) {
+      for (const slot of aspect.preferredSlots) {
+        expect(isItemSlotId(slot), `Aspect ${aspect.id} has invalid preferredSlot: ${slot}`).toBe(true);
+      }
+    }
+  });
+
+  it("all aspects have valid classes (if set)", () => {
+    for (const aspect of ASPECTS) {
+      if (!aspect.classes) continue;
+      for (const cls of aspect.classes) {
+        expect(isD4Class(cls), `Aspect ${aspect.id} has invalid class: ${cls}`).toBe(true);
+      }
+    }
+  });
+
+  it("aspects with hasRolledValue have min/max/unit", () => {
+    for (const a of ASPECTS) {
+      if (a.hasRolledValue) {
+        expect(a.minValue, `Aspect ${a.id}: hasRolledValue but no minValue`).toBeDefined();
+        expect(a.maxValue, `Aspect ${a.id}: hasRolledValue but no maxValue`).toBeDefined();
+        expect(a.unit, `Aspect ${a.id}: hasRolledValue but no unit`).toBeDefined();
+        expect(a.minValue!).toBeLessThanOrEqual(a.maxValue!);
+      }
+    }
+  });
+
+  it("all aspects have valid categories", () => {
+    const validCats = new Set(["offensive", "defensive", "utility", "resource", "mobility"]);
+    for (const a of ASPECTS) {
+      expect(validCats.has(a.category), `Aspect ${a.id} has invalid category: ${a.category}`).toBe(true);
+    }
+  });
+
+  it("getAspectDef returns correct aspect", () => {
+    const a = ASPECTS[0];
+    expect(getAspectDef(a.id)).toEqual(a);
+    expect(getAspectDef("nonexistent")).toBeUndefined();
+  });
+
+  it("getAspectsForClass includes generic aspects", () => {
+    const generic = ASPECTS.filter((a) => !a.classes);
+    const forSorc = getAspectsForClass("Sorcerer");
+    for (const g of generic) {
+      expect(forSorc.map((a) => a.id)).toContain(g.id);
+    }
+  });
+
+  it("getAspectsForClass excludes aspects for other classes", () => {
+    const forBarb = getAspectsForClass("Barbarian");
+    const sorcOnly = ASPECTS.filter(
+      (a) => a.classes && a.classes.includes("Sorcerer") && !a.classes.includes("Barbarian"),
+    );
+    for (const a of sorcOnly) {
+      expect(forBarb.map((x) => x.id)).not.toContain(a.id);
+    }
+  });
+
+  it("has class-specific aspects for each of the 8 classes", () => {
+    for (const cls of D4_CLASSES) {
+      const classAspects = ASPECTS.filter(
+        (a) => a.classes && a.classes.includes(cls),
+      );
+      expect(classAspects.length, `No class-specific aspects for ${cls}`).toBeGreaterThan(0);
+    }
+  });
+});
+
+// ── Skill catalog ──────────────────────────────────────────────────
+
+describe("SKILLS catalog", () => {
+  it("has at least 80 entries", () => {
+    expect(SKILLS.length).toBeGreaterThanOrEqual(80);
+  });
+
+  it("has no duplicate IDs", () => {
+    const ids = SKILLS.map((s) => s.id);
+    const dupes = ids.filter((id, i) => ids.indexOf(id) !== i);
+    expect(dupes).toEqual([]);
+  });
+
+  it("all skills have valid class values", () => {
+    for (const s of SKILLS) {
+      expect(isD4Class(s.class), `Skill ${s.id} has invalid class: ${s.class}`).toBe(true);
+    }
+  });
+
+  it("all skills have maxRank >= 1", () => {
+    for (const s of SKILLS) {
+      expect(s.maxRank, `Skill ${s.id} has maxRank < 1`).toBeGreaterThanOrEqual(1);
+    }
+  });
+
+  it("has skills for each of the 8 classes", () => {
+    for (const cls of D4_CLASSES) {
+      const classSkills = getSkillsForClass(cls);
+      expect(classSkills.length, `No skills for ${cls}`).toBeGreaterThan(0);
+    }
+  });
+
+  it("getSkillDef returns correct skill", () => {
+    const s = SKILLS[0];
+    expect(getSkillDef(s.id)).toEqual(s);
+    expect(getSkillDef("nonexistent")).toBeUndefined();
+  });
+});
+
+// ── Class catalog ──────────────────────────────────────────────────
+
+describe("CLASSES catalog", () => {
+  it("has exactly 8 classes", () => {
+    expect(CLASSES).toHaveLength(8);
+  });
+
+  it("IDs match D4_CLASSES", () => {
+    const catalogIds = CLASSES.map((c) => c.id).sort();
+    expect(catalogIds).toEqual([...D4_CLASSES].sort());
+  });
+
+  it("all weapon slots are valid ItemSlotIds", () => {
+    for (const cls of CLASSES) {
+      for (const slot of cls.weaponSlots) {
+        expect(isItemSlotId(slot), `Class ${cls.id} has invalid weaponSlot: ${slot}`).toBe(true);
+      }
+    }
+  });
+
+  it("getClassDef returns correct class", () => {
+    const cls = CLASSES[0];
+    expect(getClassDef(cls.id)).toEqual(cls);
+  });
+
+  it("Barbarian has 4 weapon slots", () => {
+    expect(getWeaponSlots("Barbarian")).toHaveLength(4);
+  });
+
+  it("non-Barbarian classes have 2 weapon slots", () => {
+    for (const cls of D4_CLASSES.filter((c) => c !== "Barbarian")) {
+      expect(getWeaponSlots(cls), `${cls} should have 2 weapon slots`).toHaveLength(2);
+    }
+  });
+});
+
+// ── Slot catalog ────────────────────────────────────────────────────
+
+describe("SLOTS catalog", () => {
+  it("has 13 slots", () => {
+    expect(SLOTS).toHaveLength(13);
+  });
+
+  it("IDs match ITEM_SLOT_IDS", () => {
+    const catalogIds = SLOTS.map((s) => s.id).sort();
+    expect(catalogIds).toEqual([...ITEM_SLOT_IDS].sort());
+  });
+
+  it("all cluster values are valid", () => {
+    const validClusters = new Set(["armor", "weapon", "jewelry"]);
+    for (const s of SLOTS) {
+      expect(validClusters.has(s.cluster), `Slot ${s.id} has invalid cluster: ${s.cluster}`).toBe(true);
+    }
+  });
+
+  it("getSlotDef returns correct slot", () => {
+    const s = SLOTS[0];
+    expect(getSlotDef(s.id)).toEqual(s);
+    expect(getSlotDef("invalid" as never)).toBeUndefined();
+  });
+
+  it("getSlotsForClass includes standard slots for all classes", () => {
+    for (const cls of D4_CLASSES) {
+      const classSlots = getSlotsForClass(cls);
+      expect(classSlots.some((s) => s.id === "helm"), `${cls} should have helm slot`).toBe(true);
+      expect(classSlots.some((s) => s.id === "amulet"), `${cls} should have amulet slot`).toBe(true);
+    }
+  });
+
+  it("Barbarian has weapon3 and weapon4 slots", () => {
+    const barbSlots = getSlotsForClass("Barbarian");
+    expect(barbSlots.some((s) => s.id === "weapon3")).toBe(true);
+    expect(barbSlots.some((s) => s.id === "weapon4")).toBe(true);
+  });
+
+  it("Sorcerer does not have weapon3 slot", () => {
+    const sorcSlots = getSlotsForClass("Sorcerer");
+    expect(sorcSlots.some((s) => s.id === "weapon3")).toBe(false);
+  });
+});
