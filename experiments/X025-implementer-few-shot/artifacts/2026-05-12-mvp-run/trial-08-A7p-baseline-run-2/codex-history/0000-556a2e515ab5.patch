+++ b/components/d4/editors/AffixPicker.tsx
@@ -0,0 +1,275 @@
+"use client";
+
+import { useState, useRef, useEffect } from "react";
+import { Search, X } from "lucide-react";
+import type { AffixDef, D4Class, ItemSlotId } from "@/lib/types";
+import { getAffixesForSlot } from "@/lib/catalog";
+
+interface AffixPickerProps {
+  slot: ItemSlotId;
+  characterClass?: D4Class;
+  /** Currently selected affix ID (if any) */
+  value?: string;
+  /** Called when user selects an affix */
+  onSelect: (affixId: string) => void;
+  /** Called when user clears the selection */
+  onClear?: () => void;
+  /** Affix IDs already used on this item (to prevent duplicates) */
+  excludeIds?: string[];
+  disabled?: boolean;
+}
+
+export function AffixPicker({
+  slot,
+  characterClass,
+  value,
+  onSelect,
+  onClear,
+  excludeIds = [],
+  disabled = false,
+}: AffixPickerProps) {
+  const [open, setOpen] = useState(false);
+  const [query, setQuery] = useState("");
+  const inputRef = useRef<HTMLInputElement>(null);
+  const containerRef = useRef<HTMLDivElement>(null);
+
+  const available = getAffixesForSlot(slot, characterClass).filter(
+    (a) => !excludeIds.includes(a.id) || a.id === value,
+  );
+
+  const filtered =
+    query.trim() === ""
+      ? available
+      : available.filter((a) =>
+          a.label.toLowerCase().includes(query.toLowerCase()),
+        );
+
+  // Group into class-specific and universal
+  const classSpecific = filtered.filter((a) => a.category === "class-specific");
+  const universal = filtered.filter((a) => a.category !== "class-specific");
+
+  const selected = value ? available.find((a) => a.id === value) : null;
+
+  // Close on outside click
+  useEffect(() => {
+    function handleClick(e: MouseEvent) {
+      if (containerRef.current && !containerRef.current.contains(e.target as Node)) {
+        setOpen(false);
+        setQuery("");
+      }
+    }
+    if (open) document.addEventListener("mousedown", handleClick);
+    return () => document.removeEventListener("mousedown", handleClick);
+  }, [open]);
+
+  // Focus input when opened
+  useEffect(() => {
+    if (open) setTimeout(() => inputRef.current?.focus(), 50);
+  }, [open]);
+
+  function handleSelect(affix: AffixDef) {
+    onSelect(affix.id);
+    setOpen(false);
+    setQuery("");
+  }
+
+  return (
+    <div ref={containerRef} style={{ position: "relative", flex: 1 }}>
+      {/* Trigger */}
+      <button
+        type="button"
