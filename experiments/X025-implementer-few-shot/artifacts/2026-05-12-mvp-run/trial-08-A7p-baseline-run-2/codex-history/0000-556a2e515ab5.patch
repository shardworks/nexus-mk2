@@ -0,0 +1,173 @@
+"use client";
+
+import { useState } from "react";
+import type { Character, D4Class } from "@/lib/types";
+import { D4_CLASSES } from "@/lib/types";
+import { validateCharacter } from "@/lib/validation";
+import { CLASSES } from "@/lib/catalog";
+
+interface CharacterFormProps {
+  /** Existing character to edit (undefined = creating new) */
+  initial?: Partial<Character>;
+  onSave: (data: Pick<Character, "name" | "class" | "level">) => void;
+  onCancel?: () => void;
+  loading?: boolean;
+}
+
+export function CharacterForm({
+  initial,
+  onSave,
+  onCancel,
+  loading = false,
+}: CharacterFormProps) {
+  const [name, setName] = useState(initial?.name ?? "");
+  const [cls, setCls] = useState<D4Class>(initial?.class ?? "Sorcerer");
+  const [level, setLevel] = useState<string>(
+    initial?.level !== undefined ? String(initial.level) : "100",
+  );
+  const [errors, setErrors] = useState<Record<string, string>>({});
+
+  function handleSubmit(e: React.FormEvent) {
+    e.preventDefault();
+    const data = {
+      name: name.trim(),
+      class: cls,
+      level: Number(level),
+    };
+    const errs = validateCharacter(data);
+    setErrors(errs);
+    if (Object.keys(errs).length > 0) return;
+    onSave(data);
+  }
+
+  return (
+    <form onSubmit={handleSubmit} style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
+      {/* Name */}
+      <Field label="Character name" error={errors.name}>
+        <input
+          value={name}
+          onChange={(e) => setName(e.target.value)}
+          placeholder="e.g. Doomed Aura Sorcerer"
+          autoFocus
+          style={inputStyle(!!errors.name)}
+        />
+      </Field>
+
+      {/* Class */}
+      <Field label="Class" error={errors.class}>
+        <select
+          value={cls}
+          onChange={(e) => setCls(e.target.value as D4Class)}
+          style={inputStyle(!!errors.class)}
+        >
+          {D4_CLASSES.map((c) => {
+            const def = CLASSES.find((cd) => cd.id === c);
+            return (
+              <option key={c} value={c}>
+                {c}{def ? ` (${def.resource})` : ""}
+              </option>
+            );
+          })}
+        </select>
+      </Field>
+
+      {/* Level */}
+      <Field label="Level" error={errors.level} hint="1–100">
+        <input
+          type="number"
+          value={level}
+          onChange={(e) => setLevel(e.target.value)}
+          min={1}
+          max={100}
+          style={{ ...inputStyle(!!errors.level), textAlign: "right", fontFamily: "var(--font-mono)" }}
+        />
+      </Field>
+
+      {/* Actions */}
+      <div style={{ display: "flex", justifyContent: "flex-end", gap: "8px", marginTop: "4px" }}>
+        {onCancel && (
+          <button type="button" onClick={onCancel} style={cancelBtnStyle} disabled={loading}>
+            Cancel
+          </button>
+        )}
+        <button type="submit" style={saveBtnStyle} disabled={loading}>
+          {loading ? "Saving…" : initial ? "Update character" : "Create character"}
+        </button>
+      </div>
+    </form>
+  );
+}
+
+function Field({
+  label,
+  error,
+  hint,
+  children,
+}: {
+  label: string;
+  error?: string;
+  hint?: string;
+  children: React.ReactNode;
+}) {
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "4px" }}>
+      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "baseline" }}>
+        <label style={{
+          fontSize: "11px",
+          fontWeight: 600,
+          color: "var(--stone-500)",
+          textTransform: "uppercase",
+          letterSpacing: "0.06em",
+        }}>
+          {label}
+        </label>
+        {hint && (
+          <span style={{ fontSize: "11px", color: "var(--stone-600)" }}>{hint}</span>
+        )}
+      </div>
+      {children}
+      {error && (
+        <span style={{ fontSize: "11px", color: "var(--danger)" }} role="alert">
+          {error}
+        </span>
+      )}
+    </div>
+  );
+}
+
+function inputStyle(hasError: boolean): React.CSSProperties {
+  return {
+    width: "100%",
+    height: "32px",
+    padding: "0 10px",
+    background: "var(--surface-1)",
+    border: `1px solid ${hasError ? "var(--danger)" : "var(--stone-700)"}`,
+    borderRadius: "var(--radius-card)",
+    color: "var(--stone-200)",
+    fontSize: "13px",
+    outline: "none",
+    boxSizing: "border-box",
+    fontFamily: "var(--font-sans)",
+  };
+}
+
+const cancelBtnStyle: React.CSSProperties = {
+  padding: "6px 14px",
+  background: "none",
+  border: "1px solid var(--stone-700)",
+  borderRadius: "var(--radius-card)",
+  cursor: "pointer",
+  color: "var(--stone-300)",
+  fontSize: "13px",
+};
+
+const saveBtnStyle: React.CSSProperties = {
+  padding: "6px 14px",
+  background: "var(--accent)",
+  border: "1px solid transparent",
+  borderRadius: "var(--radius-card)",
+  cursor: "pointer",
+  color: "var(--surface-0)",
+  fontSize: "13px",
+  fontWeight: 600,
+};
diff --git a/components/d4/editors/GearEditor.tsx b/components/d4/editors/GearEditor.tsx
new file mode 100644
index 0000000..0c10b5a
--- /dev/null
+++ b/components/d4/editors/GearEditor.tsx
@@ -0,0 +1,310 @@
+"use client";
+
+import { useState } from "react";
+import { Edit2, Plus } from "lucide-react";
+import type {
+  D4Class,
+  EquippedItem,
+  ItemRarity,
+  ItemSlotId,
+} from "@/lib/types";
+import { getSlotsForClass } from "@/lib/catalog";
+import { getAffixDef, getAspectDef } from "@/lib/catalog";
+import { ItemEditorModal } from "./ItemEditorModal";
+
+const RARITY_COLORS: Record<ItemRarity, string> = {
+  common: "var(--rarity-common)",
+  magic: "var(--rarity-magic)",
+  rare: "var(--rarity-rare)",
+  legendary: "var(--rarity-legendary)",
+  unique: "var(--rarity-unique)",
+  mythic: "var(--rarity-mythic)",
+};
+
+interface GearEditorProps {
+  characterClass: D4Class;
+  equippedItems: Partial<Record<ItemSlotId, EquippedItem>>;
+  onChange: (equippedItems: Partial<Record<ItemSlotId, EquippedItem>>) => void;
+}
+
+export function GearEditor({
+  characterClass,
+  equippedItems,
+  onChange,
+}: GearEditorProps) {
+  const [editingSlot, setEditingSlot] = useState<ItemSlotId | null>(null);
+
+  const slots = getSlotsForClass(characterClass);
+  const armorSlots = slots.filter((s) => s.cluster === "armor");
+  const weaponSlots = slots.filter((s) => s.cluster === "weapon");
+  const jewelrySlots = slots.filter((s) => s.cluster === "jewelry");
+
+  function handleSave(item: EquippedItem) {
+    onChange({ ...equippedItems, [item.slot]: item });
+  }
+
+  function handleRemove(slot: ItemSlotId) {
+    const next = { ...equippedItems };
+    delete next[slot];
+    onChange(next);
+  }
+
+  const editingItem = editingSlot ? equippedItems[editingSlot] : undefined;
+  const editingSlotDef = editingSlot ? slots.find((s) => s.id === editingSlot) : null;
+
+  return (
+    <>
+      <div style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
+        {/* Top row: armor + jewelry */}
+        <div style={{ display: "flex", gap: "16px", alignItems: "flex-start" }}>
+          <GearCluster
+            title="Armor"
+            slots={armorSlots}
+            items={equippedItems}
+            onEdit={setEditingSlot}
+          />
+          <GearCluster
+            title="Jewelry"
+            slots={jewelrySlots}
+            items={equippedItems}
+            onEdit={setEditingSlot}
+          />
+        </div>
+        {/* Bottom row: weapons */}
+        <GearCluster
+          title="Weapons"
+          slots={weaponSlots}
+          items={equippedItems}
+          onEdit={setEditingSlot}
+        />
+      </div>
+
+      {/* Item editor modal */}
+      {editingSlot && (
+        <ItemEditorModal
+          open={editingSlot !== null}
+          onClose={() => setEditingSlot(null)}
+          slot={editingSlot}
+          slotLabel={editingSlotDef?.label ?? editingSlot}
+          characterClass={characterClass}
+          item={editingItem}
+          onSave={handleSave}
+          onRemove={editingItem ? () => handleRemove(editingSlot) : undefined}
+        />
+      )}
+    </>
+  );
+}
+
+function GearCluster({
+  title,
+  slots,
+  items,
+  onEdit,
+}: {
+  title: string;
+  slots: ReturnType<typeof getSlotsForClass>;
+  items: Partial<Record<ItemSlotId, EquippedItem>>;
+  onEdit: (slot: ItemSlotId) => void;
+}) {
+  return (
+    <div style={{ flex: 1, minWidth: 0, display: "flex", flexDirection: "column", gap: "8px" }}>
+      <div style={{
+        fontSize: "11px",
+        fontWeight: 600,
+        color: "var(--stone-500)",
+        textTransform: "uppercase",
+        letterSpacing: "0.08em",
+        paddingBottom: "4px",
+        borderBottom: "1px solid var(--stone-800)",
+      }}>
+        {title}
+      </div>
+      {slots.map((slot) => {
+        const item = items[slot.id];
+        return item ? (
+          <EditableItemCard
+            key={slot.id}
+            item={item}
+            slotLabel={slot.label}
+            onEdit={() => onEdit(slot.id)}
+          />
+        ) : (
+          <EmptySlotButton
+            key={slot.id}
+            label={slot.label}
+            onAdd={() => onEdit(slot.id)}
+          />
+        );
+      })}
+    </div>
+  );
+}
+
+function EditableItemCard({
+  item,
+  slotLabel,
+  onEdit,
+}: {
+  item: EquippedItem;
+  slotLabel: string;
+  onEdit: () => void;
+}) {
+  const rarityColor = RARITY_COLORS[item.rarity];
+  const aspectDef = item.aspect ? getAspectDef(item.aspect.aspectId) : null;
+
+  return (
+    <div
+      className={item.isAncestral ? "ancestral" : undefined}
+      style={{
+        position: "relative",
+        borderRadius: "var(--radius-card)",
+        border: `1px solid ${rarityColor}4d`,  // 30% opacity border
+        background: "var(--surface-1)",
+        padding: "var(--item-card-padding)",
+        cursor: "pointer",
+      }}
+      onClick={onEdit}
+      role="button"
+      tabIndex={0}
+      aria-label={`Edit ${slotLabel}: ${item.name}`}
+      onKeyDown={(e) => {
+        if (e.key === "Enter" || e.key === " ") onEdit();
+      }}
+      onMouseEnter={(e) => {
+        (e.currentTarget as HTMLDivElement).style.background = "var(--surface-2)";
+      }}
+      onMouseLeave={(e) => {
+        (e.currentTarget as HTMLDivElement).style.background = "var(--surface-1)";
+      }}
+    >
+      {/* Edit hint */}
+      <div style={{
+        position: "absolute",
+        top: "6px",
+        right: "6px",
+        color: "var(--stone-600)",
+        opacity: 0,
+        transition: "opacity 100ms ease",
+      }}
+        className="edit-hint"
+      >
+        <Edit2 size={11} />
+      </div>
+
+      {/* Item name + power */}
+      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: "4px" }}>
+        <span style={{
+          fontSize: "13px",
+          fontWeight: 600,
+          color: rarityColor,
+          lineHeight: 1.2,
+        }}>
+          {item.name}
+        </span>
+        {item.itemPower !== undefined && (
+          <span style={{
+            fontSize: "11px",
+            color: "var(--stone-500)",
+            fontFamily: "var(--font-mono)",
+            marginLeft: "8px",
+            flexShrink: 0,
+          }}>
+            {item.itemPower}
+          </span>
+        )}
+      </div>
+
+      {/* Slot label */}
+      <div style={{ fontSize: "11px", color: "var(--stone-600)", marginBottom: "4px" }}>
+        {slotLabel}{item.masterworkRank ? ` · MW${item.masterworkRank}` : ""}
+      </div>
+
+      {/* Aspect */}
+      {aspectDef && (
+        <div style={{
+          fontSize: "11px",
+          color: "var(--rarity-legendary)",
+          fontStyle: "italic",
+          marginBottom: "4px",
+        }}>
+          {aspectDef.name}
+          {item.aspect?.rolledValue !== undefined && (
+            <span style={{ fontFamily: "var(--font-mono)", fontStyle: "normal", marginLeft: "4px" }}>
+              [{item.aspect.rolledValue}]
+            </span>
+          )}
+        </div>
+      )}
+
+      {/* Affixes */}
+      {item.affixes.length > 0 && (
+        <div style={{ display: "flex", flexDirection: "column", gap: "var(--item-card-row-gap)" }}>
+          {item.affixes.map((affix, i) => {
+            const def = getAffixDef(affix.affixId);
+            return (
+              <div key={i} style={{ display: "flex", gap: "6px", alignItems: "baseline" }}>
+                <span style={{
+                  fontSize: "12px",
+                  fontFamily: "var(--font-mono)",
+                  fontVariantNumeric: "tabular-nums",
+                  color: "var(--stone-200)",
+                  flexShrink: 0,
+                }}>
+                  +{affix.rolledValue}{def?.unit === "percent" ? "%" : ""}
+                  {affix.isGreaterAffix && (
+                    <span style={{ color: "var(--rarity-rare)", marginLeft: "2px" }}>★</span>
+                  )}
+                </span>
+                <span style={{ fontSize: "12px", color: "var(--stone-400)" }}>
+                  {def?.label ?? affix.affixId}
+                </span>
+              </div>
+            );
+          })}
+        </div>
+      )}
+    </div>
+  );
+}
+
+function EmptySlotButton({
+  label,
+  onAdd,
+}: {
+  label: string;
+  onAdd: () => void;
+}) {
+  return (
+    <button
+      type="button"
+      onClick={onAdd}
+      style={{
+        width: "100%",
+        borderRadius: "var(--radius-card)",
+        border: "1px dashed var(--stone-800)",
+        background: "transparent",
+        padding: "10px 8px",
+        display: "flex",
+        alignItems: "center",
+        justifyContent: "center",
+        gap: "6px",
+        cursor: "pointer",
+        color: "var(--stone-700)",
+        fontSize: "12px",
+        transition: "border-color 100ms ease, color 100ms ease",
+      }}
+      onMouseEnter={(e) => {
+        (e.currentTarget as HTMLButtonElement).style.borderColor = "var(--stone-600)";
+        (e.currentTarget as HTMLButtonElement).style.color = "var(--stone-500)";
+      }}
+      onMouseLeave={(e) => {
+        (e.currentTarget as HTMLButtonElement).style.borderColor = "var(--stone-800)";
+        (e.currentTarget as HTMLButtonElement).style.color = "var(--stone-700)";
+      }}
+    >
+      <Plus size={11} />
+      {label}
+    </button>
+  );
+}
diff --git a/components/d4/editors/ItemEditorModal.tsx b/components/d4/editors/ItemEditorModal.tsx
new file mode 100644
