+              display: "flex",
+              alignItems: "center",
+              gap: "6px",
+              padding: "6px 8px",
+              borderBottom: "1px solid var(--stone-800)",
+            }}
+          >
+            <Search size={12} style={{ color: "var(--stone-500)", flexShrink: 0 }} />
+            <input
+              ref={inputRef}
+              value={query}
+              onChange={(e) => setQuery(e.target.value)}
+              placeholder="Filter affixes…"
+              style={{
+                flex: 1,
+                background: "none",
+                border: "none",
+                outline: "none",
+                color: "var(--stone-200)",
+                fontSize: "12px",
+              }}
+            />
+          </div>
+
+          {/* List */}
+          <div style={{ overflowY: "auto", padding: "4px" }}>
+            {filtered.length === 0 && (
+              <div style={{ padding: "8px", fontSize: "12px", color: "var(--stone-500)", textAlign: "center" }}>
+                No affixes match.
+              </div>
+            )}
+
+            {classSpecific.length > 0 && (
+              <>
+                <div style={{
+                  padding: "4px 8px 2px",
+                  fontSize: "11px",
+                  fontWeight: 600,
+                  color: "var(--stone-500)",
+                  textTransform: "uppercase",
+                  letterSpacing: "0.06em",
+                }}>
+                  {characterClass ?? "Class-Specific"}
+                </div>
+                {classSpecific.map((a) => (
+                  <AffixOption
+                    key={a.id}
+                    affix={a}
+                    selected={a.id === value}
+                    onSelect={handleSelect}
+                  />
+                ))}
+                {universal.length > 0 && (
+                  <div style={{ margin: "4px 0", height: "1px", background: "var(--stone-800)" }} />
+                )}
+              </>
+            )}
+
+            {universal.map((a) => (
+              <AffixOption
+                key={a.id}
+                affix={a}
+                selected={a.id === value}
+                onSelect={handleSelect}
+              />
+            ))}
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
+
+function AffixOption({
+  affix,
+  selected,
+  onSelect,
+}: {
+  affix: AffixDef;
+  selected: boolean;
+  onSelect: (a: AffixDef) => void;
+}) {
+  return (
+    <button
+      type="button"
+      onClick={() => onSelect(affix)}
+      style={{
+        width: "100%",
+        display: "flex",
+        alignItems: "center",
+        justifyContent: "space-between",
+        gap: "8px",
+        padding: "4px 8px",
+        borderRadius: "3px",
+        border: "none",
+        background: selected ? "var(--stone-800)" : "transparent",
+        cursor: "pointer",
+        textAlign: "left",
+        color: selected ? "var(--stone-100)" : "var(--stone-300)",
+        fontSize: "12px",
+      }}
+      onMouseEnter={(e) => {
+        (e.currentTarget as HTMLButtonElement).style.background = "var(--stone-800)";
+        (e.currentTarget as HTMLButtonElement).style.color = "var(--stone-100)";
+      }}
+      onMouseLeave={(e) => {
+        (e.currentTarget as HTMLButtonElement).style.background = selected ? "var(--stone-800)" : "transparent";
+        (e.currentTarget as HTMLButtonElement).style.color = selected ? "var(--stone-100)" : "var(--stone-300)";
+      }}
+    >
+      <span>{affix.label}</span>
+      <span style={{ fontSize: "11px", color: "var(--stone-500)", whiteSpace: "nowrap", fontFamily: "var(--font-mono)" }}>
+        {affix.minValue}–{affix.maxValue}{affix.unit === "percent" ? "%" : ""}
+      </span>
+    </button>
+  );
+}
