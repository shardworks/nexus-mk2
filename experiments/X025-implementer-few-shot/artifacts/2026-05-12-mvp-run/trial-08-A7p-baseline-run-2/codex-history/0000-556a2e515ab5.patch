+"use client";
+
+import type { D4Class, SkillSelection } from "@/lib/types";
+import { getSkillsForClass } from "@/lib/catalog";
+
+interface SkillEditorProps {
+  characterClass: D4Class;
+  selections: SkillSelection[];
+  onChange: (selections: SkillSelection[]) => void;
+}
+
+const CATEGORY_LABELS: Record<string, string> = {
+  "basic": "Basic",
+  "core": "Core",
+  "defensive": "Defensive",
+  "conjuration": "Conjuration",
+  "macabre": "Macabre",
+  "companion": "Companion",
+  "brawling": "Brawling",
+  "weapon-mastery": "Weapon Mastery",
+  "ultimate": "Ultimate",
+  "key-passive": "Key Passive",
+  "passive": "Passive",
+};
+
+export function SkillEditor({ characterClass, selections, onChange }: SkillEditorProps) {
+  const skills = getSkillsForClass(characterClass);
+
+  function getSelection(skillId: string): SkillSelection | undefined {
+    return selections.find((s) => s.skillId === skillId);
+  }
+
+  function setRank(skillId: string, maxRank: number, rank: number) {
+    const clamped = Math.max(0, Math.min(maxRank, rank));
+    const existing = selections.find((s) => s.skillId === skillId);
+    if (clamped === 0) {
+      onChange(selections.filter((s) => s.skillId !== skillId));
+    } else if (existing) {
+      onChange(selections.map((s) => s.skillId === skillId ? { ...s, rank: clamped } : s));
+    } else {
+      onChange([...selections, { skillId, rank: clamped }]);
+    }
+  }
+
+  // Group by category
+  const groups: Record<string, typeof skills> = {};
+  for (const skill of skills) {
+    const cat = skill.category;
+    if (!groups[cat]) groups[cat] = [];
+    groups[cat].push(skill);
+  }
+
+  const categoryOrder = [
+    "basic", "core", "defensive", "conjuration", "macabre", "companion",
+    "brawling", "weapon-mastery", "ultimate", "key-passive", "passive",
+  ];
+
+  const orderedCategories = categoryOrder.filter((c) => groups[c]?.length > 0);
+
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
+      {orderedCategories.map((cat) => (
+        <div key={cat}>
+          <div style={{
+            fontSize: "11px",
+            fontWeight: 600,
+            color: "var(--stone-500)",
+            textTransform: "uppercase",
+            letterSpacing: "0.06em",
+            paddingBottom: "6px",
+            borderBottom: "1px solid var(--stone-800)",
+            marginBottom: "6px",
+          }}>
+            {CATEGORY_LABELS[cat] ?? cat}
+          </div>
+          <div style={{ display: "flex", flexDirection: "column", gap: "4px" }}>
+            {(groups[cat] ?? []).map((skill) => {
+              const sel = getSelection(skill.id);
+              const rank = sel?.rank ?? 0;
+              const isKeyPassive = skill.category === "key-passive";
+              const isUltimate = skill.category === "ultimate";
+
+              return (
+                <div
+                  key={skill.id}
+                  style={{
+                    display: "flex",
+                    alignItems: "center",
+                    gap: "8px",
+                    padding: "4px 8px",
+                    borderRadius: "var(--radius-card)",
+                    background: rank > 0 ? "var(--surface-1)" : "transparent",
+                    border: rank > 0
+                      ? "1px solid var(--stone-700)"
+                      : "1px solid transparent",
+                  }}
+                >
+                  {/* Skill name */}
+                  <span style={{
+                    flex: 1,
+                    fontSize: "13px",
+                    color: rank > 0 ? "var(--stone-100)" : "var(--stone-400)",
+                    fontWeight: rank > 0 ? 500 : 400,
+                  }}>
+                    {skill.name}
+                  </span>
+
+                  {/* Tags (small, condensed) */}
+                  {skill.tags.length > 0 && (
+                    <div style={{ display: "flex", gap: "3px", flexWrap: "wrap", maxWidth: "120px", justifyContent: "flex-end" }}>
+                      {skill.tags.slice(0, 3).map((tag) => (
+                        <span key={tag} style={{
+                          fontSize: "10px",
+                          padding: "1px 4px",
+                          borderRadius: "var(--radius-pill)",
+                          background: "var(--stone-800)",
+                          color: "var(--stone-400)",
+                        }}>
+                          {tag}
+                        </span>
+                      ))}
+                    </div>
+                  )}
+
+                  {/* Rank control */}
+                  {isKeyPassive || isUltimate ? (
+                    // Toggle for ultimates and key passives
+                    <button
+                      type="button"
+                      onClick={() => setRank(skill.id, skill.maxRank, rank > 0 ? 0 : 1)}
+                      style={{
+                        width: "36px",
+                        height: "22px",
+                        background: rank > 0 ? "var(--accent)" : "var(--stone-800)",
+                        border: "1px solid var(--stone-700)",
+                        borderRadius: "var(--radius-pill)",
+                        cursor: "pointer",
+                        fontSize: "10px",
+                        color: rank > 0 ? "var(--surface-0)" : "var(--stone-500)",
+                        fontWeight: 600,
+                      }}
+                    >
+                      {rank > 0 ? "ON" : "OFF"}
+                    </button>
+                  ) : (
+                    // Rank stepper for regular skills
+                    <div style={{ display: "flex", alignItems: "center", gap: "4px" }}>
+                      <button
+                        type="button"
+                        onClick={() => setRank(skill.id, skill.maxRank, rank - 1)}
+                        disabled={rank === 0}
+                        aria-label={`Decrease rank for ${skill.name}`}
+                        style={{
+                          width: "20px",
+                          height: "20px",
+                          background: "var(--stone-800)",
+                          border: "1px solid var(--stone-700)",
+                          borderRadius: "2px",
+                          cursor: rank === 0 ? "not-allowed" : "pointer",
+                          color: rank === 0 ? "var(--stone-700)" : "var(--stone-300)",
+                          fontSize: "13px",
+                          lineHeight: 1,
+                          display: "flex",
+                          alignItems: "center",
+                          justifyContent: "center",
+                        }}
+                      >
+                        −
+                      </button>
+                      <span style={{
+                        width: "28px",
+                        textAlign: "center",
+                        fontSize: "12px",
+                        fontFamily: "var(--font-mono)",
+                        color: rank > 0 ? "var(--stone-100)" : "var(--stone-600)",
+                      }}>
+                        {rank}/{skill.maxRank}
+                      </span>
+                      <button
+                        type="button"
+                        onClick={() => setRank(skill.id, skill.maxRank, rank + 1)}
+                        disabled={rank >= skill.maxRank}
+                        aria-label={`Increase rank for ${skill.name}`}
+                        style={{
+                          width: "20px",
+                          height: "20px",
+                          background: "var(--stone-800)",
+                          border: "1px solid var(--stone-700)",
+                          borderRadius: "2px",
+                          cursor: rank >= skill.maxRank ? "not-allowed" : "pointer",
+                          color: rank >= skill.maxRank ? "var(--stone-700)" : "var(--stone-300)",
+                          fontSize: "13px",
+                          lineHeight: 1,
+                          display: "flex",
+                          alignItems: "center",
+                          justifyContent: "center",
+                        }}
+                      >
+                        +
+                      </button>
+                    </div>
+                  )}
+                </div>
+              );
+            })}
+          </div>
+        </div>
+      ))}
+    </div>
+  );
+}
diff --git a/components/layout/CommandPalette.tsx b/components/layout/CommandPalette.tsx
new file mode 100644
index 0000000..c45ee9d
--- /dev/null
+++ b/components/layout/CommandPalette.tsx
@@ -0,0 +1,191 @@
+"use client";
+
+/**
+ * Functional command palette (cmd-K).
+ * Replaces the CommandPaletteStub from v1.
+ *
+ * Commands in v2:
+ * - Navigate to characters
+ * - Navigate to builds (demo)
+ * - Create new character
+ * - Navigate by character name (dynamic, fetched on open)
+ */
+
+import { useEffect, useState, useCallback } from "react";
+import { useRouter } from "next/navigation";
+import {
+  Dialog,
+  DialogContent,
+} from "@/components/ui/dialog";
+import {
+  Command,
+  CommandEmpty,
+  CommandGroup,
+  CommandInput,
+  CommandItem,
+  CommandList,
+  CommandSeparator,
+} from "@/components/ui/command";
+import { User, Sword, Plus, Upload, Download } from "lucide-react";
+import type { Character, Build } from "@/lib/types";
+
+export function CommandPalette() {
+  const router = useRouter();
+  const [open, setOpen] = useState(false);
+  const [characters, setCharacters] = useState<Character[]>([]);
+  const [builds, setBuilds] = useState<Build[]>([]);
+
+  // Open on cmd-K / ctrl-K
+  useEffect(() => {
+    const handleKeyDown = (e: KeyboardEvent) => {
+      const isMac = navigator.platform.toUpperCase().includes("MAC");
+      const modifier = isMac ? e.metaKey : e.ctrlKey;
+      if (modifier && e.key === "k") {
+        e.preventDefault();
+        setOpen((prev) => !prev);
+      }
+    };
+    document.addEventListener("keydown", handleKeyDown);
+    return () => document.removeEventListener("keydown", handleKeyDown);
+  }, []);
+
+  // Fetch characters + builds when palette opens
+  const fetchData = useCallback(async () => {
+    try {
+      const [charRes, buildRes] = await Promise.all([
+        fetch("/api/characters"),
+        fetch("/api/builds"),
+      ]);
+      if (charRes.ok) setCharacters(await charRes.json());
+      if (buildRes.ok) setBuilds(await buildRes.json());
+    } catch {
+      // Palette still works with empty lists
+    }
+  }, []);
+
+  useEffect(() => {
+    if (open) fetchData();
+  }, [open, fetchData]);
+
+  function navigate(href: string) {
+    router.push(href);
+    setOpen(false);
+  }
+
+  function handleExport() {
+    // Export all data by triggering browser download
+    const data = { characters, builds };
+    const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
+    const url = URL.createObjectURL(blob);
+    const a = document.createElement("a");
+    a.href = url;
+    a.download = `d4-builds-export-${new Date().toISOString().slice(0, 10)}.json`;
+    a.click();
+    URL.revokeObjectURL(url);
+    setOpen(false);
+  }
+
+  return (
+    <Dialog open={open} onOpenChange={setOpen}>
+      <DialogContent
+        className="overflow-hidden p-0 shadow-lg"
+        style={{ maxWidth: "32rem", background: "var(--surface-2)", border: "1px solid var(--stone-700)" }}
+      >
+        <Command
+          className="[&_[cmdk-group-heading]]:px-2 [&_[cmdk-group-heading]]:font-medium [&_[cmdk-group]:not([hidden])_~[cmdk-group]]:pt-0 [&_[cmdk-group]]:px-2 [&_[cmdk-input-wrapper]_svg]:h-5 [&_[cmdk-input-wrapper]_svg]:w-5 [&_[cmdk-input]]:h-12 [&_[cmdk-item]]:px-2 [&_[cmdk-item]]:py-3 [&_[cmdk-item]_svg]:h-5 [&_[cmdk-item]_svg]:w-5"
+          style={{ background: "var(--surface-2)" }}
+        >
+          <CommandInput placeholder="Type a command or search…" />
+          <CommandList>
+            <CommandEmpty>No results found.</CommandEmpty>
+
+            {/* Navigation */}
+            <CommandGroup heading="Navigate">
+              <CommandItem onSelect={() => navigate("/characters")}>
+                <User className="mr-2 h-4 w-4" />
+                <span>Go to Characters</span>
+              </CommandItem>
+              <CommandItem onSelect={() => navigate("/character/demo")}>
+                <Sword className="mr-2 h-4 w-4" />
+                <span>View demo build</span>
+              </CommandItem>
+            </CommandGroup>
+
+            {/* Actions */}
+            <CommandSeparator />
+            <CommandGroup heading="Actions">
+              <CommandItem onSelect={() => { navigate("/characters"); }}>
+                <Plus className="mr-2 h-4 w-4" />
+                <span>New character</span>
+                <span style={{ marginLeft: "auto", fontSize: "11px", color: "var(--stone-500)" }}>
+                  Opens characters page
+                </span>
+              </CommandItem>
+              <CommandItem onSelect={handleExport}>
+                <Download className="mr-2 h-4 w-4" />
+                <span>Export all data</span>
+              </CommandItem>
+            </CommandGroup>
+
+            {/* Characters (dynamic) */}
+            {characters.length > 0 && (
+              <>
+                <CommandSeparator />
+                <CommandGroup heading="Characters">
+                  {characters.map((char) => (
+                    <CommandItem
+                      key={char.id}
+                      value={`character-${char.name}-${char.class}`}
+                      onSelect={() => navigate("/characters")}
+                    >
+                      <User className="mr-2 h-4 w-4" />
+                      <span>{char.name}</span>
+                      <span style={{
+                        marginLeft: "8px",
+                        fontSize: "11px",
+                        color: "var(--stone-500)",
+                      }}>
+                        {char.class} · Lv {char.level}
+                      </span>
+                    </CommandItem>
+                  ))}
+                </CommandGroup>
+              </>
+            )}
+
+            {/* Builds (dynamic) */}
+            {builds.length > 0 && (
+              <>
+                <CommandSeparator />
+                <CommandGroup heading="Builds">
+                  {builds.map((build) => {
+                    const char = characters.find((c) => c.id === build.characterId);
+                    return (
+                      <CommandItem
+                        key={build.id}
+                        value={`build-${build.name}-${char?.name ?? ""}`}
+                        onSelect={() => navigate("/characters")}
+                      >
+                        <Sword className="mr-2 h-4 w-4" />
+                        <span>{build.name}</span>
+                        {char && (
+                          <span style={{
+                            marginLeft: "8px",
+                            fontSize: "11px",
+                            color: "var(--stone-500)",
+                          }}>
+                            {char.name}
+                          </span>
+                        )}
+                      </CommandItem>
+                    );
+                  })}
+                </CommandGroup>
+              </>
+            )}
+          </CommandList>
+        </Command>
+      </DialogContent>
+    </Dialog>
+  );
+}
