@@ -0,0 +1,585 @@
+"use client";
+
+import { useState } from "react";
+import { X, Plus, Trash2 } from "lucide-react";
+import type {
+  AppliedAspect,
+  D4Class,
+  EquippedItem,
+  ItemRarity,
+  ItemSlotId,
+  RolledAffix,
+} from "@/lib/types";
+import { ITEM_RARITIES } from "@/lib/types";
+import { getAffixDef, getAspectDef } from "@/lib/catalog";
+import { validateAffixValue, validateItemPower } from "@/lib/validation";
+import { AffixPicker } from "./AffixPicker";
+import { AspectPicker } from "./AspectPicker";
+import { Dialog, DialogContent } from "@/components/ui/dialog";
+
+const RARITY_LABELS: Record<ItemRarity, string> = {
+  common: "Common",
+  magic: "Magic",
+  rare: "Rare",
+  legendary: "Legendary",
+  unique: "Unique",
+  mythic: "Mythic",
+};
+
+const RARITY_COLORS: Record<ItemRarity, string> = {
+  common: "var(--rarity-common)",
+  magic: "var(--rarity-magic)",
+  rare: "var(--rarity-rare)",
+  legendary: "var(--rarity-legendary)",
+  unique: "var(--rarity-unique)",
+  mythic: "var(--rarity-mythic)",
+};
+
+interface ItemEditorModalProps {
+  open: boolean;
+  onClose: () => void;
+  slot: ItemSlotId;
+  slotLabel: string;
+  characterClass: D4Class;
+  /** Existing item to edit, or undefined for new */
+  item?: EquippedItem;
+  onSave: (item: EquippedItem) => void;
+  onRemove?: () => void;
+}
+
+export function ItemEditorModal({
+  open,
+  onClose,
+  slot,
+  slotLabel,
+  characterClass,
+  item,
+  onSave,
+  onRemove,
+}: ItemEditorModalProps) {
+  const [name, setName] = useState(item?.name ?? "");
+  const [rarity, setRarity] = useState<ItemRarity>(item?.rarity ?? "legendary");
+  const [itemPower, setItemPower] = useState<string>(
+    item?.itemPower !== undefined ? String(item.itemPower) : "",
+  );
+  const [isAncestral, setIsAncestral] = useState(item?.isAncestral ?? false);
+  const [masterworkRank, setMasterworkRank] = useState<string>(
+    item?.masterworkRank !== undefined ? String(item.masterworkRank) : "",
+  );
+
+  // Affixes: up to 4
+  const [affixes, setAffixes] = useState<Array<{ affixId: string; rolledValue: string }>>(
+    (item?.affixes ?? []).map((a) => ({
+      affixId: a.affixId,
+      rolledValue: String(a.rolledValue),
+    })),
+  );
+
+  // Aspect
+  const [aspectId, setAspectId] = useState<string | undefined>(item?.aspect?.aspectId);
+  const [aspectValue, setAspectValue] = useState<string>(
+    item?.aspect?.rolledValue !== undefined ? String(item.aspect.rolledValue) : "",
+  );
+
+  const [errors, setErrors] = useState<Record<string, string>>({});
+
+  function resetToItem() {
+    setName(item?.name ?? "");
+    setRarity(item?.rarity ?? "legendary");
+    setItemPower(item?.itemPower !== undefined ? String(item.itemPower) : "");
+    setIsAncestral(item?.isAncestral ?? false);
+    setMasterworkRank(item?.masterworkRank !== undefined ? String(item.masterworkRank) : "");
+    setAffixes(
+      (item?.affixes ?? []).map((a) => ({
+        affixId: a.affixId,
+        rolledValue: String(a.rolledValue),
+      })),
+    );
+    setAspectId(item?.aspect?.aspectId);
+    setAspectValue(
+      item?.aspect?.rolledValue !== undefined ? String(item.aspect.rolledValue) : "",
+    );
+    setErrors({});
+  }
+
+  function handleClose() {
+    resetToItem();
+    onClose();
+  }
+
+  function addAffix() {
+    if (affixes.length >= 4) return;
+    setAffixes((prev) => [...prev, { affixId: "", rolledValue: "" }]);
+  }
+
+  function updateAffix(
+    index: number,
+    field: "affixId" | "rolledValue",
+    value: string,
+  ) {
+    setAffixes((prev) =>
+      prev.map((a, i) => (i === index ? { ...a, [field]: value } : a)),
+    );
+    // Clear error when editing
+    setErrors((prev) => {
+      const next = { ...prev };
+      delete next[`affixes.${index}`];
+      return next;
+    });
+  }
+
+  function removeAffix(index: number) {
+    setAffixes((prev) => prev.filter((_, i) => i !== index));
+  }
+
+  function validate(): boolean {
+    const newErrors: Record<string, string> = {};
+
+    if (!name.trim()) newErrors.name = "Item name is required.";
+
+    if (itemPower !== "") {
+      const power = Number(itemPower);
+      const pwErr = validateItemPower(power);
+      if (pwErr) newErrors.itemPower = pwErr;
+    }
+
+    affixes.forEach((a, i) => {
+      if (!a.affixId) return; // empty row — will be skipped
+      if (!a.rolledValue) {
+        newErrors[`affixes.${i}`] = "Enter a value.";
+        return;
+      }
+      const val = Number(a.rolledValue);
+      if (isNaN(val)) {
+        newErrors[`affixes.${i}`] = "Must be a number.";
+        return;
+      }
+      const err = validateAffixValue(a.affixId, val);
+      if (err) newErrors[`affixes.${i}`] = err;
+    });
+
+    setErrors(newErrors);
+    return Object.keys(newErrors).length === 0;
+  }
+
+  function handleSave() {
+    if (!validate()) return;
+
+    const rolledAffixes: RolledAffix[] = affixes
+      .filter((a) => a.affixId && a.rolledValue !== "")
+      .map((a) => ({
+        affixId: a.affixId,
+        rolledValue: Number(a.rolledValue),
+      }));
+
+    let aspect: AppliedAspect | undefined;
+    if (aspectId) {
+      const def = getAspectDef(aspectId);
+      aspect = {
+        aspectId,
+        rolledValue:
+          def?.hasRolledValue && aspectValue !== ""
+            ? Number(aspectValue)
+            : undefined,
+      };
+    }
+
+    const saved: EquippedItem = {
+      id: item?.id ?? `item-${slot}-${Date.now()}`,
+      slot,
+      name: name.trim(),
+      rarity,
+      itemPower: itemPower !== "" ? Number(itemPower) : undefined,
+      affixes: rolledAffixes,
+      aspect,
+      isAncestral: isAncestral || undefined,
+      masterworkRank:
+        masterworkRank !== "" ? Number(masterworkRank) : undefined,
+    };
+
+    onSave(saved);
+    onClose();
+  }
+
+  const aspectDef = aspectId ? getAspectDef(aspectId) : null;
+  const usedAffixIds = affixes.map((a) => a.affixId).filter(Boolean);
+
+  if (!open) return null;
+
+  return (
+    <Dialog open={open} onOpenChange={(o) => !o && handleClose()}>
+      <DialogContent
+        style={{
+          maxWidth: "580px",
+          padding: 0,
+          background: "var(--surface-2)",
+          border: "1px solid var(--stone-700)",
+        }}
+      >
+        {/* Header */}
+        <div
+          style={{
+            display: "flex",
+            alignItems: "center",
+            justifyContent: "space-between",
+            padding: "14px 16px",
+            borderBottom: "1px solid var(--stone-800)",
+          }}
+        >
+          <div>
+            <div style={{ fontSize: "14px", fontWeight: 600, color: "var(--stone-100)" }}>
+              {item ? "Edit item" : "Add item"}
+            </div>
+            <div style={{ fontSize: "12px", color: "var(--stone-500)" }}>
+              {slotLabel}
+            </div>
+          </div>
+          <button
+            onClick={handleClose}
+            style={{
+              background: "none",
+              border: "none",
+              cursor: "pointer",
+              color: "var(--stone-500)",
+              padding: "4px",
+            }}
+            aria-label="Close"
+          >
+            <X size={16} />
+          </button>
+        </div>
+
+        {/* Body */}
+        <div style={{ padding: "16px", display: "flex", flexDirection: "column", gap: "14px" }}>
+          {/* Name */}
+          <FieldGroup label="Item name" error={errors.name}>
+            <input
+              value={name}
+              onChange={(e) => setName(e.target.value)}
+              placeholder="e.g. Harlequin Crest"
+              style={inputStyle(!!errors.name)}
+              autoFocus
+            />
+          </FieldGroup>
+
+          {/* Rarity + Item Power row */}
+          <div style={{ display: "flex", gap: "12px" }}>
+            <FieldGroup label="Rarity" style={{ width: "160px", flexShrink: 0 }}>
+              <select
+                value={rarity}
+                onChange={(e) => setRarity(e.target.value as ItemRarity)}
+                style={{
+                  ...inputStyle(false),
+                  color: RARITY_COLORS[rarity],
+                }}
+              >
+                {ITEM_RARITIES.map((r) => (
+                  <option key={r} value={r} style={{ color: RARITY_COLORS[r] }}>
+                    {RARITY_LABELS[r]}
+                  </option>
+                ))}
+              </select>
+            </FieldGroup>
+
+            <FieldGroup label="Item Power" error={errors.itemPower} style={{ flex: 1 }}>
+              <input
+                type="number"
+                value={itemPower}
+                onChange={(e) => setItemPower(e.target.value)}
+                placeholder="e.g. 925"
+                min={100}
+                max={925}
+                style={{ ...inputStyle(!!errors.itemPower), textAlign: "right" }}
+              />
+            </FieldGroup>
+
+            <FieldGroup label="MW Rank" style={{ width: "80px", flexShrink: 0 }}>
+              <input
+                type="number"
+                value={masterworkRank}
+                onChange={(e) => setMasterworkRank(e.target.value)}
+                placeholder="0–12"
+                min={0}
+                max={12}
+                style={{ ...inputStyle(false), textAlign: "right" }}
+              />
+            </FieldGroup>
+          </div>
+
+          {/* Ancestral toggle */}
+          <label style={{ display: "flex", alignItems: "center", gap: "8px", cursor: "pointer", userSelect: "none" }}>
+            <input
+              type="checkbox"
+              checked={isAncestral}
+              onChange={(e) => setIsAncestral(e.target.checked)}
+              style={{ accentColor: "var(--ancestral-border)", width: "14px", height: "14px" }}
+            />
+            <span style={{ fontSize: "12px", color: "var(--stone-400)" }}>Ancestral</span>
+          </label>
+
+          {/* Affixes */}
+          <div>
+            <div style={{
+              display: "flex",
+              alignItems: "center",
+              justifyContent: "space-between",
+              marginBottom: "6px",
+            }}>
+              <label style={{ fontSize: "11px", fontWeight: 600, color: "var(--stone-500)", textTransform: "uppercase", letterSpacing: "0.06em" }}>
+                Affixes
+              </label>
+              {affixes.length < 4 && (
+                <button
+                  type="button"
+                  onClick={addAffix}
+                  style={{
+                    display: "flex",
+                    alignItems: "center",
+                    gap: "4px",
+                    padding: "2px 6px",
+                    background: "none",
+                    border: "1px solid var(--stone-700)",
+                    borderRadius: "var(--radius-card)",
+                    cursor: "pointer",
+                    fontSize: "11px",
+                    color: "var(--stone-400)",
+                  }}
+                >
+                  <Plus size={10} />
+                  Add
+                </button>
+              )}
+            </div>
+
+            <div style={{ display: "flex", flexDirection: "column", gap: "6px" }}>
+              {affixes.map((a, i) => {
+                const def = a.affixId ? getAffixDef(a.affixId) : null;
+                return (
+                  <div key={i} style={{ display: "flex", gap: "6px", alignItems: "center" }}>
+                    <AffixPicker
+                      slot={slot}
+                      characterClass={characterClass}
+                      value={a.affixId || undefined}
+                      onSelect={(id) => updateAffix(i, "affixId", id)}
+                      onClear={() => {
+                        updateAffix(i, "affixId", "");
+                        updateAffix(i, "rolledValue", "");
+                      }}
+                      excludeIds={usedAffixIds.filter((id) => id !== a.affixId)}
+                    />
+                    <div style={{ display: "flex", flexDirection: "column", width: "90px", flexShrink: 0 }}>
+                      <input
+                        type="number"
+                        value={a.rolledValue}
+                        onChange={(e) => updateAffix(i, "rolledValue", e.target.value)}
+                        placeholder={
+                          def
+                            ? `${def.minValue}–${def.maxValue}`
+                            : "value"
+                        }
+                        disabled={!a.affixId}
+                        style={{
+                          ...inputStyle(!!errors[`affixes.${i}`]),
+                          textAlign: "right",
+                          fontFamily: "var(--font-mono)",
+                          fontSize: "12px",
+                          opacity: a.affixId ? 1 : 0.4,
+                        }}
+                      />
+                      {errors[`affixes.${i}`] && (
+                        <span style={{ fontSize: "10px", color: "var(--danger)", marginTop: "2px" }}>
+                          {errors[`affixes.${i}`]}
+                        </span>
+                      )}
+                    </div>
+                    <button
+                      type="button"
+                      onClick={() => removeAffix(i)}
+                      aria-label="Remove affix"
+                      style={{
+                        background: "none",
+                        border: "none",
+                        cursor: "pointer",
+                        color: "var(--stone-600)",
+                        padding: "2px",
+                        flexShrink: 0,
+                      }}
+                    >
+                      <Trash2 size={12} />
+                    </button>
+                  </div>
+                );
+              })}
+              {affixes.length === 0 && (
+                <div style={{ fontSize: "12px", color: "var(--stone-600)", fontStyle: "italic" }}>
+                  No affixes. Add up to 4.
+                </div>
+              )}
+            </div>
+          </div>
+
+          {/* Aspect */}
+          <div>
+            <label style={{
+              display: "block",
+              fontSize: "11px",
+              fontWeight: 600,
+              color: "var(--stone-500)",
+              textTransform: "uppercase",
+              letterSpacing: "0.06em",
+              marginBottom: "6px",
+            }}>
+              Aspect
+            </label>
+            <div style={{ display: "flex", gap: "8px", alignItems: "flex-start" }}>
+              <AspectPicker
+                characterClass={characterClass}
+                value={aspectId}
+                onSelect={setAspectId}
+                onClear={() => {
+                  setAspectId(undefined);
+                  setAspectValue("");
+                }}
+              />
+              {aspectDef?.hasRolledValue && (
+                <input
+                  type="number"
+                  value={aspectValue}
+                  onChange={(e) => setAspectValue(e.target.value)}
+                  placeholder={`${aspectDef.minValue}–${aspectDef.maxValue}`}
+                  style={{
+                    ...inputStyle(false),
+                    width: "90px",
+                    flexShrink: 0,
+                    textAlign: "right",
+                    fontFamily: "var(--font-mono)",
+                    fontSize: "12px",
+                  }}
+                />
+              )}
+            </div>
+          </div>
+        </div>
+
+        {/* Footer */}
+        <div style={{
+          display: "flex",
+          justifyContent: "space-between",
+          alignItems: "center",
+          padding: "12px 16px",
+          borderTop: "1px solid var(--stone-800)",
+        }}>
+          <div>
+            {onRemove && item && (
+              <button
+                type="button"
+                onClick={() => {
+                  onRemove();
+                  onClose();
+                }}
+                style={{
+                  display: "flex",
+                  alignItems: "center",
+                  gap: "6px",
+                  padding: "6px 10px",
+                  background: "none",
+                  border: "1px solid var(--danger)",
+                  borderRadius: "var(--radius-card)",
+                  cursor: "pointer",
+                  color: "var(--danger)",
+                  fontSize: "13px",
+                }}
+              >
+                <Trash2 size={13} />
+                Remove item
+              </button>
+            )}
+          </div>
+          <div style={{ display: "flex", gap: "8px" }}>
+            <button
+              type="button"
+              onClick={handleClose}
+              style={cancelBtnStyle}
+            >
+              Cancel
+            </button>
+            <button
+              type="button"
+              onClick={handleSave}
+              style={saveBtnStyle}
+            >
+              Save item
+            </button>
+          </div>
+        </div>
+      </DialogContent>
+    </Dialog>
+  );
+}
+
+function FieldGroup({
+  label,
+  error,
+  children,
+  style,
+}: {
+  label: string;
+  error?: string;
+  children: React.ReactNode;
+  style?: React.CSSProperties;
+}) {
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "4px", ...style }}>
+      <label style={{
+        fontSize: "11px",
+        fontWeight: 600,
+        color: "var(--stone-500)",
+        textTransform: "uppercase",
+        letterSpacing: "0.06em",
+      }}>
+        {label}
+      </label>
+      {children}
+      {error && (
+        <span style={{ fontSize: "11px", color: "var(--danger)" }}>{error}</span>
+      )}
+    </div>
+  );
+}
+
+function inputStyle(hasError: boolean): React.CSSProperties {
+  return {
+    width: "100%",
+    height: "28px",
+    padding: "0 8px",
+    background: "var(--surface-1)",
+    border: `1px solid ${hasError ? "var(--danger)" : "var(--stone-700)"}`,
+    borderRadius: "var(--radius-card)",
+    color: "var(--stone-200)",
+    fontSize: "13px",
+    outline: "none",
+    fontFamily: "var(--font-sans)",
+    boxSizing: "border-box",
+  };
+}
+
+const cancelBtnStyle: React.CSSProperties = {
+  padding: "6px 14px",
+  background: "none",
+  border: "1px solid var(--stone-700)",
+  borderRadius: "var(--radius-card)",
+  cursor: "pointer",
+  color: "var(--stone-300)",
+  fontSize: "13px",
+};
+
+const saveBtnStyle: React.CSSProperties = {
+  padding: "6px 14px",
+  background: "var(--accent)",
+  border: "1px solid transparent",
+  borderRadius: "var(--radius-card)",
+  cursor: "pointer",
+  color: "var(--surface-0)",
+  fontSize: "13px",
+  fontWeight: 600,
+};
