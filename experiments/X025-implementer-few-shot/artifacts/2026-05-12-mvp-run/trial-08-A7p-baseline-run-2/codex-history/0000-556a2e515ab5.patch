@@ -0,0 +1,41 @@
+import { NextResponse } from "next/server";
+import { readBuild, writeBuild, deleteBuild } from "@/lib/persistence";
+import type { Build } from "@/lib/types";
+import { validateBuild, isValid } from "@/lib/validation";
+
+type Params = { params: Promise<{ id: string }> };
+
+export async function GET(_req: Request, { params }: Params) {
+  const { id } = await params;
+  const build = await readBuild(id);
+  if (!build) {
+    return NextResponse.json({ error: "Build not found" }, { status: 404 });
+  }
+  return NextResponse.json(build);
+}
+
+export async function PUT(request: Request, { params }: Params) {
+  const { id } = await params;
+  const existing = await readBuild(id);
+  if (!existing) {
+    return NextResponse.json({ error: "Build not found" }, { status: 404 });
+  }
+  const body = (await request.json()) as Partial<Build>;
+  const merged: Build = { ...existing, ...body, id };
+  const errors = validateBuild(merged);
+  if (!isValid(errors)) {
+    return NextResponse.json({ errors }, { status: 422 });
+  }
+  const updated: Build = {
+    ...merged,
+    updatedAt: new Date().toISOString(),
+  };
+  await writeBuild(updated);
+  return NextResponse.json(updated);
+}
+
+export async function DELETE(_req: Request, { params }: Params) {
+  const { id } = await params;
+  await deleteBuild(id);
+  return new NextResponse(null, { status: 204 });
+}
