@@ -0,0 +1,178 @@
+/**
+ * Validation functions for v2 data model.
+ *
+ * All validators return a string error message on failure, or undefined on success.
+ * Inline validation per visual-spec.md §9.14 and §10.5.
+ */
+
+import type {
+  Build,
+  Character,
+  D4Class,
+  EquippedItem,
+  ItemRarity,
+  ItemSlotId,
+  RolledAffix,
+  SkillSelection,
+} from "@/lib/types";
+import { isD4Class, isItemRarity, isItemSlotId } from "@/lib/types";
+import { getAffixDef } from "@/lib/catalog";
+import { getSkillDef } from "@/lib/catalog";
+
+// ── Field-level validators (return error string or undefined) ────
+
+/** Validate a character's display name */
+export function validateCharacterName(name: string): string | undefined {
+  if (!name || !name.trim()) return "Name is required.";
+  if (name.trim().length > 60) return "Name must be 60 characters or fewer.";
+  return undefined;
+}
+
+/** Validate a class selection */
+export function validateClass(cls: string): string | undefined {
+  if (!isD4Class(cls)) return `Unknown class: ${cls}`;
+  return undefined;
+}
+
+/** Validate character level (1–100) */
+export function validateCharacterLevel(level: number): string | undefined {
+  if (!Number.isInteger(level)) return "Level must be a whole number.";
+  if (level < 1 || level > 100) return "Level must be between 1 and 100.";
+  return undefined;
+}
+
+/** Validate paragon level (0–300) */
+export function validateParagonLevel(paragonLevel: number): string | undefined {
+  if (!Number.isInteger(paragonLevel)) return "Paragon level must be a whole number.";
+  if (paragonLevel < 0 || paragonLevel > 300) return "Paragon level must be between 0 and 300.";
+  return undefined;
+}
+
+/** Validate an item power value (100–925 range used in Season 13) */
+export function validateItemPower(power: number): string | undefined {
+  if (!Number.isInteger(power)) return "Item Power must be a whole number.";
+  if (power < 100 || power > 925) return "Item Power must be between 100 and 925.";
+  return undefined;
+}
+
+/** Validate an item's rarity selection */
+export function validateItemRarity(rarity: string): string | undefined {
+  if (!isItemRarity(rarity as ItemRarity)) return `Unknown rarity: ${rarity}`;
+  return undefined;
+}
+
+/** Validate an item's slot */
+export function validateItemSlot(slot: string): string | undefined {
+  if (!isItemSlotId(slot as ItemSlotId)) return `Unknown slot: ${slot}`;
+  return undefined;
+}
+
+/** Validate a single rolled affix value against its catalog definition */
+export function validateAffixValue(
+  affixId: string,
+  rolledValue: number,
+): string | undefined {
+  const def = getAffixDef(affixId);
+  if (!def) return `Unknown affix: ${affixId}`;
+  if (typeof rolledValue !== "number" || isNaN(rolledValue)) {
+    return "Value must be a number.";
+  }
+  if (rolledValue < def.minValue || rolledValue > def.maxValue) {
+    return `Value must be between ${def.minValue} and ${def.maxValue} (${def.label}).`;
+  }
+  return undefined;
+}
+
+/** Validate a skill rank against the skill's max rank */
+export function validateSkillRank(
+  skillId: string,
+  rank: number,
+): string | undefined {
+  const def = getSkillDef(skillId);
+  if (!def) return `Unknown skill: ${skillId}`;
+  if (!Number.isInteger(rank)) return "Rank must be a whole number.";
+  if (rank < 0) return "Rank cannot be negative.";
+  if (rank > def.maxRank) return `Max rank for ${def.name} is ${def.maxRank}.`;
+  return undefined;
+}
+
+/** Validate a build name */
+export function validateBuildName(name: string): string | undefined {
+  if (!name || !name.trim()) return "Build name is required.";
+  if (name.trim().length > 80) return "Build name must be 80 characters or fewer.";
+  return undefined;
+}
+
+/** Validate a masterwork rank (0–12) */
+export function validateMasterworkRank(rank: number): string | undefined {
+  if (!Number.isInteger(rank)) return "Masterwork rank must be a whole number.";
+  if (rank < 0 || rank > 12) return "Masterwork rank must be between 0 and 12.";
+  return undefined;
+}
+
+// ── Object-level validators (return Record<field, error> | undefined) ──
+
+export type FieldErrors = Record<string, string>;
+
+/** Validate a complete Character object. Returns field errors or empty object. */
+export function validateCharacter(char: Partial<Character>): FieldErrors {
+  const errors: FieldErrors = {};
+
+  const nameErr = validateCharacterName(char.name ?? "");
+  if (nameErr) errors.name = nameErr;
+
+  const classErr = validateClass(char.class ?? "");
+  if (classErr) errors.class = classErr;
+
+  if (char.level !== undefined) {
+    const levelErr = validateCharacterLevel(char.level);
+    if (levelErr) errors.level = levelErr;
+  } else {
+    errors.level = "Level is required.";
+  }
+
+  return errors;
+}
+
+/** Validate a complete Build object. Returns field errors or empty object. */
+export function validateBuild(build: Partial<Build>): FieldErrors {
+  const errors: FieldErrors = {};
+
+  const nameErr = validateBuildName(build.name ?? "");
+  if (nameErr) errors.name = nameErr;
+
+  if (build.paragonLevel !== undefined) {
+    const parErr = validateParagonLevel(build.paragonLevel);
+    if (parErr) errors.paragonLevel = parErr;
+  }
+
+  // Validate each equipped item's affixes
+  if (build.equippedItems) {
+    for (const [slot, item] of Object.entries(build.equippedItems)) {
+      if (!item) continue;
+      item.affixes.forEach((affix, i) => {
+        const affixErr = validateAffixValue(affix.affixId, affix.rolledValue);
+        if (affixErr) errors[`equippedItems.${slot}.affixes.${i}`] = affixErr;
+      });
+      if (item.masterworkRank !== undefined) {
+        const mwErr = validateMasterworkRank(item.masterworkRank);
+        if (mwErr) errors[`equippedItems.${slot}.masterworkRank`] = mwErr;
+      }
+    }
+  }
+
+  // Validate each skill selection's rank
+  if (build.skills) {
+    build.skills.forEach((sel, i) => {
+      const rankErr = validateSkillRank(sel.skillId, sel.rank);
+      if (rankErr) errors[`skills.${i}`] = rankErr;
+    });
+  }
+
+  return errors;
+}
+
+/** Returns true if the FieldErrors object has no errors. */
+export function isValid(errors: FieldErrors): boolean {
+  return Object.keys(errors).length === 0;
+}
