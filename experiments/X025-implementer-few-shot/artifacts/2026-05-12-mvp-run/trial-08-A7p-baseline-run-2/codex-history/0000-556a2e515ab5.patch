+/**
+ * D4 entity catalog — central export and lookup helpers.
+ *
+ * Import from this module rather than from individual catalog files
+ * to get access to all data and helpers in one import.
+ */
+
+export { CLASSES, getClassDef, getWeaponSlots } from "./classes";
+export { SLOTS, getSlotsForClass, getSlotDef, STANDARD_SLOTS } from "./slots";
+export { AFFIXES } from "./affixes";
+export { ASPECTS } from "./aspects";
+export { SKILLS, getSkillsForClass, getSkillDef } from "./skills";
+
+import { AFFIXES } from "./affixes";
+import { ASPECTS } from "./aspects";
+import type { AffixDef, AspectDef, D4Class, ItemSlotId } from "@/lib/types";
+
+// ── Affix lookup helpers ─────────────────────────────────────────
+
+/** Look up an affix definition by ID */
+export function getAffixDef(id: string): AffixDef | undefined {
+  return AFFIXES.find((a) => a.id === id);
+}
+
+/**
+ * Returns affixes valid for a given slot, optionally filtered by class.
+ * If no class is provided, returns all affixes for the slot (including
+ * class-specific ones for all classes).
+ */
+export function getAffixesForSlot(
+  slot: ItemSlotId,
+  cls?: D4Class,
+): AffixDef[] {
+  return AFFIXES.filter((a) => {
+    if (!a.slots.includes(slot)) return false;
+    if (cls && a.classes && !a.classes.includes(cls)) return false;
+    return true;
+  });
+}
+
+/** Returns only the class-specific affixes (skill rank affixes) for a class */
+export function getClassAffixes(cls: D4Class): AffixDef[] {
+  return AFFIXES.filter(
+    (a) => a.category === "class-specific" && a.classes?.includes(cls),
+  );
+}
+
+// ── Aspect lookup helpers ────────────────────────────────────────
+
+/** Look up an aspect definition by ID */
+export function getAspectDef(id: string): AspectDef | undefined {
+  return ASPECTS.find((a) => a.id === id);
+}
+
+/**
+ * Returns aspects available for a given class.
+ * Includes generic (class-unset) aspects.
+ */
+export function getAspectsForClass(cls: D4Class): AspectDef[] {
+  return ASPECTS.filter(
+    (a) => !a.classes || a.classes.includes(cls),
+  );
+}
