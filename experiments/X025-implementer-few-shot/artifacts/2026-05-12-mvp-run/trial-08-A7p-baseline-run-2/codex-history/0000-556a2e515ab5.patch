@@ -0,0 +1,223 @@
+"use client";
+
+import { useState } from "react";
+import type { Build, D4Class, EquippedItem, ItemSlotId, ParagonAllocation, SkillSelection } from "@/lib/types";
+import { GearEditor } from "./GearEditor";
+import { SkillEditor } from "./SkillEditor";
+import { ParagonEditor } from "./ParagonEditor";
+
+interface BuildEditorProps {
+  build: Build;
+  characterClass: D4Class;
+  onSave: (build: Build) => void;
+  onCancel?: () => void;
+  loading?: boolean;
+}
+
+type ActiveTab = "gear" | "skills" | "paragon";
+
+export function BuildEditor({
+  build,
+  characterClass,
+  onSave,
+  onCancel,
+  loading = false,
+}: BuildEditorProps) {
+  const [activeTab, setActiveTab] = useState<ActiveTab>("gear");
+  const [name, setName] = useState(build.name);
+  const [nameError, setNameError] = useState<string | undefined>();
+  const [equippedItems, setEquippedItems] = useState<Partial<Record<ItemSlotId, EquippedItem>>>(
+    build.equippedItems ?? {},
+  );
+  const [skills, setSkills] = useState<SkillSelection[]>(build.skills ?? []);
+  const [paragonLevel, setParagonLevel] = useState(build.paragonLevel ?? 0);
+  const [paragonAllocation, setParagonAllocation] = useState<ParagonAllocation>(
+    build.paragonAllocation ?? { boardNames: [], glyphs: [], notes: "" },
+  );
+  const [notes, setNotes] = useState(build.notes ?? "");
+
+  function handleSave() {
+    if (!name.trim()) {
+      setNameError("Build name is required.");
+      return;
+    }
+    setNameError(undefined);
+
+    const updated: Build = {
+      ...build,
+      name: name.trim(),
+      equippedItems,
+      skills,
+      paragonLevel,
+      paragonAllocation,
+      notes: notes || undefined,
+      updatedAt: new Date().toISOString(),
+    };
+    onSave(updated);
+  }
+
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "0", height: "100%" }}>
+      {/* Build name + actions header */}
+      <div style={{
+        display: "flex",
+        alignItems: "center",
+        gap: "12px",
+        padding: "12px 16px",
+        borderBottom: "1px solid var(--stone-800)",
+        flexShrink: 0,
+      }}>
+        <div style={{ flex: 1 }}>
+          <input
+            value={name}
+            onChange={(e) => {
+              setName(e.target.value);
+              setNameError(undefined);
+            }}
+            placeholder="Build name"
+            style={{
+              width: "100%",
+              background: "none",
+              border: "none",
+              outline: "none",
+              color: "var(--accent)",
+              fontSize: "16px",
+              fontWeight: 600,
+              borderBottom: `1px solid ${nameError ? "var(--danger)" : "var(--stone-800)"}`,
+              padding: "2px 0",
+            }}
+          />
+          {nameError && (
+            <span style={{ fontSize: "11px", color: "var(--danger)" }}>{nameError}</span>
+          )}
+        </div>
+        <div style={{ display: "flex", gap: "6px" }}>
+          {onCancel && (
+            <button type="button" onClick={onCancel} style={cancelBtnStyle} disabled={loading}>
+              Cancel
+            </button>
+          )}
+          <button type="button" onClick={handleSave} style={saveBtnStyle} disabled={loading}>
+            {loading ? "Saving…" : "Save build"}
+          </button>
+        </div>
+      </div>
+
+      {/* Tab bar */}
+      <div style={{
+        display: "flex",
+        borderBottom: "1px solid var(--stone-800)",
+        flexShrink: 0,
+      }}>
+        {(["gear", "skills", "paragon"] as ActiveTab[]).map((tab) => (
+          <button
+            key={tab}
+            type="button"
+            onClick={() => setActiveTab(tab)}
+            style={{
+              padding: "8px 16px",
+              background: "none",
+              border: "none",
+              borderBottom: activeTab === tab ? "2px solid var(--accent)" : "2px solid transparent",
+              cursor: "pointer",
+              fontSize: "13px",
+              fontWeight: activeTab === tab ? 600 : 400,
+              color: activeTab === tab ? "var(--stone-100)" : "var(--stone-500)",
+              textTransform: "capitalize",
+              transition: "color 100ms ease",
+            }}
+          >
+            {tab === "paragon" ? `Paragon (Lv ${paragonLevel})` : tab.charAt(0).toUpperCase() + tab.slice(1)}
+          </button>
+        ))}
+      </div>
+
+      {/* Tab content */}
+      <div style={{ flex: 1, overflowY: "auto", padding: "16px" }}>
+        {activeTab === "gear" && (
+          <GearEditor
+            characterClass={characterClass}
+            equippedItems={equippedItems}
+            onChange={setEquippedItems}
+          />
+        )}
+
+        {activeTab === "skills" && (
+          <SkillEditor
+            characterClass={characterClass}
+            selections={skills}
+            onChange={setSkills}
+          />
+        )}
+
+        {activeTab === "paragon" && (
+          <ParagonEditor
+            paragonLevel={paragonLevel}
+            allocation={paragonAllocation}
+            onChangeLevel={setParagonLevel}
+            onChangeAllocation={setParagonAllocation}
+          />
+        )}
+      </div>
+
+      {/* Build notes (always visible at bottom) */}
+      <div style={{
+        flexShrink: 0,
+        borderTop: "1px solid var(--stone-800)",
+        padding: "12px 16px",
+      }}>
+        <label style={{
+          fontSize: "11px",
+          fontWeight: 600,
+          color: "var(--stone-500)",
+          textTransform: "uppercase",
+          letterSpacing: "0.06em",
+          display: "block",
+          marginBottom: "6px",
+        }}>
+          Build notes
+        </label>
+        <textarea
+          value={notes}
+          onChange={(e) => setNotes(e.target.value)}
+          placeholder="Playstyle notes, acquisition targets, etc."
+          rows={2}
+          style={{
+            width: "100%",
+            background: "var(--surface-1)",
+            border: "1px solid var(--stone-800)",
+            borderRadius: "var(--radius-card)",
+            color: "var(--stone-300)",
+            fontSize: "12px",
+            padding: "6px 8px",
+            outline: "none",
+            resize: "none",
+            boxSizing: "border-box",
+            fontFamily: "var(--font-sans)",
+          }}
+        />
+      </div>
+    </div>
+  );
+}
+
+const cancelBtnStyle: React.CSSProperties = {
+  padding: "5px 12px",
+  background: "none",
+  border: "1px solid var(--stone-700)",
+  borderRadius: "var(--radius-card)",
+  cursor: "pointer",
+  color: "var(--stone-300)",
+  fontSize: "12px",
+};
+
+const saveBtnStyle: React.CSSProperties = {
+  padding: "5px 12px",
+  background: "var(--accent)",
+  border: "1px solid transparent",
+  borderRadius: "var(--radius-card)",
+  cursor: "pointer",
+  color: "var(--surface-0)",
+  fontSize: "12px",
+  fontWeight: 600,
+};
