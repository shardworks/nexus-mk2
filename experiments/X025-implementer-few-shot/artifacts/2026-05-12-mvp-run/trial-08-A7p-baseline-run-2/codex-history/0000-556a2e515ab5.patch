+++ b/components/d4/BuildDetailView.tsx
@@ -0,0 +1,288 @@
+"use client";
+
+/**
+ * BuildDetailView — read-only summary of a saved build.
+ * Replaces the v1 BuildSummaryView for saved builds.
+ * Uses the v2 Build + Character types from lib/types.
+ */
+
+import type { Build, Character, EquippedItem, ItemRarity, ItemSlotId } from "@/lib/types";
+import { getAffixDef, getAspectDef, getSlotsForClass } from "@/lib/catalog";
+import { getSkillDef } from "@/lib/catalog";
+
+const RARITY_COLORS: Record<ItemRarity, string> = {
+  common: "var(--rarity-common)",
+  magic: "var(--rarity-magic)",
+  rare: "var(--rarity-rare)",
+  legendary: "var(--rarity-legendary)",
+  unique: "var(--rarity-unique)",
+  mythic: "var(--rarity-mythic)",
+};
+
+interface BuildDetailViewProps {
+  character: Character;
+  build: Build;
+}
+
+export function BuildDetailView({ character, build }: BuildDetailViewProps) {
+  const slots = getSlotsForClass(character.class);
+  const armorSlots = slots.filter((s) => s.cluster === "armor");
+  const weaponSlots = slots.filter((s) => s.cluster === "weapon");
+  const jewelrySlots = slots.filter((s) => s.cluster === "jewelry");
+
+  const equippedCount = Object.keys(build.equippedItems).length;
+  const allocatedSkills = build.skills.filter((s) => s.rank > 0);
+
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "24px" }}>
+      {/* Build header */}
+      <div>
+        <h1 style={{ fontSize: "22px", fontWeight: 600, color: "var(--stone-100)", margin: 0, lineHeight: 1.2 }}>
+          {character.name}
+        </h1>
+        <div style={{ display: "flex", gap: "12px", alignItems: "center", marginTop: "6px", flexWrap: "wrap" }}>
+          <span style={{ fontSize: "14px", color: "var(--accent)", fontWeight: 600 }}>
+            {build.name}
+          </span>
+          <span style={{ color: "var(--stone-600)" }}>·</span>
+          <span style={{ fontSize: "13px", color: "var(--stone-400)" }}>{character.class}</span>
+          <span style={{ color: "var(--stone-600)" }}>·</span>
+          <span style={{ fontSize: "13px", color: "var(--stone-400)" }}>Level {character.level}</span>
+          <span style={{ color: "var(--stone-600)" }}>·</span>
+          <span style={{ fontSize: "13px", color: "var(--stone-400)" }}>
+            Paragon {build.paragonLevel}
+          </span>
+          <span style={{ color: "var(--stone-600)" }}>·</span>
+          <span style={{ fontSize: "12px", color: "var(--stone-600)", fontStyle: "italic" }}>
+            {equippedCount}/13 slots · {allocatedSkills.length} skills
+          </span>
+        </div>
+      </div>
+
+      {/* Gear grid */}
+      <div style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
+        <div style={{ display: "flex", gap: "16px", alignItems: "flex-start" }}>
+          <GearCluster
+            title="Armor"
+            slots={armorSlots}
+            items={build.equippedItems}
+          />
+          <GearCluster
+            title="Jewelry"
+            slots={jewelrySlots}
+            items={build.equippedItems}
+          />
+        </div>
+        <GearCluster title="Weapons" slots={weaponSlots} items={build.equippedItems} />
+      </div>
+
+      {/* Skills (compact list) */}
+      {allocatedSkills.length > 0 && (
+        <div>
+          <div style={{ fontSize: "11px", fontWeight: 600, color: "var(--stone-500)", textTransform: "uppercase", letterSpacing: "0.08em", marginBottom: "8px" }}>
+            Skills
+          </div>
+          <div style={{ display: "flex", flexWrap: "wrap", gap: "6px" }}>
+            {allocatedSkills.map((sel) => {
+              const def = getSkillDef(sel.skillId);
+              if (!def) return null;
+              return (
+                <div key={sel.skillId} style={{
+                  display: "flex",
+                  alignItems: "center",
+                  gap: "4px",
+                  padding: "3px 8px",
+                  background: "var(--surface-1)",
+                  border: "1px solid var(--stone-700)",
+                  borderRadius: "var(--radius-pill)",
+                  fontSize: "12px",
+                  color: "var(--stone-200)",
+                }}>
+                  {def.name}
+                  {def.maxRank > 1 && (
+                    <span style={{ fontSize: "11px", color: "var(--stone-500)", fontFamily: "var(--font-mono)" }}>
+                      {sel.rank}/{def.maxRank}
+                    </span>
+                  )}
+                </div>
+              );
+            })}
+          </div>
+        </div>
+      )}
+
+      {/* Paragon summary */}
+      {build.paragonLevel > 0 && (
+        <div>
+          <div style={{ fontSize: "11px", fontWeight: 600, color: "var(--stone-500)", textTransform: "uppercase", letterSpacing: "0.08em", marginBottom: "8px" }}>
+            Paragon
+          </div>
+          <div style={{ display: "flex", flexDirection: "column", gap: "4px", fontSize: "13px", color: "var(--stone-400)" }}>
+            {build.paragonAllocation.boardNames.length > 0 ? (
+              build.paragonAllocation.boardNames.map((b, i) => {
+                const boardGlyphs = build.paragonAllocation.glyphs.filter(
+                  (g) => g.boardIndex === i && g.glyphId,
+                );
+                return (
+                  <div key={i} style={{ display: "flex", gap: "8px", alignItems: "baseline" }}>
+                    <span style={{ color: "var(--stone-300)", minWidth: "20px" }}>{i + 1}.</span>
+                    <span>{b || "(unnamed board)"}</span>
+                    {boardGlyphs.length > 0 && (
+                      <span style={{ color: "var(--stone-600)", fontSize: "12px" }}>
+                        · {boardGlyphs.map((g) => `${g.glyphId}${g.glyphRank ? ` (${g.glyphRank})` : ""}`).join(", ")}
+                      </span>
+                    )}
+                  </div>
+                );
+              })
+            ) : (
+              <span style={{ color: "var(--stone-600)", fontStyle: "italic" }}>
+                No boards configured.
+              </span>
+            )}
+          </div>
+        </div>
+      )}
+
+      {/* Build notes */}
+      {build.notes && (
+        <div>
+          <div style={{ fontSize: "11px", fontWeight: 600, color: "var(--stone-500)", textTransform: "uppercase", letterSpacing: "0.08em", marginBottom: "6px" }}>
+            Notes
+          </div>
+          <p style={{ fontSize: "13px", color: "var(--stone-400)", margin: 0, lineHeight: 1.5 }}>
+            {build.notes}
+          </p>
+        </div>
+      )}
+    </div>
+  );
+}
+
+function GearCluster({
+  title,
+  slots,
+  items,
+}: {
+  title: string;
+  slots: ReturnType<typeof getSlotsForClass>;
+  items: Partial<Record<ItemSlotId, EquippedItem>>;
+}) {
+  return (
+    <div style={{ flex: 1, minWidth: 0, display: "flex", flexDirection: "column", gap: "8px" }}>
+      <div style={{
+        fontSize: "11px",
+        fontWeight: 600,
+        color: "var(--stone-500)",
+        textTransform: "uppercase",
+        letterSpacing: "0.08em",
+        paddingBottom: "4px",
+        borderBottom: "1px solid var(--stone-800)",
+      }}>
+        {title}
+      </div>
+      {slots.map((slot) => {
+        const item = items[slot.id];
+        return item ? (
+          <ItemCardReadOnly key={slot.id} item={item} slotLabel={slot.label} />
+        ) : (
+          <EmptySlot key={slot.id} label={slot.label} />
+        );
+      })}
+    </div>
+  );
+}
+
+function ItemCardReadOnly({
+  item,
+  slotLabel,
+}: {
+  item: EquippedItem;
+  slotLabel: string;
+}) {
+  const rarityColor = RARITY_COLORS[item.rarity];
+  const aspectDef = item.aspect ? getAspectDef(item.aspect.aspectId) : null;
+
+  return (
+    <div
+      className={item.isAncestral ? "ancestral" : undefined}
+      style={{
+        borderRadius: "var(--radius-card)",
+        border: `1px solid ${rarityColor}4d`,
+        background: "var(--surface-1)",
+        padding: "var(--item-card-padding)",
+      }}
+    >
+      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: "4px" }}>
+        <span style={{ fontSize: "13px", fontWeight: 600, color: rarityColor, lineHeight: 1.2 }}>
+          {item.name}
+        </span>
+        {item.itemPower !== undefined && (
+          <span style={{
+            fontSize: "11px",
+            color: "var(--stone-500)",
+            fontFamily: "var(--font-mono)",
+            marginLeft: "8px",
+            flexShrink: 0,
+          }}>
+            {item.itemPower}
+          </span>
+        )}
+      </div>
+      <div style={{ fontSize: "11px", color: "var(--stone-600)", marginBottom: "4px" }}>
+        {slotLabel}{item.masterworkRank ? ` · MW${item.masterworkRank}` : ""}
+      </div>
+      {aspectDef && (
+        <div style={{ fontSize: "11px", color: "var(--rarity-legendary)", fontStyle: "italic", marginBottom: "4px" }}>
+          {aspectDef.name}
+          {item.aspect?.rolledValue !== undefined && (
+            <span style={{ fontFamily: "var(--font-mono)", fontStyle: "normal", marginLeft: "4px" }}>
+              [{item.aspect.rolledValue}]
+            </span>
+          )}
+        </div>
+      )}
+      {item.affixes.length > 0 && (
+        <div style={{ display: "flex", flexDirection: "column", gap: "var(--item-card-row-gap)" }}>
+          {item.affixes.map((affix, i) => {
+            const def = getAffixDef(affix.affixId);
+            return (
+              <div key={i} style={{ display: "flex", gap: "6px", alignItems: "baseline" }}>
+                <span style={{
+                  fontSize: "12px",
+                  fontFamily: "var(--font-mono)",
+                  fontVariantNumeric: "tabular-nums",
+                  color: "var(--stone-200)",
+                  flexShrink: 0,
+                }}>
+                  +{affix.rolledValue}{def?.unit === "percent" ? "%" : ""}
+                  {affix.isGreaterAffix && <span style={{ color: "var(--rarity-rare)", marginLeft: "2px" }}>★</span>}
+                </span>
+                <span style={{ fontSize: "12px", color: "var(--stone-400)" }}>
+                  {def?.label ?? affix.affixId}
+                </span>
+              </div>
+            );
+          })}
+        </div>
+      )}
+    </div>
+  );
+}
+
+function EmptySlot({ label }: { label: string }) {
+  return (
+    <div style={{
+      borderRadius: "var(--radius-card)",
+      border: "1px dashed var(--stone-800)",
+      padding: "10px 8px",
+      display: "flex",
+      alignItems: "center",
+      justifyContent: "center",
+      color: "var(--stone-700)",
+      fontSize: "11px",
+    }}>
+      {label}
+    </div>
+  );
+}
