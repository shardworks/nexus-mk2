+          >
+            <Plus size={11} />
+            New
+          </button>
+        </div>
+
+        {/* Character list */}
+        <div style={{ flex: 1, overflowY: "auto" }}>
+          {characters.length === 0 ? (
+            <div style={{ padding: "16px 12px", color: "var(--stone-600)", fontSize: "13px" }}>
+              No characters yet.{" "}
+              <button
+                onClick={() => setShowNewCharacter(true)}
+                style={{ background: "none", border: "none", cursor: "pointer", color: "var(--accent)", fontSize: "13px", padding: 0 }}
+              >
+                Create one.
+              </button>
+            </div>
+          ) : (
+            characters.map((char) => {
+              const isActive = selected?.id === char.id;
+              const builds = buildsMap[char.id] ?? [];
+              return (
+                <button
+                  key={char.id}
+                  onClick={() => setSelected(char)}
+                  style={{
+                    width: "100%",
+                    display: "flex",
+                    alignItems: "flex-start",
+                    gap: "8px",
+                    padding: "10px 12px",
+                    background: isActive ? "var(--surface-2)" : "transparent",
+                    border: "none",
+                    borderLeft: isActive ? "2px solid var(--accent)" : "2px solid transparent",
+                    cursor: "pointer",
+                    textAlign: "left",
+                    borderBottom: "1px solid var(--stone-900)",
+                  }}
+                >
+                  <User size={14} style={{ color: "var(--stone-500)", flexShrink: 0, marginTop: "2px" }} />
+                  <div style={{ overflow: "hidden" }}>
+                    <div style={{
+                      fontSize: "13px",
+                      fontWeight: isActive ? 600 : 400,
+                      color: isActive ? "var(--stone-100)" : "var(--stone-300)",
+                      overflow: "hidden",
+                      textOverflow: "ellipsis",
+                      whiteSpace: "nowrap",
+                    }}>
+                      {char.name}
+                    </div>
+                    <div style={{ fontSize: "11px", color: "var(--stone-600)", marginTop: "2px" }}>
+                      {char.class} · Lv {char.level}
+                    </div>
+                    {builds.length > 0 && (
+                      <div style={{ fontSize: "11px", color: "var(--stone-700)", marginTop: "1px", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
+                        {builds[0].name}
+                      </div>
+                    )}
+                  </div>
+                </button>
+              );
+            })
+          )}
+        </div>
+      </div>
+
+      {/* Right: detail view (70%) */}
+      <div style={{ flex: 1, overflow: "hidden", display: "flex", flexDirection: "column" }}>
+        {!selected ? (
+          <div style={{
+            flex: 1,
+            display: "flex",
+            alignItems: "center",
+            justifyContent: "center",
+            flexDirection: "column",
+            gap: "12px",
+            color: "var(--stone-600)",
+          }}>
+            <User size={32} style={{ opacity: 0.3 }} />
+            <div style={{ fontSize: "14px" }}>Select a character or create one.</div>
+            <button
+              onClick={() => setShowNewCharacter(true)}
+              style={{
+                padding: "6px 16px",
+                background: "var(--accent)",
+                border: "none",
+                borderRadius: "var(--radius-card)",
+                cursor: "pointer",
+                color: "var(--surface-0)",
+                fontSize: "13px",
+                fontWeight: 600,
+              }}
+            >
+              Create character
+            </button>
+          </div>
+        ) : editingBuild && activeBuild ? (
+          <BuildEditor
+            build={activeBuild}
+            characterClass={selected.class}
+            onSave={saveBuild}
+            onCancel={() => setEditingBuild(false)}
+            loading={saving}
+          />
+        ) : (
+          <div style={{ flex: 1, overflowY: "auto", padding: "20px 24px" }}>
+            {/* Character actions */}
+            <div style={{
+              display: "flex",
+              gap: "8px",
+              marginBottom: "20px",
+              justifyContent: "flex-end",
+            }}>
+              {activeBuild ? (
+                <button
+                  onClick={() => setEditingBuild(true)}
+                  style={primaryBtnStyle}
+                >
+                  Edit build
+                </button>
+              ) : (
+                <button
+                  onClick={async () => {
+                    const build = makeEmptyBuild(selected.id);
+                    await saveBuild(build);
+                    setEditingBuild(true);
+                  }}
+                  style={primaryBtnStyle}
+                >
+                  Create build
+                </button>
+              )}
+              <button
+                onClick={() => setShowEditCharacter(true)}
+                style={secondaryBtnStyle}
+              >
+                Edit character
+              </button>
+              <button
+                onClick={() => deleteCharacter(selected.id)}
+                style={dangerBtnStyle}
+              >
+                Delete
+              </button>
+            </div>
+
+            {/* Build detail view */}
+            {activeBuild ? (
+              <BuildDetailView character={selected} build={activeBuild} />
+            ) : (
+              <div style={{ color: "var(--stone-600)", fontSize: "13px" }}>
+                No build yet. Create one to start entering gear.
+              </div>
+            )}
+          </div>
+        )}
+      </div>
+
+      {/* New character modal */}
+      <Dialog open={showNewCharacter} onOpenChange={(o) => !o && setShowNewCharacter(false)}>
+        <DialogContent style={{ maxWidth: "420px", background: "var(--surface-2)", border: "1px solid var(--stone-700)" }}>
+          <div style={{ padding: "20px" }}>
+            <h2 style={{ fontSize: "16px", fontWeight: 600, color: "var(--stone-100)", margin: "0 0 16px" }}>
+              New character
+            </h2>
+            <CharacterForm
+              onSave={createCharacter}
+              onCancel={() => setShowNewCharacter(false)}
+              loading={saving}
+            />
+          </div>
+        </DialogContent>
+      </Dialog>
+
+      {/* Edit character modal */}
+      <Dialog open={showEditCharacter} onOpenChange={(o) => !o && setShowEditCharacter(false)}>
+        <DialogContent style={{ maxWidth: "420px", background: "var(--surface-2)", border: "1px solid var(--stone-700)" }}>
+          <div style={{ padding: "20px" }}>
+            <h2 style={{ fontSize: "16px", fontWeight: 600, color: "var(--stone-100)", margin: "0 0 16px" }}>
+              Edit character
+            </h2>
+            {selected && (
+              <CharacterForm
+                initial={selected}
+                onSave={updateCharacter}
+                onCancel={() => setShowEditCharacter(false)}
+                loading={saving}
