+++ b/lib/types/index.ts
@@ -0,0 +1,425 @@
+/**
+ * Canonical type definitions for D4 Tools v2.
+ *
+ * This module is the single source of truth for the data model.
+ * All subsequent work — API import (v3), scoring engine, comparison logic —
+ * consumes these types.
+ */
+
+// ──────────────────────────────────────────────
+// Primitive enums
+// ──────────────────────────────────────────────
+
+export type D4Class =
+  | "Barbarian"
+  | "Druid"
+  | "Necromancer"
+  | "Rogue"
+  | "Sorcerer"
+  | "Spiritborn"
+  | "Paladin"
+  | "Warlock";
+
+/**
+ * All 13 equipment slots. weapon3/weapon4/weapon5 are the extra weapon
+ * slots Barbarians use (dual-2H system). Other classes leave them empty.
+ */
+export type ItemSlotId =
+  | "helm"
+  | "chest"
+  | "gloves"
+  | "pants"
+  | "boots"
+  | "mainHand"
+  | "offHand"
+  | "weapon3"
+  | "weapon4"
+  | "weapon5"
+  | "amulet"
+  | "ring1"
+  | "ring2";
+
+export type ItemRarity =
+  | "common"
+  | "magic"
+  | "rare"
+  | "legendary"
+  | "unique"
+  | "mythic";
+
+export type DamageType =
+  | "physical"
+  | "fire"
+  | "cold"
+  | "lightning"
+  | "poison"
+  | "shadow";
+
+export type ConstraintEnforcement = "hard" | "soft";
+
+// ──────────────────────────────────────────────
+// Catalog types (templates — not user data)
+// ──────────────────────────────────────────────
+
+/**
+ * A single affix definition from the D4 item catalog.
+ * Describes the template; user data lives in RolledAffix.
+ */
+export interface AffixDef {
+  id: string;
+  /** Human-readable label, e.g. "Critical Strike Chance" */
+  label: string;
+  /** Tooltip template with {value} placeholder, e.g. "+{value}% Critical Strike Chance" */
+  tooltip: string;
+  minValue: number;
+  maxValue: number;
+  /** How the value is expressed in-game */
+  unit: "flat" | "percent" | "x-multiplier";
+  /** Which item slots can roll this affix */
+  slots: ItemSlotId[];
+  /** If set, only these classes can have this affix. Undefined = all classes. */
+  classes?: D4Class[];
+  category: "offensive" | "defensive" | "utility" | "class-specific";
+  /** True for affixes built-in to the item type (cannot be re-rolled via enchanting) */
+  isImplicit?: boolean;
+  /** True for affixes added via the Tempering system */
+  isTempered?: boolean;
+}
+
+/**
+ * A legendary aspect definition from the D4 catalog.
+ */
+export interface AspectDef {
+  id: string;
+  name: string;
+  description: string;
+  /** Best slots to imprint this aspect (for aspect-priority suggestions) */
+  preferredSlots: ItemSlotId[];
+  /** If set, only these classes can use this aspect. Undefined = all classes. */
+  classes?: D4Class[];
+  /** Whether this aspect has a numeric roll (e.g. "+[X]% damage") */
+  hasRolledValue: boolean;
+  minValue?: number;
+  maxValue?: number;
+  unit?: "flat" | "percent" | "x-multiplier";
+  category: "offensive" | "defensive" | "utility" | "resource" | "mobility";
+  /** If this aspect applies specifically to one damage type */
+  damageType?: DamageType;
+}
+
+/** Active skill category labels per class tree layout */
+export type SkillCategory =
+  | "basic"
+  | "core"
+  | "defensive"
+  | "conjuration"   // Sorcerer
+  | "macabre"       // Necromancer
+  | "companion"     // Druid / Rogue
+  | "brawling"      // Barbarian
+  | "weapon-mastery" // Barbarian
+  | "ultimate"
+  | "key-passive"
+  | "passive";
+
+/**
+ * A skill definition from the D4 catalog.
+ */
+export interface SkillDef {
+  id: string;
+  name: string;
+  class: D4Class;
+  maxRank: number;
+  category: SkillCategory;
+  /** Skill tags used by affixes and aspects (e.g. "Fire", "Pyromancy", "Core") */
+  tags: string[];
+  resourceCost?: number;
+  cooldown?: number;
+  description?: string;
+}
+
+/** Per-class slot availability (which slots exist for this class) */
+export interface ClassDef {
+  id: D4Class;
+  label: string;
+  /** The primary attribute that scales this class's damage */
+  primaryAttribute: "Strength" | "Intelligence" | "Willpower" | "Dexterity";
+  /** Primary resource name (Fury, Mana, Spirit, etc.) */
+  resource: string;
+  /** Which weapon slots are available. Defaults to ["mainHand","offHand"] */
+  weaponSlots: ItemSlotId[];
+}
+
+/** Slot definition metadata */
+export interface SlotDef {
+  id: ItemSlotId;
+  label: string;
+  cluster: "armor" | "weapon" | "jewelry";
+  /** If true, only some classes can use this slot */
+  classSpecific?: boolean;
+  /** If set, only these classes have this slot */
+  availableFor?: D4Class[];
+}
+
+// ──────────────────────────────────────────────
+// Item types (user data)
+// ──────────────────────────────────────────────
+
+/**
+ * A specific affix on a user's item, with the actual rolled value.
+ */
+export interface RolledAffix {
+  affixId: string;       // references AffixDef.id
+  rolledValue: number;   // the actual rolled numeric value
+  /** Greater Affix (★): rolled in the top tier of its range */
+  isGreaterAffix?: boolean;
+}
+
+/**
+ * An aspect imprinted on a user's item.
+ */
+export interface AppliedAspect {
+  aspectId: string;      // references AspectDef.id
+  rolledValue?: number;  // if AspectDef.hasRolledValue, the rolled value
+}
+
+/**
+ * An item in a character's gear slot.
+ */
+export interface EquippedItem {
+  id: string;
+  slot: ItemSlotId;
+  name: string;
+  rarity: ItemRarity;
+  itemPower?: number;
+  /** Up to 4 regular affixes */
+  affixes: RolledAffix[];
+  /** Tempered affixes added via Tempering system (Vessel of Hatred+) */
+  temperedAffixes?: RolledAffix[];
+  aspect?: AppliedAspect;
+  isAncestral?: boolean;
+  /** 0–12 masterworking rank */
+  masterworkRank?: number;
+}
+
+/**
+ * A target/desired item spec for a slot.
+ * Represents intent: what the user wants this slot to look like.
+ * Can be a full hypothetical or a partial constraint.
+ */
+export interface TargetItemSpec {
+  slot: ItemSlotId;
+  /** Must have this aspect imprinted */
+  requiredAspectId?: string;
+  /** Must have at least these affixes */
+  requiredAffixIds?: string[];
+  /** Nice-to-have affixes (soft targets) */
+  preferredAffixIds?: string[];
+  notes?: string;
+}
+
+// ──────────────────────────────────────────────
+// Build composition types
+// ──────────────────────────────────────────────
+
+/**
+ * A skill the character has allocated points into.
+ */
+export interface SkillSelection {
+  skillId: string;  // references SkillDef.id
+  rank: number;     // 0 = not selected; 1–maxRank = allocated
+}
+
+/**
+ * A glyph socketed in a paragon board socket.
+ */
+export interface GlyphSocket {
+  boardIndex: number;   // 0 = starting board, 1+ = connected boards
+  socketIndex: number;  // 0-5 per board
+  glyphId?: string;     // references future glyph catalog
+  glyphRank?: number;   // glyph level 1–21
+}
+
+/**
+ * The character's paragon board allocation.
+ * Visual board rendering is out of scope for v2; this records structured data
+ * for the scoring engine and is surfaced as lists in the UI.
+ */
+export interface ParagonAllocation {
+  /** Named paragon boards selected, in order */
+  boardNames: string[];
+  /** Glyph assignments per socket */
+  glyphs: GlyphSocket[];
+  /** Freeform notes on paragon strategy */
+  notes?: string;
+}
+
+// ──────────────────────────────────────────────
+// Playstyle constraints
+// ──────────────────────────────────────────────
+
+export interface SkillConstraint {
+  type: "skill";
+  enforcement: ConstraintEnforcement;
+  skillId: string;
+  mode: "must-include" | "must-exclude";
+}
+
+export interface DamageTypeConstraint {
+  type: "damage-type";
+  enforcement: ConstraintEnforcement;
+  damageType: DamageType;
+  mode: "must" | "mostly" | "cannot";
+}
+
+export interface MechanicConstraint {
+  type: "mechanic";
+  enforcement: ConstraintEnforcement;
+  /** e.g. "overpower", "crowd-control", "lucky-hit", "fortify" */
+  mechanic: string;
+}
+
+export interface ContentConstraint {
+  type: "content";
+  enforcement: ConstraintEnforcement;
+  /** e.g. "pit-pushing", "helltide", "boss-dps" */
+  content: string;
+}
+
+export interface ItemConstraint {
+  type: "item";
+  enforcement: ConstraintEnforcement;
+  mode: "must-use" | "avoid";
+  aspectId?: string;
+  notes?: string;
+}
+
+export type PlaystyleConstraint =
+  | SkillConstraint
+  | DamageTypeConstraint
+  | MechanicConstraint
+  | ContentConstraint
+  | ItemConstraint;
+
+/**
+ * Uptime declarations for conditional affixes.
+ * The scoring engine multiplies a conditional affix's contribution by its declared uptime.
+ * Keyed by condition name (e.g. "vulnerable", "cc", "fortify", "injured").
+ */
+export type UptimeDeclarations = Record<string, number>;
+
+// ──────────────────────────────────────────────
+// Top-level persistent entities
+// ──────────────────────────────────────────────
+
+/**
+ * A D4 character. The persistent entity belonging to the user.
+ * Characters are the owner of builds.
+ */
+export interface Character {
+  id: string;
+  name: string;
+  class: D4Class;
+  /** Character level 1–100 */
+  level: number;
+  createdAt: string;  // ISO 8601
+  updatedAt: string;
+}
+
+/**
+ * A build. An optimization target layered on a character.
+ * One character can have many builds; v2 UI treats it as one active build.
+ * Data model supports the eventual one-to-many.
+ */
+export interface Build {
+  id: string;
+  characterId: string;
+  name: string;
+
+  // Skills
+  skills: SkillSelection[];
+
+  // Gear: per-slot current items + optional target specs
+  equippedItems: Partial<Record<ItemSlotId, EquippedItem>>;
+  targetItems: Partial<Record<ItemSlotId, TargetItemSpec>>;
+
+  // Paragon
+  paragonLevel: number;  // 0–300+
+  paragonAllocation: ParagonAllocation;
+
+  // Playstyle
+  constraints: PlaystyleConstraint[];
+  uptimes: UptimeDeclarations;
+
+  notes?: string;
+
+  createdAt: string;
+  updatedAt: string;
+}
+
+// ──────────────────────────────────────────────
+// Type guards
+// ──────────────────────────────────────────────
+
+const D4_CLASSES: readonly D4Class[] = [
+  "Barbarian",
+  "Druid",
+  "Necromancer",
+  "Rogue",
+  "Sorcerer",
+  "Spiritborn",
+  "Paladin",
+  "Warlock",
+] as const;
+
+const ITEM_SLOT_IDS: readonly ItemSlotId[] = [
+  "helm",
+  "chest",
+  "gloves",
+  "pants",
+  "boots",
+  "mainHand",
+  "offHand",
+  "weapon3",
+  "weapon4",
+  "weapon5",
+  "amulet",
+  "ring1",
+  "ring2",
+] as const;
+
+const ITEM_RARITIES: readonly ItemRarity[] = [
+  "common",
+  "magic",
+  "rare",
+  "legendary",
+  "unique",
+  "mythic",
+] as const;
+
+const DAMAGE_TYPES: readonly DamageType[] = [
+  "physical",
+  "fire",
+  "cold",
+  "lightning",
+  "poison",
+  "shadow",
+] as const;
+
+export function isD4Class(value: unknown): value is D4Class {
+  return D4_CLASSES.includes(value as D4Class);
+}
+
+export function isItemSlotId(value: unknown): value is ItemSlotId {
+  return ITEM_SLOT_IDS.includes(value as ItemSlotId);
+}
+
+export function isItemRarity(value: unknown): value is ItemRarity {
+  return ITEM_RARITIES.includes(value as ItemRarity);
+}
+
+export function isDamageType(value: unknown): value is DamageType {
+  return DAMAGE_TYPES.includes(value as DamageType);
+}
+
+/** All valid D4 class values (for selects and validation) */
+export { D4_CLASSES, ITEM_SLOT_IDS, ITEM_RARITIES, DAMAGE_TYPES };
