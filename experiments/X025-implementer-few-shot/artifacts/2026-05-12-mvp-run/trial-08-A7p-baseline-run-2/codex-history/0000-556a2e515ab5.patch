+import { NextResponse } from "next/server";
+import { listBuilds, listBuildsForCharacter, writeBuild } from "@/lib/persistence";
+import type { Build } from "@/lib/types";
+import { validateBuild, isValid } from "@/lib/validation";
+
+export async function GET(request: Request) {
+  const { searchParams } = new URL(request.url);
+  const characterId = searchParams.get("characterId");
+  const builds = characterId
+    ? await listBuildsForCharacter(characterId)
+    : await listBuilds();
+  return NextResponse.json(builds);
+}
+
+export async function POST(request: Request) {
+  const body = (await request.json()) as Partial<Build>;
+  const errors = validateBuild(body);
+  if (!isValid(errors)) {
+    return NextResponse.json({ errors }, { status: 422 });
+  }
+  const build = body as Build;
+  await writeBuild(build);
+  return NextResponse.json(build, { status: 201 });
+}
