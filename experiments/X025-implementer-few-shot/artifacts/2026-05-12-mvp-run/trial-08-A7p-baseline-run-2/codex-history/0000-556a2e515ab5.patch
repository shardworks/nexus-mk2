+"use client";
+
+import { useState } from "react";
+import { Plus, Trash2 } from "lucide-react";
+import type { GlyphSocket, ParagonAllocation } from "@/lib/types";
+import { validateParagonLevel } from "@/lib/validation";
+
+interface ParagonEditorProps {
+  paragonLevel: number;
+  allocation: ParagonAllocation;
+  onChangeLevel: (level: number) => void;
+  onChangeAllocation: (allocation: ParagonAllocation) => void;
+}
+
+export function ParagonEditor({
+  paragonLevel,
+  allocation,
+  onChangeLevel,
+  onChangeAllocation,
+}: ParagonEditorProps) {
+  const [levelInput, setLevelInput] = useState(String(paragonLevel));
+  const [levelError, setLevelError] = useState<string | undefined>();
+
+  function handleLevelChange(val: string) {
+    setLevelInput(val);
+    const num = Number(val);
+    const err = validateParagonLevel(num);
+    setLevelError(err);
+    if (!err) onChangeLevel(num);
+  }
+
+  function addBoard() {
+    onChangeAllocation({
+      ...allocation,
+      boardNames: [...allocation.boardNames, ""],
+    });
+  }
+
+  function updateBoard(index: number, name: string) {
+    const next = allocation.boardNames.map((b, i) => (i === index ? name : b));
+    onChangeAllocation({ ...allocation, boardNames: next });
+  }
+
+  function removeBoard(index: number) {
+    onChangeAllocation({
+      ...allocation,
+      boardNames: allocation.boardNames.filter((_, i) => i !== index),
+      glyphs: allocation.glyphs.filter((g) => g.boardIndex !== index).map((g) => ({
+        ...g,
+        boardIndex: g.boardIndex > index ? g.boardIndex - 1 : g.boardIndex,
+      })),
+    });
+  }
+
+  function updateGlyph(boardIndex: number, socketIndex: number, field: keyof GlyphSocket, value: string | number) {
+    const existing = allocation.glyphs.find(
+      (g) => g.boardIndex === boardIndex && g.socketIndex === socketIndex,
+    );
+    if (existing) {
+      onChangeAllocation({
+        ...allocation,
+        glyphs: allocation.glyphs.map((g) =>
+          g.boardIndex === boardIndex && g.socketIndex === socketIndex
+            ? { ...g, [field]: value }
+            : g,
+        ),
+      });
+    } else {
+      onChangeAllocation({
+        ...allocation,
+        glyphs: [...allocation.glyphs, { boardIndex, socketIndex, [field]: value }],
+      });
+    }
+  }
+
+  function updateNotes(notes: string) {
+    onChangeAllocation({ ...allocation, notes });
+  }
+
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "14px" }}>
+      {/* Paragon level */}
+      <div>
+        <label style={sectionLabelStyle}>Paragon level</label>
+        <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
+          <input
+            type="number"
+            value={levelInput}
+            onChange={(e) => handleLevelChange(e.target.value)}
+            min={0}
+            max={300}
+            style={{
+              ...inputStyle(!!levelError),
+              width: "80px",
+              textAlign: "right",
+              fontFamily: "var(--font-mono)",
+            }}
+          />
+          <span style={{ fontSize: "12px", color: "var(--stone-500)" }}>
+            / 300 · {Math.max(0, paragonLevel) * 4} points
+          </span>
+        </div>
+        {levelError && (
+          <span style={{ fontSize: "11px", color: "var(--danger)", display: "block", marginTop: "4px" }}>
+            {levelError}
+          </span>
+        )}
+      </div>
+
+      {/* Boards */}
+      <div>
+        <div style={{
+          display: "flex",
+          alignItems: "center",
+          justifyContent: "space-between",
+          marginBottom: "8px",
+        }}>
+          <label style={sectionLabelStyle}>Boards</label>
+          {allocation.boardNames.length < 6 && (
+            <button
+              type="button"
+              onClick={addBoard}
+              style={{
+                display: "flex",
+                alignItems: "center",
+                gap: "4px",
+                padding: "2px 8px",
+                background: "none",
+                border: "1px solid var(--stone-700)",
+                borderRadius: "var(--radius-card)",
+                cursor: "pointer",
+                fontSize: "11px",
+                color: "var(--stone-400)",
+              }}
+            >
+              <Plus size={10} />
+              Add board
+            </button>
+          )}
+        </div>
+
+        {allocation.boardNames.length === 0 && (
+          <div style={{ fontSize: "12px", color: "var(--stone-600)", fontStyle: "italic" }}>
+            No boards configured. Add a board to record glyph assignments.
+          </div>
+        )}
+
+        <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
+          {allocation.boardNames.map((boardName, boardIndex) => {
+            const boardGlyphs = allocation.glyphs.filter(
+              (g) => g.boardIndex === boardIndex,
+            );
+
+            return (
+              <div
+                key={boardIndex}
+                style={{
+                  border: "1px solid var(--stone-800)",
+                  borderRadius: "var(--radius-card)",
+                  padding: "10px 12px",
+                  background: "var(--surface-1)",
+                }}
+              >
+                {/* Board name row */}
+                <div style={{ display: "flex", gap: "8px", alignItems: "center", marginBottom: "8px" }}>
+                  <span style={{ fontSize: "11px", color: "var(--stone-500)", minWidth: "14px" }}>
+                    {boardIndex + 1}.
+                  </span>
+                  <input
+                    value={boardName}
+                    onChange={(e) => updateBoard(boardIndex, e.target.value)}
+                    placeholder={boardIndex === 0 ? "Starting board (default)" : "Board name"}
+                    style={{ ...inputStyle(false), flex: 1, height: "26px" }}
+                  />
+                  {boardIndex > 0 && (
+                    <button
+                      type="button"
+                      onClick={() => removeBoard(boardIndex)}
+                      aria-label="Remove board"
+                      style={{
+                        background: "none",
+                        border: "none",
+                        cursor: "pointer",
+                        color: "var(--stone-600)",
+                        padding: "2px",
+                      }}
+                    >
+                      <Trash2 size={12} />
+                    </button>
+                  )}
+                </div>
+
+                {/* Glyph sockets (up to 6 per board) */}
+                <div style={{
+                  display: "grid",
+                  gridTemplateColumns: "repeat(3, 1fr)",
+                  gap: "6px",
+                }}>
+                  {[0, 1, 2, 3, 4, 5].map((socketIndex) => {
+                    const glyph = boardGlyphs.find(
+                      (g) => g.socketIndex === socketIndex,
+                    );
+                    return (
+                      <div key={socketIndex} style={{
+                        display: "flex",
+                        flexDirection: "column",
+                        gap: "3px",
+                      }}>
+                        <label style={{ fontSize: "10px", color: "var(--stone-600)" }}>
+                          Socket {socketIndex + 1}
+                        </label>
+                        <input
+                          value={glyph?.glyphId ?? ""}
+                          onChange={(e) =>
+                            updateGlyph(boardIndex, socketIndex, "glyphId", e.target.value)
+                          }
+                          placeholder="Glyph name"
+                          style={{ ...inputStyle(false), height: "24px", fontSize: "11px" }}
+                        />
+                        <div style={{ display: "flex", gap: "4px", alignItems: "center" }}>
+                          <input
+                            type="number"
+                            value={glyph?.glyphRank ?? ""}
+                            onChange={(e) =>
+                              updateGlyph(boardIndex, socketIndex, "glyphRank", Number(e.target.value))
+                            }
+                            placeholder="Rank"
+                            min={1}
+                            max={21}
+                            style={{
+                              ...inputStyle(false),
+                              height: "22px",
+                              fontSize: "11px",
+                              width: "50px",
+                              textAlign: "right",
+                              fontFamily: "var(--font-mono)",
+                            }}
+                          />
+                          <span style={{ fontSize: "10px", color: "var(--stone-600)" }}>/21</span>
+                        </div>
+                      </div>
+                    );
+                  })}
+                </div>
+              </div>
+            );
+          })}
+        </div>
+      </div>
+
+      {/* Notes */}
+      <div>
+        <label style={sectionLabelStyle}>Notes</label>
+        <textarea
+          value={allocation.notes ?? ""}
+          onChange={(e) => updateNotes(e.target.value)}
+          placeholder="Paragon strategy notes…"
+          rows={3}
+          style={{
+            width: "100%",
+            padding: "8px",
+            background: "var(--surface-1)",
+            border: "1px solid var(--stone-700)",
+            borderRadius: "var(--radius-card)",
+            color: "var(--stone-200)",
+            fontSize: "13px",
+            outline: "none",
+            resize: "vertical",
+            boxSizing: "border-box",
+            fontFamily: "var(--font-sans)",
+          }}
+        />
+      </div>
+    </div>
+  );
+}
+
+const sectionLabelStyle: React.CSSProperties = {
+  display: "block",
+  fontSize: "11px",
+  fontWeight: 600,
+  color: "var(--stone-500)",
+  textTransform: "uppercase",
+  letterSpacing: "0.06em",
+  marginBottom: "6px",
+};
+
+function inputStyle(hasError: boolean): React.CSSProperties {
+  return {
+    width: "100%",
+    height: "28px",
+    padding: "0 8px",
+    background: "var(--surface-0)",
+    border: `1px solid ${hasError ? "var(--danger)" : "var(--stone-800)"}`,
+    borderRadius: "var(--radius-card)",
+    color: "var(--stone-200)",
+    fontSize: "12px",
+    outline: "none",
+    boxSizing: "border-box",
+    fontFamily: "var(--font-sans)",
+  };
+}
