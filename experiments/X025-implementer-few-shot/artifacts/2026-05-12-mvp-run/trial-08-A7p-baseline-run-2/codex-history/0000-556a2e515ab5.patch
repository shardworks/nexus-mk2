+/**
+ * D4 class definitions catalog.
+ * Covers all 8 classes in Season 13 (Lord of Hatred): the original 6 + Spiritborn (Season 6)
+ * + Paladin and Warlock (Season 13).
+ *
+ * Primary attribute assignments for Paladin/Warlock are marked unverified per docs/data-sources/02-stats.md.
+ */
+
+import type { ClassDef, D4Class, ItemSlotId } from "@/lib/types";
+
+/** Standard two-weapon slots for non-Barbarian classes */
+const STD_WEAPON_SLOTS: ItemSlotId[] = ["mainHand", "offHand"];
+
+/** Barbarian uses up to 4 weapon slots (dual-2H or 2H+2x1H) */
+const BARB_WEAPON_SLOTS: ItemSlotId[] = [
+  "mainHand",
+  "offHand",
+  "weapon3",
+  "weapon4",
+];
+
+export const CLASSES: ClassDef[] = [
+  {
+    id: "Barbarian",
+    label: "Barbarian",
+    primaryAttribute: "Strength",
+    resource: "Fury",
+    weaponSlots: BARB_WEAPON_SLOTS,
+  },
+  {
+    id: "Druid",
+    label: "Druid",
+    primaryAttribute: "Willpower",
+    resource: "Spirit",
+    weaponSlots: STD_WEAPON_SLOTS,
+  },
+  {
+    id: "Necromancer",
+    label: "Necromancer",
+    primaryAttribute: "Intelligence",
+    resource: "Essence",
+    weaponSlots: STD_WEAPON_SLOTS,
+  },
+  {
+    id: "Rogue",
+    label: "Rogue",
+    primaryAttribute: "Dexterity",
+    resource: "Energy",
+    weaponSlots: STD_WEAPON_SLOTS,
+  },
+  {
+    id: "Sorcerer",
+    label: "Sorcerer",
+    primaryAttribute: "Intelligence",
+    resource: "Mana",
+    weaponSlots: STD_WEAPON_SLOTS,
+  },
+  {
+    id: "Spiritborn",
+    label: "Spiritborn",
+    primaryAttribute: "Willpower",
+    resource: "Vigor",
+    weaponSlots: STD_WEAPON_SLOTS,
+  },
+  {
+    // ⚠️ Primary attribute unverified for Season 13 — see docs/data-sources/02-stats.md
+    id: "Paladin",
+    label: "Paladin",
+    primaryAttribute: "Strength",
+    // ⚠️ Resource name unverified — "Faith" is assumed from community references
+    resource: "Faith",
+    weaponSlots: STD_WEAPON_SLOTS,
+  },
+  {
+    // ⚠️ Primary attribute unverified for Season 13 — see docs/data-sources/02-stats.md
+    id: "Warlock",
+    label: "Warlock",
+    primaryAttribute: "Intelligence",
+    // ⚠️ Resource name unverified — "Corruption" is assumed from community references
+    resource: "Corruption",
+    weaponSlots: STD_WEAPON_SLOTS,
+  },
+];
+
+/** Look up a class definition by ID. */
+export function getClassDef(id: D4Class): ClassDef | undefined {
+  return CLASSES.find((c) => c.id === id);
+}
+
+/** Returns the weapon slots available for a given class. */
+export function getWeaponSlots(id: D4Class): ItemSlotId[] {
+  return getClassDef(id)?.weaponSlots ?? ["mainHand", "offHand"];
+}
