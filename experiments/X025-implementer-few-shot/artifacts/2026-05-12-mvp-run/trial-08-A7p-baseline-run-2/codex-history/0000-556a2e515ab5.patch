+    label: "2H Bludgeoning",
+    cluster: "weapon",
+    classSpecific: true,
+    availableFor: ["Barbarian"],
+  },
+  {
+    id: "weapon4",
+    label: "2H Slashing",
+    cluster: "weapon",
+    classSpecific: true,
+    availableFor: ["Barbarian"],
+  },
+  {
+    id: "weapon5",
+    label: "1H Off-Weapon",
+    cluster: "weapon",
+    classSpecific: true,
+    availableFor: ["Barbarian"],
+  },
+
+  // ── Jewelry ────────────────────────────────────────────────────
+  { id: "amulet", label: "Amulet", cluster: "jewelry" },
+  { id: "ring1",  label: "Ring 1", cluster: "jewelry" },
+  { id: "ring2",  label: "Ring 2", cluster: "jewelry" },
+];
+
+/** Returns all slots available for a given class */
+export function getSlotsForClass(cls: D4Class): SlotDef[] {
+  return SLOTS.filter(
+    (s) => !s.classSpecific || (s.availableFor?.includes(cls) ?? false),
+  );
+}
+
+/** Look up a slot definition by ID */
+export function getSlotDef(id: ItemSlotId): SlotDef | undefined {
+  return SLOTS.find((s) => s.id === id);
+}
+
+/** The standard 10 slots every non-Barbarian class uses */
+export const STANDARD_SLOTS: ItemSlotId[] = [
+  "helm",
+  "chest",
+  "gloves",
+  "pants",
+  "boots",
+  "mainHand",
+  "offHand",
+  "amulet",
+  "ring1",
+  "ring2",
+];
