+"use client";
+
+import { useState, useRef, useEffect } from "react";
+import { Search, X } from "lucide-react";
+import type { AspectDef, D4Class } from "@/lib/types";
+import { getAspectsForClass } from "@/lib/catalog";
+
+interface AspectPickerProps {
+  characterClass: D4Class;
+  value?: string;
+  onSelect: (aspectId: string) => void;
+  onClear?: () => void;
+  disabled?: boolean;
+}
+
+export function AspectPicker({
+  characterClass,
+  value,
+  onSelect,
+  onClear,
+  disabled = false,
+}: AspectPickerProps) {
+  const [open, setOpen] = useState(false);
+  const [query, setQuery] = useState("");
+  const inputRef = useRef<HTMLInputElement>(null);
+  const containerRef = useRef<HTMLDivElement>(null);
+
+  const available = getAspectsForClass(characterClass);
+
+  const filtered =
+    query.trim() === ""
+      ? available
+      : available.filter(
+          (a) =>
+            a.name.toLowerCase().includes(query.toLowerCase()) ||
+            a.description.toLowerCase().includes(query.toLowerCase()),
+        );
+
+  // Group into class-specific and generic
+  const classSpecific = filtered.filter(
+    (a) => a.classes && a.classes.includes(characterClass),
+  );
+  const generic = filtered.filter((a) => !a.classes);
+
+  const selected = value ? available.find((a) => a.id === value) : null;
+
+  useEffect(() => {
+    function handleClick(e: MouseEvent) {
+      if (containerRef.current && !containerRef.current.contains(e.target as Node)) {
+        setOpen(false);
+        setQuery("");
+      }
+    }
+    if (open) document.addEventListener("mousedown", handleClick);
+    return () => document.removeEventListener("mousedown", handleClick);
+  }, [open]);
+
+  useEffect(() => {
+    if (open) setTimeout(() => inputRef.current?.focus(), 50);
+  }, [open]);
+
+  function handleSelect(aspect: AspectDef) {
+    onSelect(aspect.id);
+    setOpen(false);
+    setQuery("");
+  }
+
+  const categoryBadgeColor: Record<string, string> = {
+    offensive: "var(--rarity-rare)",
+    defensive: "var(--success)",
+    utility: "var(--stone-400)",
+    resource: "var(--info)",
+    mobility: "var(--accent)",
+  };
+
+  return (
+    <div ref={containerRef} style={{ position: "relative", width: "100%" }}>
+      {/* Trigger */}
+      <button
+        type="button"
+        disabled={disabled}
+        onClick={() => setOpen((o) => !o)}
+        style={{
+          width: "100%",
+          height: "28px",
+          display: "flex",
+          alignItems: "center",
+          justifyContent: "space-between",
+          gap: "6px",
+          padding: "0 8px",
+          background: "var(--surface-1)",
+          border: "1px solid var(--stone-700)",
+          borderRadius: "var(--radius-card)",
+          cursor: disabled ? "not-allowed" : "pointer",
+          color: selected ? "var(--rarity-legendary)" : "var(--stone-500)",
+          fontSize: "12px",
+          fontStyle: selected ? "italic" : "normal",
+          textAlign: "left",
+          opacity: disabled ? 0.5 : 1,
+        }}
+      >
+        <span style={{ overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>
+          {selected ? selected.name : "No aspect…"}
+        </span>
+        <div style={{ display: "flex", gap: "2px", alignItems: "center", flexShrink: 0 }}>
+          {selected && onClear && (
+            <span
+              role="button"
+              tabIndex={0}
+              aria-label="Remove aspect"
+              onClick={(e) => {
+                e.stopPropagation();
+                onClear();
+              }}
+              onKeyDown={(e) => {
+                if (e.key === "Enter" || e.key === " ") {
+                  e.stopPropagation();
+                  onClear?.();
+                }
+              }}
+              style={{
+                display: "flex",
+                alignItems: "center",
+                padding: "2px",
+                borderRadius: "2px",
+                cursor: "pointer",
+                color: "var(--stone-400)",
+              }}
+            >
+              <X size={10} />
+            </span>
+          )}
+          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" style={{ color: "var(--stone-500)" }}>
+            <path d="M1 1l4 4 4-4" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
+          </svg>
+        </div>
+      </button>
+
+      {/* Dropdown */}
+      {open && (
+        <div
+          style={{
+            position: "absolute",
+            top: "calc(100% + 4px)",
+            left: 0,
+            right: 0,
+            zIndex: 50,
+            background: "var(--surface-2)",
+            border: "1px solid var(--stone-700)",
+            borderRadius: "var(--radius-card)",
+            boxShadow: "0 4px 16px rgba(0,0,0,0.5)",
+            maxHeight: "360px",
+            display: "flex",
+            flexDirection: "column",
+            minWidth: "280px",
+          }}
+        >
+          {/* Search */}
+          <div style={{
+            display: "flex",
+            alignItems: "center",
+            gap: "6px",
+            padding: "6px 8px",
+            borderBottom: "1px solid var(--stone-800)",
+          }}>
+            <Search size={12} style={{ color: "var(--stone-500)", flexShrink: 0 }} />
+            <input
+              ref={inputRef}
+              value={query}
+              onChange={(e) => setQuery(e.target.value)}
+              placeholder="Filter aspects…"
+              style={{
+                flex: 1,
+                background: "none",
+                border: "none",
+                outline: "none",
+                color: "var(--stone-200)",
+                fontSize: "12px",
+              }}
+            />
+          </div>
+
+          {/* List */}
+          <div style={{ overflowY: "auto", padding: "4px" }}>
+            {filtered.length === 0 && (
+              <div style={{ padding: "8px", fontSize: "12px", color: "var(--stone-500)", textAlign: "center" }}>
+                No aspects match.
+              </div>
+            )}
+
+            {classSpecific.length > 0 && (
+              <>
+                <div style={{
+                  padding: "4px 8px 2px",
+                  fontSize: "11px",
+                  fontWeight: 600,
+                  color: "var(--stone-500)",
+                  textTransform: "uppercase",
+                  letterSpacing: "0.06em",
+                }}>
+                  {characterClass}
+                </div>
+                {classSpecific.map((a) => (
+                  <AspectOption
+                    key={a.id}
+                    aspect={a}
+                    selected={a.id === value}
+                    onSelect={handleSelect}
+                    categoryColor={categoryBadgeColor[a.category] ?? "var(--stone-500)"}
+                  />
+                ))}
+                {generic.length > 0 && (
+                  <div style={{ margin: "4px 0", height: "1px", background: "var(--stone-800)" }} />
+                )}
+              </>
+            )}
+
+            {generic.length > 0 && (
+              <>
+                <div style={{
+                  padding: "4px 8px 2px",
+                  fontSize: "11px",
+                  fontWeight: 600,
+                  color: "var(--stone-500)",
+                  textTransform: "uppercase",
+                  letterSpacing: "0.06em",
+                }}>
+                  Generic
+                </div>
+                {generic.map((a) => (
+                  <AspectOption
+                    key={a.id}
+                    aspect={a}
+                    selected={a.id === value}
+                    onSelect={handleSelect}
+                    categoryColor={categoryBadgeColor[a.category] ?? "var(--stone-500)"}
+                  />
+                ))}
+              </>
+            )}
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
+
+function AspectOption({
+  aspect,
+  selected,
+  onSelect,
+  categoryColor,
+}: {
+  aspect: AspectDef;
+  selected: boolean;
+  onSelect: (a: AspectDef) => void;
+  categoryColor: string;
+}) {
+  return (
+    <button
+      type="button"
+      onClick={() => onSelect(aspect)}
+      style={{
+        width: "100%",
+        display: "flex",
+        flexDirection: "column",
+        alignItems: "flex-start",
+        gap: "2px",
+        padding: "5px 8px",
+        borderRadius: "3px",
+        border: "none",
+        background: selected ? "var(--stone-800)" : "transparent",
+        cursor: "pointer",
+        textAlign: "left",
+      }}
+      onMouseEnter={(e) => {
+        (e.currentTarget as HTMLButtonElement).style.background = "var(--stone-800)";
+      }}
+      onMouseLeave={(e) => {
+        (e.currentTarget as HTMLButtonElement).style.background = selected ? "var(--stone-800)" : "transparent";
+      }}
+    >
+      <div style={{ display: "flex", alignItems: "center", gap: "6px", width: "100%" }}>
+        <span style={{
+          fontSize: "12px",
+          color: "var(--rarity-legendary)",
+          fontStyle: "italic",
+          fontWeight: 500,
+        }}>
+          {aspect.name}
+        </span>
+        <span style={{
+          fontSize: "10px",
+          color: categoryColor,
+          marginLeft: "auto",
+          textTransform: "capitalize",
+          flexShrink: 0,
+        }}>
+          {aspect.category}
+        </span>
+      </div>
+      <span style={{ fontSize: "11px", color: "var(--stone-500)", lineHeight: 1.3 }}>
+        {aspect.description}
+      </span>
+    </button>
+  );
+}
