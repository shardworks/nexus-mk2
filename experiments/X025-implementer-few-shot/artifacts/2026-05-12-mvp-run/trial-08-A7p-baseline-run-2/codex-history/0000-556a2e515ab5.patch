+/**
+ * Type guard and constant tests for lib/types.
+ */
+
+import { describe, it, expect } from "vitest";
+import {
+  isD4Class,
+  isItemSlotId,
+  isItemRarity,
+  isDamageType,
+  D4_CLASSES,
+  ITEM_SLOT_IDS,
+  ITEM_RARITIES,
+  DAMAGE_TYPES,
+} from "@/lib/types";
+
+describe("isD4Class", () => {
+  it("returns true for all valid classes", () => {
+    const valid = ["Barbarian", "Druid", "Necromancer", "Rogue", "Sorcerer", "Spiritborn", "Paladin", "Warlock"];
+    for (const cls of valid) {
+      expect(isD4Class(cls), `${cls} should be valid`).toBe(true);
+    }
+  });
+
+  it("returns false for invalid values", () => {
+    expect(isD4Class("Wizard")).toBe(false);
+    expect(isD4Class("")).toBe(false);
+    expect(isD4Class(null)).toBe(false);
+    expect(isD4Class(undefined)).toBe(false);
+    expect(isD4Class(42)).toBe(false);
+  });
+
+  it("is case-sensitive", () => {
+    expect(isD4Class("barbarian")).toBe(false);
+    expect(isD4Class("SORCERER")).toBe(false);
+  });
+});
+
+describe("isItemSlotId", () => {
+  it("returns true for all valid slot IDs", () => {
+    const valid = ["helm", "chest", "gloves", "pants", "boots", "mainHand", "offHand", "weapon3", "weapon4", "weapon5", "amulet", "ring1", "ring2"];
+    for (const slot of valid) {
+      expect(isItemSlotId(slot), `${slot} should be valid`).toBe(true);
+    }
+  });
+
+  it("returns false for invalid values", () => {
+    expect(isItemSlotId("Helm")).toBe(false);
+    expect(isItemSlotId("HELM")).toBe(false);
+    expect(isItemSlotId("weapon6")).toBe(false);
+    expect(isItemSlotId("")).toBe(false);
+    expect(isItemSlotId(null)).toBe(false);
+  });
+});
+
+describe("isItemRarity", () => {
+  it("returns true for all valid rarities", () => {
+    const valid = ["common", "magic", "rare", "legendary", "unique", "mythic"];
+    for (const r of valid) {
+      expect(isItemRarity(r), `${r} should be valid`).toBe(true);
+    }
+  });
+
+  it("returns false for invalid values", () => {
+    expect(isItemRarity("epic")).toBe(false);
+    expect(isItemRarity("Legendary")).toBe(false);
+    expect(isItemRarity("")).toBe(false);
+    expect(isItemRarity(null)).toBe(false);
+  });
+});
+
+describe("isDamageType", () => {
+  it("returns true for all valid damage types", () => {
+    const valid = ["physical", "fire", "cold", "lightning", "poison", "shadow"];
+    for (const dt of valid) {
+      expect(isDamageType(dt), `${dt} should be valid`).toBe(true);
+    }
+  });
+
+  it("returns false for invalid values", () => {
+    expect(isDamageType("arcane")).toBe(false);
+    expect(isDamageType("Fire")).toBe(false);
+    expect(isDamageType("")).toBe(false);
+  });
+});
+
+describe("constant arrays", () => {
+  it("D4_CLASSES has 8 entries", () => {
+    expect(D4_CLASSES).toHaveLength(8);
+  });
+
+  it("ITEM_SLOT_IDS has 13 entries", () => {
+    expect(ITEM_SLOT_IDS).toHaveLength(13);
+  });
+
+  it("ITEM_RARITIES has 6 entries", () => {
+    expect(ITEM_RARITIES).toHaveLength(6);
+  });
+
+  it("DAMAGE_TYPES has 6 entries", () => {
+    expect(DAMAGE_TYPES).toHaveLength(6);
+  });
+});
