+/**
+ * Validation function tests for lib/validation.
+ */
+
+import { describe, it, expect } from "vitest";
+import {
+  validateCharacterName,
+  validateClass,
+  validateCharacterLevel,
+  validateParagonLevel,
+  validateItemPower,
+  validateItemRarity,
+  validateItemSlot,
+  validateAffixValue,
+  validateSkillRank,
+  validateBuildName,
+  validateMasterworkRank,
+  validateCharacter,
+  validateBuild,
+  isValid,
+} from "@/lib/validation";
+
+// ── Field validators ───────────────────────────────────────────────
+
+describe("validateCharacterName", () => {
+  it("accepts valid names", () => {
+    expect(validateCharacterName("My Sorcerer")).toBeUndefined();
+    expect(validateCharacterName("X")).toBeUndefined();
+    expect(validateCharacterName("A".repeat(60))).toBeUndefined();
+  });
+
+  it("rejects empty names", () => {
+    expect(validateCharacterName("")).toBeDefined();
+    expect(validateCharacterName("   ")).toBeDefined();
+  });
+
+  it("rejects names over 60 chars", () => {
+    expect(validateCharacterName("A".repeat(61))).toBeDefined();
+  });
+});
+
+describe("validateClass", () => {
+  it("accepts all valid D4 classes", () => {
+    const valid = ["Barbarian", "Druid", "Necromancer", "Rogue", "Sorcerer", "Spiritborn", "Paladin", "Warlock"];
+    for (const cls of valid) {
+      expect(validateClass(cls)).toBeUndefined();
+    }
+  });
+
+  it("rejects invalid classes", () => {
+    expect(validateClass("Wizard")).toBeDefined();
+    expect(validateClass("")).toBeDefined();
+    expect(validateClass("sorcerer")).toBeDefined(); // case-sensitive
+  });
+});
+
+describe("validateCharacterLevel", () => {
+  it("accepts 1 through 100", () => {
+    expect(validateCharacterLevel(1)).toBeUndefined();
+    expect(validateCharacterLevel(50)).toBeUndefined();
+    expect(validateCharacterLevel(100)).toBeUndefined();
+  });
+
+  it("rejects 0 and negatives", () => {
+    expect(validateCharacterLevel(0)).toBeDefined();
+    expect(validateCharacterLevel(-1)).toBeDefined();
+  });
+
+  it("rejects over 100", () => {
+    expect(validateCharacterLevel(101)).toBeDefined();
+  });
+
+  it("rejects non-integers", () => {
+    expect(validateCharacterLevel(50.5)).toBeDefined();
+  });
+});
+
+describe("validateParagonLevel", () => {
+  it("accepts 0 through 300", () => {
+    expect(validateParagonLevel(0)).toBeUndefined();
+    expect(validateParagonLevel(150)).toBeUndefined();
+    expect(validateParagonLevel(300)).toBeUndefined();
+  });
+
+  it("rejects negatives and over 300", () => {
+    expect(validateParagonLevel(-1)).toBeDefined();
+    expect(validateParagonLevel(301)).toBeDefined();
+  });
+
+  it("rejects non-integers", () => {
+    expect(validateParagonLevel(100.5)).toBeDefined();
+  });
+});
+
+describe("validateItemPower", () => {
+  it("accepts 100 through 925", () => {
+    expect(validateItemPower(100)).toBeUndefined();
+    expect(validateItemPower(800)).toBeUndefined();
+    expect(validateItemPower(925)).toBeUndefined();
+  });
+
+  it("rejects out-of-range values", () => {
+    expect(validateItemPower(99)).toBeDefined();
+    expect(validateItemPower(926)).toBeDefined();
+  });
+});
+
+describe("validateItemRarity", () => {
+  it("accepts valid rarities", () => {
+    const valid = ["common", "magic", "rare", "legendary", "unique", "mythic"];
+    for (const r of valid) {
+      expect(validateItemRarity(r)).toBeUndefined();
+    }
+  });
+
+  it("rejects invalid rarities", () => {
+    expect(validateItemRarity("epic")).toBeDefined();
+    expect(validateItemRarity("Legendary")).toBeDefined();
+  });
+});
+
+describe("validateItemSlot", () => {
+  it("accepts valid slot IDs", () => {
+    expect(validateItemSlot("helm")).toBeUndefined();
+    expect(validateItemSlot("mainHand")).toBeUndefined();
+  });
+
+  it("rejects invalid slot IDs", () => {
+    expect(validateItemSlot("Helm")).toBeDefined();
+    expect(validateItemSlot("weapon99")).toBeDefined();
+  });
+});
+
+describe("validateAffixValue", () => {
+  it("accepts value within range", () => {
+    // "max-life" has minValue: 200, maxValue: 1640
+    expect(validateAffixValue("max-life", 200)).toBeUndefined();
+    expect(validateAffixValue("max-life", 1000)).toBeUndefined();
+    expect(validateAffixValue("max-life", 1640)).toBeUndefined();
+  });
+
+  it("rejects value below min", () => {
+    expect(validateAffixValue("max-life", 199)).toBeDefined();
+  });
+
+  it("rejects value above max", () => {
+    expect(validateAffixValue("max-life", 1641)).toBeDefined();
+  });
+
+  it("rejects unknown affix ID", () => {
+    expect(validateAffixValue("nonexistent-affix", 100)).toBeDefined();
+  });
+
+  it("rejects NaN", () => {
+    expect(validateAffixValue("max-life", NaN)).toBeDefined();
+  });
+});
+
+describe("validateSkillRank", () => {
+  it("accepts valid ranks for a skill", () => {
+    // sorc-fireball has maxRank: 5
+    expect(validateSkillRank("sorc-fireball", 0)).toBeUndefined();
+    expect(validateSkillRank("sorc-fireball", 3)).toBeUndefined();
+    expect(validateSkillRank("sorc-fireball", 5)).toBeUndefined();
+  });
+
+  it("rejects rank above maxRank", () => {
+    expect(validateSkillRank("sorc-fireball", 6)).toBeDefined();
+  });
+
+  it("rejects negative rank", () => {
+    expect(validateSkillRank("sorc-fireball", -1)).toBeDefined();
+  });
+
+  it("rejects non-integer rank", () => {
+    expect(validateSkillRank("sorc-fireball", 2.5)).toBeDefined();
+  });
+
+  it("rejects unknown skill ID", () => {
+    expect(validateSkillRank("unknown-skill-id", 1)).toBeDefined();
+  });
+});
+
+describe("validateMasterworkRank", () => {
+  it("accepts 0 through 12", () => {
+    expect(validateMasterworkRank(0)).toBeUndefined();
+    expect(validateMasterworkRank(6)).toBeUndefined();
+    expect(validateMasterworkRank(12)).toBeUndefined();
+  });
+
+  it("rejects out-of-range values", () => {
+    expect(validateMasterworkRank(-1)).toBeDefined();
+    expect(validateMasterworkRank(13)).toBeDefined();
+  });
+});
+
+// ── Object-level validators ────────────────────────────────────────
+
+describe("validateCharacter", () => {
+  it("returns empty errors for a valid character", () => {
+    const errors = validateCharacter({
+      name: "My Sorcerer",
+      class: "Sorcerer",
+      level: 100,
+    });
+    expect(isValid(errors)).toBe(true);
+    expect(errors).toEqual({});
+  });
+
+  it("returns errors for invalid fields", () => {
+    const errors = validateCharacter({
+      name: "",
+      class: "Wizard" as never, // intentionally invalid for test
+      level: 200,
+    });
+    expect(errors.name).toBeDefined();
+    expect(errors.class).toBeDefined();
+    expect(errors.level).toBeDefined();
+    expect(isValid(errors)).toBe(false);
+  });
+
+  it("requires level field", () => {
+    const errors = validateCharacter({ name: "Test", class: "Druid" });
+    expect(errors.level).toBeDefined();
+  });
+});
+
+describe("validateBuild", () => {
+  it("returns empty errors for a valid build", () => {
+    const errors = validateBuild({
+      name: "My Build",
+      paragonLevel: 150,
+      skills: [{ skillId: "sorc-fireball", rank: 3 }],
+      equippedItems: {},
+    });
+    expect(isValid(errors)).toBe(true);
+  });
+
+  it("returns error for invalid build name", () => {
+    const errors = validateBuild({ name: "", paragonLevel: 0 });
+    expect(errors.name).toBeDefined();
+  });
+
+  it("returns error for invalid paragon level", () => {
+    const errors = validateBuild({ name: "Build", paragonLevel: 999 });
+    expect(errors.paragonLevel).toBeDefined();
+  });
+
+  it("returns error for invalid affix value in equipped item", () => {
+    const errors = validateBuild({
+      name: "Build",
+      paragonLevel: 0,
+      equippedItems: {
+        helm: {
+          id: "test",
+          slot: "helm",
+          name: "Test Helm",
+          rarity: "legendary",
+          affixes: [{ affixId: "max-life", rolledValue: 99999 }], // too high
+        },
+      },
+    });
+    expect(Object.keys(errors).some((k) => k.includes("affixes"))).toBe(true);
+  });
+
+  it("returns error for invalid skill rank", () => {
+    const errors = validateBuild({
+      name: "Build",
+      paragonLevel: 0,
+      skills: [{ skillId: "sorc-fireball", rank: 99 }], // too high
+    });
+    expect(Object.keys(errors).some((k) => k.includes("skills"))).toBe(true);
+  });
+});
+
+describe("isValid", () => {
+  it("returns true for empty errors object", () => {
+    expect(isValid({})).toBe(true);
+  });
+
+  it("returns false when there are errors", () => {
+    expect(isValid({ name: "Required" })).toBe(false);
+  });
+});
