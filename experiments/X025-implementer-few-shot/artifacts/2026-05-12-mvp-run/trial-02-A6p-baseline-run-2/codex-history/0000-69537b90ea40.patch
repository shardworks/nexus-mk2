+      cursor: pointer; color: var(--blue, #7aa2f7);
+      text-decoration: underline; background: none; border: none;
+      padding: 0; font-family: inherit; font-size: inherit;
+    }
+    .link-id:hover { opacity: 0.8; }
+    .link-meta { opacity: 0.5; font-size: 0.75rem; font-style: italic; }
