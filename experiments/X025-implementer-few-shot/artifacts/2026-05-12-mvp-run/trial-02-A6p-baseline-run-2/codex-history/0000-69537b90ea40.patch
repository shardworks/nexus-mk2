+    .error-msg { color: var(--red, #f7768e); font-size: 0.875rem; margin-top: 0.25rem; }
+    .warn-msg  { color: var(--yellow, #e0af68); font-size: 0.875rem; margin-top: 0.25rem; }
+
+    /* ── Split layout ────────────────────────────────────────────────── */
+    #main-split { display: flex; gap: 16px; align-items: flex-start; }
+    #tree-area  { flex: 1.6; min-width: 0; }
+    #detail-pane { flex: 1; min-width: 280px; display: none; }
+
+    /* ── Tree nodes ──────────────────────────────────────────────────── */
