+/**
+ * Unit tests for detail-pane rendering and link navigation in pages/clicks/index.html.
+ *
+ * Re-declares the extracted pure functions (they are IIFE-scoped in the page)
+ * and tests:
+ *   - renderDetailContent  — all fields, children, links sections (D24)
+ *   - renderLinkRow        — prefix-dispatch navigation (D15)
+ *   - statusBadge          — D20 class mapping (shared helper)
+ *
+ * Uses node:test + assert/strict.  No browser / JSDOM required.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Extracted pure helpers (mirrors pages/clicks/index.html) ─────────
+
+function escHtml(s) {
+  return String(s)
+    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+}
+
+function escAttr(s) {
+  return String(s)
+    .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
+    .replace(/</g, '&lt;').replace(/>/g, '&gt;');
+}
+
+function statusBadge(status) {
+  const map = {
+    live:      'badge badge--active',
+    parked:    'badge badge--warning',
+    concluded: 'badge badge--success',
+    dropped:   'badge badge--error',
+  };
+  return `<span class="${map[status] ?? 'badge'}">${escHtml(status)}</span>`;
+}
+
+function fmtDate(iso) {
+  if (!iso) return '';
+  return new Date(iso).toLocaleString();
+}
+
+/**
+ * Render one link row with prefix-dispatch navigation (D15).
+ * c-* → in-page click detail (button with data-click-id)
+ * w-* → writs page link (<a href="/pages/writs/?writ=…">)
+ * other → plain text span
+ */
+function renderLinkRow(link, dir, clickId) {
+  const peerId = dir === '→' ? link.targetId : link.sourceId;
+  let peerHtml;
+  if (peerId.startsWith('c-')) {
+    peerHtml = `<button class="link-id" data-click-id="${escAttr(peerId)}" data-meta-id="${escAttr(peerId)}">${escHtml(peerId)}</button>`;
+  } else if (peerId.startsWith('w-')) {
+    peerHtml = `<a class="link-id" href="/pages/writs/?writ=${encodeURIComponent(peerId)}" data-meta-id="${escAttr(peerId)}">${escHtml(peerId)}</a>`;
+  } else {
+    peerHtml = `<span data-meta-id="${escAttr(peerId)}">${escHtml(peerId)}</span>`;
+  }
+
+  return `<div class="link-row">` +
+    `<span class="link-dir">${dir}</span>` +
+    peerHtml +
+    `<span style="opacity:0.55;font-size:0.75rem">${escHtml(link.linkType)}</span>` +
+    `<span class="link-meta" data-meta-for="${escAttr(peerId)}"></span>` +
+    `<button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.72rem"` +
+      ` data-action="unlink"` +
+      ` data-source="${escAttr(link.sourceId)}" data-target="${escAttr(link.targetId)}"` +
+      ` data-link-type="${escAttr(link.linkType)}" data-click-id="${escAttr(clickId)}">×</button>` +
+  `</div>`;
+}
+
+function renderDetailContent(click) {
+  const id = click.id;
+  const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+  let html = '';
+
+  // Fields grid (D24)
+  html += `<div class="detail-section"><dl class="detail-grid">`;
+  html += `<dt>ID</dt><dd><code>${escHtml(id)}</code> `;
+  html += `<button class="copy-id-btn" data-copy-id="${escAttr(id)}">📋</button></dd>`;
+  html += `<dt>Goal</dt><dd>${escHtml(click.goal)}</dd>`;
+  html += `<dt>Status</dt><dd>${statusBadge(click.status)}</dd>`;
+
+  if (click.parent) {
+    html += `<dt>Parent</dt><dd>`;
+    html += `<button class="link-id" data-click-id="${escAttr(click.parent.id)}">${escHtml(click.parent.id)}</button>`;
+    html += ` ${statusBadge(click.parent.status)} <span>${escHtml(click.parent.goal ?? '')}</span>`;
+    html += `</dd>`;
+  }
+
+  html += `<dt>Created</dt><dd>${escHtml(fmtDate(click.createdAt))}</dd>`;
+  if (click.resolvedAt) html += `<dt>Resolved</dt><dd>${escHtml(fmtDate(click.resolvedAt))}</dd>`;
+  if (click.createdSessionId) html += `<dt>Created by</dt><dd><code>${escHtml(click.createdSessionId)}</code></dd>`;
+  if (click.resolvedSessionId) html += `<dt>Resolved by</dt><dd><code>${escHtml(click.resolvedSessionId)}</code></dd>`;
+  html += `</dl></div>`;
+
+  // Conclusion (expandable if terminal) — D24/D10
+  if (isTerminal && click.conclusion) {
+    html += `<div class="detail-section">`;
+    html += `<details><summary>▸ Conclusion</summary>`;
+    html += `<div class="conclusion-text">${escHtml(click.conclusion)}</div>`;
+    html += `</details></div>`;
+  }
+
+  // Lifecycle actions (D11)
+  if (!isTerminal) {
+    html += `<div class="detail-section">`;
+    html += `<h4>Actions</h4>`;
+    html += `<div class="action-buttons" id="action-btns-${escAttr(id)}">`;
+    if (click.status === 'live') {
+      html += `<button class="btn" data-action="park" data-id="${escAttr(id)}">Park</button>`;
+    }
+    if (click.status === 'parked') {
+      html += `<button class="btn btn--primary" data-action="resume" data-id="${escAttr(id)}">Resume</button>`;
+    }
+    html += `<button class="btn btn--success" data-action="conclude" data-id="${escAttr(id)}">Conclude…</button>`;
+    html += `<button class="btn btn--danger" data-action="drop" data-id="${escAttr(id)}">Drop…</button>`;
+    html += `</div>`;
+    html += `<div id="confirm-area-${escAttr(id)}"></div>`;
+    html += `<div class="error-msg" id="action-error-${escAttr(id)}" style="display:none"></div>`;
+    html += `</div>`;
+  }
+
+  // Children (D22)
+  const childItems = click.children?.items ?? [];
+  html += `<div class="detail-section">`;
+  html += `<h4>Children (${childItems.length})</h4>`;
+  if (click.children?.summary && Object.keys(click.children.summary).length > 0) {
+    html += `<div class="summary-badges">`;
+    for (const [st, cnt] of Object.entries(click.children.summary)) {
+      html += statusBadge(st) + `<span class="summary-count">${cnt}</span>`;
+    }
+    html += `</div>`;
+  }
+  if (childItems.length > 0) {
+    html += `<table class="data-table"><thead><tr><th>Status</th><th>Goal</th><th>ID</th></tr></thead><tbody>`;
+    for (const child of childItems) {
+      html += `<tr class="child-detail-row" data-child-id="${escAttr(child.id)}">`;
+      html += `<td>${statusBadge(child.status)}</td>`;
+      html += `<td>${escHtml(child.goal ?? '')}</td>`;
+      html += `<td><code>${escHtml(child.id)}</code></td>`;
+      html += `</tr>`;
+    }
+    html += `</tbody></table>`;
+  } else {
+    html += `<p style="font-size:0.825rem;opacity:0.5;margin:0.25rem 0">No children.</p>`;
+  }
+  html += `</div>`;
+
+  // Links (D14/D15/D16)
+  const outbound = click.links?.outbound ?? [];
+  const inbound  = click.links?.inbound  ?? [];
+  html += `<div class="detail-section" id="links-section-${escAttr(id)}">`;
+  html += `<h4>Links</h4>`;
+  if (outbound.length === 0 && inbound.length === 0) {
+    html += `<p style="font-size:0.825rem;opacity:0.5;margin:0.25rem 0">No links.</p>`;
+  }
+  for (const l of outbound) html += renderLinkRow(l, '→', id);
+  for (const l of inbound)  html += renderLinkRow(l, '←', id);
+
+  // Add-link form
+  html += `<div class="add-link-form" id="add-link-form-${escAttr(id)}">`;
+  html += `<input type="text" id="link-target-${escAttr(id)}" placeholder="Target ID">`;
+  html += `<select id="link-type-${escAttr(id)}">`;
+  html += `<option value="related">related</option>`;
+  html += `<option value="commissioned">commissioned</option>`;
+  html += `<option value="supersedes">supersedes</option>`;
+  html += `<option value="depends-on">depends-on</option>`;
+  html += `</select>`;
+  html += `<button class="btn" data-action="addlink" data-id="${escAttr(id)}">Link</button>`;
+  html += `<div class="error-msg" id="link-error-${escAttr(id)}" style="display:none"></div>`;
+  html += `</div>`;
+  html += `</div>`;
+
+  return html;
+}
+
+// ── Test fixtures ────────────────────────────────────────────────────
+
+function makeClick(overrides = {}) {
+  return {
+    id: 'c-abc123-def456',
+    goal: 'Test the thing',
+    status: 'live',
+    createdAt: '2025-01-01T10:00:00Z',
+    links: { outbound: [], inbound: [] },
+    children: { summary: {}, items: [] },
+    ...overrides,
+  };
+}
+
+function makeLink(sourceId, targetId, linkType = 'related') {
+  return { id: `${sourceId}:${targetId}:${linkType}`, sourceId, targetId, linkType, createdAt: '2025-01-01T00:00:00Z' };
+}
+
+// ── renderDetailContent — field rendering (D24) ──────────────────────
+
+describe('renderDetailContent — field rendering (D24)', () => {
+  it('renders the click ID as a code element', () => {
+    const html = renderDetailContent(makeClick({ id: 'c-abc123-xyz789' }));
+    assert.ok(html.includes('<code>c-abc123-xyz789</code>'), 'ID should be in code tag');
+  });
+
+  it('renders the goal text', () => {
+    const html = renderDetailContent(makeClick({ goal: 'Build the feature' }));
+    assert.ok(html.includes('Build the feature'));
+  });
+
+  it('renders a status badge using D20 classes', () => {
+    const html = renderDetailContent(makeClick({ status: 'live' }));
+    assert.ok(html.includes('badge--active'), 'live → badge--active');
+  });
+
+  it('renders createdAt field', () => {
+    const html = renderDetailContent(makeClick({ createdAt: '2025-06-01T12:00:00Z' }));
+    assert.ok(html.includes('<dt>Created</dt>'), 'Created field should be present');
+  });
+
+  it('renders resolvedAt field when present', () => {
+    const html = renderDetailContent(makeClick({
+      status: 'concluded',
+      conclusion: 'Done',
+      resolvedAt: '2025-06-02T12:00:00Z',
+    }));
+    assert.ok(html.includes('<dt>Resolved</dt>'), 'Resolved field should be present');
+  });
+
+  it('omits resolvedAt field when absent', () => {
+    const html = renderDetailContent(makeClick({ resolvedAt: undefined }));
+    assert.ok(!html.includes('<dt>Resolved</dt>'), 'Resolved should not appear if absent');
+  });
+
+  it('renders createdSessionId field when present', () => {
+    const html = renderDetailContent(makeClick({ createdSessionId: 'sess-123' }));
+    assert.ok(html.includes('<dt>Created by</dt>'), 'Created by should appear');
+    assert.ok(html.includes('sess-123'));
+  });
+
+  it('omits createdSessionId when absent', () => {
+    const html = renderDetailContent(makeClick({ createdSessionId: undefined }));
+    assert.ok(!html.includes('<dt>Created by</dt>'));
+  });
+
+  it('renders resolvedSessionId when present', () => {
+    const html = renderDetailContent(makeClick({
+      status: 'concluded', conclusion: 'Done',
+      resolvedSessionId: 'sess-resolve-99',
+    }));
+    assert.ok(html.includes('<dt>Resolved by</dt>'));
+    assert.ok(html.includes('sess-resolve-99'));
+  });
+
+  it('renders parent link with click ID when parent exists', () => {
+    const html = renderDetailContent(makeClick({
+      parent: { id: 'c-parent-001', goal: 'Parent goal', status: 'live' },
+    }));
+    assert.ok(html.includes('<dt>Parent</dt>'), 'Parent field should appear');
+    assert.ok(html.includes('data-click-id="c-parent-001"'), 'Parent link should be in-page');
+    assert.ok(html.includes('Parent goal'), 'Parent goal should appear');
+  });
+
+  it('omits parent section when parent is null', () => {
+    const html = renderDetailContent(makeClick({ parent: null }));
+    assert.ok(!html.includes('<dt>Parent</dt>'));
+  });
+
+  it('renders expandable conclusion for concluded click (D10)', () => {
+    const html = renderDetailContent(makeClick({
+      status: 'concluded',
+      conclusion: 'Finished — all done.',
+      resolvedAt: '2025-06-10T00:00:00Z',
+    }));
+    assert.ok(html.includes('<details>'), 'conclusion should be in <details>');
+    assert.ok(html.includes('▸ Conclusion'), 'disclosure summary should say Conclusion');
+    assert.ok(html.includes('Finished — all done.'), 'conclusion text should appear');
+  });
+
+  it('renders expandable conclusion for dropped click (D10)', () => {
+    const html = renderDetailContent(makeClick({
+      status: 'dropped',
+      conclusion: 'Not worth it.',
+      resolvedAt: '2025-06-10T00:00:00Z',
+    }));
+    assert.ok(html.includes('<details>'));
+    assert.ok(html.includes('Not worth it.'));
+  });
+
+  it('does not render conclusion section when status is live', () => {
+    const html = renderDetailContent(makeClick({ status: 'live' }));
+    assert.ok(!html.includes('<details>'), 'no details for live click');
+  });
+
+  it('does not render conclusion section when conclusion is absent', () => {
+    const html = renderDetailContent(makeClick({
+      status: 'concluded',
+      resolvedAt: '2025-06-10T00:00:00Z',
+    }));
+    assert.ok(!html.includes('<details>'), 'no details when conclusion is absent');
+  });
+
+  it('escapes HTML in goal', () => {
+    const html = renderDetailContent(makeClick({ goal: '<img src=x onerror=alert(1)>' }));
+    assert.ok(!html.includes('<img'), 'img tag must be escaped in goal');
+    assert.ok(html.includes('&lt;img'), 'escaped form should appear');
+  });
+});
+
+// ── renderDetailContent — lifecycle actions (D11) ────────────────────
+
+describe('renderDetailContent — lifecycle actions (D11)', () => {
+  it('shows Park button for live click', () => {
+    const html = renderDetailContent(makeClick({ status: 'live' }));
+    assert.ok(html.includes('data-action="park"'), 'Park button for live click');
+  });
+
+  it('does not show Resume button for live click', () => {
+    const html = renderDetailContent(makeClick({ status: 'live' }));
+    assert.ok(!html.includes('data-action="resume"'), 'no Resume for live');
+  });
+
+  it('shows Resume button for parked click', () => {
+    const html = renderDetailContent(makeClick({ status: 'parked' }));
+    assert.ok(html.includes('data-action="resume"'), 'Resume button for parked');
+  });
+
+  it('does not show Park button for parked click', () => {
+    const html = renderDetailContent(makeClick({ status: 'parked' }));
+    assert.ok(!html.includes('data-action="park"'), 'no Park for already-parked');
+  });
+
+  it('shows Conclude and Drop for live click', () => {
+    const html = renderDetailContent(makeClick({ status: 'live' }));
+    assert.ok(html.includes('data-action="conclude"'), 'Conclude present for live');
+    assert.ok(html.includes('data-action="drop"'), 'Drop present for live');
+  });
+
+  it('shows Conclude and Drop for parked click', () => {
+    const html = renderDetailContent(makeClick({ status: 'parked' }));
+    assert.ok(html.includes('data-action="conclude"'), 'Conclude present for parked');
+    assert.ok(html.includes('data-action="drop"'), 'Drop present for parked');
+  });
+
+  it('hides all lifecycle action buttons for concluded click', () => {
+    const html = renderDetailContent(makeClick({
+      status: 'concluded', conclusion: 'Done',
+      resolvedAt: '2025-06-01T00:00:00Z',
+    }));
+    assert.ok(!html.includes('data-action="park"'), 'no Park for concluded');
+    assert.ok(!html.includes('data-action="resume"'), 'no Resume for concluded');
+    assert.ok(!html.includes('data-action="conclude"'), 'no Conclude for concluded');
+    assert.ok(!html.includes('data-action="drop"'), 'no Drop for concluded');
+  });
+
+  it('hides all lifecycle action buttons for dropped click', () => {
+    const html = renderDetailContent(makeClick({
+      status: 'dropped', conclusion: 'Abandoned',
+      resolvedAt: '2025-06-01T00:00:00Z',
+    }));
+    assert.ok(!html.includes('data-action="park"'));
+    assert.ok(!html.includes('data-action="resume"'));
+    assert.ok(!html.includes('data-action="conclude"'));
+    assert.ok(!html.includes('data-action="drop"'));
+  });
+});
+
+// ── renderDetailContent — children section (D22) ─────────────────────
+
+describe('renderDetailContent — children section (D22)', () => {
+  it('renders children count in heading', () => {
+    const html = renderDetailContent(makeClick({
+      children: {
+        summary: { live: 2 },
+        items: [
+          { id: 'c-child-1', goal: 'Child A', status: 'live' },
+          { id: 'c-child-2', goal: 'Child B', status: 'live' },
+        ],
+      },
+    }));
+    assert.ok(html.includes('Children (2)'));
+  });
+
+  it('renders status-count badge strip (D22)', () => {
+    const html = renderDetailContent(makeClick({
+      children: {
+        summary: { live: 1, parked: 2 },
+        items: [
+          { id: 'c-c1', goal: 'A', status: 'live' },
+          { id: 'c-c2', goal: 'B', status: 'parked' },
+          { id: 'c-c3', goal: 'C', status: 'parked' },
+        ],
+      },
+    }));
+    assert.ok(html.includes('badge--active'), 'live badge in summary');
+    assert.ok(html.includes('badge--warning'), 'parked badge in summary');
+    assert.ok(html.includes('summary-badges'), 'summary-badges container');
+  });
+
+  it('renders children in a table with clickable rows (D22)', () => {
+    const html = renderDetailContent(makeClick({
+      children: {
+        summary: { live: 1 },
+        items: [{ id: 'c-child-99', goal: 'Do something', status: 'live' }],
+      },
+    }));
+    assert.ok(html.includes('child-detail-row'), 'clickable child row');
+    assert.ok(html.includes('data-child-id="c-child-99"'), 'child data-child-id attr');
+    assert.ok(html.includes('Do something'), 'child goal in table');
+  });
+
+  it('shows "No children" when children array is empty', () => {
+    const html = renderDetailContent(makeClick({
+      children: { summary: {}, items: [] },
+    }));
+    assert.ok(html.includes('No children'), 'no children message');
+    assert.ok(!html.includes('child-detail-row'), 'no child rows');
+  });
+
+  it('omits summary badge strip when summary is empty', () => {
+    const html = renderDetailContent(makeClick({
+      children: {
+        summary: {},
+        items: [{ id: 'c-c1', goal: 'Child', status: 'live' }],
+      },
+    }));
+    assert.ok(!html.includes('summary-badges'), 'no badge strip for empty summary');
+  });
+});
+
+// ── renderDetailContent — links section (D14/D15) ────────────────────
+
+describe('renderDetailContent — links section', () => {
+  it('shows "No links" when links are empty', () => {
+    const html = renderDetailContent(makeClick({
+      links: { outbound: [], inbound: [] },
+    }));
+    assert.ok(html.includes('No links'), 'no-links message');
+  });
+
+  it('renders link-type select with four required values (D14)', () => {
+    const html = renderDetailContent(makeClick());
+    assert.ok(html.includes('value="related"'), 'related option');
+    assert.ok(html.includes('value="commissioned"'), 'commissioned option');
+    assert.ok(html.includes('value="supersedes"'), 'supersedes option');
+    assert.ok(html.includes('value="depends-on"'), 'depends-on option');
+  });
+
+  it('renders outbound link with → direction indicator', () => {
+    const click = makeClick({ id: 'c-src' });
+    click.links.outbound = [makeLink('c-src', 'c-target-1', 'related')];
+    const html = renderDetailContent(click);
+    assert.ok(html.includes('→'), 'outbound direction arrow');
+    assert.ok(html.includes('c-target-1'));
+  });
+
+  it('renders inbound link with ← direction indicator', () => {
+    const click = makeClick({ id: 'c-target' });
+    click.links.inbound = [makeLink('c-other', 'c-target', 'commissioned')];
+    const html = renderDetailContent(click);
+    assert.ok(html.includes('←'), 'inbound direction arrow');
+    assert.ok(html.includes('c-other'));
+  });
+
+  it('renders the link type label alongside target', () => {
+    const click = makeClick({ id: 'c-src' });
+    click.links.outbound = [makeLink('c-src', 'c-tgt', 'supersedes')];
+    const html = renderDetailContent(click);
+    assert.ok(html.includes('supersedes'), 'link type label');
+  });
+
+  it('renders remove button for each link', () => {
+    const click = makeClick({ id: 'c-src' });
+    click.links.outbound = [makeLink('c-src', 'c-tgt', 'related')];
+    const html = renderDetailContent(click);
+    assert.ok(html.includes('data-action="unlink"'), 'remove/unlink button');
+  });
+});
+
+// ── renderLinkRow — prefix-dispatch navigation (D15) ─────────────────
+
+describe('renderLinkRow — cross-substrate link navigation (D15)', () => {
+  it('c-* target → in-page button with data-click-id', () => {
+    const link = makeLink('c-src', 'c-other-click', 'related');
+    const html = renderLinkRow(link, '→', 'c-src');
+    assert.ok(html.includes('data-click-id="c-other-click"'), 'c- target has data-click-id');
+    assert.ok(!html.includes('href'), 'c- target must not use href navigation');
+    assert.ok(html.includes('class="link-id"'), 'should have link-id class');
+  });
+
+  it('w-* target → <a> pointing to /pages/writs/?writ=<id>', () => {
+    const link = makeLink('c-src', 'w-writ-42', 'commissioned');
+    const html = renderLinkRow(link, '→', 'c-src');
+    assert.ok(html.includes('href="/pages/writs/?writ=w-writ-42"'), 'w- target uses writs page URL');
+    assert.ok(!html.includes('data-click-id="w-writ-42"'), 'w- target ID should not be used as data-click-id');
+  });
+
+  it('w-* target URL-encodes the writ ID', () => {
+    const link = makeLink('c-src', 'w-some+id', 'related');
+    const html = renderLinkRow(link, '→', 'c-src');
+    // encodeURIComponent('w-some+id') = 'w-some%2Bid'
+    assert.ok(html.includes('w-some%2Bid') || html.includes('w-some+id'),
+      'writ ID should appear in href');
+  });
+
+  it('other target → plain text span (not clickable)', () => {
+    const link = makeLink('c-src', 'gh-1234', 'related');
+    const html = renderLinkRow(link, '→', 'c-src');
+    assert.ok(!html.includes('data-click-id="gh-1234"'), 'other target ID should not be in data-click-id');
+    assert.ok(!html.includes('href'), 'other target has no href');
+    // The peer ID should still render
+    assert.ok(html.includes('gh-1234'), 'peer ID should appear as text');
+  });
+
+  it('inbound link uses sourceId as the peer for ← direction', () => {
+    const link = makeLink('c-inbound-src', 'c-current', 'depends-on');
+    const html = renderLinkRow(link, '←', 'c-current');
+    assert.ok(html.includes('data-click-id="c-inbound-src"'), 'inbound peer is sourceId');
+    // The unlink button carries data-click-id="c-current" (owner ID for post-unlink refresh);
+    // the navigable peer element must point to c-inbound-src, which the assertion above confirms.
+  });
+
+  it('link-meta span is present for lazy metadata loading (D16)', () => {
+    const link = makeLink('c-src', 'c-target', 'related');
+    const html = renderLinkRow(link, '→', 'c-src');
+    assert.ok(html.includes('link-meta'), 'link-meta span for lazy loading');
+    assert.ok(html.includes('data-meta-for="c-target"'), 'data-meta-for attribute');
+  });
+});
diff --git a/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
new file mode 100644
index 0000000..be28531
--- /dev/null
+++ b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
@@ -0,0 +1,459 @@
+/**
+ * Unit tests for the click-tree page pure logic in pages/clicks/index.html.
+ *
+ * Re-declares the extracted pure functions (they are IIFE-scoped in the page)
+ * and tests:
+ *   - pruneForest        — status-filter prune semantics (D6)
+ *   - scopedForest       — subtree scoping (D23)
+ *   - findAncestorPath   — breadcrumb ancestor-chain derivation (D23)
+ *   - statusBadge        — CSS badge class mapping (D20)
+ *   - renderNodeHtml     — tree-node HTML output (D9/D10)
+ *
+ * Uses node:test + assert/strict.  No browser / JSDOM required.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Minimal DOM shim (same pattern as writs companion tests) ─────────
+
+class FakeElement {
+  constructor(tag) {
+    this.tagName = (tag ?? 'div').toUpperCase();
+    this.className = '';
+    this.textContent = '';
+    this.innerHTML = '';
+    this.dataset = {};
+    this.children = [];
+    this._listeners = {};
+    this.style = {};
+  }
+  appendChild(child) { this.children.push(child); return child; }
+  querySelectorAll() { return []; }
+  addEventListener(ev, fn) {
+    if (!this._listeners[ev]) this._listeners[ev] = [];
+    this._listeners[ev].push(fn);
+  }
+  get classList() {
+    const self = this;
+    return {
+      toggle(cls, force) {
+        const classes = self.className.split(/\s+/).filter(Boolean);
+        const idx = classes.indexOf(cls);
+        if (force === true  && idx === -1) classes.push(cls);
+        if (force === false && idx !== -1) classes.splice(idx, 1);
+        if (force === undefined) {
+          if (idx === -1) classes.push(cls); else classes.splice(idx, 1);
+        }
+        self.className = classes.join(' ');
+      },
+      add(cls) {
+        if (!self.className.split(/\s+/).includes(cls)) {
+          self.className = (self.className + ' ' + cls).trim();
+        }
+      },
+      contains(cls) { return self.className.split(/\s+/).includes(cls); },
+    };
+  }
+}
+
+// ── Extracted pure functions (mirrors pages/clicks/index.html) ────────
+
+const ALL_STATUSES = ['live', 'parked', 'concluded', 'dropped'];
+
+function escHtml(s) {
+  return String(s)
+    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+}
+
+function escAttr(s) {
+  return String(s)
+    .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
+    .replace(/</g, '&lt;').replace(/>/g, '&gt;');
+}
+
+function statusBadge(status) {
+  const map = {
+    live:      'badge badge--active',
+    parked:    'badge badge--warning',
+    concluded: 'badge badge--success',
+    dropped:   'badge badge--error',
+  };
+  return `<span class="${map[status] ?? 'badge'}">${escHtml(status)}</span>`;
+}
+
+function shortId(id) {
+  const parts = String(id).split('-');
+  return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+}
+
+/**
+ * Prune forest to only include nodes matching statusSet (D6).
+ * Non-matching node AND its entire subtree are removed.
+ */
+function pruneForest(trees, statusSet) {
+  if (!statusSet || statusSet.size === ALL_STATUSES.length) return trees;
+  const result = [];
+  for (const tree of trees) {
+    if (!statusSet.has(tree.click.status)) continue;
+    const prunedChildren = pruneForest(tree.children, statusSet);
+    result.push({ click: tree.click, children: prunedChildren });
+  }
+  return result;
+}
+
+/**
+ * Return the subtree rooted at rootId (D23).
+ */
+function scopedForest(trees, rootId) {
+  if (!rootId) return trees;
+  function find(nodes) {
+    for (const t of nodes) {
+      if (t.click.id === rootId) return [t];
+      const found = find(t.children);
+      if (found.length) return found;
+    }
+    return [];
+  }
+  return find(trees);
+}
+
+/**
+ * Walk the forest to find path from any root to targetId (D23 breadcrumb).
+ */
+function findAncestorPath(trees, targetId) {
+  function search(nodes, path) {
+    for (const t of nodes) {
+      const next = [...path, t.click];
+      if (t.click.id === targetId) return next;
+      const found = search(t.children, next);
+      if (found) return found;
+    }
+    return null;
+  }
+  return search(trees, []) ?? [];
+}
+
+function renderNodeHtml(tree, depth) {
+  const click = tree.click;
+  const id = click.id;
+  const isCollapsed = false; // default: all expanded (D8)
+  const hasChildren = tree.children.length > 0;
+  const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+
+  let html = `<div class="tree-node" data-id="${escAttr(id)}">`;
+  html += `<div class="node-row" data-id="${escAttr(id)}" style="padding-left:${depth * 0.15}rem">`;
+
+  if (hasChildren) {
+    html += `<button class="expand-btn" data-expand-id="${escAttr(id)}">▾</button>`;
+  } else {
+    html += `<span class="expand-btn" style="opacity:0;pointer-events:none">▾</span>`;
+  }
+
+  html += statusBadge(click.status);
+
+  html += `<span class="node-id-wrap">`;
+  html += `<code class="node-id">${escHtml(shortId(id))}</code>`;
+  html += `<button class="copy-id-btn" data-copy-id="${escAttr(id)}">📋</button>`;
+  html += `</span>`;
+
+  html += `<span class="node-goal" data-select-id="${escAttr(id)}">${escHtml(click.goal)}</span>`;
+  html += `<button class="focus-btn" data-focus-id="${escAttr(id)}">⌖</button>`;
+  html += `</div>`;
+
+  if (isTerminal && click.conclusion) {
+    html += `<details class="conclusion-wrap">`;
+    html += `<summary>▸ Conclusion</summary>`;
+    html += `<div class="conclusion-text">${escHtml(click.conclusion)}</div>`;
+    html += `</details>`;
+  }
+
+  if (hasChildren) {
+    html += `<div class="node-children">`;
+    for (const child of tree.children) {
+      html += renderNodeHtml(child, depth + 1);
+    }
+    html += `</div>`;
+  }
+
+  html += `</div>`;
+  return html;
+}
+
+// ── Test fixtures ────────────────────────────────────────────────────
+
+function click(id, goal, status, extras = {}) {
+  return { id, goal, status, createdAt: '2025-01-01T00:00:00Z', ...extras };
+}
+
+function tree(click, ...children) {
+  return { click, children };
+}
+
+// ── pruneForest (D6) ─────────────────────────────────────────────────
+
+describe('pruneForest — status filter with prune semantics', () => {
+  it('returns full forest when all statuses selected', () => {
+    const root = tree(click('c-1', 'Root', 'live'),
+      tree(click('c-2', 'Child', 'parked')));
+    const result = pruneForest([root], new Set(ALL_STATUSES));
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].children.length, 1);
+  });
+
+  it('prunes nodes that do not match the filter', () => {
+    const root = tree(
+      click('c-1', 'Root', 'live'),
+      tree(click('c-2', 'Parked child', 'parked')),
+      tree(click('c-3', 'Live child', 'live')),
+    );
+    const result = pruneForest([root], new Set(['live']));
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].children.length, 1);
+    assert.strictEqual(result[0].children[0].click.id, 'c-3');
+  });
+
+  it('prunes the entire subtree when parent does not match', () => {
+    const parkedParent = tree(
+      click('c-2', 'Parked parent', 'parked'),
+      tree(click('c-3', 'Live grandchild', 'live')), // should be pruned with parent
+    );
+    const root = tree(click('c-1', 'Root', 'live'), parkedParent);
+    const result = pruneForest([root], new Set(['live']));
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].children.length, 0, 'parked subtree and its live child both pruned');
+  });
+
+  it('prunes the root if it does not match', () => {
+    const root = tree(click('c-1', 'Root', 'parked'));
+    const result = pruneForest([root], new Set(['live']));
+    assert.strictEqual(result.length, 0);
+  });
+
+  it('supports multi-status filter', () => {
+    const f = [
+      tree(click('c-1', 'Live root', 'live')),
+      tree(click('c-2', 'Parked root', 'parked')),
+      tree(click('c-3', 'Concluded root', 'concluded')),
+    ];
+    const result = pruneForest(f, new Set(['live', 'parked']));
+    assert.strictEqual(result.length, 2);
+    assert.ok(result.every(t => ['live', 'parked'].includes(t.click.status)));
+  });
+
+  it('returns empty array when nothing matches', () => {
+    const f = [tree(click('c-1', 'Live', 'live'))];
+    const result = pruneForest(f, new Set(['dropped']));
+    assert.strictEqual(result.length, 0);
+  });
+
+  it('skips pruning when statusSet has all 4 statuses', () => {
+    // Optimisation path: returns trees reference unchanged
+    const f = [tree(click('c-1', 'Root', 'live'))];
+    const result = pruneForest(f, new Set(ALL_STATUSES));
+    assert.strictEqual(result, f);
+  });
+});
+
+// ── scopedForest (D23) ───────────────────────────────────────────────
+
+describe('scopedForest — subtree scoping', () => {
+  const deep = tree(
+    click('c-1', 'Root', 'live'),
+    tree(
+      click('c-2', 'Child A', 'live'),
+      tree(click('c-4', 'Grandchild A1', 'live')),
+    ),
+    tree(click('c-3', 'Child B', 'parked')),
+  );
+  const forest = [deep];
+
+  it('returns full forest when rootId is null', () => {
+    const result = scopedForest(forest, null);
+    assert.strictEqual(result, forest);
+  });
+
+  it('returns subtree rooted at a direct child', () => {
+    const result = scopedForest(forest, 'c-2');
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].click.id, 'c-2');
+    assert.strictEqual(result[0].children.length, 1);
+  });
+
+  it('returns subtree rooted at a grandchild', () => {
+    const result = scopedForest(forest, 'c-4');
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].click.id, 'c-4');
+  });
+
+  it('returns empty array when rootId not found', () => {
+    const result = scopedForest(forest, 'c-999');
+    assert.strictEqual(result.length, 0);
+  });
+
+  it('returns [root] when rootId is the root itself', () => {
+    const result = scopedForest(forest, 'c-1');
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].click.id, 'c-1');
+  });
+});
+
+// ── findAncestorPath (D23 breadcrumb) ────────────────────────────────
+
+describe('findAncestorPath — breadcrumb derivation', () => {
+  const grandchild = click('c-4', 'Grandchild', 'live');
+  const childA = click('c-2', 'Child A', 'live');
+  const root = click('c-1', 'Root', 'live');
+  const forest = [
+    tree(root, tree(childA, tree(grandchild))),
+    tree(click('c-3', 'Root B', 'live')),
+  ];
+
+  it('returns single-element path for a root node', () => {
+    const path = findAncestorPath(forest, 'c-1');
+    assert.strictEqual(path.length, 1);
+    assert.strictEqual(path[0].id, 'c-1');
+  });
+
+  it('returns two-element path for a direct child', () => {
+    const path = findAncestorPath(forest, 'c-2');
+    assert.strictEqual(path.length, 2);
+    assert.strictEqual(path[0].id, 'c-1');
+    assert.strictEqual(path[1].id, 'c-2');
+  });
+
+  it('returns three-element path for a grandchild', () => {
+    const path = findAncestorPath(forest, 'c-4');
+    assert.strictEqual(path.length, 3);
+    assert.deepStrictEqual(path.map(c => c.id), ['c-1', 'c-2', 'c-4']);
+  });
+
+  it('returns [] when target not found', () => {
+    const path = findAncestorPath(forest, 'c-999');
+    assert.deepStrictEqual(path, []);
+  });
+
+  it('finds roots from multiple forest trees', () => {
+    const path = findAncestorPath(forest, 'c-3');
+    assert.strictEqual(path.length, 1);
+    assert.strictEqual(path[0].id, 'c-3');
+  });
+});
+
+// ── statusBadge (D20) ────────────────────────────────────────────────
+
+describe('statusBadge — CSS class mapping (D20)', () => {
+  it('live → badge--active (animated cyan)', () => {
+    const html = statusBadge('live');
+    assert.ok(html.includes('badge badge--active'), `got: ${html}`);
+    assert.ok(html.includes('live'));
+  });
+
+  it('parked → badge--warning (yellow)', () => {
+    const html = statusBadge('parked');
+    assert.ok(html.includes('badge badge--warning'), `got: ${html}`);
+  });
+
+  it('concluded → badge--success (green)', () => {
+    const html = statusBadge('concluded');
+    assert.ok(html.includes('badge badge--success'), `got: ${html}`);
+  });
+
+  it('dropped → badge--error (red)', () => {
+    const html = statusBadge('dropped');
+    assert.ok(html.includes('badge badge--error'), `got: ${html}`);
+  });
+
+  it('unknown status → plain badge', () => {
+    const html = statusBadge('unknown');
+    assert.ok(html.includes('class="badge"'), `got: ${html}`);
+  });
+});
+
+// ── renderNodeHtml — tree-node HTML (D9/D10) ─────────────────────────
+
+describe('renderNodeHtml — tree node rendering', () => {
+  it('renders node goal in output', () => {
+    const node = tree(click('c-1', 'Ship the feature', 'live'));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(html.includes('Ship the feature'));
+  });
+
+  it('renders status badge (D9: CSS badge, not Unicode)', () => {
+    const node = tree(click('c-1', 'Live click', 'live'));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(html.includes('badge--active'), 'live status should use badge--active');
+    assert.ok(!html.includes('●'), 'must not use Unicode status glyphs (D9)');
+  });
+
+  it('renders short ID in node-id code element', () => {
+    const node = tree(click('c-mo1mq8ry-abc123', 'Test', 'live'));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(html.includes('c-mo1mq8ry'), 'short ID should appear');
+    assert.ok(html.includes('node-id'), 'should have node-id class');
+  });
+
+  it('renders expand button when node has children', () => {
+    const child = tree(click('c-2', 'Child', 'live'));
+    const node  = tree(click('c-1', 'Parent', 'live'), child);
+    const html  = renderNodeHtml(node, 0);
+    assert.ok(html.includes('data-expand-id'), 'expand button present when children exist');
+  });
+
+  it('does not render expand button for leaf nodes', () => {
+    const node = tree(click('c-1', 'Leaf', 'live'));
+    const html = renderNodeHtml(node, 0);
+    // No data-expand-id on leaf nodes
+    assert.ok(!html.includes('data-expand-id'), 'no expand button on leaf node');
+  });
+
+  it('renders focus button on every node (D5)', () => {
+    const node = tree(click('c-1', 'Root', 'live'));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(html.includes('data-focus-id'), 'focus button should exist');
+  });
+
+  it('renders copy-id button (D5)', () => {
+    const node = tree(click('c-1', 'Root', 'live'));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(html.includes('copy-id-btn'), 'copy-id button should exist');
+  });
+
+  it('renders conclusion as disclosure triangle for concluded click (D10)', () => {
+    const node = tree(click('c-1', 'Done', 'concluded', { conclusion: 'Finished successfully' }));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(html.includes('<details'), 'conclusion should use <details>');
+    assert.ok(html.includes('▸ Conclusion'), 'disclosure summary text');
+    assert.ok(html.includes('Finished successfully'), 'conclusion text should appear');
+  });
+
+  it('renders conclusion disclosure for dropped click (D10)', () => {
+    const node = tree(click('c-1', 'Abandoned', 'dropped', { conclusion: 'Not needed' }));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(html.includes('<details'), 'dropped conclusion should use <details>');
+    assert.ok(html.includes('Not needed'));
+  });
+
+  it('does not render conclusion details for live click', () => {
+    const node = tree(click('c-1', 'Active', 'live'));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(!html.includes('<details'), 'live node has no conclusion details');
+  });
+
+  it('renders children recursively', () => {
+    const grandchild = tree(click('c-3', 'Grandchild', 'live'));
+    const child = tree(click('c-2', 'Child', 'live'), grandchild);
+    const root  = tree(click('c-1', 'Root', 'live'), child);
+    const html  = renderNodeHtml(root, 0);
+    assert.ok(html.includes('Grandchild'), 'grandchild goal should appear');
+    assert.ok(html.includes('node-children'), 'node-children container should appear');
+  });
+
+  it('escapes HTML in goal text', () => {
+    const node = tree(click('c-1', '<script>alert(1)</script>', 'live'));
+    const html = renderNodeHtml(node, 0);
+    assert.ok(!html.includes('<script>'), 'script tags must be escaped');
+    assert.ok(html.includes('&lt;script&gt;'), 'escaped script tag should appear');
+  });
+});
diff --git a/packages/plugins/ratchet/pages/clicks/index.html b/packages/plugins/ratchet/pages/clicks/index.html
new file mode 100644
index 0000000..5fffc25
--- /dev/null
+++ b/packages/plugins/ratchet/pages/clicks/index.html
@@ -0,0 +1,1009 @@
+<!DOCTYPE html>
+<html lang="en">
