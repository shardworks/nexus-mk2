+    .breadcrumb-current { opacity: 0.7; }
+
+    /* ── Create form ─────────────────────────────────────────────────── */
+    #create-section { margin-bottom: 16px; display: none; }
+    #create-section.open { display: block; }
+    #create-section h3 { margin: 0 0 0.75rem; }
