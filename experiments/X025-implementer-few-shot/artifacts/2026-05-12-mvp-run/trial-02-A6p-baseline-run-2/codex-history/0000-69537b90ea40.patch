+      background: transparent; color: var(--text-dim, #565f89);
+      border: none; padding: 0 0.15rem; cursor: pointer;
+      font-size: 0.8rem; min-width: 1.1rem; text-align: center; flex-shrink: 0;
+    }
+    .expand-btn:hover { color: var(--text, #c0caf5); }
+    .node-goal {
+      flex: 1; min-width: 0; white-space: nowrap;
+      overflow: hidden; text-overflow: ellipsis; font-size: 0.875rem;
+    }
+    .node-id-wrap { display: flex; align-items: center; gap: 0.2rem; flex-shrink: 0; }
+    .node-id { font-size: 0.72rem; opacity: 0.65; }
+    .copy-id-btn {
+      padding: 0.05rem 0.25rem; font-size: 0.65rem; cursor: pointer;
+      background: transparent; border: 1px solid var(--border, #414868);
+      border-radius: 3px; color: inherit; line-height: 1.4;
+    }
+    .copy-id-btn:hover { border-color: var(--cyan, #7dcfff); }
+    .focus-btn {
+      background: transparent; border: 1px solid var(--border, #414868);
+      border-radius: 3px; color: var(--text-dim, #565f89);
+      padding: 0.05rem 0.35rem; font-size: 0.7rem; cursor: pointer; flex-shrink: 0;
+    }
+    .focus-btn:hover { color: var(--cyan, #7dcfff); border-color: var(--cyan, #7dcfff); }
+    .node-children {
+      margin-left: 1.1rem;
+      border-left: 1px solid var(--border, #3b4261);
+      padding-left: 0.3rem;
