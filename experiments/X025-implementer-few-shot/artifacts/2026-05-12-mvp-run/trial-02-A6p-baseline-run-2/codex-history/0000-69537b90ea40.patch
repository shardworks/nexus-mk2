+    }
+    .add-link-form input, .add-link-form select {
+      padding: 0.3rem 0.5rem; background: var(--surface2, #24283b);
+      border: 1px solid var(--border, #414868); border-radius: 4px;
+      color: inherit; font-size: 0.825rem; font-family: inherit;
+    }
+    .summary-badges {
+      display: flex; gap: 0.5rem; flex-wrap: wrap;
+      align-items: center; margin-bottom: 0.5rem;
+    }
+    .summary-count { font-size: 0.8rem; opacity: 0.8; }
+    tr.child-detail-row { cursor: pointer; }
+    tr.child-detail-row:hover { opacity: 0.85; }
+  </style>
+</head>
+<body>
+<main style="padding: 24px;">
+  <h1>Clicks</h1>
+
+  <!-- Toolbar -->
+  <div class="card" style="margin-bottom: 16px;">
+    <div class="toolbar" id="toolbar">
+      <button class="btn btn--primary" id="btn-new-click">New Click</button>
+      <button class="btn" id="btn-refresh">Refresh</button>
+      <span style="display:inline-flex;gap:0.4rem;flex-wrap:wrap;align-items:center">
+        <span style="font-size:0.875rem;opacity:0.6">Status:</span>
+        <button class="btn filter-btn active-filter" data-status="all">All</button>
+        <button class="btn filter-btn" data-status="live">live</button>
+        <button class="btn filter-btn" data-status="parked">parked</button>
+        <button class="btn filter-btn" data-status="concluded">concluded</button>
+        <button class="btn filter-btn" data-status="dropped">dropped</button>
+      </span>
+    </div>
+  </div>
+
+  <!-- Breadcrumb (hidden when full forest is shown) -->
+  <div id="breadcrumb"></div>
+
+  <!-- Create click form (toggleable) -->
+  <div id="create-section" class="card">
+    <h3>New Click</h3>
+    <div class="form-row">
+      <label for="create-goal-input">Goal</label>
+      <input type="text" id="create-goal-input" placeholder="What are you trying to accomplish?" required>
+    </div>
+    <div class="form-row">
+      <label for="create-parent-input">Parent ID <span style="opacity:0.5">(optional — prefix accepted)</span></label>
+      <input type="text" id="create-parent-input" placeholder="c-xxxxxx">
+    </div>
+    <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap">
+      <button class="btn btn--primary" id="create-submit-btn">Create</button>
+      <button class="btn" id="create-cancel-btn">Cancel</button>
+      <div id="create-error" class="error-msg" style="display:none"></div>
+    </div>
+  </div>
+
+  <!-- Main split: tree (left) + detail pane (right) -->
+  <div id="main-split">
+    <div id="tree-area" class="card">
+      <div id="tree-container">
+        <div class="empty-state">Loading clicks…</div>
+      </div>
+    </div>
+
+    <div id="detail-pane" class="card">
+      <div id="detail-pane-header">
+        <h3 id="detail-pane-title"></h3>
+        <button id="close-detail-btn" title="Close">×</button>
+      </div>
+      <div id="detail-content"></div>
+    </div>
+  </div>
+
+</main>
+
+<script>
+(() => {
+  // ── State ────────────────────────────────────────────────────────────
+  let forest = [];          // full ClickTree[] from API
+  const ALL_STATUSES = ['live', 'parked', 'concluded', 'dropped'];
+  let activeStatuses = new Set(ALL_STATUSES);
+  let scopeRootId = null;   // null = full forest; string = subtree root id
+  let selectedId = null;    // id currently shown in detail pane
+  let collapsed = new Set(); // ids of collapsed tree nodes (default: all expanded)
+
+  // ── API helper ───────────────────────────────────────────────────────
+  async function api(method, path, body) {
+    const opts = { method, headers: { 'Content-Type': 'application/json' } };
+    if (body !== undefined) opts.body = JSON.stringify(body);
+    const res = await fetch(path, opts);
+    const json = await res.json();
+    if (!res.ok) throw new Error(json.error ?? `HTTP ${res.status}`);
+    return json;
+  }
+
+  // ── Escape helpers ───────────────────────────────────────────────────
+  function escHtml(s) {
+    return String(s)
+      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
+      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+  }
+  function escAttr(s) {
+    return String(s)
+      .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
+      .replace(/</g, '&lt;').replace(/>/g, '&gt;');
+  }
+
+  // ── Error helpers ────────────────────────────────────────────────────
+  function showError(el, msg) { el.textContent = msg; el.style.display = 'block'; }
+  function clearError(el) { el.textContent = ''; el.style.display = 'none'; }
+
+  // ── Status badge (D9/D20) ────────────────────────────────────────────
+  function statusBadge(status) {
+    const map = {
+      live:      'badge badge--active',
+      parked:    'badge badge--warning',
+      concluded: 'badge badge--success',
+      dropped:   'badge badge--error',
+    };
+    return `<span class="${map[status] ?? 'badge'}">${escHtml(status)}</span>`;
+  }
+
+  function fmtDate(iso) {
+    if (!iso) return '';
+    return new Date(iso).toLocaleString();
+  }
+
+  // Short ID: "c-<base36ts>" (first two hyphen-delimited segments)
+  function shortId(id) {
+    const parts = String(id).split('-');
+    return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+  }
+
+  async function copyToClipboard(text, feedbackEl) {
+    try {
+      await navigator.clipboard.writeText(text);
+      const orig = feedbackEl.textContent;
+      feedbackEl.textContent = '✓';
+      setTimeout(() => { feedbackEl.textContent = orig; }, 1500);
+    } catch (e) { /* ignore */ }
+  }
+
+  // ── Forest helpers ───────────────────────────────────────────────────
+
+  /**
+   * Prune forest so only nodes matching statusSet are included.
+   * A non-matching node AND its entire subtree are removed (D6).
+   */
+  function pruneForest(trees, statusSet) {
+    if (!statusSet || statusSet.size === ALL_STATUSES.length) return trees;
+    const result = [];
+    for (const tree of trees) {
+      if (!statusSet.has(tree.click.status)) continue;
+      const prunedChildren = pruneForest(tree.children, statusSet);
+      result.push({ click: tree.click, children: prunedChildren });
+    }
+    return result;
+  }
+
+  /**
+   * Return the single-element array containing the subtree rooted at rootId,
+   * or [] if rootId is null or not found.
+   */
+  function scopedForest(trees, rootId) {
+    if (!rootId) return trees;
+    function find(nodes) {
+      for (const t of nodes) {
+        if (t.click.id === rootId) return [t];
+        const found = find(t.children);
+        if (found.length) return found;
+      }
+      return [];
+    }
+    return find(trees);
+  }
+
+  /**
+   * Walk the full forest to find the path (array of ClickDoc) from
+   * any forest root down to targetId. Returns [] if not found.
+   */
+  function findAncestorPath(trees, targetId) {
+    function search(nodes, path) {
+      for (const t of nodes) {
+        const next = [...path, t.click];
+        if (t.click.id === targetId) return next;
+        const found = search(t.children, next);
+        if (found) return found;
+      }
+      return null;
+    }
+    return search(trees, []) ?? [];
+  }
+
+  // ── Tree rendering ───────────────────────────────────────────────────
+
+  function renderNodeHtml(tree, depth) {
+    const click = tree.click;
+    const id = click.id;
+    const isCollapsed = collapsed.has(id);
+    const hasChildren = tree.children.length > 0;
+    const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+    const isSelected = selectedId === id;
+
+    let html = `<div class="tree-node" data-id="${escAttr(id)}">`;
+
+    // Node row
+    html += `<div class="node-row${isSelected ? ' selected' : ''}" data-id="${escAttr(id)}"`;
+    html += ` style="padding-left:${depth * 0.15}rem">`;
+
+    // Expand/collapse button (or spacer)
+    if (hasChildren) {
+      const icon = isCollapsed ? '▸' : '▾';
+      html += `<button class="expand-btn" data-expand-id="${escAttr(id)}" title="${isCollapsed ? 'Expand' : 'Collapse'}">${icon}</button>`;
+    } else {
+      html += `<span class="expand-btn" style="opacity:0;pointer-events:none">▾</span>`;
+    }
+
+    // Status badge (D9)
+    html += statusBadge(click.status);
+
+    // Short ID + copy button
+    html += `<span class="node-id-wrap">`;
+    html += `<code class="node-id">${escHtml(shortId(id))}</code>`;
+    html += `<button class="copy-id-btn" data-copy-id="${escAttr(id)}" title="Copy ID" tabindex="-1">📋</button>`;
+    html += `</span>`;
+
+    // Goal text — clicking opens detail pane (D5)
+    html += `<span class="node-goal" data-select-id="${escAttr(id)}" title="${escAttr(click.goal)}">${escHtml(click.goal)}</span>`;
+
+    // Focus/scope button (D5/D23)
+    html += `<button class="focus-btn" data-focus-id="${escAttr(id)}" title="Scope to this subtree">⌖</button>`;
+
+    html += `</div>`; // end .node-row
+
+    // Conclusion toggle for terminal clicks (D10)
+    if (isTerminal && click.conclusion) {
+      html += `<details class="conclusion-wrap">`;
+      html += `<summary>▸ Conclusion</summary>`;
+      html += `<div class="conclusion-text">${escHtml(click.conclusion)}</div>`;
+      html += `</details>`;
+    }
+
+    // Children subtree (D8: expanded by default)
+    if (hasChildren) {
+      html += `<div class="node-children${isCollapsed ? ' collapsed' : ''}">`;
+      for (const child of tree.children) {
+        html += renderNodeHtml(child, depth + 1);
+      }
+      html += `</div>`;
+    }
+
+    html += `</div>`; // end .tree-node
+    return html;
+  }
+
+  function renderTree() {
+    const container = document.getElementById('tree-container');
+
+    // Apply scope first, then status filter
+    const scoped = scopedForest(forest, scopeRootId);
+    const visible = pruneForest(scoped, activeStatuses);
+
+    if (visible.length === 0) {
+      const msg = forest.length === 0
+        ? 'No clicks found.'
+        : 'No clicks match the current filters.';
+      container.innerHTML = `<div class="empty-state">${msg}</div>`;
+      renderBreadcrumb();
+      return;
+    }
+
+    let html = '';
+    for (const tree of visible) {
+      html += renderNodeHtml(tree, 0);
+    }
+    container.innerHTML = html;
+    wireTreeEvents(container);
+    renderBreadcrumb();
+  }
+
+  function wireTreeEvents(container) {
+    // Expand/collapse
+    container.querySelectorAll('[data-expand-id]').forEach(btn => {
+      btn.addEventListener('click', e => {
+        e.stopPropagation();
+        const id = btn.dataset.expandId;
+        if (collapsed.has(id)) collapsed.delete(id);
+        else collapsed.add(id);
+        renderTree();
+      });
+    });
+
+    // Copy ID buttons
+    container.querySelectorAll('.copy-id-btn[data-copy-id]').forEach(btn => {
+      btn.addEventListener('click', e => {
+        e.stopPropagation();
+        copyToClipboard(btn.dataset.copyId, btn);
+      });
+    });
+
+    // Goal / row click → select click (opens detail pane) — D5
+    container.querySelectorAll('[data-select-id]').forEach(el => {
+      el.addEventListener('click', e => {
+        e.stopPropagation();
+        selectClick(el.dataset.selectId);
+      });
+    });
+
+    // Also allow clicking the node row itself (but not on action buttons)
+    container.querySelectorAll('.node-row[data-id]').forEach(row => {
+      row.addEventListener('click', () => selectClick(row.dataset.id));
+    });
+
+    // Focus buttons → scope to subtree (D23)
+    container.querySelectorAll('[data-focus-id]').forEach(btn => {
+      btn.addEventListener('click', e => {
+        e.stopPropagation();
+        setScope(btn.dataset.focusId);
+      });
+    });
+  }
+
+  // ── Breadcrumb (D23) ─────────────────────────────────────────────────
+
+  function renderBreadcrumb() {
+    const el = document.getElementById('breadcrumb');
+    if (!scopeRootId) {
+      el.style.display = 'none';
+      return;
+    }
+    const path = findAncestorPath(forest, scopeRootId);
+    if (!path.length) {
+      el.style.display = 'none';
+      return;
+    }
+
+    let html = `<button class="breadcrumb-link" id="bc-show-all">Show all</button>`;
+    for (let i = 0; i < path.length; i++) {
+      const c = path[i];
+      const label = shortId(c.id) + ': ' + (c.goal.length > 32 ? c.goal.slice(0, 31) + '…' : c.goal);
+      html += `<span class="breadcrumb-sep">/</span>`;
+      if (i === path.length - 1) {
+        html += `<span class="breadcrumb-current" title="${escAttr(c.goal)}">${escHtml(label)}</span>`;
+      } else {
+        html += `<button class="breadcrumb-link" data-bc-scope="${escAttr(c.id)}" title="${escAttr(c.goal)}">${escHtml(label)}</button>`;
+      }
+    }
+
+    el.innerHTML = html;
+    el.style.display = 'flex';
+
+    el.querySelector('#bc-show-all').addEventListener('click', () => setScope(null));
+    el.querySelectorAll('[data-bc-scope]').forEach(btn => {
+      btn.addEventListener('click', () => setScope(btn.dataset.bcScope));
+    });
+  }
+
+  function setScope(rootId) {
+    scopeRootId = rootId;
+    const params = new URLSearchParams(window.location.search);
+    if (rootId) params.set('root', rootId); else params.delete('root');
+    if (selectedId) params.set('click', selectedId); else params.delete('click');
+    const qs = params.toString();
+    history.pushState({}, '', qs ? '?' + qs : window.location.pathname);
+    renderTree();
+  }
+
+  // ── Status filter (D6/D7) ────────────────────────────────────────────
+
+  function setStatusFilter(status) {
+    if (status === 'all') {
+      activeStatuses = new Set(ALL_STATUSES);
+    } else {
+      const allActive = ALL_STATUSES.every(s => activeStatuses.has(s));
+      if (allActive) {
+        activeStatuses = new Set([status]);
+      } else {
+        if (activeStatuses.has(status)) activeStatuses.delete(status);
+        else activeStatuses.add(status);
+      }
+    }
+
+    // Sync button visual state
+    const nowAllActive = ALL_STATUSES.every(s => activeStatuses.has(s));
+    document.querySelectorAll('.filter-btn[data-status]').forEach(btn => {
+      const s = btn.dataset.status;
+      const active = s === 'all' ? nowAllActive : activeStatuses.has(s);
+      btn.classList.toggle('active-filter', active);
+    });
+
+    renderTree();
+  }
+
+  // ── Select click → open detail pane ─────────────────────────────────
+
+  async function selectClick(id) {
+    selectedId = id;
+
+    // Update URL (D19)
+    const params = new URLSearchParams(window.location.search);
+    params.set('click', id);
+    if (scopeRootId) params.set('root', scopeRootId);
+    history.pushState({}, '', '?' + params.toString());
+
+    // Highlight selected node
+    document.querySelectorAll('.node-row').forEach(row => {
+      row.classList.toggle('selected', row.dataset.id === id);
+    });
+
+    await loadDetail(id);
+  }
+
+  async function loadDetail(id) {
+    const pane = document.getElementById('detail-pane');
+    const content = document.getElementById('detail-content');
+    const titleEl = document.getElementById('detail-pane-title');
+
+    pane.style.display = 'block';
+    titleEl.textContent = 'Loading…';
+    content.innerHTML = '<div style="opacity:0.5;font-size:0.875rem;padding:0.5rem 0">Loading…</div>';
+
+    try {
+      const click = await api('GET', '/api/click/show?id=' + encodeURIComponent(id));
+      titleEl.textContent = click.goal;
+      content.innerHTML = renderDetailContent(click);
+      wireDetailEvents(content, click);
+      loadLinkMetadata(content, click);
+    } catch (e) {
+      titleEl.textContent = id;
+      content.innerHTML = `<div class="error-msg">Failed to load: ${escHtml(e.message)}</div>`;
+    }
+  }
+
+  // ── Detail pane rendering (D24) ──────────────────────────────────────
+
+  function renderDetailContent(click) {
+    const id = click.id;
+    const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+    let html = '';
+
+    // ── Fields grid (D24) ───────────────────────────────────────────
+    html += `<div class="detail-section"><dl class="detail-grid">`;
+    html += `<dt>ID</dt><dd><code>${escHtml(id)}</code> `;
+    html += `<button class="copy-id-btn" data-copy-id="${escAttr(id)}" style="font-size:0.7rem;padding:0.1rem 0.3rem">📋</button></dd>`;
+    html += `<dt>Goal</dt><dd>${escHtml(click.goal)}</dd>`;
+    html += `<dt>Status</dt><dd>${statusBadge(click.status)}</dd>`;
+
+    if (click.parent) {
+      html += `<dt>Parent</dt><dd>`;
+      html += `<button class="link-id" data-click-id="${escAttr(click.parent.id)}">${escHtml(click.parent.id)}</button>`;
+      html += ` ${statusBadge(click.parent.status)} <span style="opacity:0.7;font-size:0.8rem">${escHtml(click.parent.goal ?? '')}</span>`;
+      html += `</dd>`;
+    }
+
+    html += `<dt>Created</dt><dd>${escHtml(fmtDate(click.createdAt))}</dd>`;
+    if (click.resolvedAt) html += `<dt>Resolved</dt><dd>${escHtml(fmtDate(click.resolvedAt))}</dd>`;
+    if (click.createdSessionId) html += `<dt>Created by</dt><dd><code>${escHtml(click.createdSessionId)}</code></dd>`;
+    if (click.resolvedSessionId) html += `<dt>Resolved by</dt><dd><code>${escHtml(click.resolvedSessionId)}</code></dd>`;
+    html += `</dl></div>`;
+
+    // ── Conclusion (expandable if terminal) — D10/D24 ───────────────
+    if (isTerminal && click.conclusion) {
+      html += `<div class="detail-section">`;
+      html += `<details><summary style="cursor:pointer;font-size:0.875rem;opacity:0.75;list-style:none;user-select:none">▸ Conclusion</summary>`;
+      html += `<div class="conclusion-text" style="margin-top:0.3rem">${escHtml(click.conclusion)}</div>`;
+      html += `</details></div>`;
+    }
+
+    // ── Lifecycle actions (D11) ──────────────────────────────────────
+    if (!isTerminal) {
+      html += `<div class="detail-section">`;
+      html += `<h4>Actions</h4>`;
+      html += `<div class="action-buttons" id="action-btns-${escAttr(id)}">`;
+      if (click.status === 'live') {
+        html += `<button class="btn" data-action="park" data-id="${escAttr(id)}">Park</button>`;
+      }
+      if (click.status === 'parked') {
+        html += `<button class="btn btn--primary" data-action="resume" data-id="${escAttr(id)}">Resume</button>`;
+      }
+      // Conclude and Drop available for live and parked
+      html += `<button class="btn btn--success" data-action="conclude" data-id="${escAttr(id)}">Conclude…</button>`;
+      html += `<button class="btn btn--danger" data-action="drop" data-id="${escAttr(id)}">Drop…</button>`;
+      html += `</div>`;
+      html += `<div id="confirm-area-${escAttr(id)}"></div>`;
+      html += `<div class="error-msg" id="action-error-${escAttr(id)}" style="display:none"></div>`;
+      html += `</div>`;
+    }
+
+    // ── Children (D22) ───────────────────────────────────────────────
+    const childItems = click.children?.items ?? [];
+    html += `<div class="detail-section">`;
+    html += `<h4>Children (${childItems.length})</h4>`;
+    if (click.children?.summary && Object.keys(click.children.summary).length > 0) {
+      html += `<div class="summary-badges">`;
+      for (const [st, cnt] of Object.entries(click.children.summary)) {
+        html += statusBadge(st) + `<span class="summary-count">${cnt}</span>`;
+      }
+      html += `</div>`;
+    }
+    if (childItems.length > 0) {
+      html += `<table class="data-table"><thead><tr><th>Status</th><th>Goal</th><th>ID</th></tr></thead><tbody>`;
+      for (const child of childItems) {
+        html += `<tr class="child-detail-row" data-child-id="${escAttr(child.id)}">`;
+        html += `<td>${statusBadge(child.status)}</td>`;
+        html += `<td>${escHtml(child.goal ?? '')}</td>`;
+        html += `<td><code>${escHtml(child.id)}</code></td>`;
+        html += `</tr>`;
+      }
+      html += `</tbody></table>`;
+    } else {
+      html += `<p style="font-size:0.825rem;opacity:0.5;margin:0.25rem 0">No children.</p>`;
+    }
+    html += `</div>`;
+
+    // ── Links (D14/D15/D16) ──────────────────────────────────────────
+    const outbound = click.links?.outbound ?? [];
+    const inbound  = click.links?.inbound  ?? [];
+    html += `<div class="detail-section" id="links-section-${escAttr(id)}">`;
+    html += `<h4>Links</h4>`;
+    if (outbound.length === 0 && inbound.length === 0) {
+      html += `<p style="font-size:0.825rem;opacity:0.5;margin:0.25rem 0">No links.</p>`;
+    }
+    for (const l of outbound) html += renderLinkRow(l, '→', id);
+    for (const l of inbound)  html += renderLinkRow(l, '←', id);
+
+    // Add-link form — select dropdown per D14
+    html += `<div class="add-link-form" id="add-link-form-${escAttr(id)}">`;
+    html += `<input type="text" id="link-target-${escAttr(id)}" placeholder="Target ID (c-… or w-…)" style="width:160px">`;
+    html += `<select id="link-type-${escAttr(id)}">`;
+    html += `<option value="related">related</option>`;
+    html += `<option value="commissioned">commissioned</option>`;
+    html += `<option value="supersedes">supersedes</option>`;
+    html += `<option value="depends-on">depends-on</option>`;
+    html += `</select>`;
+    html += `<button class="btn" data-action="addlink" data-id="${escAttr(id)}">Link</button>`;
+    html += `<div class="error-msg" id="link-error-${escAttr(id)}" style="display:none"></div>`;
+    html += `</div>`;
+    html += `</div>`; // end links-section
+
+    return html;
+  }
+
+  /**
+   * Render one link row with prefix-dispatch navigation (D15).
+   * c-* → in-page click detail; w-* → writs page; other → plain text.
+   */
+  function renderLinkRow(link, dir, clickId) {
+    const peerId = dir === '→' ? link.targetId : link.sourceId;
+    let peerHtml;
+    if (peerId.startsWith('c-')) {
+      peerHtml = `<button class="link-id" data-click-id="${escAttr(peerId)}" data-meta-id="${escAttr(peerId)}">${escHtml(peerId)}</button>`;
+    } else if (peerId.startsWith('w-')) {
+      peerHtml = `<a class="link-id" href="/pages/writs/?writ=${encodeURIComponent(peerId)}" data-meta-id="${escAttr(peerId)}">${escHtml(peerId)}</a>`;
+    } else {
+      peerHtml = `<span data-meta-id="${escAttr(peerId)}">${escHtml(peerId)}</span>`;
+    }
+
+    return `<div class="link-row">` +
+      `<span class="link-dir">${dir}</span>` +
+      peerHtml +
+      `<span style="opacity:0.55;font-size:0.75rem">${escHtml(link.linkType)}</span>` +
+      `<span class="link-meta" data-meta-for="${escAttr(peerId)}"></span>` +
+      `<button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.72rem"` +
+        ` data-action="unlink"` +
+        ` data-source="${escAttr(link.sourceId)}" data-target="${escAttr(link.targetId)}"` +
+        ` data-link-type="${escAttr(link.linkType)}" data-click-id="${escAttr(clickId)}">×</button>` +
+    `</div>`;
+  }
+
+  /**
+   * Lazily fetch metadata for each link target and populate .link-meta labels (D16).
+   */
+  async function loadLinkMetadata(container, click) {
+    const outbound = click.links?.outbound ?? [];
+    const inbound  = click.links?.inbound  ?? [];
+    const seen = new Set();
+
+    for (const link of [...outbound, ...inbound]) {
+      const peerId = link.sourceId === click.id ? link.targetId : link.sourceId;
+      if (seen.has(peerId)) continue;
+      seen.add(peerId);
+
+      const metaEls = container.querySelectorAll(`.link-meta[data-meta-for]`);
+      let metaEl = null;
+      metaEls.forEach(el => { if (el.dataset.metaFor === peerId) metaEl = el; });
+      if (!metaEl) continue;
+
+      if (peerId.startsWith('c-')) {
+        try {
+          const other = await api('GET', '/api/click/show?id=' + encodeURIComponent(peerId));
+          metaEl.textContent = '— ' + (other.goal ?? '');
+        } catch { /* ignore */ }
+      } else if (peerId.startsWith('w-')) {
+        try {
+          const other = await api('GET', '/api/writ/show?id=' + encodeURIComponent(peerId));
+          metaEl.textContent = '— ' + (other.title ?? '');
+        } catch { /* ignore — writ apparatus may not be installed */ }
+      }
+    }
+  }
+
+  // ── Wire detail pane events ──────────────────────────────────────────
+
+  function wireDetailEvents(container, click) {
+    const id = click.id;
+
+    // Copy ID buttons
+    container.querySelectorAll('.copy-id-btn[data-copy-id]').forEach(btn => {
+      btn.addEventListener('click', e => {
+        e.stopPropagation();
+        copyToClipboard(btn.dataset.copyId, btn);
+      });
+    });
+
+    // Parent link → open parent detail
+    container.querySelectorAll('.link-id[data-click-id]').forEach(btn => {
+      btn.addEventListener('click', e => {
+        e.preventDefault();
+        selectClick(btn.dataset.clickId);
+      });
+    });
+
+    // Child row clicks → navigate to child detail (D22)
+    container.querySelectorAll('.child-detail-row').forEach(row => {
+      row.addEventListener('click', () => selectClick(row.dataset.childId));
+    });
+
+    // Action buttons (data-action)
+    container.querySelectorAll('[data-action]').forEach(btn => {
+      btn.addEventListener('click', e => {
+        e.stopPropagation();
+        handleDetailAction(btn.dataset.action, btn.dataset.id ?? id, btn, container, click);
+      });
+    });
+  }
+
+  function handleDetailAction(action, id, btn, container, click) {
+    if (action === 'park') {
+      doPark(id, btn, container);
+    } else if (action === 'resume') {
+      doResume(id, btn, container);
+    } else if (action === 'conclude') {
+      showConfirmSection(id, 'conclude', container);
+    } else if (action === 'drop') {
+      showConfirmSection(id, 'drop', container);
+    } else if (action === 'unlink') {
+      doUnlink(btn.dataset.source, btn.dataset.target, btn.dataset.linkType, btn, btn.dataset.clickId ?? id);
+    } else if (action === 'addlink') {
+      const targetInput = document.getElementById(`link-target-${id}`);
+      const typeSelect  = document.getElementById(`link-type-${id}`);
+      const errEl       = document.getElementById(`link-error-${id}`);
+      doAddLink(id, targetInput?.value.trim() ?? '', typeSelect?.value ?? '', btn, errEl);
+    }
+  }
+
+  async function doPark(id, btn, container) {
+    const errEl = container.querySelector(`#action-error-${id}`);
+    if (errEl) clearError(errEl);
+    btn.disabled = true; const orig = btn.textContent; btn.textContent = '…';
+    try { await api('POST', '/api/click/park', { id }); await refreshAfterMutation(id); }
+    catch (e) { if (errEl) showError(errEl, e.message); }
+    finally { btn.disabled = false; btn.textContent = orig; }
+  }
+
+  async function doResume(id, btn, container) {
+    const errEl = container.querySelector(`#action-error-${id}`);
+    if (errEl) clearError(errEl);
+    btn.disabled = true; const orig = btn.textContent; btn.textContent = '…';
+    try { await api('POST', '/api/click/resume', { id }); await refreshAfterMutation(id); }
+    catch (e) { if (errEl) showError(errEl, e.message); }
+    finally { btn.disabled = false; btn.textContent = orig; }
+  }
+
+  function showConfirmSection(id, action, container) {
+    const area = container.querySelector(`#confirm-area-${id}`);
+    const errEl = container.querySelector(`#action-error-${id}`);
+    if (errEl) clearError(errEl);
+    if (!area) return;
+
+    const actionLabel   = action === 'conclude' ? 'Conclude' : 'Drop';
+    const confirmLabel  = `Confirm ${actionLabel}`;
+    const btnClass      = action === 'conclude' ? 'btn--success' : 'btn--danger';
+
+    area.innerHTML = `
+      <div class="confirm-section">
+        <label>Conclusion (required)</label>
+        <input type="text" id="confirm-input-${escAttr(id)}" placeholder="Enter conclusion…">
+        <button class="btn ${btnClass}" id="confirm-btn-${escAttr(id)}" disabled>${escHtml(confirmLabel)}</button>
+        <div class="error-msg" id="confirm-error-${escAttr(id)}" style="display:none"></div>
+      </div>`;
+
+    const input      = document.getElementById(`confirm-input-${id}`);
+    const confirmBtn = document.getElementById(`confirm-btn-${id}`);
+    const confirmErr = document.getElementById(`confirm-error-${id}`);
+
+    if (!input || !confirmBtn) return;
+    input.focus();
+    input.addEventListener('input', () => {
+      confirmBtn.disabled = !input.value.trim();
+      if (confirmErr) clearError(confirmErr);
+    });
+    confirmBtn.addEventListener('click', async () => {
+      const conclusion = input.value.trim();
+      if (!conclusion) return;
+      confirmBtn.disabled = true;
+      confirmBtn.textContent = action === 'conclude' ? 'Concluding…' : 'Dropping…';
+      try {
+        const route = action === 'conclude' ? '/api/click/conclude' : '/api/click/drop';
+        await api('POST', route, { id, conclusion });
+        area.innerHTML = '';
+        await refreshAfterMutation(id);
+      } catch (e) {
+        if (confirmErr) showError(confirmErr, e.message);
+        confirmBtn.disabled = false;
+        confirmBtn.textContent = confirmLabel;
+      }
+    });
+  }
+
+  async function doUnlink(sourceId, targetId, linkType, btn, clickId) {
+    const orig = btn.textContent; btn.disabled = true;
+    try {
+      await api('POST', '/api/click/unlink', { sourceId, targetId, linkType });
+      await refreshAfterMutation(clickId);
+    } catch (e) {
+      alert(`Unlink failed: ${e.message}`);
+      btn.disabled = false; btn.textContent = orig;
+    }
+  }
+
+  async function doAddLink(clickId, targetId, linkType, btn, errEl) {
+    if (errEl) clearError(errEl);
+    if (!targetId) { if (errEl) showError(errEl, 'Target ID is required.'); return; }
+    if (!linkType) { if (errEl) showError(errEl, 'Link type is required.'); return; }
+    btn.disabled = true; const orig = btn.textContent; btn.textContent = 'Linking…';
+    try {
+      await api('POST', '/api/click/link', { sourceId: clickId, targetId, linkType });
+      const inp = document.getElementById(`link-target-${clickId}`);
+      if (inp) inp.value = '';
+      await refreshAfterMutation(clickId);
+    } catch (e) {
+      if (errEl) showError(errEl, e.message);
+    } finally { btn.disabled = false; btn.textContent = orig; }
+  }
+
+  // ── Post-mutation refresh (D17) ──────────────────────────────────────
+
+  async function refreshAfterMutation(reopenId) {
+    await loadData();             // full refetch
+    if (reopenId) {
+      await loadDetail(reopenId); // re-render detail pane
+    }
+  }
+
+  // ── Create form (D13) ────────────────────────────────────────────────
+
+  function openCreateForm() {
+    const section = document.getElementById('create-section');
+    section.classList.add('open');
+    // Pre-fill parent ID when a click is already selected (D12 "pre-fill is additive")
+    if (selectedId) {
+      const parentInput = document.getElementById('create-parent-input');
+      if (parentInput && !parentInput.value) parentInput.value = selectedId;
+    }
+    document.getElementById('create-goal-input').focus();
+  }
+
+  function closeCreateForm() {
+    document.getElementById('create-section').classList.remove('open');
+    document.getElementById('create-goal-input').value = '';
+    document.getElementById('create-parent-input').value = '';
+    clearError(document.getElementById('create-error'));
+  }
+
+  async function submitCreateForm() {
+    const goalInput   = document.getElementById('create-goal-input');
+    const parentInput = document.getElementById('create-parent-input');
+    const submitBtn   = document.getElementById('create-submit-btn');
+    const errEl       = document.getElementById('create-error');
+
+    clearError(errEl);
+    const goal     = goalInput.value.trim();
+    const parentId = parentInput.value.trim() || undefined;
+
+    if (!goal) { showError(errEl, 'Goal is required.'); return; }
+
+    submitBtn.disabled = true; submitBtn.textContent = 'Creating…';
+    try {
+      const newClick = await api('POST', '/api/click/create', { goal, parentId });
+      closeCreateForm();
+      await loadData();
+      await selectClick(newClick.id);
+    } catch (e) {
+      showError(errEl, e.message);
+    } finally {
+      submitBtn.disabled = false; submitBtn.textContent = 'Create';
+    }
+  }
+
+  // ── Data loading ─────────────────────────────────────────────────────
+
+  async function loadData() {
+    try {
+      forest = await api('GET', '/api/click/tree?format=json');
+      renderTree();
+    } catch (e) {
+      document.getElementById('tree-container').innerHTML =
+        `<div class="error-msg">Failed to load clicks: ${escHtml(e.message)}</div>`;
+    }
+  }
+
+  // ── Event wiring ─────────────────────────────────────────────────────
+
+  document.getElementById('btn-new-click').addEventListener('click', () => {
+    const section = document.getElementById('create-section');
+    if (section.classList.contains('open')) closeCreateForm(); else openCreateForm();
+  });
+
+  document.getElementById('btn-refresh').addEventListener('click', () => loadData());
+
+  document.getElementById('create-submit-btn').addEventListener('click', submitCreateForm);
+  document.getElementById('create-cancel-btn').addEventListener('click', closeCreateForm);
+
+  document.getElementById('create-goal-input').addEventListener('keydown', e => {
+    if (e.key === 'Enter') submitCreateForm();
+  });
+
+  document.querySelectorAll('.filter-btn[data-status]').forEach(btn => {
+    btn.addEventListener('click', () => setStatusFilter(btn.dataset.status));
+  });
+
+  document.getElementById('close-detail-btn').addEventListener('click', () => {
+    document.getElementById('detail-pane').style.display = 'none';
+    selectedId = null;
+    document.querySelectorAll('.node-row.selected').forEach(r => r.classList.remove('selected'));
+    const params = new URLSearchParams(window.location.search);
+    params.delete('click');
+    const qs = params.toString();
+    history.pushState({}, '', qs ? '?' + qs : window.location.pathname);
+  });
+
+  // ── Init ─────────────────────────────────────────────────────────────
+
+  (async function init() {
+    const params = new URLSearchParams(window.location.search);
+    const initClickId = params.get('click');
+    const initRootId  = params.get('root');
+
+    if (initRootId) scopeRootId = initRootId;
+
+    await loadData();
+
+    if (initClickId) {
+      await selectClick(initClickId); // D19: auto-open detail
+    }
+  })();
+
+})();
+</script>
+</body>
+</html>
