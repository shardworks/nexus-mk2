+/**
+ * Reckoner public types.
+ *
+ * Priority dimensions, complexity tiers, petition shape, petitioner
+ * registry descriptors, configuration, and the Reckoner runtime API.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { WritDoc } from '@shardworks/clerk-apparatus';
+
+// ── Domain tags ──────────────────────────────────────────────────────────
+
+/**
+ * Classification tags for the `domain` dimension of a petition's priority.
+ * Multi-valued — a petition can belong to multiple domains simultaneously.
+ *
+ * Used by the Reckoner for filtering, patron-tunable weighting, and
+ * reporting. Not a priority axis — describes what kind of work the
+ * petition is.
+ *
+ * See §3 of docs/architecture/petitioner-registration.md.
+ */
+export type DomainTag =
+  | 'security'
+  | 'compliance'
+  | 'cost'
+  | 'feature'
+  | 'quality'
+  | 'infrastructure'
+  | 'documentation'
+  | 'research'
+  | 'ergonomics';
+
+// ── Validation allow-lists (exported for use in reckoner.ts) ─────────────
+
+/** All valid `visionRelation` values. */
+export const VALID_VISION_RELATION = [
+  'vision-blocker',
+  'vision-violator',
+  'vision-advancer',
+  'vision-neutral',
+] as const;
+
+/** All valid `severity` values. */
+export const VALID_SEVERITY = [
+  'critical',
+  'serious',
+  'moderate',
+  'minor',
+] as const;
+
+/** All valid `scope` values. */
+export const VALID_SCOPE = [
+  'whole-product',
+  'major-area',
+  'minor-area',
+] as const;
+
+/** All valid `domain` tag values. */
+export const VALID_DOMAIN: readonly DomainTag[] = [
+  'security',
+  'compliance',
+  'cost',
+  'feature',
+  'quality',
+  'infrastructure',
+  'documentation',
+  'research',
+  'ergonomics',
+] as const;
+
+// ── Priority ─────────────────────────────────────────────────────────────
+
+/**
+ * Multi-dimensional priority for a Reckoner-gated writ.
+ *
+ * Five independent axes: how the petition relates to the product vision
+ * (`visionRelation`), how bad things are if it is not acted on
+ * (`severity`), what fraction of the system is affected (`scope`), time
+ * pressure (`time`), and domain classification tags (`domain`).
+ *
+ * Designed to be **inspectable and defensible** rather than mechanically
+ * objective — petitioners declare honest inputs, the Reckoner does
+ * judgment-laden contextual collapse.
+ *
+ * Use `defaultPriority()` to obtain a fully-specified Priority with all
+ * dimensions at their conservative defaults.
+ *
+ * See §3 of docs/architecture/petitioner-registration.md.
+ */
+export type Priority = {
+  /**
+   * How this petition relates to the product vision.
+   *
+   * - `vision-blocker`  — unreachable without this; future-blocking.
+   * - `vision-violator` — current state actively diverges from the vision.
+   * - `vision-advancer` — pushes toward an aspirational aspect of the vision.
+   * - `vision-neutral`  — doesn't touch the product vision (default).
+   */
+  visionRelation:
+    | 'vision-blocker'
+    | 'vision-violator'
+    | 'vision-advancer'
+    | 'vision-neutral';
+
+  /**
+   * How bad is the situation if this petition is not acted on?
+   *
+   * - `critical`  — production breakage, security incident, irreversible damage.
+   * - `serious`   — significant ongoing degradation; daily workarounds.
+   * - `moderate`  — noticeable but tolerable.
+   * - `minor`     — easy to live with; cosmetic or convenience (default).
+   */
+  severity: 'critical' | 'serious' | 'moderate' | 'minor';
+
+  /**
+   * What fraction of the system is affected?
+   *
+   * - `whole-product` — every user / every commission / every guild.
+   * - `major-area`    — a major feature or subsystem.
+   * - `minor-area`    — a small slice, one workflow, one command (default).
+   */
+  scope: 'whole-product' | 'major-area' | 'minor-area';
+
+  /**
+   * Time-pressure axes — two genuinely independent dimensions.
+   *
+   * `decay: true` means the situation worsens over time without
+   * intervention (drift sentinels, security exposure, accumulating debt).
+   * `deadline` is a pledged date or external commitment as an ISO date
+   * string, or `null` if none.
+   */
+  time: {
+    decay: boolean;
+    deadline: string | null;
+  };
+
+  /**
+   * Multi-valued domain classification tags. Not a priority axis — used
+   * for filtering, weighting, and reporting. Empty array by default.
+   */
+  domain: Array<DomainTag>;
+};
+
+// ── Complexity ───────────────────────────────────────────────────────────
+
+/**
+ * Petitioner-side coarse estimate of expected agent token cost.
+ *
+ * Refined by the Astrolabe at plan time; this exists only for early-stage
+ * trade-offs before plans exist.
+ *
+ * - `mechanical`  — clear path, minimal exploration (~50K–200K tokens).
+ * - `bounded`     — clear scope, some exploration (~200K–1M tokens).
+ * - `exploratory` — design judgment required; multiple viable paths (~1M–5M tokens).
+ * - `open-ended`  — research/prototyping; multi-session work (~5M+ tokens).
+ *
+ * Omit when the petitioner has no basis to estimate — omission is honest;
+ * a wild guess is misleading.
+ *
+ * See §4 of docs/architecture/petitioner-registration.md.
+ */
+export type ComplexityTier =
+  | 'mechanical'
+  | 'bounded'
+  | 'exploratory'
+  | 'open-ended';
+
+// ── ReckonerExt ──────────────────────────────────────────────────────────
+
+/**
+ * The `writ.ext['reckoner']` payload. Signals to the Reckoner that this
+ * writ is Reckoner-gated and supplies the scheduling inputs.
+ *
+ * Written via `clerk.setWritExt(writId, 'reckoner', ext)`. The `petition()`
+ * helper constructs and writes this correctly; direct `clerk.post()` callers
+ * (Workflow 1) are responsible for supplying and setting it themselves.
+ *
+ * See §2 of docs/architecture/petitioner-registration.md.
+ */
+export interface ReckonerExt {
+  /**
+   * Identifies the petitioner. Must match a registered petitioner
+   * descriptor (see §5) when `enforceRegistration` is on.
+   */
+  source: string;
+
+  /**
+   * Multi-dimensional priority — all dimensions fully resolved (defaults
+   * applied for any omitted fields in the original petition request).
+   */
+  priority: Priority;
+
+  /**
+   * Optional petitioner-side coarse cost estimate. Refined by the
+   * Astrolabe at plan time; absent when the petitioner has no basis.
+   */
+  complexity?: ComplexityTier;
+
+  /**
+   * Opaque petitioner-defined structured data. The Reckoner stores it
+   * but does not introspect; the rig's implementation engine reads it
+   * if needed.
+   */
+  payload?: unknown;
+
+  /**
+   * Additive non-priority metadata — multi-instance discrimination,
+   * observability hints, diagnostic tags.
+   */
+  labels?: Record<string, string>;
+}
+
+// ── PetitionerDescriptor ─────────────────────────────────────────────────
+
+/**
+ * A single petitioner registration entry, contributed via the `petitioners`
+ * kit contribution type.
+ *
+ * Source ids must follow the `{pluginId}.{kebab-suffix}` grammar; the
+ * contributing plugin's id is validated as the prefix. Duplicate source
+ * ids across plugins are a hard startup error.
+ *
+ * See §5 of docs/architecture/petitioner-registration.md.
+ */
+export interface PetitionerDescriptor {
+  /**
+   * Source id — `{pluginId}.{kebab-suffix}` (e.g. `vision-keeper.snapshot`).
+   * Must be unique across the guild.
+   */
+  source: string;
+  /** One-line description surfaced in operator tooling and Oculus. */
+  description: string;
+}
+
+// ── PetitionRequest ──────────────────────────────────────────────────────
+
+/**
+ * Input to `reckoner.petition()` — combines writ fields and the Reckoner
+ * ext fields into a single ergonomic call.
+ *
+ * `priority` accepts a partial object; omitted dimensions are filled from
+ * `defaultPriority()` before the writ is posted. `complexity`, `payload`,
+ * and `labels` are forwarded to `writ.ext['reckoner']` unchanged.
+ *
+ * See §1 of docs/architecture/petitioner-registration.md.
+ */
+export interface PetitionRequest {
+  // ── Writ fields (forwarded to clerk.post) ────────────────────────────
+  /**
+   * Writ type. Defaults to the guild's configured default type if omitted.
+   */
+  type?: string;
+  /** Short human-readable title. */
+  title: string;
+  /** Detail text. */
+  body: string;
+  /** Target codex name. */
+  codex?: string;
+  /** Parent writ id. Omit for root petitions. */
+  parentId?: string;
+
+  // ── Reckoner ext fields ──────────────────────────────────────────────
+  /**
+   * Registered petitioner source id (e.g. `vision-keeper.snapshot`).
+   * Subject to the `enforceRegistration` config check.
+   */
+  source: string;
+  /**
+   * Priority dimensions. Accepts a partial object — any omitted dimension
+   * falls back to the defaults from `defaultPriority()`. Fully resolved
+   * before being written to `writ.ext['reckoner'].priority`.
+   */
+  priority?: Partial<Priority>;
+  /** Optional petitioner-side complexity estimate. */
+  complexity?: ComplexityTier;
+  /** Opaque petitioner-defined data. Available to the rig engine via `writ.ext['reckoner'].payload`. */
+  payload?: unknown;
+  /** Additive metadata tags. */
+  labels?: Record<string, string>;
+}
+
+// ── ReckonerConfig ───────────────────────────────────────────────────────
+
+/**
+ * Reckoner apparatus configuration — lives under the `reckoner` key in
+ * guild.json.
+ *
+ * Defaults are permissive: `enforceRegistration: false`,
+ * `disabledSources: []`.
+ *
+ * See §6 of docs/architecture/petitioner-registration.md.
+ */
+export interface ReckonerConfig {
+  /**
+   * When `true`, petitions from unregistered sources are declined (the
+   * `petition()` helper throws; the CDC handler transitions the writ to
+   * `cancelled`). When `false` (default), the Reckoner logs a warning and
+   * proceeds.
+   */
+  enforceRegistration: boolean;
+
+  /**
+   * Sources skipped by the Reckoner. Writs from these sources are left
+   * in `new` phase indefinitely until the source is removed from the list.
+   * The `petition()` helper does not check this list — it is enforced by
+   * the CDC handler (separate commission).
+   */
+  disabledSources: string[];
+}
+
+// Augment GuildConfig so `guild().guildConfig().reckoner` is typed without
+// requiring a manual type parameter at the call site.
+declare module '@shardworks/nexus-core' {
+  interface GuildConfig {
+    reckoner?: Partial<ReckonerConfig>;
+  }
+}
+
+// ── ReckonerApi ──────────────────────────────────────────────────────────
+
+/**
+ * The Reckoner's runtime API, retrieved via
+ * `guild().apparatus<ReckonerApi>('reckoner')`.
+ *
+ * The canonical ergonomic path for posting Reckoner-gated writs. Equivalent
+ * in effect to the Workflow 1 direct-post approach but with type checking,
+ * default handling, and registry validation built in.
+ *
+ * See §1 of docs/architecture/petitioner-registration.md.
+ */
+export interface ReckonerApi {
+  /**
+   * Post a writ in `new` phase with Reckoner ext set correctly.
+   *
+   * Steps:
+   * 1. Checks the source against the petitioner registry. With
+   *    `enforceRegistration: false` (default), an unregistered source
+   *    logs a warning but proceeds. With `enforceRegistration: true`, an
+   *    unregistered source throws fail-loud before posting any writ.
+   * 2. Applies `defaultPriority()` defaults to omitted priority dimensions.
+   * 3. Validates all dimension values against the schema.
+   * 4. Calls `clerk.post()` with the writ fields (type, title, body,
+   *    codex, parentId).
+   * 5. Writes `ext['reckoner']` via `clerk.setWritExt()` with source,
+   *    fully-resolved priority, and any supplied complexity/payload/labels.
+   *
+   * Returns the persisted `WritDoc` with `phase: 'new'` and
+   * `ext.reckoner` populated.
+   */
+  petition(request: PetitionRequest): Promise<WritDoc>;
+
+  /**
+   * Withdraw a held writ by transitioning it to `cancelled`.
+   *
+   * Thin wrapper around `clerk.transition(writId, 'cancelled', {resolution: reason})`.
+   * Ergonomic discoverability wrapper — identical effect to calling Clerk
+   * directly. No source check at withdraw time.
+   *
+   * Returns the updated (cancelled) `WritDoc`.
+   */
+  withdraw(writId: string, reason?: string): Promise<WritDoc>;
+
+  /**
+   * Return a snapshot of all registered petitioner descriptors.
+   *
+   * Available after `phase:started` (the registry is sealed at that point).
+   * Returns an empty array before startup is complete.
+   */
+  petitioners(): ReadonlyArray<PetitionerDescriptor>;
+
+  /**
+   * Check whether a source id is registered in the petitioner registry.
+   *
+   * Useful for tools and dashboards that want to indicate whether a source
+   * is recognised without triggering the `enforceRegistration` path.
+   */
+  isRegistered(source: string): boolean;
+
+  /**
+   * Return the resolved Reckoner configuration with all defaults applied.
+   *
+   * Reads from `guild().guildConfig().reckoner` each call so it reflects
+   * `writeConfig()` mutations without requiring a restart.
+   */
+  config(): ReckonerConfig;
+}
+
+// ── Constants ────────────────────────────────────────────────────────────
+
+/** Plugin id for the Reckoner apparatus. Matches the derived id of `@shardworks/reckoner-apparatus`. */
+export const RECKONER_PLUGIN_ID = 'reckoner';
