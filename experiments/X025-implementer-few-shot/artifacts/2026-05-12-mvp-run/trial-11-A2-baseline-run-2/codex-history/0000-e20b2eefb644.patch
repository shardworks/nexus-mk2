+/**
+ * The Reckoner — kit-static petitioner registry, guild.json configuration
+ * parsing, priority type with default-filling, and the petition() /
+ * withdraw() helper APIs.
+ *
+ * The Reckoner consumes the `petitioners` kit contribution at boot, builds
+ * a sealed registry, and exposes an ergonomic API for posting Reckoner-
+ * gated writs in the correct shape.
+ *
+ * The CDC handler that watches held writs and decides their fate is a
+ * separate commission. This apparatus is the foundation: registry, types,
+ * config parsing, and the petition/withdraw helpers.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { Plugin, StartupContext, KitEntry } from '@shardworks/nexus-core';
+import { guild } from '@shardworks/nexus-core';
+import type { ClerkApi } from '@shardworks/clerk-apparatus';
+
+import type {
+  Priority,
+  ReckonerExt,
+  ReckonerConfig,
+  PetitionerDescriptor,
+  PetitionRequest,
+  ReckonerApi,
+} from './types.ts';
+import {
+  RECKONER_PLUGIN_ID,
+  VALID_VISION_RELATION,
+  VALID_SEVERITY,
+  VALID_SCOPE,
+  VALID_DOMAIN,
+} from './types.ts';
+
+import type { WritDoc } from '@shardworks/clerk-apparatus';
+
+// ── kebab-case suffix regex ──────────────────────────────────────────────
+//
+// Matches the suffix component of a source id (`{pluginId}.{suffix}`).
+// Lowercase letters, digits, and single-hyphen separators — no leading or
+// trailing hyphen. Mirrors the Clerk's link-kind suffix regex.
+
+const SOURCE_SUFFIX_RE = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
+
+// ── Priority helpers ─────────────────────────────────────────────────────
+
+/**
+ * Return the Reckoner's default priority: all dimensions at their
+ * conservative, defer-friendly values.
+ *
+ * ```
+ * visionRelation: 'vision-neutral'
+ * severity:       'minor'
+ * scope:          'minor-area'
+ * time:           { decay: false, deadline: null }
+ * domain:         []
+ * ```
+ *
+ * Used by `petition()` to fill in any omitted dimensions from the caller's
+ * partial priority. Also useful for callers that want to override only a
+ * subset of dimensions.
+ */
+export function defaultPriority(): Priority {
+  return {
+    visionRelation: 'vision-neutral',
+    severity: 'minor',
+    scope: 'minor-area',
+    time: { decay: false, deadline: null },
+    domain: [],
+  };
+}
+
+/**
+ * Merge a partial priority object with the defaults, returning a fully
+ * specified Priority. Missing top-level fields fall back to their
+ * `defaultPriority()` value; missing `time` sub-fields fall back
+ * independently.
+ */
+function applyPriorityDefaults(partial: Partial<Priority> | undefined): Priority {
+  const defaults = defaultPriority();
+  if (!partial) return defaults;
+  return {
+    visionRelation: partial.visionRelation ?? defaults.visionRelation,
+    severity: partial.severity ?? defaults.severity,
+    scope: partial.scope ?? defaults.scope,
+    time:
+      partial.time !== undefined
+        ? {
+            decay: partial.time.decay ?? defaults.time.decay,
+            deadline:
+              partial.time.deadline !== undefined
+                ? partial.time.deadline
+                : defaults.time.deadline,
+          }
+        : defaults.time,
+    domain: partial.domain ?? defaults.domain,
+  };
+}
+
+/**
+ * Validate all dimension values in a fully-resolved Priority against the
+ * known enum values. Throws a descriptive error on any unknown value.
+ */
+function validatePriority(priority: Priority): void {
+  if (
+    !VALID_VISION_RELATION.includes(
+      priority.visionRelation as (typeof VALID_VISION_RELATION)[number],
+    )
+  ) {
+    throw new Error(
+      `[reckoner] Invalid visionRelation "${priority.visionRelation}". ` +
+        `Valid values: ${VALID_VISION_RELATION.join(', ')}.`,
+    );
+  }
+  if (
+    !VALID_SEVERITY.includes(priority.severity as (typeof VALID_SEVERITY)[number])
+  ) {
+    throw new Error(
+      `[reckoner] Invalid severity "${priority.severity}". ` +
+        `Valid values: ${VALID_SEVERITY.join(', ')}.`,
+    );
+  }
+  if (!VALID_SCOPE.includes(priority.scope as (typeof VALID_SCOPE)[number])) {
+    throw new Error(
+      `[reckoner] Invalid scope "${priority.scope}". ` +
+        `Valid values: ${VALID_SCOPE.join(', ')}.`,
+    );
+  }
+  for (const tag of priority.domain) {
+    if (!VALID_DOMAIN.includes(tag)) {
+      throw new Error(
+        `[reckoner] Invalid domain tag "${tag}". ` +
+          `Valid values: ${VALID_DOMAIN.join(', ')}.`,
+      );
+    }
+  }
+  // time.decay is boolean — any boolean is structurally valid.
+  // time.deadline is string | null — any string/null is structurally valid.
+}
+
+// ── Source-id validation ─────────────────────────────────────────────────
+
+/**
+ * Validate a source id's format: `{pluginId}.{kebab-suffix}`.
+ *
+ * Rules:
+ * - Must contain at least one `.`
+ * - The prefix (before the first `.`) must be non-empty
+ * - The suffix (after the first `.`) must match `[a-z0-9]+(?:-[a-z0-9]+)*`
+ *   (kebab-case: lowercase letters and digits separated by single hyphens,
+ *   no leading or trailing hyphen)
+ * - If `contributingPluginId` is provided, the prefix must match it exactly
+ *
+ * Throws on any violation. Callers supply `errorPrefix` to contextualise
+ * the message for their call site (e.g. `[reckoner] Kit "foo" petitioners:`).
+ */
+export function validateSourceId(
+  source: string,
+  opts: { contributingPluginId?: string; errorPrefix?: string } = {},
+): void {
+  const prefix = opts.errorPrefix ?? '[reckoner]';
+  const dotIdx = source.indexOf('.');
+  if (dotIdx <= 0 || dotIdx === source.length - 1) {
+    throw new Error(
+      `${prefix} Source id "${source}" must be of the form ` +
+        `"{pluginId}.{kebab-suffix}" (e.g. "vision-keeper.snapshot").`,
+    );
+  }
+  const pluginIdPart = source.slice(0, dotIdx);
+  const suffix = source.slice(dotIdx + 1);
+
+  if (
+    opts.contributingPluginId !== undefined &&
+    pluginIdPart !== opts.contributingPluginId
+  ) {
+    throw new Error(
+      `${prefix} Source id "${source}" has prefix "${pluginIdPart}" but ` +
+        `must match the contributing plugin id "${opts.contributingPluginId}".`,
+    );
+  }
+
+  if (!SOURCE_SUFFIX_RE.test(suffix)) {
+    throw new Error(
+      `${prefix} Source id "${source}" suffix "${suffix}" must be ` +
+        `kebab-case (lowercase letters, digits, and hyphens; not starting ` +
+        `or ending with "-").`,
+    );
+  }
+}
+
+// ── Config resolver ──────────────────────────────────────────────────────
+
+/**
+ * Read the Reckoner's config section from guild.json and apply defaults.
+ * Reads fresh each call so `writeConfig()` mutations are reflected without
+ * a restart.
+ */
+function resolveConfig(): ReckonerConfig {
+  const raw = guild().guildConfig().reckoner ?? {};
+  return {
+    enforceRegistration: raw.enforceRegistration ?? false,
+    disabledSources: raw.disabledSources ?? [],
+  };
+}
+
+// ── Registry scanning ────────────────────────────────────────────────────
+
+/** Internal registry entry — descriptor plus the contributing plugin id. */
+interface RegistryEntry {
+  descriptor: PetitionerDescriptor;
+  ownerPluginId: string;
+}
+
+/**
+ * Scan a single kit entry's `petitioners` contribution and register each
+ * descriptor into `registry`. Throws on:
+ * - Non-array `value`
+ * - Non-object entries
+ * - Missing or non-string `source` / `description`
+ * - Malformed source id (grammar check)
+ * - Plugin-id prefix mismatch
+ * - Duplicate source id (names both the existing owner and the new contributor)
+ */
+function registerKitPetitioners(
+  entry: KitEntry,
+  registry: Map<string, RegistryEntry>,
+): void {
+  const pluginId = entry.pluginId;
+  const raw = entry.value;
+
+  if (!Array.isArray(raw)) {
+    throw new Error(
+      `[reckoner] Kit "${pluginId}" petitioners: expected an array, ` +
+        `got ${typeof raw}.`,
+    );
+  }
+
+  for (const item of raw) {
+    if (typeof item !== 'object' || item === null) {
+      throw new Error(
+        `[reckoner] Kit "${pluginId}" petitioners: entry is not an ` +
+          `object (got ${item === null ? 'null' : typeof item}).`,
+      );
+    }
+    const rec = item as Record<string, unknown>;
+    const source = rec['source'];
+    const description = rec['description'];
+
+    if (typeof source !== 'string' || source.length === 0) {
+      throw new Error(
+        `[reckoner] Kit "${pluginId}" petitioners: entry is missing a ` +
+          `non-empty string "source" field.`,
+      );
+    }
+    if (typeof description !== 'string' || description.length === 0) {
+      throw new Error(
+        `[reckoner] Kit "${pluginId}" petitioners: entry "${source}" is ` +
+          `missing a non-empty string "description" field.`,
+      );
+    }
+
+    // Validate source id format (including plugin-id prefix check).
+    validateSourceId(source, {
+      contributingPluginId: pluginId,
+      errorPrefix: `[reckoner] Kit "${pluginId}" petitioners:`,
+    });
+
+    // Hard collision: two plugins contributing the same source id is a
+    // startup error — the winner is never selected by load order. Mirrors
+    // the framework-wide collision rule applied to Clerk writ-types,
+    // Spider rig-template-mappings, and the Fabricator's engines.
+    if (registry.has(source)) {
+      const existing = registry.get(source)!;
+      throw new Error(
+        `[reckoner] Duplicate petitioner source "${source}" — already ` +
+          `registered by plugin "${existing.ownerPluginId}", also contributed ` +
+          `by plugin "${pluginId}". Each source id must be unique across the guild.`,
+      );
+    }
+
+    registry.set(source, {
+      descriptor: { source, description },
+      ownerPluginId: pluginId,
+    });
+  }
+}
+
+// ── Plugin factory ───────────────────────────────────────────────────────
+
+/**
+ * Create the Reckoner apparatus plugin.
+ *
+ * Returns a `Plugin` whose apparatus:
+ * - Requires `clerk` (for `post()`, `setWritExt()`, and `transition()`).
+ * - Consumes the `petitioners` kit contribution type.
+ * - Exposes `ReckonerApi` as its `provides` object.
+ * - On `start()`, scans all `petitioners` kit entries and builds a sealed
+ *   registry; hard-fails on malformed ids or duplicate sources.
+ * - After `phase:started`, the registry is sealed and no further
+ *   registrations are possible.
+ */
+export function createReckoner(): Plugin {
+  // Registry populated during start() and logically sealed at phase:started.
+  let petitionerRegistry: Map<string, RegistryEntry> = new Map();
+
+  const api: ReckonerApi = {
+    async petition(request: PetitionRequest): Promise<WritDoc> {
+      const cfg = resolveConfig();
+      const { source } = request;
+
+      // ── Source check against registry ────────────────────────────────
+      if (!petitionerRegistry.has(source)) {
+        if (cfg.enforceRegistration) {
+          throw new Error(
+            `[reckoner] petition() failed: source "${source}" is not ` +
+              `registered in the petitioner registry. Registered sources: ` +
+              `${
+                petitionerRegistry.size === 0
+                  ? '(none)'
+                  : [...petitionerRegistry.keys()].join(', ')
+              }.`,
+          );
+        } else {
+          // Permissive mode — warn and proceed. The writ is created; the
+          // CDC handler will apply the same check when it evaluates it.
+          console.warn(
+            `[reckoner] Warning: petition source "${source}" is not ` +
+              `registered in the petitioner registry. Proceeding because ` +
+              `enforceRegistration is false.`,
+          );
+        }
+      }
+
+      // ── Apply priority defaults ──────────────────────────────────────
+      const priority = applyPriorityDefaults(request.priority);
+
+      // ── Validate dimension values ────────────────────────────────────
+      validatePriority(priority);
+
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+
+      // ── Post the writ ────────────────────────────────────────────────
+      // The writ lands in `new` phase (Clerk's default for new writs).
+      // Spider doesn't dispatch from `new`; the Reckoner CDC handler
+      // (separate commission) transitions it when it decides to approve.
+      const writ = await clerk.post({
+        type: request.type,
+        title: request.title,
+        body: request.body,
+        codex: request.codex,
+        parentId: request.parentId,
+      });
+
+      // ── Write the reckoner ext slot ──────────────────────────────────
+      // `setWritExt` performs a transactional read-modify-write on the
+      // `reckoner` sub-slot of `writ.ext` so sibling sub-slots owned by
+      // other plugins are preserved.
+      const ext: ReckonerExt = {
+        source,
+        priority,
+        ...(request.complexity !== undefined ? { complexity: request.complexity } : {}),
+        ...(request.payload !== undefined ? { payload: request.payload } : {}),
+        ...(request.labels !== undefined ? { labels: request.labels } : {}),
+      };
+
+      return clerk.setWritExt(writ.id, RECKONER_PLUGIN_ID, ext);
+    },
+
+    async withdraw(writId: string, reason?: string): Promise<WritDoc> {
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+      // Thin wrapper around clerk.transition(). Resolution is written to
+      // the `resolution` field, which persists through the terminal
+      // transition and survives in the Stacks book.
+      return clerk.transition(
+        writId,
+        'cancelled',
+        reason !== undefined ? { resolution: reason } : undefined,
+      );
+    },
+
+    petitioners(): ReadonlyArray<PetitionerDescriptor> {
+      return [...petitionerRegistry.values()].map((e) => e.descriptor);
+    },
+
+    isRegistered(source: string): boolean {
+      return petitionerRegistry.has(source);
+    },
+
+    config(): ReckonerConfig {
+      return resolveConfig();
+    },
+  };
+
+  return {
+    apparatus: {
+      requires: ['clerk'],
+      consumes: ['petitioners'],
+
+      provides: api,
+
+      async start(ctx: StartupContext): Promise<void> {
+        // Scan all kit-contributed petitioner descriptors. Malformed
+        // entries or duplicate source ids hard-fail here — a reserved
+        // source id that silently disappears (or collides with another
+        // plugin) would be worse than a startup failure.
+        petitionerRegistry = new Map();
+        for (const entry of ctx.kits('petitioners')) {
+          registerKitPetitioners(entry, petitionerRegistry);
+        }
+
+        // The registry is logically sealed at phase:started — after every
+        // apparatus's start() has completed. There is no public API to
+        // add petitioners at runtime, so sealing is structural: the only
+        // registration path is the kit contribution mechanism above.
+        // We track the event for observability and future guard points.
+        ctx.on('phase:started', () => {
+          // Registry is sealed. Any future petitioner kit contributions
+          // loaded after this point (dynamic plugin loading) would need
+          // to restart the apparatus. For now (per-plugin-load-cycle
+          // framing), this fires once at global startup completion.
+        });
+      },
+    },
+  };
+}
