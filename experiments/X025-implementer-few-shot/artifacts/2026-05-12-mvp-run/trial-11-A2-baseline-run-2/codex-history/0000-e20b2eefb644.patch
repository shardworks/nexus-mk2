+/**
+ * @shardworks/reckoner-apparatus — The Reckoner.
+ *
+ * Kit-static petitioner registry, guild.json configuration parsing, priority
+ * dimension types with default-filling, and the `reckoner.petition()` /
+ * `reckoner.withdraw()` helper APIs.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+export {
+  type DomainTag,
+  type Priority,
+  type ComplexityTier,
+  type ReckonerExt,
+  type PetitionerDescriptor,
+  type PetitionRequest,
+  type ReckonerConfig,
+  type ReckonerApi,
+  RECKONER_PLUGIN_ID,
+  VALID_VISION_RELATION,
+  VALID_SEVERITY,
+  VALID_SCOPE,
+  VALID_DOMAIN,
+} from './types.ts';
+
+export { createReckoner, defaultPriority, validateSourceId } from './reckoner.ts';
+
+// ── Default export: the apparatus plugin ──────────────────────────────────
+
+import { createReckoner } from './reckoner.ts';
+
+export default createReckoner();
