+/**
+ * Reckoner apparatus — unit tests.
+ *
+ * Covers all behavioral cases from the commission brief:
+ *
+ *   Registry building:
+ *   - Kit contributions are scanned and registered correctly.
+ *   - Malformed source id (bad format) hard-fails at startup.
+ *   - Plugin-id prefix mismatch hard-fails at startup.
+ *   - Duplicate source id (two plugins) hard-fails at startup.
+ *
+ *   petition() — source check:
+ *   - Unregistered source with enforceRegistration: false → warning, succeeds.
+ *   - Unregistered source with enforceRegistration: true → throws, no writ posted.
+ *   - Registered source → succeeds.
+ *
+ *   petition() — writ shape:
+ *   - Returns writ with phase: 'new' and ext.reckoner populated.
+ *   - All provided priority dimensions are preserved.
+ *   - Omitted priority dimensions fall back to defaultPriority().
+ *   - All ext fields (complexity, payload, labels) are set correctly.
+ *   - Invalid priority dimension values throw.
+ *
+ *   withdraw():
+ *   - Transitions the writ to 'cancelled'.
+ *   - Reason is recorded as the writ's resolution.
+ *   - Works without a reason (no resolution field).
+ *
+ *   Utilities:
+ *   - defaultPriority() returns the correct conservative defaults.
+ *   - validateSourceId() accepts and rejects cases correctly.
+ *   - petitioners() and isRegistered() reflect the registry.
+ *   - config() returns defaults when guild config is absent.
+ *   - config() reflects guild config values.
+ */
+
+import { describe, it, beforeEach, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritDoc } from '@shardworks/clerk-apparatus';
+
+import { createReckoner, defaultPriority, validateSourceId } from './reckoner.ts';
+import type { ReckonerApi, ReckonerConfig } from './types.ts';
+
+// ── Fixture helpers ──────────────────────────────────────────────────────
+
+/** Build a minimal StartupContext from an array of KitEntry records. */
+function buildCtx(entries: KitEntry[] = []): StartupContext {
+  const handlers: Array<[string, (...args: unknown[]) => void | Promise<void>]> = [];
+  return {
+    on(event: string, handler: (...args: unknown[]) => void | Promise<void>): void {
+      handlers.push([event, handler]);
+    },
+    kits(type: string): KitEntry[] {
+      return entries.filter((e) => e.type === type);
+    },
+    /** Fire a lifecycle event on all registered handlers (test helper). */
+    _fire(event: string): void {
+      for (const [e, h] of handlers) {
+        if (e === event) h();
+      }
+    },
+  } as StartupContext & { _fire(event: string): void };
+}
+
+/** Build a KitEntry for the `petitioners` contribution type. */
+function petitionersEntry(
+  pluginId: string,
+  petitioners: Array<{ source: string; description: string }>,
+): KitEntry {
+  return {
+    pluginId,
+    packageName: `@test/${pluginId}`,
+    type: 'petitioners',
+    value: petitioners,
+  };
+}
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+}
+
+/**
+ * Build a test fixture: Stacks → Clerk → Reckoner started in dependency
+ * order. `kitEntries` are fed to the Reckoner's StartupContext to simulate
+ * kit contributions.
+ *
+ * `guildConfigOverride` can supply a `reckoner` section to test config
+ * parsing (e.g. `{ reckoner: { enforceRegistration: true } }`).
+ */
+async function buildFixture(options: {
+  kitEntries?: KitEntry[];
+  guildConfigOverride?: Partial<GuildConfig>;
+} = {}): Promise<Fixture> {
+  const backend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(backend);
+  const clerkPlugin = createClerk();
+  const reckonerPlugin = createReckoner();
+
+  if (!('apparatus' in stacksPlugin)) throw new Error('stacks not an apparatus');
+  if (!('apparatus' in clerkPlugin)) throw new Error('clerk not an apparatus');
+  if (!('apparatus' in reckonerPlugin)) throw new Error('reckoner not an apparatus');
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuild: Guild = {
+    home: '/tmp/test-reckoner',
+    apparatus<T>(name: string): T {
+      const api = apparatusMap.get(name);
+      if (!api) throw new Error(`Apparatus "${name}" not installed in test fixture`);
+      return api as T;
+    },
+    config<T>(_id: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return {
+        name: 'test',
+        nexus: '0',
+        plugins: [],
+        ...(options.guildConfigOverride ?? {}),
+      };
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings() {
+      return [];
+    },
+  };
+  setGuild(fakeGuild);
+
+  // Stacks
+  stacksPlugin.apparatus.start(buildCtx());
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  backend.ensureBook({ ownerId: 'clerk', book: 'writs' }, { indexes: ['phase', 'type'] });
+  backend.ensureBook({ ownerId: 'clerk', book: 'links' }, {});
+
+  // Clerk
+  await clerkPlugin.apparatus.start(buildCtx());
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  // Reckoner
+  const reckonerCtx = buildCtx(options.kitEntries ?? []);
+  await reckonerPlugin.apparatus.start(reckonerCtx);
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  return { stacks, clerk, reckoner };
+}
+
+// ── defaultPriority() ────────────────────────────────────────────────────
+
+describe('defaultPriority()', () => {
+  it('returns all conservative defaults', () => {
+    const p = defaultPriority();
+    assert.equal(p.visionRelation, 'vision-neutral');
+    assert.equal(p.severity, 'minor');
+    assert.equal(p.scope, 'minor-area');
+    assert.equal(p.time.decay, false);
+    assert.equal(p.time.deadline, null);
+    assert.deepEqual(p.domain, []);
+  });
+
+  it('returns a fresh object on each call (no shared reference)', () => {
+    const a = defaultPriority();
+    const b = defaultPriority();
+    a.domain.push('security');
+    assert.deepEqual(b.domain, []);
+  });
+});
+
+// ── validateSourceId() ───────────────────────────────────────────────────
+
+describe('validateSourceId()', () => {
+  it('accepts valid source ids', () => {
+    assert.doesNotThrow(() => validateSourceId('vision-keeper.snapshot'));
+    assert.doesNotThrow(() => validateSourceId('patron-bridge.commission'));
+    assert.doesNotThrow(() => validateSourceId('tech-debt.detected'));
+    assert.doesNotThrow(() => validateSourceId('my-plugin.do-something'));
+    assert.doesNotThrow(() => validateSourceId('abc.xyz'));
+  });
+
+  it('rejects ids with no dot', () => {
+    assert.throws(
+      () => validateSourceId('noseparator'),
+      /must be of the form/,
+    );
+  });
+
+  it('rejects ids starting with a dot', () => {
+    assert.throws(
+      () => validateSourceId('.suffix'),
+      /must be of the form/,
+    );
+  });
+
+  it('rejects ids ending with a dot', () => {
+    assert.throws(
+      () => validateSourceId('prefix.'),
+      /must be of the form/,
+    );
+  });
+
+  it('rejects suffix with invalid characters', () => {
+    assert.throws(
+      () => validateSourceId('plugin.UPPER'),
+      /must be kebab-case/,
+    );
+    assert.throws(
+      () => validateSourceId('plugin.with!punctuation'),
+      /must be kebab-case/,
+    );
+  });
+
+  it('rejects suffix with leading hyphen', () => {
+    assert.throws(
+      () => validateSourceId('plugin.-suffix'),
+      /must be kebab-case/,
+    );
+  });
+
+  it('rejects suffix with trailing hyphen', () => {
+    assert.throws(
+      () => validateSourceId('plugin.suffix-'),
+      /must be kebab-case/,
+    );
+  });
+
+  it('rejects when contributingPluginId prefix does not match', () => {
+    assert.throws(
+      () =>
+        validateSourceId('other-plugin.snapshot', {
+          contributingPluginId: 'vision-keeper',
+        }),
+      /must match the contributing plugin id/,
+    );
+  });
+
+  it('accepts when contributingPluginId prefix matches', () => {
+    assert.doesNotThrow(() =>
+      validateSourceId('vision-keeper.snapshot', {
+        contributingPluginId: 'vision-keeper',
+      }),
+    );
+  });
+});
+
+// ── Registry building ────────────────────────────────────────────────────
+
+describe('Reckoner — registry building', () => {
+  afterEach(() => clearGuild());
+
+  it('registers petitioners from a single kit contribution', async () => {
+    const { reckoner } = await buildFixture({
+      kitEntries: [
+        petitionersEntry('vision-keeper', [
+          { source: 'vision-keeper.snapshot', description: 'Drift snapshots' },
+          { source: 'vision-keeper.elaboration', description: 'Elaboration proposals' },
+        ]),
+      ],
+    });
+
+    const ps = reckoner.petitioners();
+    assert.equal(ps.length, 2);
+    assert.ok(ps.some((p) => p.source === 'vision-keeper.snapshot'));
+    assert.ok(ps.some((p) => p.source === 'vision-keeper.elaboration'));
+  });
+
+  it('registers petitioners from multiple kit contributions', async () => {
+    const { reckoner } = await buildFixture({
+      kitEntries: [
+        petitionersEntry('vision-keeper', [
+          { source: 'vision-keeper.snapshot', description: 'Drift snapshots' },
+        ]),
+        petitionersEntry('patron-bridge', [
+          { source: 'patron-bridge.commission', description: 'Patron commissions' },
+        ]),
+      ],
+    });
+
+    assert.equal(reckoner.petitioners().length, 2);
+    assert.ok(reckoner.isRegistered('vision-keeper.snapshot'));
+    assert.ok(reckoner.isRegistered('patron-bridge.commission'));
+    assert.ok(!reckoner.isRegistered('unknown.source'));
+  });
+
+  it('starts with an empty registry when no kit contributions exist', async () => {
+    const { reckoner } = await buildFixture();
+    assert.equal(reckoner.petitioners().length, 0);
+    assert.ok(!reckoner.isRegistered('anything.here'));
+  });
+
+  it('hard-fails when two kits contribute the same source id', async () => {
+    await assert.rejects(
+      () =>
+        buildFixture({
+          kitEntries: [
+            petitionersEntry('vision-keeper', [
+              { source: 'vision-keeper.snapshot', description: 'First snapshot' },
+            ]),
+            // Same source id — different plugin id is required, but simulate a
+            // collision by constructing a valid entry from a differently-named
+            // plugin that somehow claims the same source. We test this by
+            // using two entries from the SAME plugin to hit the duplicate path.
+            petitionersEntry('vision-keeper', [
+              { source: 'vision-keeper.snapshot', description: 'Duplicate' },
+            ]),
+          ],
+        }),
+      (err: Error) => {
+        assert.ok(
+          err.message.includes('Duplicate petitioner source'),
+          `Expected duplicate error, got: ${err.message}`,
