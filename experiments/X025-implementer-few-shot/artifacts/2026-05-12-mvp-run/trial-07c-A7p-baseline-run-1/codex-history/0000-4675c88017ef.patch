+type CharacterFormProps = {
+  /** If provided, renders in edit mode with existing values pre-populated. */
+  existing?: Character;
+};
+
+type FormErrors = {
+  name?: string;
+  level?: string;
+  paragonLevel?: string;
+};
+
+export function CharacterForm({ existing }: CharacterFormProps) {
+  const router = useRouter();
+  const [name, setName] = useState(existing?.name ?? "");
+  const [d4Class, setD4Class] = useState<D4Class>(
+    existing?.class ?? "Sorcerer",
+  );
+  const [level, setLevel] = useState(String(existing?.level ?? 100));
+  const [paragonLevel, setParagonLevel] = useState(
+    String(existing?.paragonLevel ?? 0),
+  );
+  const [errors, setErrors] = useState<FormErrors>({});
+  const [saving, setSaving] = useState(false);
+  const [serverError, setServerError] = useState<string | null>(null);
+
+  const isEdit = Boolean(existing);
+
+  function validate(): FormErrors {
+    const errs: FormErrors = {};
+    if (!name.trim()) errs.name = "Name is required";
+    const lvl = Number(level);
+    if (!Number.isInteger(lvl) || lvl < 1 || lvl > MAX_CHARACTER_LEVEL) {
+      errs.level = `Level must be 1–${MAX_CHARACTER_LEVEL}`;
+    }
+    const par = Number(paragonLevel);
+    if (!Number.isInteger(par) || par < 0 || par > MAX_PARAGON_LEVEL) {
+      errs.paragonLevel = `Paragon level must be 0–${MAX_PARAGON_LEVEL}`;
+    }
+    return errs;
+  }
+
+  async function handleSubmit(e: React.FormEvent) {
+    e.preventDefault();
+    setServerError(null);
+    const errs = validate();
+    setErrors(errs);
+    if (Object.keys(errs).length > 0) return;
+
+    setSaving(true);
+    try {
+      const payload = {
+        name: name.trim(),
+        class: d4Class,
+        level: Number(level),
+        paragonLevel: Number(paragonLevel),
+      };
+
+      const url = isEdit
+        ? `/api/characters/${existing!.id}`
+        : "/api/characters";
+      const method = isEdit ? "PATCH" : "POST";
+
+      const res = await fetch(url, {
+        method,
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(payload),
+      });
+
+      if (!res.ok) {
+        const data = await res.json().catch(() => ({}));
+        throw new Error(data.error ?? `HTTP ${res.status}`);
+      }
+
+      const character: Character = await res.json();
+      router.push(`/characters/${character.id}`);
+      router.refresh();
+    } catch (err) {
+      setServerError(err instanceof Error ? err.message : "Save failed");
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  return (
+    <form onSubmit={handleSubmit} style={{ display: "flex", flexDirection: "column", gap: "20px", maxWidth: "480px" }}>
+      {serverError && (
+        <div
+          style={{
+            padding: "10px 14px",
+            borderRadius: "var(--radius-card)",
+            background: "color-mix(in srgb, var(--danger) 15%, transparent)",
+            border: "1px solid color-mix(in srgb, var(--danger) 40%, transparent)",
+            color: "var(--danger)",
+            fontSize: "13px",
+          }}
+        >
+          {serverError}
+        </div>
+      )}
+
+      {/* Name */}
+      <FieldGroup label="Character Name" error={errors.name}>
+        <input
+          type="text"
+          value={name}
+          onChange={(e) => {
+            setName(e.target.value);
+            if (errors.name) setErrors((p) => ({ ...p, name: undefined }));
+          }}
+          placeholder="e.g. Doomed Aura Sorcerer"
+          style={inputStyle(!!errors.name)}
+          autoFocus
+        />
+      </FieldGroup>
+
+      {/* Class */}
+      <FieldGroup label="Class">
+        <select
+          value={d4Class}
+          onChange={(e) => setD4Class(e.target.value as D4Class)}
+          style={selectStyle()}
+          disabled={isEdit} // class is immutable after creation
+          title={isEdit ? "Class cannot be changed after creation" : undefined}
+        >
+          {D4_CLASSES.map((c) => (
+            <option key={c} value={c}>
+              {c}
+            </option>
+          ))}
+        </select>
+        {isEdit && (
+          <div style={{ fontSize: "11px", color: "var(--stone-500)", marginTop: "4px" }}>
+            Class cannot be changed after creation.
+          </div>
+        )}
+      </FieldGroup>
+
+      {/* Level + Paragon in a row */}
+      <div style={{ display: "flex", gap: "16px" }}>
+        <FieldGroup label="Character Level" error={errors.level} style={{ flex: 1 }}>
+          <input
+            type="number"
+            min={1}
+            max={MAX_CHARACTER_LEVEL}
+            value={level}
+            onChange={(e) => {
+              setLevel(e.target.value);
+              if (errors.level) setErrors((p) => ({ ...p, level: undefined }));
+            }}
+            style={inputStyle(!!errors.level)}
+          />
+        </FieldGroup>
+
+        <FieldGroup
+          label="Paragon Level"
+          error={errors.paragonLevel}
+          style={{ flex: 1 }}
+        >
+          <input
+            type="number"
+            min={0}
+            max={MAX_PARAGON_LEVEL}
+            value={paragonLevel}
+            onChange={(e) => {
+              setParagonLevel(e.target.value);
+              if (errors.paragonLevel)
+                setErrors((p) => ({ ...p, paragonLevel: undefined }));
+            }}
+            style={inputStyle(!!errors.paragonLevel)}
+          />
+        </FieldGroup>
+      </div>
+
+      {/* Actions */}
+      <div style={{ display: "flex", gap: "10px", paddingTop: "4px" }}>
+        <button type="submit" disabled={saving} style={primaryButtonStyle}>
+          {saving ? "Saving…" : isEdit ? "Save Changes" : "Create Character"}
+        </button>
+        <button
+          type="button"
+          onClick={() => router.back()}
+          style={secondaryButtonStyle}
+        >
+          Cancel
+        </button>
+      </div>
+    </form>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// Sub-components
+// ---------------------------------------------------------------------------
+
+function FieldGroup({
+  label,
+  error,
+  children,
+  style,
+}: {
+  label: string;
+  error?: string;
+  children: React.ReactNode;
+  style?: React.CSSProperties;
+}) {
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "6px", ...style }}>
+      <label
+        style={{
+          fontSize: "12px",
+          fontWeight: 600,
+          color: "var(--stone-400)",
+          textTransform: "uppercase",
+          letterSpacing: "0.06em",
+        }}
+      >
+        {label}
+      </label>
+      {children}
+      {error && (
+        <div style={{ fontSize: "12px", color: "var(--danger)" }}>{error}</div>
+      )}
+    </div>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// Style helpers
+// ---------------------------------------------------------------------------
+
+function inputStyle(hasError: boolean): React.CSSProperties {
+  return {
+    height: "32px",
+    padding: "0 10px",
+    background: "var(--surface-2)",
+    border: `1px solid ${hasError ? "var(--danger)" : "var(--stone-700)"}`,
+    borderRadius: "var(--radius-card)",
+    color: "var(--stone-100)",
+    fontSize: "13px",
+    fontFamily: "var(--font-sans)",
+    outline: "none",
+    width: "100%",
+    boxSizing: "border-box",
+  };
+}
+
+function selectStyle(): React.CSSProperties {
+  return {
+    height: "32px",
+    padding: "0 10px",
+    background: "var(--surface-2)",
+    border: "1px solid var(--stone-700)",
+    borderRadius: "var(--radius-card)",
+    color: "var(--stone-100)",
+    fontSize: "13px",
+    fontFamily: "var(--font-sans)",
+    outline: "none",
+    width: "100%",
+    cursor: "pointer",
+  };
+}
+
+const primaryButtonStyle: React.CSSProperties = {
+  height: "32px",
+  padding: "0 16px",
+  background: "var(--accent)",
+  border: "none",
+  borderRadius: "var(--radius-card)",
+  color: "var(--stone-950)",
+  fontSize: "13px",
+  fontWeight: 600,
+  cursor: "pointer",
+};
+
+const secondaryButtonStyle: React.CSSProperties = {
+  height: "32px",
+  padding: "0 16px",
+  background: "transparent",
+  border: "1px solid var(--stone-700)",
+  borderRadius: "var(--radius-card)",
+  color: "var(--stone-300)",
+  fontSize: "13px",
+  cursor: "pointer",
+};
diff --git a/components/d4/ItemEditor.tsx b/components/d4/ItemEditor.tsx
