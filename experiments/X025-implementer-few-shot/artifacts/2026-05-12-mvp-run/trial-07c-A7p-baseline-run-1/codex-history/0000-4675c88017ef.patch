+import { describe, it, expect } from "vitest";
+import {
+  AFFIX_DEFS,
+  affixesForSlot,
+  getAffixDef,
+  validateAffixValue,
+  ASPECT_DEFS,
+  aspectsForSlot,
+  getAspectDef,
+  SKILL_DEFS,
+  skillsForClass,
+  getSkillDef,
+  validateSkillRank,
+  SLOT_DEFS,
+  slotsForClass,
+  getSlotDef,
+} from "../lib/catalog";
+import { D4_CLASSES } from "../lib/types";
+import type { D4Class } from "../lib/types";
+
+// ---------------------------------------------------------------------------
+// Affix catalog
+// ---------------------------------------------------------------------------
+
+describe("AFFIX_DEFS", () => {
+  it("has affixes for all key stat categories", () => {
+    const ids = AFFIX_DEFS.map((a) => a.id);
+    expect(ids).toContain("critical_strike_chance");
+    expect(ids).toContain("critical_strike_damage");
+    expect(ids).toContain("vulnerable_damage");
+    expect(ids).toContain("attack_speed");
+    expect(ids).toContain("maximum_life");
+    expect(ids).toContain("cooldown_reduction");
+    expect(ids).toContain("movement_speed");
+  });
+
+  it("every affix has minValue ≤ maxValue", () => {
+    for (const affix of AFFIX_DEFS) {
+      expect(affix.minValue).toBeLessThanOrEqual(affix.maxValue);
+    }
+  });
+
+  it("every affix has a non-empty label and id", () => {
+    for (const affix of AFFIX_DEFS) {
+      expect(affix.id).toBeTruthy();
+      expect(affix.label).toBeTruthy();
+    }
+  });
+
+  it("affix IDs are unique", () => {
+    const ids = AFFIX_DEFS.map((a) => a.id);
+    const unique = new Set(ids);
+    expect(unique.size).toBe(ids.length);
+  });
+});
+
+describe("affixesForSlot", () => {
+  it("returns affixes for helm slot", () => {
+    const result = affixesForSlot("helm");
+    expect(result.length).toBeGreaterThan(0);
+  });
+
+  it("filters by class — Intelligence only for Sorcerer", () => {
+    const sorcererResult = affixesForSlot("helm", "Sorcerer");
+    const barbarianResult = affixesForSlot("helm", "Barbarian");
+    const intAffix = sorcererResult.find((a) => a.id === "intelligence");
+    const intForBarbarian = barbarianResult.find((a) => a.id === "intelligence");
+    expect(intAffix).toBeDefined();
+    expect(intForBarbarian).toBeUndefined();
+  });
+
+  it("returns Strength for Barbarian but not Sorcerer", () => {
+    const barResults = affixesForSlot("chest", "Barbarian");
+    const socResults = affixesForSlot("chest", "Sorcerer");
+    expect(barResults.find((a) => a.id === "strength")).toBeDefined();
+    expect(socResults.find((a) => a.id === "strength")).toBeUndefined();
+  });
+
+  it("returns weapon affixes for mainHand slot", () => {
+    const result = affixesForSlot("mainHand");
+    expect(result.find((a) => a.id === "critical_strike_damage")).toBeDefined();
+  });
+
+  it("does not return helm-only affixes for ring slots", () => {
+    const result = affixesForSlot("ring1");
+    // cooldown_reduction is only on helm, amulet, offHand
+    const cdr = result.find((a) => a.id === "cooldown_reduction");
+    expect(cdr).toBeUndefined();
+  });
+});
+
+describe("getAffixDef", () => {
+  it("returns the correct affix by id", () => {
+    const def = getAffixDef("maximum_life");
+    expect(def).toBeDefined();
+    expect(def?.label).toBe("Maximum Life");
+  });
+
+  it("returns undefined for unknown id", () => {
+    expect(getAffixDef("does_not_exist")).toBeUndefined();
+  });
+});
+
+describe("validateAffixValue", () => {
+  it("returns null for valid value within range", () => {
+    const def = getAffixDef("critical_strike_chance");
+    expect(def).toBeDefined();
+    const midpoint = (def!.minValue + def!.maxValue) / 2;
+    expect(validateAffixValue("critical_strike_chance", midpoint)).toBeNull();
+  });
+
+  it("returns error when value is below min", () => {
+    const def = getAffixDef("critical_strike_chance")!;
+    const err = validateAffixValue("critical_strike_chance", def.minValue - 1);
+    expect(err).toBeTruthy();
+    expect(err).toContain("Min value");
+  });
+
+  it("returns error when value is above max", () => {
+    const def = getAffixDef("critical_strike_chance")!;
+    const err = validateAffixValue("critical_strike_chance", def.maxValue + 1);
+    expect(err).toBeTruthy();
+    expect(err).toContain("Max value");
+  });
+
+  it("returns error for unknown affix ID", () => {
+    const err = validateAffixValue("unknown_affix", 5);
+    expect(err).toBeTruthy();
+    expect(err).toContain("Unknown affix");
+  });
+
+  it("returns error for NaN value", () => {
+    const err = validateAffixValue("critical_strike_chance", NaN);
+    expect(err).toBeTruthy();
+  });
+});
+
+// ---------------------------------------------------------------------------
+// Aspect catalog
+// ---------------------------------------------------------------------------
+
+describe("ASPECT_DEFS", () => {
+  it("has aspects for all classes", () => {
+    for (const cls of D4_CLASSES) {
+      const classAspects = ASPECT_DEFS.filter(
+        (a) => !a.classes || a.classes.includes(cls),
+      );
+      expect(classAspects.length).toBeGreaterThan(0);
+    }
+  });
+
+  it("aspect IDs are unique", () => {
+    const ids = ASPECT_DEFS.map((a) => a.id);
+    const unique = new Set(ids);
+    expect(unique.size).toBe(ids.length);
+  });
+
+  it("aspects with hasValue have minValue and maxValue", () => {
+    for (const aspect of ASPECT_DEFS) {
+      if (aspect.hasValue) {
+        expect(aspect.minValue).toBeDefined();
+        expect(aspect.maxValue).toBeDefined();
+        expect(aspect.minValue!).toBeLessThanOrEqual(aspect.maxValue!);
+      }
+    }
+  });
+});
+
+describe("aspectsForSlot", () => {
+  it("returns aspects for amulet slot", () => {
+    const result = aspectsForSlot("amulet");
+    expect(result.length).toBeGreaterThan(0);
+  });
+
+  it("filters class-specific aspects", () => {
+    const sorcAspects = aspectsForSlot("mainHand", "Sorcerer");
+    const barbAspects = aspectsForSlot("mainHand", "Barbarian");
+    // Aspect of Piercing Cold should only be for Sorcerer
+    expect(sorcAspects.find((a) => a.id === "piercing_cold")).toBeDefined();
+    expect(barbAspects.find((a) => a.id === "piercing_cold")).toBeUndefined();
+  });
+});
+
+describe("getAspectDef", () => {
+  it("returns the correct aspect by id", () => {
+    const def = getAspectDef("conceited");
+    expect(def).toBeDefined();
+    expect(def?.name).toBe("Conceited Aspect");
+  });
+
+  it("returns undefined for unknown id", () => {
+    expect(getAspectDef("nonexistent_aspect")).toBeUndefined();
+  });
+});
+
+// ---------------------------------------------------------------------------
+// Skill catalog
+// ---------------------------------------------------------------------------
+
+describe("SKILL_DEFS", () => {
+  it("has skills for every class", () => {
+    for (const cls of D4_CLASSES as D4Class[]) {
+      const classSkills = SKILL_DEFS.filter((s) => s.class === cls);
+      expect(classSkills.length).toBeGreaterThan(0);
+    }
+  });
+
+  it("skill IDs are unique", () => {
+    const ids = SKILL_DEFS.map((s) => s.id);
+    const unique = new Set(ids);
+    expect(unique.size).toBe(ids.length);
+  });
+
+  it("all skills have maxRank >= 1", () => {
+    for (const skill of SKILL_DEFS) {
+      expect(skill.maxRank).toBeGreaterThanOrEqual(1);
+    }
+  });
+
+  it("key-passive skills have maxRank = 1", () => {
+    const keyPassives = SKILL_DEFS.filter((s) => s.category === "key-passive");
+    expect(keyPassives.length).toBeGreaterThan(0);
+    for (const kp of keyPassives) {
+      expect(kp.maxRank).toBe(1);
+    }
+  });
+});
+
+describe("skillsForClass", () => {
+  it("returns Sorcerer skills", () => {
+    const result = skillsForClass("Sorcerer");
+    expect(result.length).toBeGreaterThan(10);
+    expect(result.every((s) => s.class === "Sorcerer")).toBe(true);
+  });
+
+  it("filters by category", () => {
+    const cores = skillsForClass("Sorcerer", "core");
+    expect(cores.length).toBeGreaterThan(0);
+    expect(cores.every((s) => s.category === "core")).toBe(true);
+  });
+});
+
+describe("getSkillDef", () => {
+  it("returns the correct skill", () => {
+    const def = getSkillDef("soc_blizzard");
+    expect(def).toBeDefined();
+    expect(def?.name).toBe("Blizzard");
+    expect(def?.class).toBe("Sorcerer");
+  });
+
+  it("returns undefined for unknown skill", () => {
+    expect(getSkillDef("nonexistent_skill")).toBeUndefined();
+  });
+});
+
+describe("validateSkillRank", () => {
+  it("accepts valid ranks", () => {
+    expect(validateSkillRank("soc_blizzard", 1)).toBeNull();
+    expect(validateSkillRank("soc_blizzard", 5)).toBeNull();
+  });
+
+  it("rejects rank below 1", () => {
+    const err = validateSkillRank("soc_blizzard", 0);
+    expect(err).toBeTruthy();
+  });
+
+  it("rejects rank above maxRank", () => {
+    const def = getSkillDef("soc_avalanche"); // key-passive, maxRank=1
+    expect(def?.maxRank).toBe(1);
+    const err = validateSkillRank("soc_avalanche", 2);
+    expect(err).toBeTruthy();
+    expect(err).toContain("Max rank");
+  });
+
+  it("rejects unknown skill ID", () => {
+    const err = validateSkillRank("nonexistent", 1);
+    expect(err).toBeTruthy();
+    expect(err).toContain("Unknown skill");
+  });
+});
+
+// ---------------------------------------------------------------------------
+// Slot catalog
+// ---------------------------------------------------------------------------
+
+describe("SLOT_DEFS", () => {
+  it("defines 13 total slots", () => {
+    expect(SLOT_DEFS.length).toBe(13);
+  });
+
+  it("includes the three clusters", () => {
+    const clusters = new Set(SLOT_DEFS.map((s) => s.cluster));
+    expect(clusters.has("armor")).toBe(true);
+    expect(clusters.has("weapon")).toBe(true);
+    expect(clusters.has("jewelry")).toBe(true);
+  });
+
+  it("Barbarian-only weapon slots exist", () => {
+    const barbSlots = SLOT_DEFS.filter((s) => s.classes?.includes("Barbarian"));
+    expect(barbSlots.length).toBe(3);
+  });
+});
+
+describe("slotsForClass", () => {
+  it("Barbarian gets all 13 slots", () => {
+    expect(slotsForClass("Barbarian").length).toBe(13);
+  });
+
+  it("Sorcerer gets 10 slots (no Barb-only slots)", () => {
+    expect(slotsForClass("Sorcerer").length).toBe(10);
+  });
+
+  it("all classes get at least 10 slots", () => {
+    for (const cls of D4_CLASSES) {
+      expect(slotsForClass(cls).length).toBeGreaterThanOrEqual(10);
+    }
+  });
+});
+
+describe("getSlotDef", () => {
+  it("returns helm slot definition", () => {
+    const def = getSlotDef("helm");
+    expect(def?.label).toBe("Helm");
+    expect(def?.cluster).toBe("armor");
+  });
+
+  it("returns undefined for unknown slot", () => {
+    expect(getSlotDef("unknown_slot")).toBeUndefined();
+  });
+});
