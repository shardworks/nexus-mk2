@@ -0,0 +1,316 @@
+"use client";
+
+import { useState, useCallback } from "react";
+import { useRouter } from "next/navigation";
+import { ItemEditor } from "./ItemEditor";
+import { SkillEditor } from "./SkillEditor";
+import { slotsForClass } from "@/lib/catalog";
+import type {
+  Build,
+  Character,
+  EquippedItem,
+  EquippedSkill,
+  ItemSlotId,
+} from "@/lib/types";
+
+// ---------------------------------------------------------------------------
+// Props
+// ---------------------------------------------------------------------------
+
+type BuildFormProps = {
+  character: Character;
+  existing?: Build;
+};
+
+// ---------------------------------------------------------------------------
+// Component
+// ---------------------------------------------------------------------------
+
+export function BuildForm({ character, existing }: BuildFormProps) {
+  const router = useRouter();
+  const isEdit = Boolean(existing);
+
+  const [buildName, setBuildName] = useState(existing?.name ?? "");
+  const [nameError, setNameError] = useState<string | undefined>();
+  const [skills, setSkills] = useState<EquippedSkill[]>(existing?.skills ?? []);
+  const [equippedItems, setEquippedItems] = useState<
+    Partial<Record<ItemSlotId, EquippedItem>>
+  >(existing?.equippedItems ?? {});
+  const [notes, setNotes] = useState(existing?.notes ?? "");
+  const [saving, setSaving] = useState(false);
+  const [serverError, setServerError] = useState<string | null>(null);
+  const [activeTab, setActiveTab] = useState<"gear" | "skills" | "notes">("gear");
+
+  const slots = slotsForClass(character.class);
+
+  // -------------------------------------------------------------------------
+  // Item change handler
+  // -------------------------------------------------------------------------
+
+  const handleItemChange = useCallback(
+    (slotId: ItemSlotId, item: EquippedItem | undefined) => {
+      setEquippedItems((prev) => {
+        const next = { ...prev };
+        if (item) {
+          next[slotId] = item;
+        } else {
+          delete next[slotId];
+        }
+        return next;
+      });
+    },
+    [],
+  );
+
+  // -------------------------------------------------------------------------
+  // Submit
+  // -------------------------------------------------------------------------
+
+  async function handleSubmit(e: React.FormEvent) {
+    e.preventDefault();
+    setServerError(null);
+
+    if (!buildName.trim()) {
+      setNameError("Build name is required");
+      return;
+    }
+
+    setSaving(true);
+    try {
+      const payload = {
+        characterId: character.id,
+        name: buildName.trim(),
+        skills,
+        equippedItems,
+        paragonBoards: existing?.paragonBoards ?? [],
+        playstyleConstraints: existing?.playstyleConstraints ?? {},
+        notes: notes.trim() || undefined,
+      };
+
+      const url = isEdit ? `/api/builds/${existing!.id}` : "/api/builds";
+      const method = isEdit ? "PATCH" : "POST";
+
+      const res = await fetch(url, {
+        method,
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(payload),
+      });
+
+      if (!res.ok) {
+        const data = await res.json().catch(() => ({}));
+        throw new Error(data.error ?? `HTTP ${res.status}`);
+      }
+
+      const build: Build = await res.json();
+      router.push(`/builds/${build.id}`);
+      router.refresh();
+    } catch (err) {
+      setServerError(err instanceof Error ? err.message : "Save failed");
+    } finally {
+      setSaving(false);
+    }
+  }
+
+  // -------------------------------------------------------------------------
+  // Render
+  // -------------------------------------------------------------------------
+
+  return (
+    <form onSubmit={handleSubmit} style={{ display: "flex", flexDirection: "column", gap: "20px" }}>
+      {serverError && (
+        <div style={errorBannerStyle}>{serverError}</div>
+      )}
+
+      {/* Build name */}
+      <div style={{ display: "flex", flexDirection: "column", gap: "6px", maxWidth: "480px" }}>
+        <label style={labelStyle}>Build Name</label>
+        <input
+          type="text"
+          value={buildName}
+          onChange={(e) => {
+            setBuildName(e.target.value);
+            if (nameError) setNameError(undefined);
+          }}
+          placeholder="e.g. Blizzard / Ice Shards"
+          style={inputStyle(!!nameError)}
+          autoFocus
+        />
+        {nameError && <div style={{ fontSize: "12px", color: "var(--danger)" }}>{nameError}</div>}
+      </div>
+
+      {/* Character badge */}
+      <div
+        style={{
+          fontSize: "12px",
+          color: "var(--stone-500)",
+          padding: "6px 10px",
+          background: "var(--surface-1)",
+          borderRadius: "var(--radius-card)",
+          border: "1px solid var(--stone-800)",
+          display: "inline-block",
+        }}
+      >
+        {character.name} · <span style={{ color: "var(--accent)" }}>{character.class}</span> · Lv {character.level} · Paragon {character.paragonLevel}
+      </div>
+
+      {/* Tab nav */}
+      <div style={{ display: "flex", gap: "0", borderBottom: "1px solid var(--stone-800)" }}>
+        {(["gear", "skills", "notes"] as const).map((tab) => (
+          <button
+            key={tab}
+            type="button"
+            onClick={() => setActiveTab(tab)}
+            style={{
+              height: "34px",
+              padding: "0 16px",
+              background: "none",
+              border: "none",
+              borderBottom: activeTab === tab ? "2px solid var(--accent)" : "2px solid transparent",
+              color: activeTab === tab ? "var(--accent)" : "var(--stone-400)",
+              fontSize: "13px",
+              fontWeight: activeTab === tab ? 600 : 400,
+              cursor: "pointer",
+              marginBottom: "-1px",
+              textTransform: "capitalize",
+            }}
+          >
+            {tab}
+          </button>
+        ))}
+      </div>
+
+      {/* Gear tab */}
+      {activeTab === "gear" && (
+        <div style={{ display: "flex", flexDirection: "column", gap: "8px" }}>
+          <div
+            style={{
+              fontSize: "11px",
+              color: "var(--stone-600)",
+              marginBottom: "4px",
+            }}
+          >
+            {Object.keys(equippedItems).length} / {slots.length} slots filled
+          </div>
+          {slots.map((slot) => (
+            <ItemEditor
+              key={slot.id}
+              slotId={slot.id}
+              slotLabel={slot.label}
+              d4Class={character.class}
+              item={equippedItems[slot.id]}
+              onChange={handleItemChange}
+            />
+          ))}
+        </div>
+      )}
+
+      {/* Skills tab */}
+      {activeTab === "skills" && (
+        <SkillEditor
+          d4Class={character.class}
+          characterLevel={character.level}
+          skills={skills}
+          onChange={setSkills}
+        />
+      )}
+
+      {/* Notes tab */}
+      {activeTab === "notes" && (
+        <div style={{ display: "flex", flexDirection: "column", gap: "6px" }}>
+          <label style={labelStyle}>Notes</label>
+          <textarea
+            value={notes}
+            onChange={(e) => setNotes(e.target.value)}
+            placeholder="Build notes, strategy, target gear…"
+            rows={8}
+            style={{
+              padding: "10px",
+              background: "var(--surface-2)",
+              border: "1px solid var(--stone-700)",
+              borderRadius: "var(--radius-card)",
+              color: "var(--stone-100)",
+              fontSize: "13px",
+              fontFamily: "var(--font-sans)",
+              resize: "vertical",
+              outline: "none",
+            }}
+          />
+        </div>
+      )}
+
+      {/* Action bar */}
+      <div style={{ display: "flex", gap: "10px", paddingTop: "4px" }}>
+        <button type="submit" disabled={saving} style={primaryButtonStyle}>
+          {saving ? "Saving…" : isEdit ? "Save Changes" : "Create Build"}
+        </button>
+        <button
+          type="button"
+          onClick={() => router.back()}
+          style={secondaryButtonStyle}
+        >
+          Cancel
+        </button>
+      </div>
+    </form>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// Style helpers
+// ---------------------------------------------------------------------------
+
+const labelStyle: React.CSSProperties = {
+  fontSize: "12px",
+  fontWeight: 600,
+  color: "var(--stone-400)",
+  textTransform: "uppercase",
+  letterSpacing: "0.06em",
+};
+
+function inputStyle(hasError: boolean): React.CSSProperties {
+  return {
+    height: "32px",
+    padding: "0 10px",
+    background: "var(--surface-2)",
+    border: `1px solid ${hasError ? "var(--danger)" : "var(--stone-700)"}`,
+    borderRadius: "var(--radius-card)",
+    color: "var(--stone-100)",
+    fontSize: "13px",
+    fontFamily: "var(--font-sans)",
+    outline: "none",
+    width: "100%",
+    boxSizing: "border-box",
+  };
+}
+
+const errorBannerStyle: React.CSSProperties = {
+  padding: "10px 14px",
+  borderRadius: "var(--radius-card)",
+  background: "color-mix(in srgb, var(--danger) 15%, transparent)",
+  border: "1px solid color-mix(in srgb, var(--danger) 40%, transparent)",
+  color: "var(--danger)",
+  fontSize: "13px",
+};
+
+const primaryButtonStyle: React.CSSProperties = {
+  height: "32px",
+  padding: "0 16px",
+  background: "var(--accent)",
+  border: "none",
+  borderRadius: "var(--radius-card)",
+  color: "var(--stone-950)",
+  fontSize: "13px",
+  fontWeight: 600,
+  cursor: "pointer",
+};
+
+const secondaryButtonStyle: React.CSSProperties = {
+  height: "32px",
+  padding: "0 16px",
+  background: "transparent",
+  border: "1px solid var(--stone-700)",
+  borderRadius: "var(--radius-card)",
+  color: "var(--stone-300)",
+  fontSize: "13px",
+  cursor: "pointer",
+};
