--- /dev/null
+++ b/app/builds/[id]/page.tsx
@@ -0,0 +1,195 @@
+import Link from "next/link";
+import { notFound } from "next/navigation";
+import { getBuild } from "@/lib/persistence/builds";
+import { getCharacter } from "@/lib/persistence/characters";
+import { BuildSummaryView } from "@/components/d4/BuildSummaryView";
+import { PencilIcon } from "lucide-react";
+import { getAffixDef, getAspectDef } from "@/lib/catalog";
+import type { Build, Character, EquippedItem } from "@/lib/types";
+
+export const dynamic = "force-dynamic";
+
+interface Props {
+  params: Promise<{ id: string }>;
+}
+
+export default async function BuildDetailPage({ params }: Props) {
+  const { id } = await params;
+  const build = await getBuild(id);
+  if (!build) notFound();
+
+  const character = await getCharacter(build.characterId);
+  if (!character) notFound();
+
+  // Convert Build to the shape BuildSummaryView expects
+  const summaryCharacter = buildToSummary(build, character);
+
+  return (
+    <div>
+      {/* Breadcrumb + actions */}
+      <div
+        style={{
+          display: "flex",
+          alignItems: "center",
+          justifyContent: "space-between",
+          marginBottom: "24px",
+          gap: "16px",
+        }}
+      >
+        <div style={{ fontSize: "13px", color: "var(--stone-500)" }}>
+          <Link href="/characters" style={{ color: "var(--stone-500)", textDecoration: "none" }}>
+            Characters
+          </Link>
+          {" / "}
+          <Link
+            href={`/characters/${character.id}`}
+            style={{ color: "var(--stone-500)", textDecoration: "none" }}
+          >
+            {character.name}
+          </Link>
+          {" / "}
+          <span style={{ color: "var(--stone-300)" }}>{build.name}</span>
+        </div>
+        <Link href={`/builds/${id}/edit`} style={{ textDecoration: "none" }}>
+          <button style={editButtonStyle}>
+            <PencilIcon size={13} />
+            Edit Build
+          </button>
+        </Link>
+      </div>
+
+      <BuildSummaryView character={summaryCharacter} />
+
+      {build.notes && (
+        <div
+          style={{
+            marginTop: "32px",
+            padding: "16px",
+            background: "var(--surface-1)",
+            border: "1px solid var(--stone-800)",
+            borderRadius: "var(--radius-card)",
+            maxWidth: "640px",
+          }}
+        >
+          <div
+            style={{
+              fontSize: "11px",
+              fontWeight: 600,
+              color: "var(--stone-500)",
+              textTransform: "uppercase",
+              letterSpacing: "0.08em",
+              marginBottom: "8px",
+            }}
+          >
+            Notes
+          </div>
+          <div style={{ fontSize: "13px", color: "var(--stone-300)", whiteSpace: "pre-wrap" }}>
+            {build.notes}
+          </div>
+        </div>
+      )}
+    </div>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// Convert Build + Character → BuildSummaryView props shape
+// ---------------------------------------------------------------------------
+
+function buildToSummary(build: Build, character: Character) {
+  // Convert equippedItems to the v1-compatible Item array
+  const items = Object.values(build.equippedItems).map((item: EquippedItem) => ({
+    id: item.id,
+    slot: item.slotId,
+    name: item.name || "(unnamed)",
+    rarity: item.rarity,
+    itemPower: item.itemPower,
+    affixes: item.affixes.map((a) => {
+      const def = getAffixDef(a.affixId);
+      return {
+        label: def?.label ?? a.affixId,
+        value: formatAffixValue(a.value, def?.valueUnit ?? "flat"),
+      };
+    }),
+    aspectName: item.aspectId ? getAspectDef(item.aspectId)?.name : undefined,
+    isAncestral: item.isAncestral,
+  }));
+
+  // Derive aggregate stats from equipped items (simplified display)
+  const stats = deriveStats(build);
+
+  return {
+    name: character.name,
+    class: character.class,
+    level: character.level,
+    paragon: character.paragonLevel,
+    buildName: build.name,
+    items,
+    stats,
+  };
+}
+
+function formatAffixValue(value: number, unit: string): string {
+  if (unit === "percent") return `+${value}%`;
+  if (unit === "count") return `+${value}`;
+  return `+${value}`;
+}
+
+function deriveStats(build: Build): Array<{ label: string; value: string }> {
+  const stats: Array<{ label: string; value: string }> = [];
+  const items = Object.values(build.equippedItems);
+
+  // Aggregate affix totals for display
+  const totals: Record<string, number> = {};
+  for (const item of items) {
+    for (const affix of item.affixes) {
+      totals[affix.affixId] = (totals[affix.affixId] ?? 0) + affix.value;
+    }
+  }
+
+  // Key stats to surface
+  const DISPLAY_ORDER = [
+    "critical_strike_chance",
+    "critical_strike_damage",
+    "vulnerable_damage",
+    "attack_speed",
+    "cooldown_reduction",
+    "maximum_life",
+    "armor",
+    "movement_speed",
+    "damage_reduction",
+    "resistance_all",
+  ];
+
+  for (const id of DISPLAY_ORDER) {
+    const total = totals[id];
+    if (!total) continue;
+    const def = getAffixDef(id);
+    if (!def) continue;
+    stats.push({
+      label: def.label,
+      value: def.valueUnit === "percent" ? `${total.toFixed(1)}%` : String(Math.round(total)),
+    });
+  }
+
+  // Skills
+  if (build.skills.length > 0) {
+    stats.push({ label: "Skills Allocated", value: String(build.skills.length) });
+  }
+
+  return stats;
+}
+
+const editButtonStyle: React.CSSProperties = {
+  display: "inline-flex",
+  alignItems: "center",
+  gap: "6px",
+  height: "28px",
+  padding: "0 12px",
+  background: "transparent",
+  border: "1px solid var(--stone-700)",
+  borderRadius: "var(--radius-card)",
+  color: "var(--stone-300)",
+  fontSize: "12px",
+  cursor: "pointer",
+};
