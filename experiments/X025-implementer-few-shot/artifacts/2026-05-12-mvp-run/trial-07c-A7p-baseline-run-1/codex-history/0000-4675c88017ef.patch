+import type { SlotDef } from "@/lib/types";
+
+/**
+ * Canonical gear slot definitions.
+ * Matches the slot IDs used throughout the application.
+ */
+export const SLOT_DEFS: readonly SlotDef[] = [
+  // Armor cluster
+  { id: "helm",    label: "Helm",    cluster: "armor" },
+  { id: "chest",   label: "Chest",   cluster: "armor" },
+  { id: "gloves",  label: "Gloves",  cluster: "armor" },
+  { id: "pants",   label: "Pants",   cluster: "armor" },
+  { id: "boots",   label: "Boots",   cluster: "armor" },
+  // Weapon cluster
+  { id: "mainHand", label: "Main Hand",       cluster: "weapon" },
+  { id: "offHand",  label: "Off Hand / Focus", cluster: "weapon" },
+  {
+    id: "weapon3",
+    label: "2H Bludgeoning",
+    cluster: "weapon",
+    classes: ["Barbarian"],
+  },
+  {
+    id: "weapon4",
+    label: "2H Slashing",
+    cluster: "weapon",
+    classes: ["Barbarian"],
+  },
+  {
+    id: "weapon5",
+    label: "1H Off-Weapon",
+    cluster: "weapon",
+    classes: ["Barbarian"],
+  },
+  // Jewelry cluster
+  { id: "amulet", label: "Amulet",  cluster: "jewelry" },
+  { id: "ring1",  label: "Ring 1",  cluster: "jewelry" },
+  { id: "ring2",  label: "Ring 2",  cluster: "jewelry" },
+] as const;
+
+/** Returns all slots visible for a given class. */
+export function slotsForClass(d4Class: string): SlotDef[] {
+  return SLOT_DEFS.filter(
+    (s) => !s.classes || s.classes.includes(d4Class as never),
+  ) as SlotDef[];
+}
+
+/** Returns a slot definition by ID, or undefined if not found. */
+export function getSlotDef(id: string): SlotDef | undefined {
+  return SLOT_DEFS.find((s) => s.id === id);
+}
