@@ -0,0 +1,609 @@
+"use client";
+
+import { useState, useCallback } from "react";
+import { ChevronDownIcon, ChevronRightIcon, PlusIcon, TrashIcon, StarIcon } from "lucide-react";
+import {
+  affixesForSlot,
+  getAffixDef,
+  validateAffixValue,
+  aspectsForSlot,
+  getAspectDef,
+} from "@/lib/catalog";
+import type {
+  EquippedItem,
+  ItemRarity,
+  ItemSlotId,
+  RolledAffix,
+} from "@/lib/types";
+import { MAX_EXPLICIT_AFFIXES, MAX_TEMPERED_AFFIXES } from "@/lib/types";
+
+// ---------------------------------------------------------------------------
+// Types
+// ---------------------------------------------------------------------------
+
+type ItemEditorProps = {
+  slotId: ItemSlotId;
+  slotLabel: string;
+  d4Class: string;
+  item: EquippedItem | undefined;
+  onChange: (slotId: ItemSlotId, item: EquippedItem | undefined) => void;
+};
+
+type AffixErrors = Record<number, string | undefined>;
+
+// ---------------------------------------------------------------------------
+// Rarity colour map
+// ---------------------------------------------------------------------------
+
+const RARITIES: ItemRarity[] = [
+  "common", "magic", "rare", "legendary", "unique", "mythic",
+];
+
+const rarityColor: Record<ItemRarity, string> = {
+  common:    "var(--rarity-common)",
+  magic:     "var(--rarity-magic)",
+  rare:      "var(--rarity-rare)",
+  legendary: "var(--rarity-legendary)",
+  unique:    "var(--rarity-unique)",
+  mythic:    "var(--rarity-mythic)",
+};
+
+// ---------------------------------------------------------------------------
+// Helper — blank item
+// ---------------------------------------------------------------------------
+
+function blankItem(slotId: ItemSlotId): EquippedItem {
+  return {
+    id: `${slotId}-${Date.now()}`,
+    slotId,
+    name: "",
+    rarity: "legendary",
+    affixes: [],
+  };
+}
+
+// ---------------------------------------------------------------------------
+// Main component
+// ---------------------------------------------------------------------------
+
+export function ItemEditor({
+  slotId,
+  slotLabel,
+  d4Class,
+  item,
+  onChange,
+}: ItemEditorProps) {
+  const [expanded, setExpanded] = useState(Boolean(item));
+  const [affixErrors, setAffixErrors] = useState<AffixErrors>({});
+
+  const availableAffixes = affixesForSlot(slotId, d4Class);
+  const availableAspects = aspectsForSlot(slotId, d4Class);
+
+  // -------------------------------------------------------------------------
+  // Helpers
+  // -------------------------------------------------------------------------
+
+  function updateItem(updates: Partial<EquippedItem>) {
+    const base = item ?? blankItem(slotId);
+    onChange(slotId, { ...base, ...updates });
+  }
+
+  function handleAddItem() {
+    onChange(slotId, blankItem(slotId));
+    setExpanded(true);
+  }
+
+  function handleRemoveItem() {
+    onChange(slotId, undefined);
+    setExpanded(false);
+    setAffixErrors({});
+  }
+
+  // -------------------------------------------------------------------------
+  // Affix handlers
+  // -------------------------------------------------------------------------
+
+  const updateAffixField = useCallback(
+    (index: number, field: keyof RolledAffix, value: string | number | boolean) => {
+      if (!item) return;
+      const newAffixes = [...item.affixes];
+      newAffixes[index] = { ...newAffixes[index], [field]: value } as RolledAffix;
+
+      // Validate value when affixId and value are both set
+      if (field === "value" || field === "affixId") {
+        const affix = newAffixes[index];
+        if (affix.affixId) {
+          const err = validateAffixValue(affix.affixId, Number(affix.value));
+          setAffixErrors((prev) => ({ ...prev, [index]: err ?? undefined }));
+        }
+      }
+
+      updateItem({ affixes: newAffixes });
+    },
+    [item],
+  );
+
+  function addAffix(isTempered = false) {
+    if (!item) return;
+    const explicitCount = item.affixes.filter((a) => !a.isTempered).length;
+    const temperedCount = item.affixes.filter((a) => a.isTempered).length;
+    if (!isTempered && explicitCount >= MAX_EXPLICIT_AFFIXES) return;
+    if (isTempered && temperedCount >= MAX_TEMPERED_AFFIXES) return;
+
+    const newAffix: RolledAffix = {
+      affixId: availableAffixes[0]?.id ?? "",
+      value: 0,
+      isTempered,
+    };
+    updateItem({ affixes: [...item.affixes, newAffix] });
+  }
+
+  function removeAffix(index: number) {
+    if (!item) return;
+    const newAffixes = item.affixes.filter((_, i) => i !== index);
+    setAffixErrors((prev) => {
+      const next: AffixErrors = {};
+      Object.entries(prev).forEach(([k, v]) => {
+        const ki = Number(k);
+        if (ki < index) next[ki] = v;
+        else if (ki > index) next[ki - 1] = v;
+      });
+      return next;
+    });
+    updateItem({ affixes: newAffixes });
+  }
+
+  // -------------------------------------------------------------------------
+  // Aspect handlers
+  // -------------------------------------------------------------------------
+
+  function handleAspectChange(aspectId: string) {
+    const def = getAspectDef(aspectId);
+    updateItem({
+      aspectId: aspectId || undefined,
+      aspectValue: def?.hasValue ? (def.minValue ?? 0) : undefined,
+    });
+  }
+
+  // -------------------------------------------------------------------------
+  // Render
+  // -------------------------------------------------------------------------
+
+  const explicitAffixes = item?.affixes.filter((a) => !a.isTempered) ?? [];
+  const temperedAffixes = item?.affixes.filter((a) => a.isTempered) ?? [];
+  const aspectDef = item?.aspectId ? getAspectDef(item.aspectId) : undefined;
+
+  return (
+    <div
+      style={{
+        border: "1px solid var(--stone-800)",
+        borderRadius: "var(--radius-card)",
+        overflow: "hidden",
+        background: "var(--surface-1)",
+      }}
+    >
+      {/* Slot header */}
+      <div
+        style={{
+          display: "flex",
+          alignItems: "center",
+          justifyContent: "space-between",
+          padding: "8px 12px",
+          borderBottom: expanded && item ? "1px solid var(--stone-800)" : undefined,
+          cursor: item ? "pointer" : undefined,
+        }}
+        onClick={item ? () => setExpanded((p) => !p) : undefined}
+      >
+        <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
+          {item && (
+            <span style={{ color: "var(--stone-500)", flexShrink: 0 }}>
+              {expanded ? <ChevronDownIcon size={14} /> : <ChevronRightIcon size={14} />}
+            </span>
+          )}
+          <span
+            style={{
+              fontSize: "12px",
+              fontWeight: 600,
+              color: "var(--stone-500)",
+              textTransform: "uppercase",
+              letterSpacing: "0.06em",
+            }}
+          >
+            {slotLabel}
+          </span>
+          {item && (
+            <span
+              style={{
+                fontSize: "13px",
+                fontWeight: 600,
+                color: rarityColor[item.rarity],
+                marginLeft: "4px",
+              }}
+            >
+              {item.name || "(unnamed)"}
+            </span>
+          )}
+        </div>
+
+        {!item ? (
+          <button
+            onClick={(e) => { e.stopPropagation(); handleAddItem(); }}
+            style={ghostButtonStyle}
+            title="Add item to this slot"
+          >
+            <PlusIcon size={13} />
+            Add Item
+          </button>
+        ) : (
+          <button
+            onClick={(e) => { e.stopPropagation(); handleRemoveItem(); }}
+            style={{ ...ghostButtonStyle, color: "var(--danger)" }}
+            title="Remove item from slot"
+          >
+            <TrashIcon size={13} />
+          </button>
+        )}
+      </div>
+
+      {/* Item editor body */}
+      {item && expanded && (
+        <div style={{ padding: "12px", display: "flex", flexDirection: "column", gap: "14px" }}>
+          {/* Name + Rarity + Item Power */}
+          <div style={{ display: "flex", gap: "10px", flexWrap: "wrap" }}>
+            <div style={{ flex: "2 1 160px" }}>
+              <FieldLabel>Item Name</FieldLabel>
+              <input
+                type="text"
+                value={item.name}
+                onChange={(e) => updateItem({ name: e.target.value })}
+                placeholder="e.g. Harlequin Crest"
+                style={inputStyle(false)}
+              />
+            </div>
+
+            <div style={{ flex: "1 1 100px" }}>
+              <FieldLabel>Rarity</FieldLabel>
+              <select
+                value={item.rarity}
+                onChange={(e) => updateItem({ rarity: e.target.value as ItemRarity })}
+                style={{
+                  ...inputStyle(false),
+                  color: rarityColor[item.rarity],
+                }}
+              >
+                {RARITIES.map((r) => (
+                  <option key={r} value={r} style={{ color: rarityColor[r] }}>
+                    {r.charAt(0).toUpperCase() + r.slice(1)}
+                  </option>
+                ))}
+              </select>
+            </div>
+
+            <div style={{ flex: "1 1 80px" }}>
+              <FieldLabel>Item Power</FieldLabel>
+              <input
+                type="number"
+                min={0}
+                max={1000}
+                value={item.itemPower ?? ""}
+                onChange={(e) =>
+                  updateItem({ itemPower: e.target.value ? Number(e.target.value) : undefined })
+                }
+                placeholder="925"
+                style={inputStyle(false)}
+              />
+            </div>
+
+            <div style={{ flex: "0 0 auto", display: "flex", alignItems: "flex-end" }}>
+              <label style={{ display: "flex", alignItems: "center", gap: "6px", cursor: "pointer", paddingBottom: "6px" }}>
+                <input
+                  type="checkbox"
+                  checked={item.isAncestral ?? false}
+                  onChange={(e) => updateItem({ isAncestral: e.target.checked })}
+                  style={{ accentColor: "var(--accent)" }}
+                />
+                <span style={{ fontSize: "12px", color: "var(--stone-400)" }}>Ancestral</span>
+              </label>
+            </div>
+          </div>
+
+          {/* Affixes */}
+          <div>
+            <div
+              style={{
+                display: "flex",
+                alignItems: "center",
+                justifyContent: "space-between",
+                marginBottom: "8px",
+              }}
+            >
+              <FieldLabel>Affixes</FieldLabel>
+              <div style={{ display: "flex", gap: "6px" }}>
+                {explicitAffixes.length < MAX_EXPLICIT_AFFIXES && (
+                  <button onClick={() => addAffix(false)} style={tinyButtonStyle}>
+                    <PlusIcon size={11} /> Add Affix
+                  </button>
+                )}
+                {temperedAffixes.length < MAX_TEMPERED_AFFIXES && (
+                  <button onClick={() => addAffix(true)} style={{ ...tinyButtonStyle, color: "var(--rarity-legendary)" }}>
+                    <PlusIcon size={11} /> + Tempered
+                  </button>
+                )}
+              </div>
+            </div>
+
+            <div style={{ display: "flex", flexDirection: "column", gap: "6px" }}>
+              {item.affixes.map((affix, i) => {
+                const affixDef = affix.affixId ? getAffixDef(affix.affixId) : undefined;
+                const err = affixErrors[i];
+                const globalIndex = i;
+
+                return (
+                  <AffixRow
+                    key={i}
+                    affix={affix}
+                    affixDef={affixDef}
+                    availableAffixes={availableAffixes}
+                    error={err}
+                    onAffixIdChange={(id) => {
+                      const def = getAffixDef(id);
+                      updateAffixField(globalIndex, "affixId", id);
+                      // Reset value to midpoint when changing affix type
+                      if (def) {
+                        const mid = Math.round((def.minValue + def.maxValue) / 2 * 10) / 10;
+                        updateAffixField(globalIndex, "value", mid);
+                      }
+                    }}
+                    onValueChange={(v) => updateAffixField(globalIndex, "value", v)}
+                    onGreaterToggle={() =>
+                      updateAffixField(globalIndex, "isGreater", !affix.isGreater)
+                    }
+                    onRemove={() => removeAffix(i)}
+                  />
+                );
+              })}
+
+              {item.affixes.length === 0 && (
+                <div style={{ fontSize: "12px", color: "var(--stone-600)", fontStyle: "italic" }}>
+                  No affixes — click "Add Affix" above.
+                </div>
+              )}
+            </div>
+          </div>
+
+          {/* Aspect */}
+          {(item.rarity === "legendary" || item.rarity === "unique") && (
+            <div>
+              <FieldLabel>Legendary Aspect</FieldLabel>
+              <div style={{ display: "flex", gap: "8px", flexWrap: "wrap" }}>
+                <select
+                  value={item.aspectId ?? ""}
+                  onChange={(e) => handleAspectChange(e.target.value)}
+                  style={{ ...inputStyle(false), flex: "1 1 200px", color: item.aspectId ? "var(--rarity-legendary)" : "var(--stone-500)" }}
+                >
+                  <option value="">— No aspect —</option>
+                  {availableAspects.map((a) => (
+                    <option key={a.id} value={a.id}>
+                      {a.name}
+                    </option>
+                  ))}
+                </select>
+
+                {aspectDef?.hasValue && (
+                  <input
+                    type="number"
+                    value={item.aspectValue ?? ""}
+                    onChange={(e) => updateItem({ aspectValue: Number(e.target.value) })}
+                    placeholder={`${aspectDef.minValue}–${aspectDef.maxValue}`}
+                    style={{ ...inputStyle(false), width: "100px", flex: "0 0 100px" }}
+                    min={aspectDef.minValue}
+                    max={aspectDef.maxValue}
+                    step={aspectDef.valueUnit === "percent" ? 0.1 : 1}
+                  />
+                )}
+              </div>
+              {aspectDef && (
+                <div style={{ fontSize: "11px", color: "var(--stone-500)", marginTop: "4px", fontStyle: "italic" }}>
+                  {aspectDef.description.replace("{value}", String(item.aspectValue ?? "?"))}
+                </div>
+              )}
+            </div>
+          )}
+        </div>
+      )}
+    </div>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// AffixRow
+// ---------------------------------------------------------------------------
+
+type AffixRowProps = {
+  affix: RolledAffix;
+  affixDef: ReturnType<typeof getAffixDef>;
+  availableAffixes: ReturnType<typeof affixesForSlot>;
+  error?: string;
+  onAffixIdChange: (id: string) => void;
+  onValueChange: (v: number) => void;
+  onGreaterToggle: () => void;
+  onRemove: () => void;
+};
+
+function AffixRow({
+  affix,
+  affixDef,
+  availableAffixes,
+  error,
+  onAffixIdChange,
+  onValueChange,
+  onGreaterToggle,
+  onRemove,
+}: AffixRowProps) {
+  const valueStr = affixDef?.valueUnit === "percent"
+    ? `${affixDef.minValue}%–${affixDef.maxValue}%`
+    : `${affixDef?.minValue}–${affixDef?.maxValue}`;
+
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "3px" }}>
+      <div style={{ display: "flex", gap: "6px", alignItems: "center" }}>
+        {/* Greater affix star */}
+        <button
+          type="button"
+          onClick={onGreaterToggle}
+          title={affix.isGreater ? "Greater affix (★)" : "Mark as greater affix"}
+          style={{
+            background: "none",
+            border: "none",
+            cursor: "pointer",
+            color: affix.isGreater ? "var(--accent)" : "var(--stone-700)",
+            padding: "0",
+            flexShrink: 0,
+            lineHeight: 1,
+          }}
+        >
+          <StarIcon size={12} fill={affix.isGreater ? "currentColor" : "none"} />
+        </button>
+
+        {/* Affix picker */}
+        <select
+          value={affix.affixId}
+          onChange={(e) => onAffixIdChange(e.target.value)}
+          style={{
+            flex: "1",
+            height: "28px",
+            padding: "0 6px",
+            background: "var(--surface-2)",
+            border: `1px solid ${error ? "var(--danger)" : "var(--stone-800)"}`,
+            borderRadius: "var(--radius-card)",
+            color: affix.isTempered ? "var(--rarity-legendary)" : "var(--stone-300)",
+            fontSize: "12px",
+            fontFamily: "var(--font-sans)",
+          }}
+        >
+          {availableAffixes.map((a) => (
+            <option key={a.id} value={a.id}>
+              {a.label}
+              {affix.isTempered ? " (tempered)" : ""}
+            </option>
+          ))}
+        </select>
+
+        {/* Value input */}
+        <input
+          type="number"
+          value={affix.value}
+          onChange={(e) => onValueChange(Number(e.target.value))}
+          step={affixDef?.valueUnit === "percent" ? 0.5 : 1}
+          min={affixDef?.minValue}
+          max={affixDef?.maxValue}
+          placeholder={valueStr}
+          style={{
+            width: "72px",
+            height: "28px",
+            padding: "0 6px",
+            background: "var(--surface-2)",
+            border: `1px solid ${error ? "var(--danger)" : "var(--stone-800)"}`,
+            borderRadius: "var(--radius-card)",
+            color: "var(--stone-100)",
+            fontSize: "12px",
+            fontFamily: "var(--font-mono)",
+            fontVariantNumeric: "tabular-nums",
+            flexShrink: 0,
+          }}
+        />
+        {affixDef?.valueUnit === "percent" && (
+          <span style={{ color: "var(--stone-500)", fontSize: "12px", flexShrink: 0 }}>%</span>
+        )}
+
+        {/* Remove button */}
+        <button
+          type="button"
+          onClick={onRemove}
+          style={{
+            background: "none",
+            border: "none",
+            cursor: "pointer",
+            color: "var(--stone-600)",
+            padding: "2px",
+            flexShrink: 0,
+          }}
+          title="Remove affix"
+        >
+          <TrashIcon size={12} />
+        </button>
+      </div>
+
+      {error && (
+        <div style={{ fontSize: "11px", color: "var(--danger)", paddingLeft: "18px" }}>
+          {error}
+        </div>
+      )}
+    </div>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// Small helpers
+// ---------------------------------------------------------------------------
+
+function FieldLabel({ children }: { children: React.ReactNode }) {
+  return (
+    <div
+      style={{
+        fontSize: "11px",
+        fontWeight: 600,
+        color: "var(--stone-500)",
+        textTransform: "uppercase",
+        letterSpacing: "0.06em",
+        marginBottom: "5px",
+      }}
+    >
+      {children}
+    </div>
+  );
+}
+
+function inputStyle(hasError: boolean): React.CSSProperties {
+  return {
+    height: "30px",
+    padding: "0 8px",
+    background: "var(--surface-2)",
+    border: `1px solid ${hasError ? "var(--danger)" : "var(--stone-700)"}`,
+    borderRadius: "var(--radius-card)",
