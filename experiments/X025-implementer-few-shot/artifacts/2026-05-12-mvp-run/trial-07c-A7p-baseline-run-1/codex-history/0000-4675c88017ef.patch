diff --git a/lib/types/index.ts b/lib/types/index.ts
new file mode 100644
index 0000000..113119d
--- /dev/null
+++ b/lib/types/index.ts
@@ -0,0 +1,355 @@
+/**
+ * Canonical type definitions for D4 Build Tools v2.
+ *
+ * This module is the authoritative source for all domain types consumed by:
+ * - The UI (character editor, gear editor, build views)
+ * - The persistence layer (JSON serialisation shapes)
+ * - The scoring engine (build input contract, see docs/scoring-engine.md §3)
+ * - v3 API import (must conform to these types)
+ *
+ * Subsequent commissions MUST NOT redefine or shadow these types.
+ */
+
+// ---------------------------------------------------------------------------
+// Primitive enumerations
+// ---------------------------------------------------------------------------
+
+export type D4Class =
+  | "Barbarian"
+  | "Druid"
+  | "Necromancer"
+  | "Rogue"
+  | "Sorcerer"
+  | "Spiritborn"
+  | "Paladin"
+  | "Warlock";
+
+export const D4_CLASSES: D4Class[] = [
+  "Barbarian",
+  "Druid",
+  "Necromancer",
+  "Rogue",
+  "Sorcerer",
+  "Spiritborn",
+  "Paladin",
+  "Warlock",
+];
+
+export type ItemRarity =
+  | "common"
+  | "magic"
+  | "rare"
+  | "legendary"
+  | "unique"
+  | "mythic";
+
+export type ItemSlotId =
+  | "helm"
+  | "chest"
+  | "gloves"
+  | "pants"
+  | "boots"
+  | "mainHand"
+  | "offHand"
+  | "weapon3" // 2H Bludgeoning — Barbarian
+  | "weapon4" // 2H Slashing — Barbarian
+  | "weapon5" // 1H Off-Weapon — Barbarian
+  | "amulet"
+  | "ring1"
+  | "ring2";
+
+export type DamageType =
+  | "physical"
+  | "fire"
+  | "cold"
+  | "lightning"
+  | "poison"
+  | "shadow";
+
+export type SkillCategory =
+  | "basic"
+  | "core"
+  | "defensive"
+  | "conjuration"   // Sorcerer
+  | "companion"     // Druid / Rogue
+  | "wrath"         // Druid (Werewolf / Werebear)
+  | "macabre"       // Necromancer
+  | "corruption"    // Necromancer / Warlock
+  | "subterfuge"    // Rogue
+  | "agility"       // Rogue / Spiritborn
+  | "imbuement"     // Rogue
+  | "spirit"        // Spiritborn
+  | "brawling"      // Barbarian
+  | "weapon-mastery" // Barbarian
+  | "aura"          // Paladin
+  | "faith"         // Paladin
+  | "ultimate"
+  | "key-passive"
+  | "passive";
+
+// ---------------------------------------------------------------------------
+// Catalog entry types  (read-only reference data, seeded in lib/catalog/)
+// ---------------------------------------------------------------------------
+
+/** A stat affix definition from the catalog. */
+export interface AffixDef {
+  readonly id: string;
+  readonly label: string;
+  /** Minimum rolled value (numeric, before any % suffix). */
+  readonly minValue: number;
+  /** Maximum rolled value. */
+  readonly maxValue: number;
+  /** How the value is presented in the UI. */
+  readonly valueUnit: "percent" | "flat" | "count";
+  /** Which item slots this affix can appear on. Empty means all slots. */
+  readonly slots: ItemSlotId[];
+  /** If set, only these classes can roll this affix. */
+  readonly classes?: D4Class[];
+}
+
+/** A legendary aspect definition from the catalog. */
+export interface AspectDef {
+  readonly id: string;
+  readonly name: string;
+  /** Human-readable description; use {value} for the rolled-value token. */
+  readonly description: string;
+  /** Whether this aspect has a numeric rolled value the user must enter. */
+  readonly hasValue: boolean;
+  readonly minValue?: number;
+  readonly maxValue?: number;
+  readonly valueUnit?: "percent" | "flat" | "count";
+  /** Slots where this aspect can be imprinted. */
+  readonly slots: ItemSlotId[];
+  /** If set, only these classes can use this aspect. */
+  readonly classes?: D4Class[];
+}
+
+/** A skill definition from the catalog. */
+export interface SkillDef {
+  readonly id: string;
+  readonly name: string;
+  readonly class: D4Class;
+  readonly category: SkillCategory;
+  /** Maximum allocatable rank (typically 5 for actives, 3 for passives, 1 for key passives). */
+  readonly maxRank: number;
+  readonly description?: string;
+}
+
+/** An item slot definition from the catalog. */
+export interface SlotDef {
+  readonly id: ItemSlotId;
+  readonly label: string;
+  readonly cluster: "armor" | "weapon" | "jewelry";
+  /** If set, only these classes have this slot. */
+  readonly classes?: D4Class[];
+}
+
+// ---------------------------------------------------------------------------
+// Item types — what a user enters for their character's gear
+// ---------------------------------------------------------------------------
+
+/** A single affix rolled on an item, referencing the catalog by ID. */
+export interface RolledAffix {
+  /** References AffixDef.id from the catalog. */
+  affixId: string;
+  /** Actual numeric value the user typed (must be within AffixDef.minValue–maxValue). */
+  value: number;
+  /** Greater affix marker — shows ★ and means the value counts as higher. */
+  isGreater?: boolean;
+  /** Post-Vessel of Hatred tempered affix (5th affix slot). */
+  isTempered?: boolean;
+}
+
+/** A fully entered item in a gear slot. */
+export interface EquippedItem {
+  id: string;
+  slotId: ItemSlotId;
+  name: string;
+  rarity: ItemRarity;
+  itemPower?: number;
+  /** Up to 4 explicit affixes (+ 1 tempered). */
+  affixes: RolledAffix[];
+  /** References AspectDef.id if a legendary aspect is imprinted. */
+  aspectId?: string;
+  /** Rolled value for the aspect (if AspectDef.hasValue is true). */
+  aspectValue?: number;
+  isAncestral?: boolean;
+}
+
+/**
+ * A partial item target for a slot — used in theorycrafting / acquisition planning.
+ * Any field may be omitted ("I want any item with at least Vulnerable Damage").
+ */
+export interface TargetItem {
+  slotId: ItemSlotId;
+  name?: string;
+  rarity?: ItemRarity;
+  /** Desired affixes; value may be a target rather than a constraint. */
+  affixes?: Array<{ affixId: string; targetValue?: number }>;
+  aspectId?: string;
+  aspectValue?: number;
+}
+
+// ---------------------------------------------------------------------------
+// Skills
+// ---------------------------------------------------------------------------
+
+/** A skill as allocated in a build. */
+export interface EquippedSkill {
+  /** References SkillDef.id from the catalog. */
+  skillId: string;
+  rank: number;
+}
+
+// ---------------------------------------------------------------------------
+// Paragon
+// ---------------------------------------------------------------------------
+
+/** Allocation of one paragon board. */
+export interface ParagonBoardAllocation {
+  boardId: string;
+  boardName: string;
+  /** Glyph socketed in this board's glyph socket (if any). */
+  glyphId?: string;
+  /** Glyph rank (1–21). */
+  glyphRank?: number;
+  /** Node IDs allocated on this board. */
+  nodesAllocated: string[];
+}
+
+// ---------------------------------------------------------------------------
+// Playstyle constraints (scoring engine input §7)
+// ---------------------------------------------------------------------------
+
+/** Formal playstyle constraints consumed by the scoring engine. */
+export interface PlaystyleConstraints {
+  skillConstraints?: Array<{
+    skillId: string;
+    mode: "include" | "exclude";
+    hardness: "hard" | "soft";
+  }>;
+  damageTypeConstraints?: Array<{
+    type: DamageType;
+    strength: "must" | "mostly" | "cannot";
+    hardness: "hard" | "soft";
+  }>;
+  mechanicConstraints?: Array<{
+    mechanic: string;
+    hardness: "hard" | "soft";
+  }>;
+  contentTarget?: "pit" | "helltide" | "boss" | "general";
+  itemConstraints?: Array<{
+    type: "must-use" | "must-avoid";
+    /** Item name, AspectDef.id, or item category string. */
+    ref: string;
+    hardness: "hard" | "soft";
+  }>;
+}
+
+/**
+ * Per-condition uptime values for conditional affix scoring.
+ * Key is a condition tag (e.g. "vulnerable_uptime", "cc_uptime").
+ * Value is 0.0–1.0 fraction of time the condition is active.
+ */
+export type UptimeValues = Record<string, number>;
+
+// ---------------------------------------------------------------------------
+// Core domain entities (persisted as individual JSON files)
+// ---------------------------------------------------------------------------
+
+/**
+ * Character — the persistent user entity.
+ * One character per player; builds are layered on top.
+ *
+ * Persisted at: data/characters/{id}.json
+ */
+export interface Character {
+  id: string;
+  name: string;
+  class: D4Class;
+  /** Character level (1–100). */
+  level: number;
+  /**
+   * Paragon level (0–200 in S13).
+   * Determines paragon points available: level × 4.
+   */
+  paragonLevel: number;
+  createdAt: string; // ISO 8601
+  updatedAt: string; // ISO 8601
+}
+
+/**
+ * Build — an optimization target layered on a character.
+ * A character may have many builds (one-to-many; v2 UI starts with one).
+ *
+ * Persisted at: data/builds/{id}.json
+ */
+export interface Build {
+  id: string;
+  characterId: string;
+  name: string;
+
+  /** Active skills with allocated ranks. */
+  skills: EquippedSkill[];
+
+  /**
+   * Gear in each slot. Partial record — empty slots are simply absent.
+   * Also carries a parallel target-item spec per slot for theorycrafting.
+   */
+  equippedItems: Partial<Record<ItemSlotId, EquippedItem>>;
+  targetItems?: Partial<Record<ItemSlotId, TargetItem>>;
+
+  /** Paragon board allocations. */
+  paragonBoards: ParagonBoardAllocation[];
+
+  /** Playstyle constraints for the scoring engine. */
+  playstyleConstraints: PlaystyleConstraints;
+
+  /** Conditional uptime values for the scoring engine. */
+  uptimeValues?: UptimeValues;
+
+  /** Free-form notes. */
+  notes?: string;
+
+  createdAt: string; // ISO 8601
+  updatedAt: string; // ISO 8601
+}
+
+// ---------------------------------------------------------------------------
+// Validation helpers
+// ---------------------------------------------------------------------------
+
+/**
+ * Maximum paragon level in Season 13.
+ * Each paragon level grants 4 paragon points → 800 total at 200.
+ */
+export const MAX_PARAGON_LEVEL = 200;
+
+/** Maximum character level. */
+export const MAX_CHARACTER_LEVEL = 100;
+
+/** Maximum number of explicit affixes on an item (excluding tempered). */
+export const MAX_EXPLICIT_AFFIXES = 4;
+
+/** Maximum number of tempered affixes on an item. */
+export const MAX_TEMPERED_AFFIXES = 1;
+
+/** Total affix slots on an item (4 explicit + 1 tempered). */
+export const MAX_TOTAL_AFFIXES = MAX_EXPLICIT_AFFIXES + MAX_TEMPERED_AFFIXES;
+
+/**
+ * Returns the total paragon points available at the given paragon level.
+ * 4 points per level.
+ */
+export function paragronPointsAvailable(paragonLevel: number): number {
+  return paragonLevel * 4;
+}
+
+/**
+ * Returns a rough skill-point budget for a given character level.
+ * D4 grants one skill point per level from 1 to 58, plus bonus points
+ * from the skill tree (Renown etc.). This is a lower-bound estimate.
+ */
+export function skillPointBudget(level: number): number {
+  return Math.min(level, 58);
+}
