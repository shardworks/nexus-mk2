@@ -0,0 +1,98 @@
+import { readJsonFile, writeJsonFile } from "./index";
+import type { Build } from "@/lib/types";
+
+const INDEX_FILE = "builds/index.json";
+
+/** Returns the file path for a build's JSON file. */
+function buildFile(id: string): string {
+  return `builds/${id}.json`;
+}
+
+/** Reads the build index. */
+async function readIndex(): Promise<Build[]> {
+  return (await readJsonFile<Build[]>(INDEX_FILE)) ?? [];
+}
+
+/** Writes the build index. */
+async function writeIndex(builds: Build[]): Promise<void> {
+  await writeJsonFile(INDEX_FILE, builds);
+}
+
+/** Lists all builds. Optionally filtered by characterId. */
+export async function listBuilds(characterId?: string): Promise<Build[]> {
+  const all = await readIndex();
+  if (!characterId) return all;
+  return all.filter((b) => b.characterId === characterId);
+}
+
+/** Loads a single build by ID. Returns null if not found. */
+export async function getBuild(id: string): Promise<Build | null> {
+  return readJsonFile<Build>(buildFile(id));
+}
+
+/** Creates a new build and persists it. */
+export async function createBuild(
+  data: Omit<Build, "id" | "createdAt" | "updatedAt">,
+): Promise<Build> {
+  const now = new Date().toISOString();
+  const build: Build = {
+    ...data,
+    id: generateId(),
+    createdAt: now,
+    updatedAt: now,
+  };
+
+  await writeJsonFile(buildFile(build.id), build);
+
+  const index = await readIndex();
+  index.push(build);
+  await writeIndex(index);
+
+  return build;
+}
+
+/** Updates an existing build. Throws if not found. */
+export async function updateBuild(
+  id: string,
+  updates: Partial<Omit<Build, "id" | "characterId" | "createdAt">>,
+): Promise<Build> {
+  const existing = await getBuild(id);
+  if (!existing) throw new Error(`Build not found: ${id}`);
+
+  const updated: Build = {
+    ...existing,
+    ...updates,
+    id,
+    characterId: existing.characterId,
+    createdAt: existing.createdAt,
+    updatedAt: new Date().toISOString(),
+  };
+
+  await writeJsonFile(buildFile(id), updated);
+
+  const index = await readIndex();
+  const idx = index.findIndex((b) => b.id === id);
+  if (idx >= 0) {
+    index[idx] = updated;
+  } else {
+    index.push(updated);
+  }
+  await writeIndex(index);
+
+  return updated;
+}
+
+/** Deletes a build (removes from index; individual file stays on disk). */
+export async function deleteBuild(id: string): Promise<void> {
+  const index = await readIndex();
+  const filtered = index.filter((b) => b.id !== id);
+  await writeIndex(filtered);
+}
+
+// ---------------------------------------------------------------------------
+// ID generation
+// ---------------------------------------------------------------------------
+
+function generateId(): string {
+  return `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
+}
