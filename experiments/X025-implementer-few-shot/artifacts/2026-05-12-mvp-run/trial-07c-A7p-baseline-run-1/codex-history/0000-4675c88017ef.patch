+  { id: "war_curse_of_agony",  name: "Curse of Agony",  class: "Warlock", category: "corruption", maxRank: 5 },
+  { id: "war_shadow_rift",     name: "Shadow Rift",     class: "Warlock", category: "ultimate", maxRank: 5 },
+  { id: "war_void_eruption",   name: "Void Eruption",   class: "Warlock", category: "ultimate", maxRank: 5 },
+  { id: "war_soul_fracture",   name: "Soul Fracture",   class: "Warlock", category: "key-passive", maxRank: 1 },
+  { id: "war_torment",         name: "Torment",         class: "Warlock", category: "key-passive", maxRank: 1 },
+  { id: "war_dark_pact_kp",    name: "Dark Pact",       class: "Warlock", category: "key-passive", maxRank: 1 },
+  { id: "war_affliction",      name: "Affliction",      class: "Warlock", category: "passive", maxRank: 3 },
+  { id: "war_haunting_presence", name: "Haunting Presence", class: "Warlock", category: "passive", maxRank: 3 },
+];
+
+export const SKILL_DEFS: readonly SkillDef[] = skillsData;
+
+/** Returns all skills for a given class, optionally filtered by category. */
+export function skillsForClass(
+  d4Class: D4Class,
+  category?: string,
+): SkillDef[] {
+  return SKILL_DEFS.filter(
+    (s) => s.class === d4Class && (!category || s.category === category),
+  ) as SkillDef[];
+}
+
+/** Returns a skill definition by ID, or undefined. */
+export function getSkillDef(id: string): SkillDef | undefined {
+  return SKILL_DEFS.find((s) => s.id === id);
+}
+
+/**
+ * Validates a skill rank against the catalog maximum.
+ * Returns null if valid, or an error message string.
+ */
+export function validateSkillRank(skillId: string, rank: number): string | null {
+  const def = getSkillDef(skillId);
+  if (!def) return `Unknown skill: ${skillId}`;
+  if (!Number.isInteger(rank) || rank < 1) return "Rank must be at least 1";
+  if (rank > def.maxRank) return `Max rank for ${def.name} is ${def.maxRank}`;
+  return null;
+}
