+/** Returns all affixes that can appear on the given slot. */
+export function affixesForSlot(slotId: string, d4Class?: string): AffixDef[] {
+  return AFFIX_DEFS.filter((a) => {
+    const slotOk = a.slots.length === 0 || a.slots.includes(slotId as ItemSlotId);
+    const classOk = !a.classes || !d4Class || a.classes.includes(d4Class as never);
+    return slotOk && classOk;
+  }) as AffixDef[];
+}
+
+/** Returns an affix definition by ID, or undefined. */
+export function getAffixDef(id: string): AffixDef | undefined {
+  return AFFIX_DEFS.find((a) => a.id === id);
+}
+
+/**
+ * Validates a rolled affix value against catalog ranges.
+ * Returns null if valid, or an error message string.
+ */
+export function validateAffixValue(affixId: string, value: number): string | null {
+  const def = getAffixDef(affixId);
+  if (!def) return `Unknown affix: ${affixId}`;
+  if (isNaN(value)) return "Value must be a number";
+  if (value < def.minValue) return `Min value is ${def.minValue}`;
+  if (value > def.maxValue) return `Max value is ${def.maxValue}`;
+  return null;
+}
