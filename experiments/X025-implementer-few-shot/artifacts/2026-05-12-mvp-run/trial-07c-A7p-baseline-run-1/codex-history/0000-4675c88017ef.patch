+import { describe, it, expect } from "vitest";
+import {
+  D4_CLASSES,
+  MAX_PARAGON_LEVEL,
+  MAX_CHARACTER_LEVEL,
+  MAX_EXPLICIT_AFFIXES,
+  MAX_TEMPERED_AFFIXES,
+  MAX_TOTAL_AFFIXES,
+  paragronPointsAvailable,
+  skillPointBudget,
+} from "../lib/types";
+
+// ---------------------------------------------------------------------------
+// Constants
+// ---------------------------------------------------------------------------
+
+describe("constants", () => {
+  it("D4_CLASSES has exactly 8 classes", () => {
+    expect(D4_CLASSES).toHaveLength(8);
+  });
+
+  it("D4_CLASSES includes all expected classes", () => {
+    const expected = [
+      "Barbarian", "Druid", "Necromancer", "Rogue",
+      "Sorcerer", "Spiritborn", "Paladin", "Warlock",
+    ];
+    for (const cls of expected) {
+      expect(D4_CLASSES).toContain(cls);
+    }
+  });
+
+  it("MAX_PARAGON_LEVEL is 200", () => {
+    expect(MAX_PARAGON_LEVEL).toBe(200);
+  });
+
+  it("MAX_CHARACTER_LEVEL is 100", () => {
+    expect(MAX_CHARACTER_LEVEL).toBe(100);
+  });
+
+  it("MAX_EXPLICIT_AFFIXES is 4", () => {
+    expect(MAX_EXPLICIT_AFFIXES).toBe(4);
+  });
+
+  it("MAX_TEMPERED_AFFIXES is 1", () => {
+    expect(MAX_TEMPERED_AFFIXES).toBe(1);
+  });
+
+  it("MAX_TOTAL_AFFIXES equals explicit + tempered", () => {
+    expect(MAX_TOTAL_AFFIXES).toBe(MAX_EXPLICIT_AFFIXES + MAX_TEMPERED_AFFIXES);
+  });
+});
+
+// ---------------------------------------------------------------------------
+// Helpers
+// ---------------------------------------------------------------------------
+
+describe("paragronPointsAvailable", () => {
+  it("returns 0 for paragon level 0", () => {
+    expect(paragronPointsAvailable(0)).toBe(0);
+  });
+
+  it("returns 4 for paragon level 1", () => {
+    expect(paragronPointsAvailable(1)).toBe(4);
+  });
+
+  it("returns 800 for paragon level 200 (max)", () => {
+    expect(paragronPointsAvailable(200)).toBe(800);
+  });
+
+  it("is linear (4 per level)", () => {
+    for (let i = 0; i <= 200; i++) {
+      expect(paragronPointsAvailable(i)).toBe(i * 4);
+    }
+  });
+});
+
+describe("skillPointBudget", () => {
+  it("returns 1 at level 1", () => {
+    expect(skillPointBudget(1)).toBeGreaterThanOrEqual(1);
+  });
+
+  it("returns at most 58 (cap at max skill-tree levels)", () => {
+    expect(skillPointBudget(100)).toBeLessThanOrEqual(58);
+  });
+
+  it("is non-decreasing with level", () => {
+    let prev = skillPointBudget(1);
+    for (let i = 2; i <= 100; i++) {
+      const curr = skillPointBudget(i);
+      expect(curr).toBeGreaterThanOrEqual(prev);
+      prev = curr;
+    }
+  });
+});
