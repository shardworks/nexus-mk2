+++ b/components/d4/SkillEditor.tsx
@@ -0,0 +1,346 @@
+"use client";
+
+import { useState, useMemo } from "react";
+import { PlusIcon, TrashIcon } from "lucide-react";
+import { skillsForClass, getSkillDef, validateSkillRank } from "@/lib/catalog";
+import { skillPointBudget } from "@/lib/types";
+import type { EquippedSkill, D4Class, SkillCategory } from "@/lib/types";
+
+type SkillEditorProps = {
+  d4Class: D4Class;
+  characterLevel: number;
+  skills: EquippedSkill[];
+  onChange: (skills: EquippedSkill[]) => void;
+};
+
+const CATEGORY_ORDER: SkillCategory[] = [
+  "basic", "core", "defensive",
+  "conjuration", "companion", "wrath", "macabre", "corruption",
+  "subterfuge", "agility", "imbuement",
+  "brawling", "weapon-mastery",
+  "spirit", "faith", "aura",
+  "ultimate", "key-passive", "passive",
+];
+
+const CATEGORY_LABELS: Partial<Record<SkillCategory, string>> = {
+  "basic": "Basic",
+  "core": "Core",
+  "defensive": "Defensive",
+  "conjuration": "Conjuration",
+  "companion": "Companion",
+  "wrath": "Wrath",
+  "macabre": "Macabre",
+  "corruption": "Corruption",
+  "subterfuge": "Subterfuge",
+  "agility": "Agility",
+  "imbuement": "Imbuement",
+  "brawling": "Brawling",
+  "weapon-mastery": "Weapon Mastery",
+  "spirit": "Spirit",
+  "faith": "Faith",
+  "aura": "Aura",
+  "ultimate": "Ultimate",
+  "key-passive": "Key Passive",
+  "passive": "Passives",
+};
+
+export function SkillEditor({
+  d4Class,
+  characterLevel,
+  skills,
+  onChange,
+}: SkillEditorProps) {
+  const [rankErrors, setRankErrors] = useState<Record<number, string | undefined>>({});
+
+  const allClassSkills = useMemo(() => skillsForClass(d4Class), [d4Class]);
+  const budget = skillPointBudget(characterLevel);
+  const totalAllocated = skills.reduce((sum, s) => sum + s.rank, 0);
+  const overBudget = totalAllocated > budget;
+
+  // Skill IDs already added
+  const addedIds = new Set(skills.map((s) => s.skillId));
+
+  // Available (not yet added) skills grouped by category
+  const availableByCategory = useMemo(() => {
+    const groups: Partial<Record<SkillCategory, typeof allClassSkills>> = {};
+    for (const skill of allClassSkills) {
+      if (!addedIds.has(skill.id)) {
+        if (!groups[skill.category]) groups[skill.category] = [];
+        groups[skill.category]!.push(skill);
+      }
+    }
+    return groups;
+  }, [allClassSkills, addedIds]);
+
+  // Skills by category for the "add skill" dropdown
+  const dropdownOptions = CATEGORY_ORDER.flatMap((cat) => {
+    const group = availableByCategory[cat] ?? [];
+    return group.length > 0
+      ? [{ type: "group" as const, label: CATEGORY_LABELS[cat] ?? cat }, ...group.map((s) => ({ type: "skill" as const, skill: s }))]
+      : [];
+  });
+
+  function addSkill(skillId: string) {
+    const def = getSkillDef(skillId);
+    if (!def || addedIds.has(skillId)) return;
+    onChange([...skills, { skillId, rank: 1 }]);
+  }
+
+  function removeSkill(index: number) {
+    const next = skills.filter((_, i) => i !== index);
+    setRankErrors((prev) => {
+      const clean: Record<number, string | undefined> = {};
+      Object.entries(prev).forEach(([k, v]) => {
+        const ki = Number(k);
+        if (ki < index) clean[ki] = v;
+        else if (ki > index) clean[ki - 1] = v;
+      });
+      return clean;
+    });
+    onChange(next);
+  }
+
+  function updateRank(index: number, rank: number) {
+    const skill = skills[index];
+    if (!skill) return;
+    const err = validateSkillRank(skill.skillId, rank);
+    setRankErrors((prev) => ({ ...prev, [index]: err ?? undefined }));
+    const next = [...skills];
+    next[index] = { ...skill, rank };
+    onChange(next);
+  }
+
+  // Group equipped skills by category for display
+  const equippedByCategory = useMemo(() => {
+    const groups: Partial<Record<SkillCategory, Array<{ skill: EquippedSkill; index: number }>>> = {};
+    skills.forEach((s, i) => {
+      const def = getSkillDef(s.skillId);
+      const cat = def?.category ?? "passive";
+      if (!groups[cat]) groups[cat] = [];
+      groups[cat]!.push({ skill: s, index: i });
+    });
+    return groups;
+  }, [skills]);
+
+  const categoriesPresent = CATEGORY_ORDER.filter((c) => equippedByCategory[c]?.length);
+
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "16px" }}>
+      {/* Budget indicator */}
+      <div style={{ display: "flex", alignItems: "center", gap: "12px" }}>
+        <div style={{ fontSize: "12px", color: overBudget ? "var(--danger)" : "var(--stone-500)" }}>
+          {totalAllocated} / {budget} skill points
+          {overBudget && " — over budget"}
+        </div>
+      </div>
+
+      {/* Add skill */}
+      <div style={{ display: "flex", gap: "8px" }}>
+        <AddSkillDropdown options={dropdownOptions} onAdd={addSkill} />
+      </div>
+
+      {/* Equipped skills grouped by category */}
+      {categoriesPresent.length === 0 ? (
+        <div style={{ fontSize: "12px", color: "var(--stone-600)", fontStyle: "italic" }}>
+          No skills added yet.
+        </div>
+      ) : (
+        <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
+          {categoriesPresent.map((cat) => {
+            const entries = equippedByCategory[cat] ?? [];
+            return (
+              <div key={cat}>
+                <div
+                  style={{
+                    fontSize: "11px",
+                    fontWeight: 600,
+                    color: "var(--stone-600)",
+                    textTransform: "uppercase",
+                    letterSpacing: "0.07em",
+                    marginBottom: "6px",
+                  }}
+                >
+                  {CATEGORY_LABELS[cat] ?? cat}
+                </div>
+                <div style={{ display: "flex", flexDirection: "column", gap: "5px" }}>
+                  {entries.map(({ skill, index }) => {
+                    const def = getSkillDef(skill.skillId);
+                    const err = rankErrors[index];
+                    return (
+                      <SkillRow
+                        key={skill.skillId}
+                        skillName={def?.name ?? skill.skillId}
+                        maxRank={def?.maxRank ?? 5}
+                        rank={skill.rank}
+                        error={err}
+                        onRankChange={(r) => updateRank(index, r)}
+                        onRemove={() => removeSkill(index)}
+                      />
+                    );
+                  })}
+                </div>
+              </div>
+            );
+          })}
+        </div>
+      )}
+    </div>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// AddSkillDropdown
+// ---------------------------------------------------------------------------
+
+type DropdownOption =
+  | { type: "group"; label: string }
+  | { type: "skill"; skill: ReturnType<typeof getSkillDef> & {} };
+
+function AddSkillDropdown({
+  options,
+  onAdd,
+}: {
+  options: DropdownOption[];
+  onAdd: (id: string) => void;
+}) {
+  const [selected, setSelected] = useState("");
+
+  function handleAdd() {
+    if (selected) {
+      onAdd(selected);
+      setSelected("");
+    }
+  }
+
+  return (
+    <>
+      <select
+        value={selected}
+        onChange={(e) => setSelected(e.target.value)}
+        style={{
+          flex: 1,
+          height: "30px",
+          padding: "0 8px",
+          background: "var(--surface-2)",
+          border: "1px solid var(--stone-700)",
+          borderRadius: "var(--radius-card)",
+          color: selected ? "var(--stone-100)" : "var(--stone-500)",
+          fontSize: "13px",
+        }}
+      >
+        <option value="">— Pick a skill to add —</option>
+        {options.map((opt, i) =>
+          opt.type === "group" ? (
+            <optgroup key={`g-${i}`} label={opt.label} />
+          ) : (
+            <option key={opt.skill.id} value={opt.skill.id}>
+              {opt.skill.name} (max {opt.skill.maxRank})
+            </option>
+          ),
+        )}
+      </select>
+      <button
+        type="button"
+        onClick={handleAdd}
+        disabled={!selected}
+        style={{
+          display: "inline-flex",
+          alignItems: "center",
+          gap: "4px",
+          height: "30px",
+          padding: "0 12px",
+          background: selected ? "var(--accent)" : "var(--surface-2)",
+          border: "1px solid var(--stone-700)",
+          borderRadius: "var(--radius-card)",
+          color: selected ? "var(--stone-950)" : "var(--stone-600)",
+          fontSize: "12px",
+          fontWeight: 600,
+          cursor: selected ? "pointer" : "default",
+        }}
+      >
+        <PlusIcon size={12} />
+        Add
+      </button>
+    </>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// SkillRow
+// ---------------------------------------------------------------------------
+
+function SkillRow({
+  skillName,
+  maxRank,
+  rank,
+  error,
+  onRankChange,
+  onRemove,
+}: {
+  skillName: string;
+  maxRank: number;
+  rank: number;
+  error?: string;
+  onRankChange: (r: number) => void;
+  onRemove: () => void;
+}) {
+  return (
+    <div style={{ display: "flex", flexDirection: "column", gap: "2px" }}>
+      <div style={{ display: "flex", alignItems: "center", gap: "8px" }}>
+        <span
+          style={{
+            flex: 1,
+            fontSize: "13px",
+            color: "var(--stone-300)",
+          }}
+        >
+          {skillName}
+        </span>
+        <span style={{ fontSize: "11px", color: "var(--stone-600)" }}>
+          rank
+        </span>
+        <input
+          type="number"
+          min={1}
+          max={maxRank}
+          value={rank}
+          onChange={(e) => onRankChange(Number(e.target.value))}
+          style={{
+            width: "48px",
+            height: "26px",
+            padding: "0 6px",
+            background: "var(--surface-2)",
+            border: `1px solid ${error ? "var(--danger)" : "var(--stone-800)"}`,
+            borderRadius: "var(--radius-card)",
+            color: "var(--stone-100)",
+            fontSize: "12px",
+            fontFamily: "var(--font-mono)",
+            textAlign: "center",
+          }}
+        />
+        <span style={{ fontSize: "11px", color: "var(--stone-700)" }}>
+          / {maxRank}
+        </span>
+        <button
+          type="button"
+          onClick={onRemove}
+          style={{
+            background: "none",
+            border: "none",
+            cursor: "pointer",
+            color: "var(--stone-600)",
+            padding: "2px",
+          }}
+          title="Remove skill"
+        >
+          <TrashIcon size={12} />
+        </button>
+      </div>
+      {error && (
+        <div style={{ fontSize: "11px", color: "var(--danger)", paddingLeft: "0" }}>
+          {error}
+        </div>
+      )}
+    </div>
+  );
+}
