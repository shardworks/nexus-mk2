+import { describe, it, expect, beforeEach, afterEach } from "vitest";
+import * as fs from "fs/promises";
+import * as os from "os";
+import * as path from "path";
+
+/**
+ * Persistence tests use a real temp directory so we exercise actual
+ * file I/O without hitting the project's data/ directory.
+ */
+
+let tmpDir: string;
+
+beforeEach(async () => {
+  tmpDir = await fs.mkdtemp(path.join(os.tmpdir(), "d4-test-"));
+  process.env.DATA_DIR = tmpDir;
+});
+
+afterEach(async () => {
+  delete process.env.DATA_DIR;
+  await fs.rm(tmpDir, { recursive: true, force: true });
+});
+
+// ---------------------------------------------------------------------------
+// Core persistence helpers
+// ---------------------------------------------------------------------------
+
+describe("readJsonFile / writeJsonFile", () => {
+  it("writes and reads back JSON", async () => {
+    const { writeJsonFile, readJsonFile } = await import("../lib/persistence");
+    const data = { hello: "world", count: 42 };
+    await writeJsonFile("test.json", data);
+    const result = await readJsonFile<typeof data>("test.json");
+    expect(result).toEqual(data);
+  });
+
+  it("returns null for missing file", async () => {
+    const { readJsonFile } = await import("../lib/persistence");
+    const result = await readJsonFile("nonexistent.json");
+    expect(result).toBeNull();
+  });
+
+  it("creates subdirectories as needed", async () => {
+    const { writeJsonFile, readJsonFile } = await import("../lib/persistence");
+    await writeJsonFile("nested/deep/file.json", { ok: true });
+    const result = await readJsonFile<{ ok: boolean }>("nested/deep/file.json");
+    expect(result?.ok).toBe(true);
+  });
+});
+
+// ---------------------------------------------------------------------------
+// Character CRUD
+// ---------------------------------------------------------------------------
+
+describe("character CRUD", () => {
+  it("creates and reads back a character", async () => {
+    const { createCharacter, getCharacter } = await import(
+      "../lib/persistence/characters"
+    );
+
+    const char = await createCharacter({
+      name: "Test Sorceress",
+      class: "Sorcerer",
+      level: 100,
+      paragonLevel: 150,
+    });
+
+    expect(char.id).toBeTruthy();
+    expect(char.name).toBe("Test Sorceress");
+    expect(char.class).toBe("Sorcerer");
+    expect(char.level).toBe(100);
+    expect(char.paragonLevel).toBe(150);
+    expect(char.createdAt).toBeTruthy();
+
+    const fetched = await getCharacter(char.id);
+    expect(fetched).toEqual(char);
+  });
+
+  it("lists all created characters", async () => {
+    const { createCharacter, listCharacters } = await import(
+      "../lib/persistence/characters"
+    );
+
+    await createCharacter({ name: "Char A", class: "Barbarian", level: 100, paragonLevel: 0 });
+    await createCharacter({ name: "Char B", class: "Druid", level: 80, paragonLevel: 50 });
+
+    const list = await listCharacters();
+    expect(list).toHaveLength(2);
+    expect(list.map((c) => c.name)).toContain("Char A");
+    expect(list.map((c) => c.name)).toContain("Char B");
+  });
+
+  it("updates a character and reflects in the index", async () => {
+    const { createCharacter, updateCharacter, getCharacter, listCharacters } =
+      await import("../lib/persistence/characters");
+
+    const orig = await createCharacter({
+      name: "Original",
+      class: "Rogue",
+      level: 60,
+      paragonLevel: 10,
+    });
+
+    const updated = await updateCharacter(orig.id, {
+      name: "Updated",
+      level: 100,
+      paragonLevel: 200,
+    });
+
+    expect(updated.name).toBe("Updated");
+    expect(updated.level).toBe(100);
+    expect(updated.class).toBe("Rogue"); // unchanged
+    expect(updated.createdAt).toBe(orig.createdAt); // immutable
+
+    const fetched = await getCharacter(orig.id);
+    expect(fetched?.name).toBe("Updated");
+
+    const list = await listCharacters();
+    const indexEntry = list.find((c) => c.id === orig.id);
+    expect(indexEntry?.name).toBe("Updated");
+  });
+
+  it("returns null for non-existent character", async () => {
+    const { getCharacter } = await import("../lib/persistence/characters");
+    expect(await getCharacter("does-not-exist")).toBeNull();
+  });
+
+  it("deletes character from index", async () => {
+    const { createCharacter, deleteCharacter, listCharacters } = await import(
+      "../lib/persistence/characters"
+    );
+
+    const char = await createCharacter({
+      name: "To Delete",
+      class: "Necromancer",
+      level: 100,
+      paragonLevel: 0,
+    });
+
+    await deleteCharacter(char.id);
+    const list = await listCharacters();
+    expect(list.find((c) => c.id === char.id)).toBeUndefined();
+  });
+});
+
+// ---------------------------------------------------------------------------
+// Build CRUD
+// ---------------------------------------------------------------------------
+
+describe("build CRUD", () => {
+  it("creates and reads back a build", async () => {
+    const { createBuild, getBuild } = await import("../lib/persistence/builds");
