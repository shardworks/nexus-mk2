+"use client";
+
+import { useState } from "react";
+import { useRouter } from "next/navigation";
+import {
+  D4_CLASSES,
+  MAX_CHARACTER_LEVEL,
+  MAX_PARAGON_LEVEL,
+} from "@/lib/types";
+import type { Character, D4Class } from "@/lib/types";
