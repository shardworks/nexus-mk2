+++ b/components/layout/CommandPalette.tsx
@@ -0,0 +1,362 @@
+"use client";
+
+import { useEffect, useState, useCallback } from "react";
+import { useRouter } from "next/navigation";
+import {
+  Dialog,
+  DialogContent,
+} from "@/components/ui/dialog";
+import {
+  Command,
+  CommandEmpty,
+  CommandGroup,
+  CommandInput,
+  CommandItem,
+  CommandList,
+  CommandSeparator,
+} from "@/components/ui/command";
+import {
+  UserIcon,
+  PlusIcon,
+  SwordIcon,
+  DownloadIcon,
+  UploadIcon,
+  BookOpenIcon,
+} from "lucide-react";
+
+// ---------------------------------------------------------------------------
+// Types
+// ---------------------------------------------------------------------------
+
+type PaletteItem = {
+  id: string;
+  label: string;
+  description?: string;
+  icon?: React.ReactNode;
+  action: () => void;
+  keywords?: string[];
+};
+
+type PaletteGroup = {
+  heading: string;
+  items: PaletteItem[];
+};
+
+// ---------------------------------------------------------------------------
+// Hook: listen for Cmd-K / Ctrl-K
+// ---------------------------------------------------------------------------
+
+function useCommandPalette() {
+  const [open, setOpen] = useState(false);
+
+  useEffect(() => {
+    const handleKeyDown = (e: KeyboardEvent) => {
+      const isMac = navigator.platform.toUpperCase().includes("MAC");
+      const modifier = isMac ? e.metaKey : e.ctrlKey;
+      if (modifier && e.key === "k") {
+        e.preventDefault();
+        setOpen((prev) => !prev);
+      }
+    };
+    document.addEventListener("keydown", handleKeyDown);
+    return () => document.removeEventListener("keydown", handleKeyDown);
+  }, []);
+
+  return { open, setOpen };
+}
+
+// ---------------------------------------------------------------------------
+// Dynamic commands — fetched from the API at open time
+// ---------------------------------------------------------------------------
+
+type CharacterEntry = { id: string; name: string; class: string };
+type BuildEntry = { id: string; name: string; characterId: string };
+
+async function fetchCharacters(): Promise<CharacterEntry[]> {
+  try {
+    const res = await fetch("/api/characters", { cache: "no-store" });
+    if (!res.ok) return [];
+    return res.json();
+  } catch {
+    return [];
+  }
+}
+
+async function fetchBuilds(): Promise<BuildEntry[]> {
+  try {
+    const res = await fetch("/api/builds", { cache: "no-store" });
+    if (!res.ok) return [];
+    return res.json();
+  } catch {
+    return [];
+  }
+}
+
+// ---------------------------------------------------------------------------
+// Export file helper
+// ---------------------------------------------------------------------------
+
+function exportJson(data: unknown, filename: string) {
+  const blob = new Blob([JSON.stringify(data, null, 2)], {
+    type: "application/json",
+  });
+  const url = URL.createObjectURL(blob);
+  const a = document.createElement("a");
+  a.href = url;
+  a.download = filename;
+  a.click();
+  URL.revokeObjectURL(url);
+}
+
+async function importJson(): Promise<unknown | null> {
+  return new Promise((resolve) => {
+    const input = document.createElement("input");
+    input.type = "file";
+    input.accept = ".json";
+    input.onchange = async () => {
+      const file = input.files?.[0];
+      if (!file) return resolve(null);
+      const text = await file.text();
+      try {
+        resolve(JSON.parse(text));
+      } catch {
+        resolve(null);
+      }
+    };
+    input.click();
+  });
+}
+
+// ---------------------------------------------------------------------------
+// Component
+// ---------------------------------------------------------------------------
+
+export function CommandPalette() {
+  const router = useRouter();
+  const { open, setOpen } = useCommandPalette();
+
+  const [characters, setCharacters] = useState<CharacterEntry[]>([]);
+  const [builds, setBuilds] = useState<BuildEntry[]>([]);
+  const [importStatus, setImportStatus] = useState<string | null>(null);
+
+  // Fetch dynamic data when palette opens
+  useEffect(() => {
+    if (!open) return;
+    void Promise.all([fetchCharacters(), fetchBuilds()]).then(([chars, blds]) => {
+      setCharacters(chars);
+      setBuilds(blds);
+    });
+  }, [open]);
+
+  const run = useCallback(
+    (action: () => void) => {
+      setOpen(false);
+      action();
+    },
+    [setOpen],
+  );
+
+  // -------------------------------------------------------------------------
+  // Command groups
+  // -------------------------------------------------------------------------
+
+  const groups: PaletteGroup[] = [
+    {
+      heading: "Create",
+      items: [
+        {
+          id: "new-character",
+          label: "New Character",
+          description: "Start a new character",
+          icon: <UserIcon size={14} />,
+          action: () => run(() => router.push("/characters/new")),
+          keywords: ["create", "character", "new"],
+        },
+      ],
+    },
+    {
+      heading: "Navigate",
+      items: [
+        {
+          id: "nav-characters",
+          label: "All Characters",
+          description: "Go to characters list",
+          icon: <BookOpenIcon size={14} />,
+          action: () => run(() => router.push("/characters")),
+          keywords: ["list", "characters"],
+        },
+        ...characters.map((c) => ({
+          id: `char-${c.id}`,
+          label: c.name,
+          description: `${c.class} — jump to character`,
+          icon: <SwordIcon size={14} />,
+          action: () => run(() => router.push(`/characters/${c.id}`)),
+          keywords: [c.class.toLowerCase(), "character"],
+        })),
+        ...builds.map((b) => ({
+          id: `build-${b.id}`,
+          label: b.name,
+          description: "Jump to build",
+          icon: <SwordIcon size={14} />,
+          action: () => run(() => router.push(`/builds/${b.id}`)),
+          keywords: ["build"],
+        })),
+      ],
+    },
+    {
+      heading: "Data",
+      items: [
+        {
+          id: "export-chars",
+          label: "Export All Characters",
+          description: "Download characters.json",
+          icon: <DownloadIcon size={14} />,
+          action: () =>
+            run(async () => {
+              const data = await fetchCharacters();
+              exportJson(data, "d4-characters.json");
+            }),
+          keywords: ["export", "download", "json"],
+        },
+        {
+          id: "export-builds",
+          label: "Export All Builds",
+          description: "Download builds.json",
+          icon: <DownloadIcon size={14} />,
+          action: () =>
+            run(async () => {
+              const data = await fetchBuilds();
+              exportJson(data, "d4-builds.json");
+            }),
+          keywords: ["export", "download", "json"],
+        },
+        {
+          id: "import-build",
+          label: "Import Build File",
+          description: "Upload a build JSON to create a new build",
+          icon: <UploadIcon size={14} />,
+          action: () =>
+            run(async () => {
+              const data = await importJson();
+              if (!data) return;
+              setImportStatus("Importing…");
+              try {
+                const res = await fetch("/api/builds", {
+                  method: "POST",
+                  headers: { "Content-Type": "application/json" },
+                  body: JSON.stringify(data),
+                });
+                if (res.ok) {
+                  const build = await res.json();
+                  router.push(`/builds/${build.id}`);
+                } else {
+                  setImportStatus("Import failed — invalid build format");
+                }
+              } catch {
+                setImportStatus("Import failed");
+              }
+            }),
+          keywords: ["import", "upload", "json"],
+        },
+      ],
+    },
+  ];
+
+  // -------------------------------------------------------------------------
+  // Render
+  // -------------------------------------------------------------------------
+
+  return (
+    <>
+      <Dialog open={open} onOpenChange={setOpen}>
+        <DialogContent
+          className="overflow-hidden p-0 shadow-lg"
+          style={{ maxWidth: "32rem" }}
+        >
+          <Command
+            className={[
+              "[&_[cmdk-group-heading]]:px-2",
+              "[&_[cmdk-group-heading]]:font-medium",
+              "[&_[cmdk-group]:not([hidden])_~[cmdk-group]]:pt-0",
+              "[&_[cmdk-group]]:px-2",
+              "[&_[cmdk-input-wrapper]_svg]:h-5",
+              "[&_[cmdk-input-wrapper]_svg]:w-5",
+              "[&_[cmdk-input]]:h-12",
+              "[&_[cmdk-item]]:px-2",
+              "[&_[cmdk-item]]:py-3",
+              "[&_[cmdk-item]_svg]:h-5",
+              "[&_[cmdk-item]_svg]:w-5",
+            ].join(" ")}
+          >
+            <CommandInput placeholder="Type a command or search…" />
+            <CommandList>
+              <CommandEmpty>No commands found.</CommandEmpty>
+
+              {groups.map((group, gi) => (
+                <div key={group.heading}>
+                  {gi > 0 && <CommandSeparator />}
+                  <CommandGroup heading={group.heading}>
+                    {group.items.map((item) => (
+                      <CommandItem
+                        key={item.id}
+                        value={`${item.label} ${item.keywords?.join(" ") ?? ""}`}
+                        onSelect={item.action}
+                        style={{
+                          display: "flex",
+                          alignItems: "center",
+                          gap: "10px",
+                          cursor: "pointer",
+                        }}
+                      >
+                        <span style={{ color: "var(--stone-500)", flexShrink: 0 }}>
+                          {item.icon ?? <PlusIcon size={14} />}
+                        </span>
+                        <div style={{ flex: 1, minWidth: 0 }}>
+                          <div style={{ fontSize: "13px" }}>{item.label}</div>
+                          {item.description && (
+                            <div
+                              style={{
+                                fontSize: "11px",
+                                color: "var(--stone-500)",
+                                overflow: "hidden",
+                                textOverflow: "ellipsis",
+                                whiteSpace: "nowrap",
+                              }}
+                            >
+                              {item.description}
+                            </div>
+                          )}
+                        </div>
+                      </CommandItem>
+                    ))}
+                  </CommandGroup>
+                </div>
+              ))}
+            </CommandList>
+          </Command>
+        </DialogContent>
+      </Dialog>
+
+      {/* Import status toast */}
+      {importStatus && (
+        <div
+          style={{
+            position: "fixed",
+            bottom: "20px",
+            right: "20px",
+            padding: "10px 16px",
+            background: "var(--surface-2)",
+            border: "1px solid var(--stone-700)",
+            borderRadius: "var(--radius-card)",
+            color: "var(--stone-200)",
+            fontSize: "13px",
+            zIndex: 9999,
+          }}
+          onClick={() => setImportStatus(null)}
+        >
+          {importStatus}
+        </div>
+      )}
+    </>
+  );
+}
