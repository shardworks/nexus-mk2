+
+      const api = plugin.apparatus.provides as ReckonerApi;
+      await api.withdraw('w-test-001');
+
+      assert.equal(transitionCalls[0][2], undefined);
+    });
+  });
+
+  // ── registeredSources() ────────────────────────────────────────────
+
+  describe('registeredSources()', () => {
+    it('returns all sources registered from kit contributions', async () => {
+      const plugin = createReckoner();
+      if (!('apparatus' in plugin)) throw new Error('expected apparatus');
+
+      const kits: LoadedKit[] = [
+        {
+          id: 'alpha',
+          packageName: '@test/alpha',
+          version: '0.0.0',
+          kit: { petitioners: [{ source: 'alpha.detect', description: 'A' }] },
+        },
+        {
+          id: 'beta',
+          packageName: '@test/beta',
+          version: '0.0.0',
+          kit: { petitioners: [{ source: 'beta.scan', description: 'B' }] },
+        },
+      ];
+      const { ctx } = buildCtx(buildKitEntries(kits));
+
+      setGuild(buildFakeGuild());
+      await plugin.apparatus.start(ctx);
+
+      const api = plugin.apparatus.provides as ReckonerApi;
+      const sources = api.registeredSources();
+      assert.equal(sources.size, 2);
+      assert.equal(sources.has('alpha.detect'), true);
+      assert.equal(sources.has('beta.scan'), true);
+    });
+
+    it('returns an empty map when no petitioners are registered', async () => {
+      const plugin = createReckoner();
