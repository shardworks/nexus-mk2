+/**
+ * @shardworks/reckoner-apparatus — The Reckoner.
+ *
+ * Petitioner registry, priority types, and petition helper APIs for
+ * dimension-driven writ scheduling.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import { createReckoner } from './reckoner.ts';
+
+// ── Public types ──────────────────────────────────────────────────────────
+
+export type {
+  ComplexityTier,
+  DomainTag,
+  PetitionRequest,
+  PetitionerDescriptor,
+  Priority,
+  ReckonerApi,
+  ReckonerConfig,
+  ReckonerExt,
+  ReckonerKit,
+  ResolvedReckonerConfig,
+} from './types.ts';
+
+export { RECKONER_PLUGIN_ID } from './types.ts';
+
+// ── Helper functions ──────────────────────────────────────────────────────
+
+export {
+  createReckoner,
+  defaultPriority,
+  fillPriorityDefaults,
+  validateComplexity,
+  validatePriority,
+} from './reckoner.ts';
+
+export { validateSourceId } from './registry.ts';
+
+// ── Default export ────────────────────────────────────────────────────────
+
+export default createReckoner();
