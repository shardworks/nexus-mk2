+++ b/packages/plugins/reckoner/src/reckoner.ts
@@ -0,0 +1,314 @@
+/**
+ * The Reckoner apparatus — petitioner registry, priority types, and petition
+ * helper APIs for dimension-driven writ scheduling.
+ *
+ * This module implements:
+ *   - `defaultPriority()` — default priority dimensions per contract §3.
+ *   - `fillPriorityDefaults()` — fills a partial Priority with defaults.
+ *   - `validatePriority()` — validates all five dimensions against the schema.
+ *   - `validateComplexity()` — validates a ComplexityTier string.
+ *   - `createReckoner()` — apparatus factory.
+ *
+ * The apparatus consumes `petitioners` kit contributions, builds and seals
+ * the source registry, and exposes the `ReckonerApi` (`petition()` /
+ * `withdraw()`) via `provides`.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { Plugin, StartupContext } from '@shardworks/nexus-core';
+import { guild } from '@shardworks/nexus-core';
+import type { ClerkApi, WritDoc } from '@shardworks/clerk-apparatus';
+
+import { PetitionerRegistry } from './registry.ts';
+import type {
+  ComplexityTier,
+  PetitionRequest,
+  PetitionerDescriptor,
+  Priority,
+  ReckonerApi,
+  ReckonerConfig,
+  ReckonerExt,
+  ResolvedReckonerConfig,
+} from './types.ts';
+import { RECKONER_PLUGIN_ID } from './types.ts';
+
+// ── Default priority (§3) ────────────────────────────────────────────────
+
+/**
+ * Return the contract-specified default priority dimensions.
+ *
+ * Defaults: `vision-neutral / minor / minor-area / {decay: false, deadline: null} / []`
+ *
+ * See: docs/architecture/petitioner-registration.md §3 "Defaults when omitted"
+ */
+export function defaultPriority(): Priority {
+  return {
+    visionRelation: 'vision-neutral',
+    severity: 'minor',
+    scope: 'minor-area',
+    time: { decay: false, deadline: null },
+    domain: [],
+  };
+}
+
+/**
+ * Apply default priority dimensions for any fields omitted from `partial`.
+ *
+ * Each dimension is independently optional — a petitioner may supply
+ * `visionRelation: 'vision-violator'` without filling in `severity`,
+ * `scope`, `time`, or `domain`; those fall back to defaults.
+ */
+export function fillPriorityDefaults(partial: Partial<Priority>): Priority {
+  const defaults = defaultPriority();
+  return {
+    visionRelation: partial.visionRelation ?? defaults.visionRelation,
+    severity: partial.severity ?? defaults.severity,
+    scope: partial.scope ?? defaults.scope,
+    time: partial.time !== undefined ? partial.time : defaults.time,
+    domain: partial.domain ?? defaults.domain,
+  };
+}
+
+// ── Dimension validation ─────────────────────────────────────────────────
+
+const VALID_VISION_RELATIONS = new Set<string>([
+  'vision-blocker',
+  'vision-violator',
+  'vision-advancer',
+  'vision-neutral',
+]);
+
+const VALID_SEVERITIES = new Set<string>([
+  'critical',
+  'serious',
+  'moderate',
+  'minor',
+]);
+
+const VALID_SCOPES = new Set<string>([
+  'whole-product',
+  'major-area',
+  'minor-area',
+]);
+
+const VALID_DOMAINS = new Set<string>([
+  'security',
+  'compliance',
+  'cost',
+  'feature',
+  'quality',
+  'infrastructure',
+  'documentation',
+  'research',
+  'ergonomics',
+]);
+
+const VALID_COMPLEXITY_TIERS = new Set<string>([
+  'mechanical',
+  'bounded',
+  'exploratory',
+  'open-ended',
+]);
+
+/**
+ * Validate all five priority dimensions against the declared schema.
+ * Throws with a descriptive message on any invalid value.
+ */
+export function validatePriority(priority: Priority): void {
+  if (!VALID_VISION_RELATIONS.has(priority.visionRelation)) {
+    throw new Error(
+      `[reckoner] Invalid visionRelation "${priority.visionRelation}". ` +
+      `Valid values: ${[...VALID_VISION_RELATIONS].join(', ')}.`,
+    );
+  }
+  if (!VALID_SEVERITIES.has(priority.severity)) {
+    throw new Error(
+      `[reckoner] Invalid severity "${priority.severity}". ` +
+      `Valid values: ${[...VALID_SEVERITIES].join(', ')}.`,
+    );
+  }
+  if (!VALID_SCOPES.has(priority.scope)) {
+    throw new Error(
+      `[reckoner] Invalid scope "${priority.scope}". ` +
+      `Valid values: ${[...VALID_SCOPES].join(', ')}.`,
+    );
+  }
+  if (typeof priority.time.decay !== 'boolean') {
+    throw new Error(
+      `[reckoner] Priority time.decay must be a boolean, got ${typeof priority.time.decay}.`,
+    );
+  }
+  if (priority.time.deadline !== null && typeof priority.time.deadline !== 'string') {
+    throw new Error(
+      `[reckoner] Priority time.deadline must be a string (ISO date) or null, ` +
+      `got ${typeof priority.time.deadline}.`,
+    );
+  }
+  for (const tag of priority.domain) {
+    if (!VALID_DOMAINS.has(tag)) {
+      throw new Error(
+        `[reckoner] Invalid domain tag "${tag}". ` +
+        `Valid values: ${[...VALID_DOMAINS].join(', ')}.`,
+      );
+    }
+  }
+}
+
+/**
+ * Validate a complexity tier string against the declared enum.
+ * Throws with a descriptive message when the value is invalid.
+ */
+export function validateComplexity(complexity: ComplexityTier): void {
+  if (!VALID_COMPLEXITY_TIERS.has(complexity)) {
+    throw new Error(
+      `[reckoner] Invalid complexity tier "${complexity}". ` +
+      `Valid values: ${[...VALID_COMPLEXITY_TIERS].join(', ')}.`,
+    );
+  }
+}
+
+// ── Config helper ─────────────────────────────────────────────────────────
+
+/**
+ * Read and resolve the Reckoner configuration from `guild.json`, applying
+ * defaults for omitted fields.
+ */
+function resolveReckonerConfig(): ResolvedReckonerConfig {
+  const raw = guild().config<ReckonerConfig>('reckoner');
+  return {
+    enforceRegistration: raw.enforceRegistration ?? false,
+    disabledSources: raw.disabledSources ?? [],
+  };
+}
+
+// ── Plugin factory ────────────────────────────────────────────────────────
+
+/**
+ * Create the Reckoner apparatus plugin.
+ *
+ * The apparatus:
+ * - Consumes `petitioners` kit contributions and builds a source registry.
+ * - Seals the registry on `phase:started`.
+ * - Exposes `ReckonerApi` via `provides`:
+ *   - `petition(request)` — post a held writ with Reckoner ext populated.
+ *   - `withdraw(writId, reason?)` — cancel a held writ.
+ *   - `registeredSources()` — snapshot of the sealed registry.
+ *   - `reckonerConfig()` — resolved configuration with defaults applied.
+ *
+ * @example
+ * ```typescript
+ * // guild.json plugin entry:
+ * "@shardworks/reckoner-apparatus"
+ *
+ * // Call from another apparatus:
+ * const reckoner = guild().apparatus<ReckonerApi>('reckoner');
+ * const writ = await reckoner.petition({
+ *   type: 'mandate', title: '...', body: '...', codex: 'nexus',
+ *   source: 'vision-keeper.snapshot',
+ *   priority: { visionRelation: 'vision-violator' },
+ * });
+ * ```
+ */
+export function createReckoner(): Plugin {
+  const registry = new PetitionerRegistry();
+
+  const api: ReckonerApi = {
+    async petition(request: PetitionRequest): Promise<WritDoc> {
+      const config = resolveReckonerConfig();
+
+      // Step 1: validate source against the registry (per enforceRegistration).
+      if (!registry.has(request.source)) {
+        if (config.enforceRegistration) {
+          throw new Error(
+            `[reckoner] Unregistered source "${request.source}" — ` +
+            `petition rejected (enforceRegistration is true).`,
+          );
+        } else {
+          // Permissive mode: log a warning but proceed.
+          console.warn(
+            `[reckoner] Warning: unregistered source "${request.source}" — ` +
+            `proceeding (enforceRegistration is false).`,
+          );
+        }
+      }
+
+      // Step 2: apply priority defaults for omitted dimensions.
+      const priority = fillPriorityDefaults(request.priority);
+
+      // Step 3: validate dimension values against the schema.
+      validatePriority(priority);
+      if (request.complexity !== undefined) {
+        validateComplexity(request.complexity);
+      }
+
+      // Step 4: call clerk.post() with the writ fields.
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+      const writ = await clerk.post({
+        type: request.type,
+        title: request.title,
+        body: request.body,
+        codex: request.codex,
+        parentId: request.parentId,
+      });
+
+      // Step 5: write ext.reckoner via clerk.setWritExt().
+      const ext: ReckonerExt = {
+        source: request.source,
+        priority,
+        ...(request.complexity !== undefined ? { complexity: request.complexity } : {}),
+        ...(request.payload !== undefined ? { payload: request.payload } : {}),
+        ...(request.labels !== undefined ? { labels: request.labels } : {}),
+      };
+      const updated = await clerk.setWritExt(writ.id, RECKONER_PLUGIN_ID, ext);
+      return updated;
+    },
+
+    async withdraw(writId: string, reason?: string): Promise<WritDoc> {
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+      return clerk.transition(
+        writId,
+        'cancelled',
+        reason !== undefined ? { resolution: reason } : undefined,
+      );
+    },
+
+    registeredSources(): ReadonlyMap<string, PetitionerDescriptor> {
+      return registry.asReadonlyMap();
+    },
+
+    reckonerConfig(): ResolvedReckonerConfig {
+      return resolveReckonerConfig();
+    },
+  };
+
+  return {
+    apparatus: {
+      requires: ['clerk'],
+      consumes: ['petitioners'],
+
+      provides: api,
+
+      async start(ctx: StartupContext): Promise<void> {
+        // Consume petitioner kit contributions and build the registry.
+        for (const entry of ctx.kits('petitioners')) {
+          const value = entry.value;
+          if (!Array.isArray(value)) {
+            throw new Error(
+              `[reckoner] Plugin "${entry.pluginId}" petitioners contribution ` +
+              `must be an array, got ${typeof value}.`,
+            );
+          }
+          for (const descriptor of value) {
+            registry.register(descriptor as PetitionerDescriptor, entry.pluginId);
+          }
+        }
+
+        // Seal the registry after all plugins have started.
+        ctx.on('phase:started', () => {
+          registry.seal();
+        });
+      },
+    },
+  };
+}
