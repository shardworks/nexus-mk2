+++ b/packages/plugins/reckoner/src/types.ts
@@ -0,0 +1,329 @@
+/**
+ * Reckoner public types.
+ *
+ * The Reckoner apparatus manages Reckoner-gated writs — writs in `new` phase
+ * carrying `ext['reckoner']` that signals the Reckoner should govern their
+ * transition. This module defines the petition shape, priority dimensions,
+ * complexity tiers, the petitioner registry schema, and the runtime API.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { WritDoc } from '@shardworks/clerk-apparatus';
+
+// ── Priority dimensions (§3) ────────────────────────────────────────────
+
+/**
+ * Domain classification tags for the `domain` priority dimension.
+ * Multi-valued — a petition may span several domains.
+ */
+export type DomainTag =
+  | 'security'
+  | 'compliance'
+  | 'cost'
+  | 'feature'
+  | 'quality'
+  | 'infrastructure'
+  | 'documentation'
+  | 'research'
+  | 'ergonomics';
+
+/**
+ * Multi-dimensional priority for a Reckoner-gated writ.
+ *
+ * Designed to be inspectable and defensible rather than mechanically
+ * objective — petitioners declare honest inputs; the Reckoner does
+ * judgment-laden contextual collapse.
+ *
+ * See: docs/architecture/petitioner-registration.md §3
+ */
+export type Priority = {
+  /**
+   * How this petition relates to the product vision.
+   * - `vision-blocker`  — vision is unreachable without this.
+   * - `vision-violator` — current state actively diverges from vision.
+   * - `vision-advancer` — pushes toward an aspirational, not-yet-realized aspect.
+   * - `vision-neutral`  — doesn't touch the product vision.
+   */
+  visionRelation:
+    | 'vision-blocker'
+    | 'vision-violator'
+    | 'vision-advancer'
+    | 'vision-neutral';
+  /**
+   * Severity if the petition is not acted on.
+   * - `critical`  — production breakage, security incident, agents fully blocked.
+   * - `serious`   — significant ongoing degradation; daily workarounds.
+   * - `moderate`  — noticeable but tolerable.
+   * - `minor`     — easy to live with; cosmetic, convenience, polish.
+   */
+  severity: 'critical' | 'serious' | 'moderate' | 'minor';
+  /**
+   * What fraction of the system is affected.
+   * - `whole-product` — every user / every commission / every guild.
+   * - `major-area`    — a major feature or subsystem.
+   * - `minor-area`    — a small slice, one workflow, one command.
+   */
+  scope: 'whole-product' | 'major-area' | 'minor-area';
+  /**
+   * Time-pressure axes. Two genuinely independent signals:
+   * - `decay: true`    — urgency increases with time (drift, accumulating debt).
+   * - `deadline`       — a specific external commitment date (ISO date string).
+   * Both, either, or neither are valid combinations.
+   */
+  time: {
+    decay: boolean;
+    deadline: string | null; // ISO date string, or null
+  };
+  /**
+   * Domain classification tags. Multi-valued and non-exclusive.
+   * Used for filtering, patron-tunable weighting, and reporting.
+   */
+  domain: Array<DomainTag>;
+};
+
+// ── Complexity tier (§4) ────────────────────────────────────────────────
+
+/**
+ * Petitioner-side coarse token-cost estimate.
+ *
+ * Refined by the Astrolabe at plan time. Petitioners are encouraged to
+ * omit rather than guess — omission is honest; a wild guess is misleading.
+ *
+ * - `mechanical`   — clear path, minimal exploration (~50K–200K tokens).
+ * - `bounded`      — clear scope, some exploration (~200K–1M tokens).
+ * - `exploratory`  — design judgment required, cross-cutting (~1M–5M tokens).
+ * - `open-ended`   — research or scope likely to grow (~5M+ tokens).
+ *
+ * See: docs/architecture/petitioner-registration.md §4
+ */
+export type ComplexityTier =
+  | 'mechanical'
+  | 'bounded'
+  | 'exploratory'
+  | 'open-ended';
+
+// ── Reckoner ext shape (§2) ─────────────────────────────────────────────
+
+/**
+ * The `writ.ext['reckoner']` payload shape.
+ *
+ * The presence of this ext on a writ in `new` phase signals to the Reckoner
+ * that this writ is a held petition under its governance.
+ *
+ * See: docs/architecture/petitioner-registration.md §2
+ */
+export interface ReckonerExt {
+  /**
+   * Registered petitioner source id (e.g. `vision-keeper.snapshot`).
+   * Must match a registered petitioner when `enforceRegistration` is true.
+   */
+  source: string;
+  /**
+   * Multi-dimensional priority. All five dimensions are always present
+   * after `reckoner.petition()` applies defaults.
+   */
+  priority: Priority;
+  /**
+   * Petitioner-side coarse token-cost estimate. Omitted when the
+   * petitioner has no basis to claim one.
+   */
+  complexity?: ComplexityTier;
+  /**
+   * Opaque petitioner-defined structured data. The Reckoner stores it
+   * but does not introspect; the rig's implementation engine reads it
+   * if needed.
+   */
+  payload?: unknown;
+  /**
+   * Additive non-priority metadata for multi-instance discrimination
+   * (e.g. `'vision-keeper.io/vision-id': 'nexus'`), observability hints,
+   * and diagnostic tags.
+   */
+  labels?: Record<string, string>;
+}
+
+// ── Petitioner registry (§5) ────────────────────────────────────────────
+
+/**
+ * A petitioner descriptor declared in a kit's `petitioners` contribution.
+ *
+ * Source ids must be of the form `{pluginId}.{kebab-suffix}`, matching the
+ * convention for Lattice trigger-types and Clerk link-kinds.
+ */
+export interface PetitionerDescriptor {
+  /**
+   * Petitioner source id. Form: `{pluginId}.{kebab-suffix}`.
+   * Examples: `vision-keeper.snapshot`, `patron-bridge.commission`.
+   */
+  source: string;
+  /**
+   * One-liner describing what this petitioner emits. Used for
+   * discoverability and operator documentation.
+   */
+  description: string;
+}
+
+/**
+ * Kit contribution interface for the Reckoner's petitioner registry.
+ *
+ * Apparatus and kit packages that emit Reckoner-gated writs declare their
+ * sources via this interface in their kit or supportKit object.
+ *
+ * @example
+ * ```typescript
+ * export default {
+ *   kit: {
+ *     requires: ['reckoner'],
+ *     petitioners: [{
+ *       source: 'vision-keeper.snapshot',
+ *       description: 'Periodic vision-vs-reality snapshots.',
+ *     }],
+ *   },
+ * };
+ * ```
+ */
+export interface ReckonerKit {
+  petitioners?: PetitionerDescriptor[];
+}
+
+// ── Configuration (§6) ─────────────────────────────────────────────────
+
+/**
+ * Reckoner apparatus configuration — lives under the `reckoner` key in
+ * guild.json. All fields are optional; defaults are permissive.
+ *
+ * @example
+ * ```json
+ * {
+ *   "reckoner": {
+ *     "enforceRegistration": false,
+ *     "disabledSources": []
+ *   }
+ * }
+ * ```
+ */
+export interface ReckonerConfig {
+  /**
+   * Controls handling of petitions from unregistered sources.
+   * - `false` (default) — log a warning and proceed with normal consideration.
+   * - `true` — decline the petition, transitioning `new` → `cancelled`.
+   */
+  enforceRegistration?: boolean;
+  /**
+   * Per-source disable list. Petitions from any listed source are skipped
+   * (left in `new` phase, no reckoning entry). Removing a source from the
+   * list allows pending writs to be reconsidered.
+   */
+  disabledSources?: string[];
+}
+
+/**
+ * Fully-resolved Reckoner configuration with all defaults applied.
+ * Returned by `ReckonerApi.reckonerConfig()`.
+ */
+export interface ResolvedReckonerConfig {
+  /** Whether unregistered sources are declined (default: false). */
+  enforceRegistration: boolean;
+  /** Sources to skip entirely (default: []). */
+  disabledSources: string[];
+}
+
+// ── Helper API (§1) ─────────────────────────────────────────────────────
+
+/**
+ * Request to post a Reckoner-gated writ via `reckoner.petition()`.
+ *
+ * Writ fields are passed through to `clerk.post()`; ext.reckoner fields
+ * are combined and written via `clerk.setWritExt()`.
+ */
+export interface PetitionRequest {
+  // ── Writ fields (passed through to clerk.post) ──────────────────
+  /** Writ type — must be registered with the Clerk. */
+  type: string;
+  /** Short human-readable title. */
+  title: string;
+  /** Detail text. */
+  body: string;
+  /** Target codex name. */
+  codex: string;
+  /** Optional parent writ id. */
+  parentId?: string;
+
+  // ── ext.reckoner fields ─────────────────────────────────────────
+  /**
+   * Petitioner source id. Validated against the registry per
+   * `enforceRegistration` config.
+   */
+  source: string;
+  /**
+   * Priority dimensions. Omitted fields fall back to defaults:
+   * `vision-neutral / minor / minor-area / {decay: false, deadline: null} / []`.
+   */
+  priority: Partial<Priority>;
+  /** Optional petitioner-side token-cost estimate. */
+  complexity?: ComplexityTier;
+  /** Opaque petitioner-defined structured data. */
+  payload?: unknown;
+  /** Additive non-priority metadata (multi-instance discrimination, tags). */
+  labels?: Record<string, string>;
+}
+
+/**
+ * Runtime API exposed by the Reckoner apparatus.
+ * Retrieved via `guild().apparatus<ReckonerApi>('reckoner')`.
+ */
+export interface ReckonerApi {
+  /**
+   * Post a writ in `new` phase with Reckoner ext set correctly.
+   *
+   * Steps:
+   * 1. Validates `source` against the registry (subject to `enforceRegistration`).
+   * 2. Applies priority defaults for omitted dimensions.
+   * 3. Validates dimension values against the schema.
+   * 4. Calls `clerk.post()` with the writ fields.
+   * 5. Writes `writ.ext['reckoner']` via `clerk.setWritExt()`.
+   *
+   * Returns the persisted `WritDoc` with `phase: 'new'` and `ext.reckoner`
+   * populated. Equivalent in effect to Workflow 1 (direct `clerk.post()` with
+   * manual ext); this helper exists for type-checking, default-filling, and
+   * discoverability.
+   */
+  petition(request: PetitionRequest): Promise<WritDoc>;
+
+  /**
+   * Withdraw a held writ by transitioning it to `cancelled`.
+   *
+   * Thin wrapper around `clerk.transition(writId, 'cancelled', {resolution: reason})`.
+   * No special source-check — the wrapper's purpose is ergonomic
+   * discoverability, not enforcement.
+   */
+  withdraw(writId: string, reason?: string): Promise<WritDoc>;
+
+  /**
+   * Snapshot of all registered petitioner sources, keyed by source id.
+   * The map is sealed after `phase:started`.
+   */
+  registeredSources(): ReadonlyMap<string, PetitionerDescriptor>;
+
+  /**
+   * Current resolved Reckoner configuration with all defaults applied.
+   * Reads from `guild().config('reckoner')` on each call (no caching).
+   */
+  reckonerConfig(): ResolvedReckonerConfig;
+}
+
+// ── Constants ────────────────────────────────────────────────────────────
+
+/** Plugin id of the Reckoner apparatus. Stamped as `ext['reckoner']` key. */
+export const RECKONER_PLUGIN_ID = 'reckoner';
+
+// ── GuildConfig augmentation ─────────────────────────────────────────────
+
+// Augment GuildConfig so guild().guildConfig().reckoner is typed without
+// requiring a manual type parameter at the call site.
+declare module '@shardworks/nexus-core' {
+  interface GuildConfig {
+    reckoner?: ReckonerConfig;
+  }
+}
