+/**
+ * Reckoner apparatus — unit tests.
+ *
+ * Covers:
+ *   - PetitionerRegistry: registration, duplicate collision, source-id grammar,
+ *     prefix mismatch, sealing, post-seal registration rejection.
+ *   - `defaultPriority()`: correct default values.
+ *   - `fillPriorityDefaults()`: partial fill preserves supplied fields.
+ *   - `validatePriority()`: accepts valid dimensions, rejects invalid values.
+ *   - `validateComplexity()`: accepts valid tiers, rejects unknown values.
+ *   - `createReckoner()` apparatus:
+ *     - Consumes `petitioners` kit contributions during start().
+ *     - Non-array contribution hard-fails during start().
+ *     - `petition()` with enforceRegistration=false and unregistered source:
+ *       proceeds (warns).
+ *     - `petition()` with enforceRegistration=true and unregistered source:
+ *       throws fail-loud.
+ *     - `petition()` with registered source and partial priority: applies
+ *       defaults, resulting writ has phase 'new' and ext.reckoner populated.
+ *     - `petition()` with all priority dimensions explicit: stores exactly.
+ *     - `petition()` with invalid priority dimension: throws before posting.
+ *     - `withdraw()` transitions writ to cancelled with reason.
+ *     - `registeredSources()` returns the sealed registry snapshot.
+ *     - `reckonerConfig()` returns resolved config with defaults.
+ */
+
+import { describe, it, beforeEach, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type { Guild, GuildConfig, KitEntry, LoadedApparatus, LoadedKit } from '@shardworks/nexus-core';
+
+import type { ClerkApi, WritDoc } from '@shardworks/clerk-apparatus';
+
+import {
+  createReckoner,
+  defaultPriority,
+  fillPriorityDefaults,
+  validateComplexity,
+  validatePriority,
+} from './reckoner.ts';
+import { PetitionerRegistry, validateSourceId } from './registry.ts';
+import type { PetitionRequest, Priority, ReckonerApi, ReckonerConfig } from './types.ts';
+import { RECKONER_PLUGIN_ID } from './types.ts';
+
+// ── Test utilities ────────────────────────────────────────────────────────
+
+const FRAMEWORK_KIT_FIELDS = new Set(['requires', 'recommends']);
+
+function buildKitEntries(
+  kits: LoadedKit[],
+  apparatuses: LoadedApparatus[] = [],
+): KitEntry[] {
+  const entries: KitEntry[] = [];
+  for (const kit of kits) {
+    for (const [type, value] of Object.entries(kit.kit)) {
+      if (FRAMEWORK_KIT_FIELDS.has(type)) continue;
+      entries.push({ pluginId: kit.id, packageName: kit.packageName, type, value });
+    }
+  }
+  for (const app of apparatuses) {
+    const bag = app.apparatus.supportKit;
+    if (!bag || typeof bag !== 'object') continue;
+    for (const [type, value] of Object.entries(bag)) {
+      if (FRAMEWORK_KIT_FIELDS.has(type)) continue;
+      entries.push({ pluginId: app.id, packageName: app.packageName, type, value });
+    }
+  }
+  return entries;
+}
+
+type PhaseHandler = () => void | Promise<void>;
+
+interface TestStartupContext {
+  readonly ctx: import('@shardworks/nexus-core').StartupContext;
+  firePhaseStarted(): Promise<void>;
+}
+
+function buildCtx(entries: KitEntry[] = []): TestStartupContext {
+  const handlers: Map<string, PhaseHandler[]> = new Map();
+  const ctx: import('@shardworks/nexus-core').StartupContext = {
+    on(event: string, handler: (...args: unknown[]) => void | Promise<void>): void {
+      const list = handlers.get(event) ?? [];
+      list.push(handler as PhaseHandler);
+      handlers.set(event, list);
+    },
+    kits(type: string): KitEntry[] {
+      return [...entries.filter((e) => e.type === type)];
+    },
+  };
+  return {
+    ctx,
+    async firePhaseStarted(): Promise<void> {
+      for (const h of handlers.get('phase:started') ?? []) {
+        await h();
+      }
+    },
+  };
+}
+
+/** Minimal mock WritDoc returned by fake clerk. */
+function makeWritDoc(id = 'w-test-001', overrides: Partial<WritDoc> = {}): WritDoc {
+  return {
+    id,
+    type: 'mandate',
+    phase: 'new',
+    title: 'Test writ',
+    body: 'Test body',
+    createdAt: new Date().toISOString(),
+    updatedAt: new Date().toISOString(),
+    ...overrides,
+  };
+}
+
+/**
+ * Build a fake ClerkApi sufficient for petition() and withdraw() tests.
+ * Captures call arguments for assertion in tests.
+ */
+interface FakeClerk {
+  api: ClerkApi;
+  postCalls: Parameters<ClerkApi['post']>[];
+  setExtCalls: Parameters<ClerkApi['setWritExt']>[];
+  transitionCalls: Parameters<ClerkApi['transition']>[];
+}
+
+function buildFakeClerk(
+  options: {
+    /** Returned by post(). Default: a minimal writ with id 'w-test-001'. */
+    writDoc?: WritDoc;
+    /** If set, applies this ext and returns it from setWritExt. */
+    extDoc?: WritDoc;
+  } = {},
+): FakeClerk {
+  const postCalls: Parameters<ClerkApi['post']>[] = [];
+  const setExtCalls: Parameters<ClerkApi['setWritExt']>[] = [];
+  const transitionCalls: Parameters<ClerkApi['transition']>[] = [];
+
+  const baseDoc = options.writDoc ?? makeWritDoc();
+
+  const api = {
+    async post(request: Parameters<ClerkApi['post']>[0]): Promise<WritDoc> {
+      postCalls.push([request]);
+      return baseDoc;
+    },
+    async setWritExt(
+      writId: string,
+      pluginId: string,
+      value: unknown,
+    ): Promise<WritDoc> {
+      setExtCalls.push([writId, pluginId, value]);
+      const doc = options.extDoc ?? {
+        ...baseDoc,
+        ext: { [pluginId]: value },
+      };
+      return doc;
+    },
+    async transition(
+      id: string,
+      to: Parameters<ClerkApi['transition']>[1],
+      fields?: Partial<WritDoc>,
+    ): Promise<WritDoc> {
+      transitionCalls.push([id, to, fields]);
+      return { ...baseDoc, id, phase: to, ...fields };
+    },
+    // Stub other methods to satisfy the interface
+    async show(): Promise<WritDoc> { return baseDoc; },
+    async resolveId(prefix: string): Promise<string> { return prefix; },
+    async list(): Promise<WritDoc[]> { return []; },
+    async count(): Promise<number> { return 0; },
+    async countActive(): Promise<number> { return 0; },
+    async tree(): Promise<import('@shardworks/clerk-apparatus').WritTree[]> { return []; },
+    async countDescendantsByPhase(): Promise<Record<string, number>> { return {}; },
+    async link(): Promise<import('@shardworks/clerk-apparatus').WritLinkDoc> {
+      throw new Error('not implemented');
+    },
+    async links(): Promise<import('@shardworks/clerk-apparatus').WritLinks> {
+      return { outbound: [], inbound: [] };
+    },
+    async unlink(): Promise<void> {},
+    async edit(): Promise<WritDoc> { return baseDoc; },
+    async setWritStatus(): Promise<WritDoc> { return baseDoc; },
+    listWritTypes() { return []; },
+    async listKinds() { return []; },
+    registerWritType() {},
+    getWritTypeConfig() { return undefined; },
+    isInitial() { return true; },
+    isActive() { return false; },
+    isTerminal() { return false; },
+  } as unknown as ClerkApi;
+
+  return { api, postCalls, setExtCalls, transitionCalls };
+}
+
+/**
+ * Build a fake Guild for test isolation.
+ * The `clerk` apparatus is served from `options.clerk`.
+ * `config('reckoner')` returns `options.reckonerConfig ?? {}`.
+ */
+function buildFakeGuild(options: {
+  clerk?: ClerkApi;
+  reckonerConfig?: Partial<ReckonerConfig>;
+} = {}): Guild {
+  const apparatusMap = new Map<string, unknown>();
+  if (options.clerk) {
+    apparatusMap.set('clerk', options.clerk);
+  }
+
+  const cfg: GuildConfig = {
+    name: 'test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(options.reckonerConfig !== undefined ? { reckoner: options.reckonerConfig } : {}),
+  };
+
+  return {
+    home: '/tmp/test-guild',
+    apparatus<T>(name: string): T {
+      const api = apparatusMap.get(name);
+      if (!api) throw new Error(`Apparatus "${name}" not installed in test guild`);
+      return api as T;
+    },
+    config<T>(pluginId: string): T {
+      return ((cfg as Record<string, unknown>)[pluginId] ?? {}) as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig { return cfg; },
+    kits(): LoadedKit[] { return []; },
+    apparatuses(): LoadedApparatus[] { return []; },
+    failedPlugins() { return []; },
+    startupWarnings() { return []; },
+  };
+}
+
+// ── PetitionerRegistry unit tests ─────────────────────────────────────────
+
+describe('PetitionerRegistry', () => {
+  describe('validateSourceId', () => {
+    it('accepts a well-formed source id', () => {
+      assert.doesNotThrow(() => validateSourceId('vision-keeper.snapshot', 'vision-keeper'));
+    });
+
+    it('accepts a simple single-word prefix and suffix', () => {
+      assert.doesNotThrow(() => validateSourceId('myapp.detect', 'myapp'));
+    });
+
+    it('accepts a multi-segment kebab suffix', () => {
+      assert.doesNotThrow(() => validateSourceId('vision-keeper.drift-detected', 'vision-keeper'));
+    });
+
+    it('rejects an id with no dot separator', () => {
+      assert.throws(
+        () => validateSourceId('visionsnapshot', 'vision'),
+        /must be of the form "\{pluginId\}\.\{kebab-suffix\}"/,
+      );
+    });
+
+    it('rejects an id where the dot is at position 0', () => {
+      assert.throws(
+        () => validateSourceId('.snapshot', 'vision-keeper'),
+        /must be of the form/,
+      );
+    });
+
+    it('rejects an id where the dot is the last character', () => {
+      assert.throws(
+        () => validateSourceId('vision-keeper.', 'vision-keeper'),
+        /must be of the form/,
+      );
+    });
+
+    it('rejects an id whose prefix does not match the contributing plugin id', () => {
+      assert.throws(
+        () => validateSourceId('other-plugin.snapshot', 'vision-keeper'),
+        /must match the contributing plugin id/,
+      );
+    });
+
+    it('rejects a suffix with uppercase letters', () => {
+      assert.throws(
+        () => validateSourceId('vision-keeper.Snapshot', 'vision-keeper'),
+        /must be kebab-case/,
+      );
+    });
+
+    it('rejects a suffix with a leading hyphen', () => {
+      assert.throws(
+        () => validateSourceId('vision-keeper.-snapshot', 'vision-keeper'),
+        /must be kebab-case/,
+      );
+    });
+
+    it('rejects a suffix with a trailing hyphen', () => {
+      assert.throws(
+        () => validateSourceId('vision-keeper.snapshot-', 'vision-keeper'),
+        /must be kebab-case/,
+      );
+    });
+
+    it('rejects a suffix with consecutive hyphens', () => {
+      assert.throws(
+        () => validateSourceId('vision-keeper.snap--shot', 'vision-keeper'),
+        /must be kebab-case/,
+      );
+    });
+
+    it('rejects a suffix with a special character', () => {
+      assert.throws(
+        () => validateSourceId('vision-keeper.snap!shot', 'vision-keeper'),
+        /must be kebab-case/,
+      );
+    });
+  });
+
+  describe('register() and has()', () => {
+    it('registers a valid descriptor and reports it present', () => {
+      const reg = new PetitionerRegistry();
+      reg.register({ source: 'my-plugin.detect', description: 'Detects things' }, 'my-plugin');
+      assert.equal(reg.has('my-plugin.detect'), true);
+    });
+
+    it('get() returns the registered descriptor', () => {
+      const reg = new PetitionerRegistry();
+      const desc = { source: 'my-plugin.detect', description: 'Detects things' };
+      reg.register(desc, 'my-plugin');
+      const got = reg.get('my-plugin.detect');
+      assert.deepEqual(got, desc);
+    });
+
+    it('has() returns false for an unregistered source', () => {
+      const reg = new PetitionerRegistry();
+      assert.equal(reg.has('unknown.source'), false);
+    });
+
+    it('hard-fails when the source id is malformed', () => {
+      const reg = new PetitionerRegistry();
+      assert.throws(
