+      await api.petition({ ...baseRequest, parentId: 'w-parent-001' });
+
+      assert.equal(postCalls[0][0].parentId, 'w-parent-001');
+    });
+  });
+
+  // ── withdraw() ────────────────────────────────────────────────────
+
+  describe('withdraw()', () => {
+    it('transitions the writ to cancelled', async () => {
+      const plugin = createReckoner();
+      if (!('apparatus' in plugin)) throw new Error('expected apparatus');
+
+      const { ctx } = buildCtx([]);
+      const { api: clerk, transitionCalls } = buildFakeClerk();
+
+      setGuild(buildFakeGuild({ clerk }));
+      await plugin.apparatus.start(ctx);
+
+      const api = plugin.apparatus.provides as ReckonerApi;
+      await api.withdraw('w-test-001');
+
+      assert.equal(transitionCalls.length, 1);
+      assert.equal(transitionCalls[0][0], 'w-test-001');
+      assert.equal(transitionCalls[0][1], 'cancelled');
+    });
+
+    it('passes the reason as resolution when provided', async () => {
+      const plugin = createReckoner();
+      if (!('apparatus' in plugin)) throw new Error('expected apparatus');
+
+      const { ctx } = buildCtx([]);
+      const { api: clerk, transitionCalls } = buildFakeClerk();
+
+      setGuild(buildFakeGuild({ clerk }));
+      await plugin.apparatus.start(ctx);
+
+      const api = plugin.apparatus.provides as ReckonerApi;
+      await api.withdraw('w-test-001', 'Superseded by new snapshot');
+
+      assert.equal(transitionCalls[0][2]?.resolution, 'Superseded by new snapshot');
+    });
+
+    it('passes no fields when no reason is provided', async () => {
+      const plugin = createReckoner();
+      if (!('apparatus' in plugin)) throw new Error('expected apparatus');
+
+      const { ctx } = buildCtx([]);
+      const { api: clerk, transitionCalls } = buildFakeClerk();
