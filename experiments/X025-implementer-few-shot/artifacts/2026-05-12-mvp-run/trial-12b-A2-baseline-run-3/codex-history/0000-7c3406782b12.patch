+
+      assert.equal(postCalls.length, 0);
+    });
+
+    it('passes parentId to clerk.post() when provided', async () => {
+      const plugin = createReckoner();
+      if (!('apparatus' in plugin)) throw new Error('expected apparatus');
+
+      const kits: LoadedKit[] = [{
+        id: 'vision-keeper',
+        packageName: '@test/vision-keeper',
+        version: '0.0.0',
+        kit: { petitioners: [{ source: 'vision-keeper.snapshot', description: 'S' }] },
+      }];
+      const { ctx } = buildCtx(buildKitEntries(kits));
+      const { api: clerk, postCalls } = buildFakeClerk();
