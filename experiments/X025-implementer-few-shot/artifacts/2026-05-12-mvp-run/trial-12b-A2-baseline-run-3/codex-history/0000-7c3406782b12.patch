@@ -0,0 +1,154 @@
+/**
+ * Petitioner registry — kit-static source registry.
+ *
+ * Petitioners declare themselves via a `petitioners` kit contribution.
+ * The Reckoner consumes those contributions during `start()`, builds
+ * the registry, and seals it at `phase:started`.
+ *
+ * See: docs/architecture/petitioner-registration.md §5
+ */
+
+import type { PetitionerDescriptor } from './types.ts';
+
+// ── Source-id grammar ─────────────────────────────────────────────────────
+
+/**
+ * Grammar for source-id suffixes after the `{pluginId}.` prefix.
+ *
+ * Kebab-case: lowercase letters, digits, and hyphens. Must not start or
+ * end with a hyphen. Mirrors `KIND_SUFFIX_RE` in `@shardworks/clerk-apparatus`
+ * (same shape as Lattice trigger-types and Clerk link-kinds).
+ */
+const SOURCE_SUFFIX_RE = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
+
+/**
+ * Validate a petitioner source id for format conformance.
+ *
+ * Rules:
+ * 1. Must be of the form `{pluginId}.{kebab-suffix}` — exactly one `.`
+ *    with non-empty parts on both sides.
+ * 2. The prefix must match the `contributingPluginId` (where derivable).
+ * 3. The suffix must be kebab-case (matches `SOURCE_SUFFIX_RE`).
+ *
+ * Throws with a descriptive error on any violation.
+ */
+export function validateSourceId(source: string, contributingPluginId: string): void {
+  const dotIdx = source.indexOf('.');
+  if (dotIdx <= 0 || dotIdx === source.length - 1) {
+    throw new Error(
+      `[reckoner] Kit "${contributingPluginId}" petitioners: source "${source}" ` +
+      `must be of the form "{pluginId}.{kebab-suffix}".`,
+    );
+  }
+
+  const prefix = source.slice(0, dotIdx);
+  const suffix = source.slice(dotIdx + 1);
+
+  if (prefix !== contributingPluginId) {
+    throw new Error(
+      `[reckoner] Kit "${contributingPluginId}" petitioners: source "${source}" ` +
+      `has prefix "${prefix}" but must match the contributing plugin id ` +
+      `"${contributingPluginId}".`,
+    );
+  }
+
+  if (!SOURCE_SUFFIX_RE.test(suffix)) {
+    throw new Error(
+      `[reckoner] Kit "${contributingPluginId}" petitioners: source "${source}" ` +
+      `suffix "${suffix}" must be kebab-case (lowercase letters, digits, and hyphens; ` +
+      `not starting or ending with "-").`,
+    );
+  }
+}
+
+// ── Registry ──────────────────────────────────────────────────────────────
+
+/** Internal storage entry — descriptor plus the contributing plugin id. */
+interface RegistryEntry {
+  readonly descriptor: PetitionerDescriptor;
+  readonly pluginId: string;
+}
+
+/**
+ * Kit-static registry of Reckoner petitioner sources.
+ *
+ * Built during `start()` by consuming `petitioners` kit contributions.
+ * Sealed at `phase:started` — no further registrations are accepted after
+ * sealing.
+ *
+ * Collision policy (mirrors Clerk writ-types, Spider rig-template-mappings,
+ * and the Fabricator's engine designs): two contributions with the same
+ * `source` string are a hard startup error naming both contributing plugin ids.
+ */
+export class PetitionerRegistry {
+  /** Primary storage: source id → registry entry. */
+  private readonly _entries = new Map<string, RegistryEntry>();
+  /** Projected public view: source id → descriptor (no plugin id exposed). */
+  private readonly _publicView = new Map<string, PetitionerDescriptor>();
+  private _sealed = false;
+
+  /**
+   * Register a petitioner descriptor contributed by `pluginId`.
+   *
+   * @throws When the registry is already sealed (post `phase:started`).
+   * @throws When the source id is malformed (see `validateSourceId`).
+   * @throws When the source id was already contributed by another plugin
+   *   (hard collision error naming both plugin ids).
+   */
+  register(descriptor: PetitionerDescriptor, pluginId: string): void {
+    if (this._sealed) {
+      throw new Error(
+        `[reckoner] Cannot register petitioner source "${descriptor.source}" ` +
+        `after phase:started — registry is sealed.`,
+      );
+    }
+
+    validateSourceId(descriptor.source, pluginId);
+
+    const existing = this._entries.get(descriptor.source);
+    if (existing !== undefined) {
+      throw new Error(
+        `[reckoner] Duplicate petitioner source "${descriptor.source}": ` +
+        `contributed by both "${pluginId}" and "${existing.pluginId}".`,
+      );
+    }
+
+    this._entries.set(descriptor.source, { descriptor, pluginId });
+    this._publicView.set(descriptor.source, descriptor);
+  }
+
+  /**
+   * Seal the registry. Called on `phase:started`.
+   * After sealing, `register()` throws immediately.
+   */
+  seal(): void {
+    this._sealed = true;
+  }
+
+  /** Returns `true` when the registry is sealed. */
+  get isSealed(): boolean {
+    return this._sealed;
+  }
+
+  /** Returns `true` when `source` is registered. */
+  has(source: string): boolean {
+    return this._entries.has(source);
+  }
+
+  /**
+   * Returns the descriptor for `source`, or `undefined` when not registered.
+   */
+  get(source: string): PetitionerDescriptor | undefined {
+    return this._entries.get(source)?.descriptor;
+  }
+
+  /**
+   * Read-only snapshot view of the registry keyed by source id.
+   * Returns the same `Map` instance on every call (the map is only
+   * mutated before sealing, matching the kit-contribution snapshot
+   * semantics used by other apparatus).
+   */
+  asReadonlyMap(): ReadonlyMap<string, PetitionerDescriptor> {
+    return this._publicView;
+  }
+}
