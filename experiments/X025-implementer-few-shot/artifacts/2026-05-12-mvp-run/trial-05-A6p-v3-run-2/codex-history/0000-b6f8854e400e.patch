@@ -0,0 +1,546 @@
+/**
+ * Companion tests for pages/clicks/index.html — detail pane and link dispatch.
+ *
+ * Covers:
+ * - renderDetail: all fields rendered, children section, links section
+ * - linkTargetType: prefix dispatch for c-…, w-…, and other IDs
+ * - renderLinkRow: produces correct HTML for each link type
+ * - statusBadge mapping used in children summary strip
+ *
+ * Functions are re-declared here (IIFE-scoped in the page, not exported).
+ * Pattern mirrors packages/plugins/clerk/pages/writs/writs-hierarchy.test.js.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Helpers re-declared from index.html ────────────────────────────────
+
+function statusBadge(status) {
+  const map = {
+    live:      'badge badge--active',
+    parked:    'badge badge--warning',
+    concluded: 'badge badge--success',
+    dropped:   'badge badge--error',
+  };
+  return `<span class="${map[status] ?? 'badge'}">${status}</span>`;
+}
+
+function shortId(id) {
+  if (!id) return id;
+  const parts = id.split('-');
+  return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+}
+
+function fmtDate(iso) {
+  if (!iso) return '';
+  return new Date(iso).toLocaleString();
+}
+
+function escHtml(s) {
+  if (s == null) return '';
+  return String(s)
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;');
+}
+
+function escAttr(s) {
+  if (s == null) return '';
+  return String(s)
+    .replace(/&/g, '&amp;')
+    .replace(/"/g, '&quot;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;');
+}
+
+/**
+ * Dispatch a link target ID to its interaction type.
+ */
+function linkTargetType(id) {
+  if (!id) return 'text';
+  if (id.startsWith('c-')) return 'click';
+  if (id.startsWith('w-')) return 'writ';
+  return 'text';
+}
+
+function renderLinkRow(dir, displayId, linkType, sourceId, targetId, ltType, clickId) {
+  const type = linkTargetType(displayId);
+  const safeKey = displayId.replace(/[^a-z0-9]/gi, '_');
+  let targetHtml;
+  if (type === 'click' || type === 'writ') {
+    targetHtml = `<a class="link-target" data-link-target="${escAttr(displayId)}" href="#">${escHtml(shortId(displayId))}</a>`;
+  } else {
+    targetHtml = `<span class="link-meta">${escHtml(displayId)}</span>`;
+  }
+  return `<div class="link-row">
+      <span class="link-dir">${dir}</span>
+      ${targetHtml}
+      <span class="link-type-label">(${escHtml(linkType)})</span>
+      <span class="link-meta" id="lmeta-${escHtml(safeKey)}"></span>
+      <button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.75rem;margin-left:auto"
+        data-action="unlink"
+        data-source="${escAttr(sourceId)}"
+        data-target="${escAttr(targetId)}"
+        data-ltype="${escAttr(ltType)}"
+        data-click-id="${escAttr(clickId)}">×</button>
+    </div>`;
+}
+
+function renderDetail(detail) {
+  const click = detail;
+  const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+  let html = '';
+
+  // Header
+  html += `<div class="detail-section">`;
+  html += `<h2 class="detail-goal">${escHtml(click.goal)}</h2>`;
+  html += `<div class="detail-id-row">`;
+  html += `<code>${escHtml(click.id)}</code>`;
+  html += `<button class="node-btn" id="detail-copy-btn" data-id="${escAttr(click.id)}" title="Copy ID">📋</button>`;
+  html += `</div>`;
+  html += `</div>`;
+
+  // Details grid
+  html += `<div class="detail-section"><h4>Details</h4><dl class="detail-grid">`;
+  html += `<dt>Status</dt><dd>${statusBadge(click.status)}</dd>`;
+  if (click.parent) {
+    html += `<dt>Parent</dt><dd>`;
+    html += `<a class="link-target" data-click-id="${escAttr(click.parent.id)}" href="#">`;
+    html += `${escHtml(shortId(click.parent.id))}: ${escHtml(click.parent.goal)}`;
+    html += `</a> ${statusBadge(click.parent.status)}`;
+    html += `</dd>`;
+  }
+  html += `<dt>Created</dt><dd>${escHtml(fmtDate(click.createdAt))}</dd>`;
+  if (click.createdSessionId) {
+    html += `<dt>Session (created)</dt><dd><code>${escHtml(click.createdSessionId)}</code></dd>`;
+  }
+  if (click.resolvedAt) {
+    html += `<dt>Resolved</dt><dd>${escHtml(fmtDate(click.resolvedAt))}</dd>`;
+  }
+  if (click.resolvedSessionId) {
+    html += `<dt>Session (resolved)</dt><dd><code>${escHtml(click.resolvedSessionId)}</code></dd>`;
+  }
+  html += `</dl></div>`;
+
+  // Conclusion
+  if (isTerminal && click.conclusion) {
+    html += `<div class="detail-section">`;
+    html += `<details>`;
+    html += `<summary><h4 style="display:inline;margin:0;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;opacity:0.5">Conclusion</h4></summary>`;
+    html += `<pre style="margin-top:0.5rem;white-space:pre-wrap;word-break:break-word;font-size:0.875rem;padding:0.6rem;background:var(--bg,#1a1b26);border-radius:4px;max-height:240px;overflow-y:auto">${escHtml(click.conclusion)}</pre>`;
+    html += `</details>`;
+    html += `</div>`;
+  }
+
+  // Lifecycle actions
+  if (!isTerminal) {
+    html += `<div class="detail-section"><h4>Actions</h4>`;
+    html += `<div class="action-buttons">`;
+    if (click.status === 'live') {
+      html += `<button class="btn" data-action="park" data-id="${escAttr(click.id)}">Park</button>`;
+    }
+    if (click.status === 'parked') {
+      html += `<button class="btn btn--primary" data-action="resume" data-id="${escAttr(click.id)}">Resume</button>`;
+    }
+    if (click.status === 'live' || click.status === 'parked') {
+      html += `<button class="btn btn--success" data-action="conclude-init" data-id="${escAttr(click.id)}">Conclude</button>`;
+      html += `<button class="btn btn--danger" data-action="drop-init" data-id="${escAttr(click.id)}">Drop</button>`;
+    }
+    html += `</div>`;
+    html += `<div id="confirm-area-${escAttr(click.id)}"></div>`;
+    html += `<div class="error-msg" id="action-error-${escAttr(click.id)}" style="display:none"></div>`;
+    html += `</div>`;
+  }
+
+  // Children
+  const childItems = click.children?.items ?? [];
+  if (childItems.length > 0) {
+    html += `<div class="detail-section"><h4>Children</h4>`;
+    const summary = click.children?.summary ?? {};
+    if (Object.keys(summary).length > 0) {
+      html += `<div style="margin-bottom:0.5rem;display:flex;gap:0.35rem;flex-wrap:wrap;align-items:center">`;
+      for (const [st, count] of Object.entries(summary)) {
+        html += `${statusBadge(st)}<span style="margin-right:0.25rem;font-size:0.8rem"> ${count}</span>`;
+      }
+      html += `</div>`;
+    }
+    html += `<table class="data-table"><thead><tr>`;
+    html += `<th>Status</th><th>Goal</th><th>ID</th>`;
+    html += `</tr></thead><tbody>`;
+    for (const child of childItems) {
+      html += `<tr class="child-row" data-click-id="${escAttr(child.id)}">`;
+      html += `<td>${statusBadge(child.status)}</td>`;
+      html += `<td>${escHtml(child.goal)}</td>`;
+      html += `<td><code>${escHtml(shortId(child.id))}</code></td>`;
+      html += `</tr>`;
+    }
+    html += `</tbody></table></div>`;
+  }
+
+  // Links
+  const outbound = click.links?.outbound ?? [];
+  const inbound  = click.links?.inbound  ?? [];
+  html += `<div class="detail-section" id="links-section-${escAttr(click.id)}"><h4>Links</h4>`;
+  if (outbound.length === 0 && inbound.length === 0) {
+    html += `<p style="font-size:0.875rem;opacity:0.5">No links.</p>`;
+  }
+  for (const l of outbound) {
+    html += renderLinkRow('→', l.targetId, l.linkType, l.sourceId, l.targetId, l.linkType, click.id);
+  }
+  for (const l of inbound) {
+    html += renderLinkRow('←', l.sourceId, l.linkType, l.sourceId, l.targetId, l.linkType, click.id);
+  }
+  html += `<div class="add-link-form">`;
+  html += `<input type="text" id="link-target-${escAttr(click.id)}" placeholder="Target ID">`;
+  html += `<select id="link-type-${escAttr(click.id)}">`;
+  html += `<option value="related">related</option>`;
+  html += `<option value="commissioned">commissioned</option>`;
+  html += `<option value="supersedes">supersedes</option>`;
+  html += `<option value="depends-on">depends-on</option>`;
+  html += `</select>`;
+  html += `<button class="btn btn--primary" data-action="addlink" data-id="${escAttr(click.id)}">Add Link</button>`;
+  html += `</div>`;
+  html += `<div class="error-msg" id="link-error-${escAttr(click.id)}" style="display:none"></div>`;
+  html += `</div>`;
+
+  return html;
+}
+
+// ── Fixtures ────────────────────────────────────────────────────────────
+
+function mkDetail(overrides) {
+  return {
+    id: 'c-abc123-def456',
+    goal: 'Ship the feature',
+    status: 'live',
+    createdAt: '2025-01-15T10:00:00Z',
+    links: { outbound: [], inbound: [] },
+    children: { summary: {}, items: [] },
+    parent: null,
+    ...overrides,
+  };
+}
+
+// ── linkTargetType tests ─────────────────────────────────────────────────
+
+describe('linkTargetType', () => {
+  it('returns "click" for c- prefixed IDs', () => {
+    assert.strictEqual(linkTargetType('c-mo1mq8ry-abc123'), 'click');
+  });
+
+  it('returns "writ" for w- prefixed IDs', () => {
+    assert.strictEqual(linkTargetType('w-abc123-def456'), 'writ');
+  });
+
+  it('returns "text" for other IDs', () => {
+    assert.strictEqual(linkTargetType('github-123'), 'text');
+    assert.strictEqual(linkTargetType('https://example.com'), 'text');
+    assert.strictEqual(linkTargetType('some-external-ref'), 'text');
+  });
+
+  it('returns "text" for null/undefined', () => {
+    assert.strictEqual(linkTargetType(null), 'text');
+    assert.strictEqual(linkTargetType(undefined), 'text');
+  });
+
+  it('returns "text" for empty string', () => {
+    assert.strictEqual(linkTargetType(''), 'text');
+  });
+});
+
+// ── renderDetail — field rendering ──────────────────────────────────────
+
+describe('renderDetail — basic fields', () => {
+  it('renders the click goal as a heading', () => {
+    const html = renderDetail(mkDetail({ goal: 'My important goal' }));
+    assert.ok(html.includes('My important goal'), 'goal text should appear');
+    assert.ok(html.includes('class="detail-goal"'), 'goal element should have correct class');
+  });
+
+  it('renders the click ID', () => {
+    const html = renderDetail(mkDetail({ id: 'c-abc123-def456' }));
+    assert.ok(html.includes('c-abc123-def456'));
+  });
+
+  it('renders a copy button with the correct data-id', () => {
+    const html = renderDetail(mkDetail({ id: 'c-abc123-def456' }));
+    assert.ok(html.includes('id="detail-copy-btn"'));
+    assert.ok(html.includes('data-id="c-abc123-def456"'));
+  });
+
+  it('renders the status badge', () => {
+    const html = renderDetail(mkDetail({ status: 'live' }));
+    assert.ok(html.includes('badge--active'));
+    assert.ok(html.includes('live'));
+  });
+
+  it('renders createdAt in the details grid', () => {
+    const html = renderDetail(mkDetail({ createdAt: '2025-01-15T10:00:00Z' }));
+    assert.ok(html.includes('Created'));
+  });
+
+  it('renders parent link when parent is set', () => {
+    const html = renderDetail(mkDetail({
+      parent: { id: 'c-parent-xxx', goal: 'Parent goal', status: 'live' },
+    }));
+    assert.ok(html.includes('Parent'));
+    assert.ok(html.includes('data-click-id="c-parent-xxx"'));
+    assert.ok(html.includes('Parent goal'));
+  });
+
+  it('omits parent row when parent is null', () => {
+    const html = renderDetail(mkDetail({ parent: null }));
+    // Should not have a parent data-click-id attribute
+    assert.ok(!html.includes('data-click-id'), 'no parent link when null');
+  });
+
+  it('renders createdSessionId when present', () => {
+    const html = renderDetail(mkDetail({ createdSessionId: 'sess-alpha' }));
+    assert.ok(html.includes('sess-alpha'));
+    assert.ok(html.includes('Session (created)'));
+  });
+
+  it('omits session fields when absent', () => {
+    const html = renderDetail(mkDetail());
+    assert.ok(!html.includes('Session (created)'));
+    assert.ok(!html.includes('Session (resolved)'));
+  });
+
+  it('renders resolvedAt when present', () => {
+    const html = renderDetail(mkDetail({
+      status: 'concluded',
+      resolvedAt: '2025-02-01T12:00:00Z',
+      conclusion: 'Done!',
+    }));
+    assert.ok(html.includes('Resolved'));
+  });
+
+  it('renders resolvedSessionId when present', () => {
+    const html = renderDetail(mkDetail({
+      status: 'concluded',
+      resolvedAt: '2025-02-01T12:00:00Z',
+      conclusion: 'Done!',
+      resolvedSessionId: 'sess-beta',
+    }));
+    assert.ok(html.includes('sess-beta'));
+    assert.ok(html.includes('Session (resolved)'));
+  });
+});
+
+// ── renderDetail — conclusion section ────────────────────────────────────
+
+describe('renderDetail — conclusion (terminal)', () => {
+  it('renders conclusion in a <details> element for concluded clicks', () => {
+    const html = renderDetail(mkDetail({
+      status: 'concluded',
+      conclusion: 'Successfully shipped',
+    }));
+    assert.ok(html.includes('<details>'), 'should use details element');
+    assert.ok(html.includes('Successfully shipped'));
+  });
+
+  it('renders conclusion for dropped clicks', () => {
+    const html = renderDetail(mkDetail({
+      status: 'dropped',
+      conclusion: 'No longer needed',
+    }));
+    assert.ok(html.includes('<details>'));
+    assert.ok(html.includes('No longer needed'));
+  });
+
+  it('does not render conclusion section for live clicks', () => {
+    const html = renderDetail(mkDetail({ status: 'live' }));
+    // No conclusion block
+    assert.ok(!html.includes('<details>') || !html.includes('Conclusion'));
+  });
+
+  it('escapes HTML special chars in conclusion text', () => {
+    const html = renderDetail(mkDetail({
+      status: 'concluded',
+      conclusion: '<script>alert(1)</script>',
+    }));
+    assert.ok(!html.includes('<script>'));
+    assert.ok(html.includes('&lt;script&gt;'));
+  });
+});
+
+// ── renderDetail — lifecycle actions ─────────────────────────────────────
+
+describe('renderDetail — lifecycle actions', () => {
+  it('shows Park button for live clicks', () => {
+    const html = renderDetail(mkDetail({ status: 'live' }));
+    assert.ok(html.includes('data-action="park"'));
+  });
+
+  it('shows Conclude and Drop buttons for live clicks', () => {
+    const html = renderDetail(mkDetail({ status: 'live' }));
+    assert.ok(html.includes('data-action="conclude-init"'));
+    assert.ok(html.includes('data-action="drop-init"'));
+  });
+
+  it('shows Resume button for parked clicks', () => {
+    const html = renderDetail(mkDetail({ status: 'parked' }));
+    assert.ok(html.includes('data-action="resume"'));
+  });
+
+  it('shows Conclude and Drop buttons for parked clicks', () => {
+    const html = renderDetail(mkDetail({ status: 'parked' }));
+    assert.ok(html.includes('data-action="conclude-init"'));
+    assert.ok(html.includes('data-action="drop-init"'));
+  });
+
+  it('hides actions for terminal (concluded) clicks', () => {
+    const html = renderDetail(mkDetail({
+      status: 'concluded',
+      conclusion: 'Done',
+    }));
+    assert.ok(!html.includes('data-action="park"'));
+    assert.ok(!html.includes('data-action="conclude-init"'));
+    assert.ok(!html.includes('data-action="drop-init"'));
+  });
+
+  it('hides actions for terminal (dropped) clicks', () => {
+    const html = renderDetail(mkDetail({
+      status: 'dropped',
+      conclusion: 'Nope',
+    }));
+    assert.ok(!html.includes('data-action="park"'));
+    assert.ok(!html.includes('data-action="resume"'));
+  });
+});
+
+// ── renderDetail — children section ──────────────────────────────────────
+
+describe('renderDetail — children section', () => {
+  it('renders the children table when items exist', () => {
+    const html = renderDetail(mkDetail({
+      children: {
+        summary: { live: 2, concluded: 1 },
+        items: [
+          { id: 'c-child1-abc', goal: 'First child', status: 'live' },
+          { id: 'c-child2-abc', goal: 'Second child', status: 'live' },
+          { id: 'c-child3-abc', goal: 'Third child', status: 'concluded' },
+        ],
+      },
+    }));
+    assert.ok(html.includes('First child'));
+    assert.ok(html.includes('Second child'));
+    assert.ok(html.includes('Third child'));
+    assert.ok(html.includes('class="child-row"'));
+  });
+
+  it('renders the status-count badge strip', () => {
+    const html = renderDetail(mkDetail({
+      children: {
+        summary: { live: 3, parked: 1 },
+        items: [
+          { id: 'c-x-y', goal: 'Child', status: 'live' },
+        ],
+      },
+    }));
+    assert.ok(html.includes('badge--active'), 'live badge in summary');
+    assert.ok(html.includes('badge--warning'), 'parked badge in summary');
+  });
+
+  it('omits children section when items array is empty', () => {
+    const html = renderDetail(mkDetail({
+      children: { summary: {}, items: [] },
+    }));
+    assert.ok(!html.includes('class="child-row"'));
+  });
+
+  it('each child row has correct data-click-id for navigation', () => {
+    const html = renderDetail(mkDetail({
+      children: {
+        summary: { live: 1 },
+        items: [{ id: 'c-childX-123', goal: 'Navigate me', status: 'live' }],
+      },
+    }));
+    assert.ok(html.includes('data-click-id="c-childX-123"'));
+  });
+});
+
+// ── renderDetail — links section ──────────────────────────────────────────
+
+describe('renderDetail — links section', () => {
+  it('shows "No links." when there are no outbound or inbound links', () => {
+    const html = renderDetail(mkDetail());
+    assert.ok(html.includes('No links.'));
+  });
+
+  it('renders outbound links with → direction', () => {
+    const html = renderDetail(mkDetail({
+      links: {
+        outbound: [
+          { sourceId: 'c-me-x', targetId: 'c-other-y', linkType: 'related' },
+        ],
+        inbound: [],
+      },
+    }));
+    assert.ok(html.includes('→'));
+    assert.ok(html.includes('related'));
+    assert.ok(html.includes('c-other'));  // shortId of c-other-y
+  });
+
+  it('renders inbound links with ← direction', () => {
+    const html = renderDetail(mkDetail({
+      links: {
+        outbound: [],
+        inbound: [
+          { sourceId: 'c-caller-z', targetId: 'c-me-x', linkType: 'commissioned' },
+        ],
+      },
+    }));
+    assert.ok(html.includes('←'));
+    assert.ok(html.includes('commissioned'));
+  });
+
+  it('renders add-link form with all four link-type options', () => {
+    const html = renderDetail(mkDetail());
+    assert.ok(html.includes('value="related"'));
+    assert.ok(html.includes('value="commissioned"'));
+    assert.ok(html.includes('value="supersedes"'));
+    assert.ok(html.includes('value="depends-on"'));
+  });
+});
+
+// ── renderLinkRow tests ───────────────────────────────────────────────────
+
+describe('renderLinkRow', () => {
+  it('renders a clickable anchor for c- targets', () => {
+    const html = renderLinkRow('→', 'c-target-abc', 'related', 'c-src', 'c-target-abc', 'related', 'c-src');
+    assert.ok(html.includes('data-link-target="c-target-abc"'));
+    assert.ok(html.includes('class="link-target"'));
+    assert.ok(html.includes('c-target')); // shortId
+  });
+
+  it('renders a clickable anchor for w- targets', () => {
+    const html = renderLinkRow('←', 'w-writ-abc', 'commissioned', 'c-src', 'w-writ-abc', 'commissioned', 'c-src');
+    assert.ok(html.includes('data-link-target="w-writ-abc"'));
+    assert.ok(html.includes('class="link-target"'));
+  });
+
+  it('renders plain text (no anchor) for unknown prefix', () => {
+    const html = renderLinkRow('→', 'github-issue-42', 'related', 'c-src', 'github-issue-42', 'related', 'c-src');
+    assert.ok(!html.includes('data-link-target'));
+    assert.ok(html.includes('github-issue-42'));
+    assert.ok(html.includes('class="link-meta"'));
+  });
+
+  it('includes an unlink button with correct data attributes', () => {
+    const html = renderLinkRow('→', 'c-target-abc', 'related', 'c-src-x', 'c-target-abc', 'related', 'c-me-z');
+    assert.ok(html.includes('data-action="unlink"'));
+    assert.ok(html.includes('data-source="c-src-x"'));
+    assert.ok(html.includes('data-target="c-target-abc"'));
+    assert.ok(html.includes('data-ltype="related"'));
+    assert.ok(html.includes('data-click-id="c-me-z"'));
+  });
+
+  it('escapes HTML in the link type label', () => {
+    const html = renderLinkRow('→', 'c-x', '<evil>', 'c-src', 'c-x', '<evil>', 'c-me');
+    assert.ok(!html.includes('<evil>'));
+    assert.ok(html.includes('&lt;evil&gt;'));
+  });
+});
diff --git a/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
new file mode 100644
index 0000000..06d2ee2
--- /dev/null
+++ b/packages/plugins/ratchet/pages/clicks/clicks-tree.test.js
@@ -0,0 +1,418 @@
+/**
+ * Companion tests for pages/clicks/index.html — tree logic.
+ *
+ * Covers:
+ * - pruneForest: prune-by-status with subtree-hiding property
+ * - findSubtree: locate a node by ID in a nested forest
+ * - getAncestorPath: breadcrumb derivation
+ * - buildTreeHtml: tree node HTML generation (badges, goals, expand state)
+ * - shortId: ID abbreviation
+ * - statusBadge: CSS class selection
+ *
+ * Functions are re-declared here (IIFE-scoped in the page, not exported).
+ * Pattern mirrors packages/plugins/clerk/pages/writs/writs-hierarchy.test.js.
+ */
+
+import { describe, it } from 'node:test';
+import assert from 'node:assert/strict';
+
+// ── Helpers re-declared from index.html ────────────────────────────────
+
+function statusBadge(status) {
+  const map = {
+    live:      'badge badge--active',
+    parked:    'badge badge--warning',
+    concluded: 'badge badge--success',
+    dropped:   'badge badge--error',
+  };
+  return `<span class="${map[status] ?? 'badge'}">${status}</span>`;
+}
+
+function shortId(id) {
+  if (!id) return id;
+  const parts = id.split('-');
+  return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+}
+
+function escHtml(s) {
+  if (s == null) return '';
+  return String(s)
+    .replace(/&/g, '&amp;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;')
+    .replace(/"/g, '&quot;');
+}
+
+function escAttr(s) {
+  if (s == null) return '';
+  return String(s)
+    .replace(/&/g, '&amp;')
+    .replace(/"/g, '&quot;')
+    .replace(/</g, '&lt;')
+    .replace(/>/g, '&gt;');
+}
+
+/**
+ * Prune a ClickTree[] by status filter.
+ * Prune semantics: if a node's status is not in the set, that node AND
+ * all its descendants are removed.
+ */
+function pruneForest(trees, statuses) {
+  const result = [];
+  for (const tree of trees) {
+    if (!statuses.has(tree.click.status)) continue;
+    const prunedChildren = pruneForest(tree.children, statuses);
+    result.push({ click: tree.click, children: prunedChildren });
+  }
+  return result;
+}
+
+/**
+ * Find the ClickTree node with the given ID anywhere in the forest.
+ */
+function findSubtree(trees, id) {
+  for (const tree of trees) {
+    if (tree.click.id === id) return tree;
+    const found = findSubtree(tree.children, id);
+    if (found) return found;
+  }
+  return null;
+}
+
+/**
+ * Return the ancestor path from the forest root to the node with
+ * targetId, as an array of ClickDoc (root first, target last).
+ * Returns null if not found.
+ */
+function getAncestorPath(trees, targetId, path) {
+  path = path ?? [];
+  for (const tree of trees) {
+    const newPath = path.concat(tree.click);
+    if (tree.click.id === targetId) return newPath;
+    const found = getAncestorPath(tree.children, targetId, newPath);
+    if (found) return found;
+  }
+  return null;
+}
+
+/**
+ * Collect all click IDs in a forest recursively.
+ */
+function collectIds(trees, acc) {
+  acc = acc ?? new Set();
+  for (const tree of trees) {
+    acc.add(tree.click.id);
+    collectIds(tree.children, acc);
+  }
+  return acc;
+}
+
+// Build a minimal ClickTree node for testing.
+function mkClick(id, status, goal, children) {
+  return {
+    click: { id, status, goal, createdAt: '2025-01-01T00:00:00Z' },
+    children: children ?? [],
+  };
+}
+
+// ── pruneForest tests ───────────────────────────────────────────────────
+
+describe('pruneForest', () => {
+  it('returns empty array when no trees match', () => {
+    const forest = [mkClick('c-1', 'live', 'Root')];
+    const result = pruneForest(forest, new Set(['parked']));
+    assert.deepEqual(result, []);
+  });
+
+  it('returns forest unchanged when all statuses match', () => {
+    const all = new Set(['live', 'parked', 'concluded', 'dropped']);
+    const forest = [
+      mkClick('c-1', 'live', 'Root', [
+        mkClick('c-2', 'parked', 'Child'),
+      ]),
+    ];
+    const result = pruneForest(forest, all);
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].children.length, 1);
+  });
+
+  it('prunes non-matching root nodes entirely', () => {
+    const forest = [
+      mkClick('c-1', 'live', 'Live'),
+      mkClick('c-2', 'dropped', 'Dropped'),
+    ];
+    const result = pruneForest(forest, new Set(['live']));
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].click.id, 'c-1');
+  });
+
+  it('prunes descendant subtrees when a node does not match', () => {
+    const forest = [
+      mkClick('c-1', 'live', 'Root', [
+        mkClick('c-2', 'dropped', 'Dropped child', [
+          mkClick('c-3', 'live', 'Grandchild'),  // live but under dropped — pruned
+        ]),
+      ]),
+    ];
+    const result = pruneForest(forest, new Set(['live']));
+    assert.strictEqual(result.length, 1, 'root retained');
+    assert.strictEqual(result[0].children.length, 0, 'dropped child and its live grandchild both pruned');
+  });
+
+  it('keeps parent while pruning non-matching children', () => {
+    const forest = [
+      mkClick('c-1', 'live', 'Root', [
+        mkClick('c-2', 'live', 'Live child'),
+        mkClick('c-3', 'parked', 'Parked child'),
+      ]),
+    ];
+    const result = pruneForest(forest, new Set(['live']));
+    assert.strictEqual(result.length, 1);
+    assert.strictEqual(result[0].children.length, 1, 'only live child retained');
+    assert.strictEqual(result[0].children[0].click.id, 'c-2');
+  });
+
+  it('handles empty forest', () => {
+    const result = pruneForest([], new Set(['live']));
+    assert.deepEqual(result, []);
+  });
+
+  it('prunes all statuses when status set is empty', () => {
+    const forest = [mkClick('c-1', 'live', 'Root')];
+    const result = pruneForest(forest, new Set());
+    assert.deepEqual(result, []);
+  });
+});
+
+// ── findSubtree tests ───────────────────────────────────────────────────
+
+describe('findSubtree', () => {
+  it('finds a root node by ID', () => {
+    const forest = [mkClick('c-1', 'live', 'Root')];
+    const found = findSubtree(forest, 'c-1');
+    assert.ok(found);
+    assert.strictEqual(found.click.id, 'c-1');
+  });
+
+  it('finds a deeply nested node', () => {
+    const forest = [
+      mkClick('c-1', 'live', 'Root', [
+        mkClick('c-2', 'live', 'Child', [
+          mkClick('c-3', 'live', 'Grandchild'),
+        ]),
+      ]),
+    ];
+    const found = findSubtree(forest, 'c-3');
+    assert.ok(found);
+    assert.strictEqual(found.click.goal, 'Grandchild');
+  });
+
+  it('returns null when ID is not in the forest', () => {
+    const forest = [mkClick('c-1', 'live', 'Root')];
+    const found = findSubtree(forest, 'c-99');
+    assert.strictEqual(found, null);
+  });
+
+  it('returns null on empty forest', () => {
+    assert.strictEqual(findSubtree([], 'c-1'), null);
+  });
+
+  it('returns the subtree (including its children)', () => {
+    const forest = [
+      mkClick('c-1', 'live', 'Root', [
+        mkClick('c-2', 'live', 'Child', [
+          mkClick('c-3', 'live', 'Grandchild'),
+        ]),
+      ]),
+    ];
+    const found = findSubtree(forest, 'c-2');
+    assert.ok(found);
+    assert.strictEqual(found.children.length, 1);
+    assert.strictEqual(found.children[0].click.id, 'c-3');
+  });
+});
+
+// ── getAncestorPath tests ───────────────────────────────────────────────
+
+describe('getAncestorPath', () => {
+  it('returns single-element path for a root node', () => {
+    const forest = [mkClick('c-1', 'live', 'Root')];
+    const path = getAncestorPath(forest, 'c-1');
+    assert.ok(Array.isArray(path));
+    assert.strictEqual(path.length, 1);
+    assert.strictEqual(path[0].id, 'c-1');
+  });
+
+  it('returns full ancestor chain for a nested node', () => {
+    const forest = [
+      mkClick('c-1', 'live', 'Root', [
+        mkClick('c-2', 'live', 'Middle', [
+          mkClick('c-3', 'live', 'Leaf'),
+        ]),
+      ]),
+    ];
+    const path = getAncestorPath(forest, 'c-3');
+    assert.ok(Array.isArray(path));
+    assert.strictEqual(path.length, 3);
+    assert.strictEqual(path[0].id, 'c-1');
+    assert.strictEqual(path[1].id, 'c-2');
+    assert.strictEqual(path[2].id, 'c-3');
+  });
+
+  it('returns null when ID not found', () => {
+    const forest = [mkClick('c-1', 'live', 'Root')];
+    assert.strictEqual(getAncestorPath(forest, 'c-99'), null);
+  });
+
+  it('returns null on empty forest', () => {
+    assert.strictEqual(getAncestorPath([], 'c-1'), null);
+  });
+
+  it('returns correct path across multiple roots', () => {
+    const forest = [
+      mkClick('c-A', 'live', 'Root A'),
+      mkClick('c-B', 'live', 'Root B', [
+        mkClick('c-B1', 'live', 'Child of B'),
+      ]),
+    ];
+    const path = getAncestorPath(forest, 'c-B1');
+    assert.ok(path);
+    assert.strictEqual(path.length, 2);
+    assert.strictEqual(path[0].id, 'c-B');
+    assert.strictEqual(path[1].id, 'c-B1');
+  });
+});
+
+// ── collectIds tests ────────────────────────────────────────────────────
+
+describe('collectIds', () => {
+  it('collects all IDs from nested forest', () => {
+    const forest = [
+      mkClick('c-1', 'live', 'Root', [
+        mkClick('c-2', 'live', 'Child'),
+        mkClick('c-3', 'parked', 'Child 2', [
+          mkClick('c-4', 'concluded', 'Grandchild'),
+        ]),
+      ]),
+    ];
+    const ids = collectIds(forest);
+    assert.strictEqual(ids.size, 4);
+    assert.ok(ids.has('c-1'));
+    assert.ok(ids.has('c-2'));
+    assert.ok(ids.has('c-3'));
+    assert.ok(ids.has('c-4'));
+  });
+
+  it('returns empty set for empty forest', () => {
+    const ids = collectIds([]);
+    assert.strictEqual(ids.size, 0);
+  });
+});
+
+// ── statusBadge tests ───────────────────────────────────────────────────
+
+describe('statusBadge', () => {
+  it('maps live to badge--active', () => {
+    const html = statusBadge('live');
+    assert.ok(html.includes('badge--active'));
+    assert.ok(html.includes('live'));
+  });
+
+  it('maps parked to badge--warning', () => {
+    assert.ok(statusBadge('parked').includes('badge--warning'));
+  });
+
+  it('maps concluded to badge--success', () => {
+    assert.ok(statusBadge('concluded').includes('badge--success'));
+  });
+
+  it('maps dropped to badge--error', () => {
+    assert.ok(statusBadge('dropped').includes('badge--error'));
+  });
+
+  it('falls back to plain badge for unknown status', () => {
+    const html = statusBadge('unknown');
+    assert.ok(html.includes('class="badge"'));
+    assert.ok(html.includes('unknown'));
+  });
+});
+
+// ── shortId tests ────────────────────────────────────────────────────────
+
+describe('shortId', () => {
+  it('returns prefix-timestamp segment of a full click ID', () => {
+    const id = 'c-mo1mq8ry-a4b2c1';
+    assert.strictEqual(shortId(id), 'c-mo1mq8ry');
+  });
+
+  it('returns the ID unchanged when fewer than 2 parts', () => {
+    assert.strictEqual(shortId('nodash'), 'nodash');
+  });
+
+  it('handles two-segment IDs', () => {
+    assert.strictEqual(shortId('c-abc'), 'c-abc');
+  });
+
+  it('handles null/undefined safely', () => {
+    assert.strictEqual(shortId(null), null);
+    assert.strictEqual(shortId(undefined), undefined);
+  });
+});
+
+// ── escHtml tests ────────────────────────────────────────────────────────
+
+describe('escHtml', () => {
+  it('escapes angle brackets', () => {
+    assert.strictEqual(escHtml('<script>'), '&lt;script&gt;');
+  });
+
+  it('escapes ampersands', () => {
+    assert.strictEqual(escHtml('a & b'), 'a &amp; b');
+  });
+
+  it('escapes double quotes', () => {
+    assert.strictEqual(escHtml('"hello"'), '&quot;hello&quot;');
+  });
+
+  it('returns empty string for null', () => {
+    assert.strictEqual(escHtml(null), '');
+  });
+});
+
+// ── Subtree scoping logic ────────────────────────────────────────────────
+
+describe('subtree scoping', () => {
+  const forest = [
+    mkClick('c-root', 'live', 'Root', [
+      mkClick('c-child1', 'live', 'Child 1', [
+        mkClick('c-grandchild', 'concluded', 'Grandchild'),
+      ]),
+      mkClick('c-child2', 'parked', 'Child 2'),
+    ]),
+  ];
+
+  it('findSubtree + children gives the scoped view', () => {
+    const subtree = findSubtree(forest, 'c-child1');
+    assert.ok(subtree);
+    // The "display forest" when scoped to c-child1 is subtree.children
+    const scoped = subtree.children;
+    assert.strictEqual(scoped.length, 1);
+    assert.strictEqual(scoped[0].click.id, 'c-grandchild');
+  });
+
+  it('pruning applies on top of scoped view', () => {
+    const subtree = findSubtree(forest, 'c-root');
+    const scoped = subtree ? subtree.children : [];
+    const pruned = pruneForest(scoped, new Set(['live']));
+    // c-child1 (live) kept; c-child2 (parked) pruned
+    assert.strictEqual(pruned.length, 1);
+    assert.strictEqual(pruned[0].click.id, 'c-child1');
+  });
+
+  it('getAncestorPath derives breadcrumb for scoped root', () => {
+    const path = getAncestorPath(forest, 'c-grandchild');
+    assert.ok(path);
+    const ids = path.map(c => c.id);
+    assert.deepEqual(ids, ['c-root', 'c-child1', 'c-grandchild']);
+  });
+});
