+      flex-direction: column;
+      gap: 0.4rem;
+    }
+    .confirm-section label { font-size: 0.875rem; opacity: 0.8; }
+    .confirm-section input {
+      padding: 0.35rem 0.5rem;
+      background: var(--bg, #1a1b26);
+      border: 1px solid var(--border, #3b4261);
+      border-radius: 4px;
+      color: inherit;
+      font-size: 0.875rem;
+      font-family: var(--font-mono, monospace);
+    }
+    .confirm-section input:focus { border-color: var(--cyan, #7dcfff); outline: none; }
+    .confirm-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }
+    .action-buttons { display: flex; gap: 0.4rem; flex-wrap: wrap; }
+    #detail-empty {
+      display: flex;
+      align-items: center;
+      justify-content: center;
+      height: 160px;
+      color: var(--text-dim, #565f89);
+      font-size: 0.875rem;
+    }
+    .detail-goal {
+      font-size: 1rem;
+      font-weight: 600;
+      color: var(--text-bright, #e0e6ff);
+      margin: 0 0 0.5rem;
+      word-break: break-word;
+    }
+    .detail-id-row {
+      display: flex;
+      align-items: center;
+      gap: 0.4rem;
+      margin-bottom: 0.75rem;
+      font-size: 0.8rem;
+      color: var(--text-dim, #565f89);
+    }
+    .child-row { cursor: pointer; }
+    .child-row:hover { opacity: 0.85; }
+  </style>
+</head>
+<body>
+<main style="padding: 0;">
+  <div class="page-layout">
+
+    <!-- ── Tree panel ─────────────────────────────────────────────── -->
+    <div class="tree-panel" id="tree-panel">
+      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem">
+        <h1 style="margin:0">Clicks</h1>
+      </div>
+
+      <!-- Toolbar -->
+      <div class="card" style="margin-bottom:16px">
+        <div class="toolbar" id="toolbar">
+          <button class="btn btn--primary" id="btn-new-click">New Click</button>
+          <button class="btn" id="btn-refresh">Refresh</button>
+          <span style="display:inline-flex;gap:0.35rem;flex-wrap:wrap;align-items:center">
+            <span style="font-size:0.8rem;opacity:0.6">Status:</span>
+            <button class="btn filter-btn active-filter" id="filter-all" data-status="all">All</button>
+            <button class="btn filter-btn active-filter" data-status="live">live</button>
+            <button class="btn filter-btn active-filter" data-status="parked">parked</button>
+            <button class="btn filter-btn active-filter" data-status="concluded">concluded</button>
+            <button class="btn filter-btn active-filter" data-status="dropped">dropped</button>
+          </span>
+        </div>
+      </div>
+
+      <!-- Breadcrumb (hidden when not scoped) -->
+      <div id="breadcrumb" class="breadcrumb" style="display:none"></div>
+
+      <!-- Create-click card (toggleable) -->
+      <div id="create-section" class="card">
+        <h3>New Click</h3>
+        <div class="form-row">
+          <label for="create-goal-input">Goal (required)</label>
+          <input type="text" id="create-goal-input" placeholder="Short goal description">
+        </div>
+        <div class="form-row">
+          <label for="create-parent-input">Parent ID (optional)</label>
+          <input type="text" id="create-parent-input" placeholder="c-… or short prefix">
+        </div>
+        <div style="display:flex;gap:0.4rem;align-items:center">
+          <button class="btn btn--primary" id="create-submit-btn">Create</button>
+          <button class="btn" id="create-cancel-btn">Cancel</button>
+        </div>
+        <div id="create-error" class="error-msg" style="display:none"></div>
+      </div>
+
+      <!-- Tree output -->
+      <div id="tree-container">
+        <div class="empty-state" id="tree-empty" style="display:none">No clicks found.</div>
+        <ul class="tree-list" id="tree-root"></ul>
+      </div>
+    </div>
+
+    <!-- ── Detail panel ────────────────────────────────────────────── -->
+    <div class="detail-panel" id="detail-panel">
+      <div id="detail-empty">Select a click to view details.</div>
+      <div id="detail-content" style="display:none"></div>
+    </div>
+
+  </div>
+</main>
+
+<script>
+(() => {
+  // ── State ──────────────────────────────────────────────────────────
+  let forest = [];         // ClickTree[] — full dataset from API
+  let selectedId = null;   // currently selected click ID
+  let scopeRootId = null;  // null = full forest; string = subtree root ID
+  let expandedIds = new Set();  // IDs whose children are shown
+  // Status filter: prune semantics (D6/D7 — all selected by default)
+  let activeStatuses = new Set(['live', 'parked', 'concluded', 'dropped']);
+
+  const ALL_STATUSES = ['live', 'parked', 'concluded', 'dropped'];
+
+  // ── API helper ─────────────────────────────────────────────────────
+
+  async function api(method, path, body) {
+    const opts = { method, headers: { 'Content-Type': 'application/json' } };
+    if (body !== undefined) opts.body = JSON.stringify(body);
+    const res = await fetch(path, opts);
+    const json = await res.json();
+    if (!res.ok) throw new Error(json.error ?? `HTTP ${res.status}`);
+    return json;
+  }
+
+  // ── Pure helpers ────────────────────────────────────────────────────
+
+  function statusBadge(status) {
+    const map = {
+      live:      'badge badge--active',
+      parked:    'badge badge--warning',
+      concluded: 'badge badge--success',
+      dropped:   'badge badge--error',
+    };
+    return `<span class="${map[status] ?? 'badge'}">${status}</span>`;
+  }
+
+  function shortId(id) {
+    if (!id) return id;
+    const parts = id.split('-');
+    return parts.length >= 2 ? parts.slice(0, 2).join('-') : id;
+  }
+
+  function fmtDate(iso) {
+    if (!iso) return '';
+    return new Date(iso).toLocaleString();
+  }
+
+  function escHtml(s) {
+    if (s == null) return '';
+    return String(s)
+      .replace(/&/g, '&amp;')
+      .replace(/</g, '&lt;')
+      .replace(/>/g, '&gt;')
+      .replace(/"/g, '&quot;');
+  }
+
+  function escAttr(s) {
+    if (s == null) return '';
+    return String(s)
+      .replace(/&/g, '&amp;')
+      .replace(/"/g, '&quot;')
+      .replace(/</g, '&lt;')
+      .replace(/>/g, '&gt;');
+  }
+
+  /**
+   * Dispatch a link target ID to its interaction type.
+   * Pure function — no DOM, no side effects.
+   */
+  function linkTargetType(id) {
+    if (!id) return 'text';
+    if (id.startsWith('c-')) return 'click';
+    if (id.startsWith('w-')) return 'writ';
+    return 'text';
+  }
+
+  function showError(el, msg) {
+    if (!el) return;
+    el.textContent = msg;
+    el.style.display = 'block';
+  }
+
+  function clearError(el) {
+    if (!el) return;
+    el.textContent = '';
+    el.style.display = 'none';
+  }
+
+  async function copyToClipboard(text, btn) {
+    try {
+      await navigator.clipboard.writeText(text);
+      const orig = btn.textContent;
+      btn.textContent = '✓';
+      setTimeout(() => { btn.textContent = orig; }, 1500);
+    } catch (e) { console.error('Copy failed', e); }
+  }
+
+  // ── Tree operations (pure) ──────────────────────────────────────────
+
+  /**
+   * Prune a ClickTree[] by status filter.
+   * Prune semantics: if a node's status is not in the set, that node AND
+   * all its descendants are removed. Matching nodes have their children
+   * recursively pruned.
+   */
+  function pruneForest(trees, statuses) {
+    const result = [];
+    for (const tree of trees) {
+      if (!statuses.has(tree.click.status)) continue;
+      const prunedChildren = pruneForest(tree.children, statuses);
+      result.push({ click: tree.click, children: prunedChildren });
+    }
+    return result;
+  }
+
+  /**
+   * Find the ClickTree node with the given ID anywhere in the forest.
+   */
+  function findSubtree(trees, id) {
+    for (const tree of trees) {
+      if (tree.click.id === id) return tree;
+      const found = findSubtree(tree.children, id);
+      if (found) return found;
+    }
+    return null;
+  }
+
+  /**
+   * Return the ancestor path from the forest root to the node with
+   * targetId, as an array of ClickDoc (root first, target last).
+   * Returns null if not found.
+   */
+  function getAncestorPath(trees, targetId, path) {
+    path = path ?? [];
+    for (const tree of trees) {
+      const newPath = path.concat(tree.click);
+      if (tree.click.id === targetId) return newPath;
+      const found = getAncestorPath(tree.children, targetId, newPath);
+      if (found) return found;
+    }
+    return null;
+  }
+
+  /**
+   * Collect all click IDs in a forest recursively.
+   */
+  function collectIds(trees, acc) {
+    acc = acc ?? new Set();
+    for (const tree of trees) {
+      acc.add(tree.click.id);
+      collectIds(tree.children, acc);
+    }
+    return acc;
+  }
+
+  /**
+   * Return the forest to display: apply scope, then prune by status.
+   */
+  function getDisplayForest() {
+    let source = forest;
+    if (scopeRootId) {
+      const subtree = findSubtree(forest, scopeRootId);
+      source = subtree ? subtree.children : [];
+    }
+    return pruneForest(source, activeStatuses);
+  }
+
+  // ── Tree HTML rendering ─────────────────────────────────────────────
+
+  function buildTreeHtml(trees) {
+    let html = '';
+    for (const tree of trees) {
+      html += buildNodeHtml(tree);
+    }
+    return html;
+  }
+
+  function buildNodeHtml(tree) {
+    const { click, children } = tree;
+    const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+    const hasChildren = children.length > 0;
+    const isExpanded = expandedIds.has(click.id);
+    const isSelected = click.id === selectedId;
+
+    const selectedClass = isSelected ? ' selected' : '';
+    const sid = escHtml(shortId(click.id));
+
+    let html = `<li class="tree-node" data-id="${escAttr(click.id)}">`;
+
+    // Node row
+    html += `<div class="node-row${selectedClass}" data-id="${escAttr(click.id)}">`;
+
+    // Expand/collapse button
+    if (hasChildren) {
+      const arrow = isExpanded ? '▾' : '▸';
+      const expandTitle = isExpanded ? 'Collapse' : 'Expand';
+      html += `<button class="expand-btn" data-action="expand" data-id="${escAttr(click.id)}" title="${expandTitle}">${arrow}</button>`;
+    } else {
+      html += `<button class="expand-btn invisible" aria-hidden="true">▸</button>`;
+    }
+
+    // Status badge
+    html += statusBadge(click.status);
+
+    // Goal text (click to select)
+    html += `<span class="node-goal" title="${escAttr(click.goal)}">${escHtml(click.goal)}</span>`;
+
+    // Short ID
+    html += `<span class="node-id">${sid}</span>`;
+
+    // Hover action buttons
+    html += `<div class="node-actions">`;
+    html += `<button class="node-btn" data-action="copy" data-id="${escAttr(click.id)}" title="Copy full ID">📋</button>`;
+    html += `<button class="node-btn" data-action="focus" data-id="${escAttr(click.id)}" title="Scope tree to this subtree">⊙</button>`;
+    html += `</div>`;
+
+    html += `</div>`; // end .node-row
+
+    // Conclusion disclosure (terminal nodes only — D10)
+    if (isTerminal && click.conclusion) {
+      html += `<details class="conclusion-detail">`;
+      html += `<summary>Conclusion</summary>`;
+      html += `<div class="conclusion-text">${escHtml(click.conclusion)}</div>`;
+      html += `</details>`;
+    }
+
+    // Children subtree
+    if (hasChildren) {
+      const display = isExpanded ? '' : 'display:none';
+      html += `<ul class="tree-children" style="${display}">`;
+      html += buildTreeHtml(children);
+      html += `</ul>`;
+    }
+
+    html += `</li>`;
+    return html;
+  }
+
+  function renderTree() {
+    const rootEl = document.getElementById('tree-root');
+    const emptyEl = document.getElementById('tree-empty');
+    const displayForest = getDisplayForest();
+
+    rootEl.innerHTML = buildTreeHtml(displayForest);
+
+    if (displayForest.length === 0) {
+      emptyEl.style.display = 'block';
+    } else {
+      emptyEl.style.display = 'none';
+    }
+  }
+
+  // ── Breadcrumb ──────────────────────────────────────────────────────
+
+  function renderBreadcrumb() {
+    const el = document.getElementById('breadcrumb');
+    if (!scopeRootId) {
+      el.style.display = 'none';
+      el.innerHTML = '';
+      return;
+    }
+    const path = getAncestorPath(forest, scopeRootId) ?? [];
+    el.innerHTML = '';
+    el.style.display = 'flex';
+
+    // "Show all" link
+    const showAll = document.createElement('a');
+    showAll.textContent = 'Show all';
+    showAll.href = '#';
+    showAll.addEventListener('click', e => { e.preventDefault(); clearScopeRoot(); });
+    el.appendChild(showAll);
+
+    // Ancestor segments
+    for (const click of path) {
+      const sep = document.createElement('span');
+      sep.className = 'sep';
+      sep.textContent = '›';
+      el.appendChild(sep);
+
+      if (click.id === scopeRootId) {
+        const span = document.createElement('span');
+        span.className = 'crumb-current';
+        span.textContent = click.goal;
+        span.title = click.id;
+        el.appendChild(span);
+      } else {
+        const a = document.createElement('a');
+        a.textContent = click.goal;
+        a.href = '#';
+        a.title = click.id;
+        const capturedId = click.id;
+        a.addEventListener('click', e => { e.preventDefault(); setScopeRoot(capturedId); });
+        el.appendChild(a);
+      }
+    }
+  }
+
+  // ── Scope root management ───────────────────────────────────────────
+
+  function setScopeRoot(id) {
+    scopeRootId = id;
+    const url = new URL(window.location.href);
+    url.searchParams.set('root', id);
+    window.history.pushState({}, '', url.toString());
+    renderBreadcrumb();
+    renderTree();
+  }
+
+  function clearScopeRoot() {
+    scopeRootId = null;
+    const url = new URL(window.location.href);
+    url.searchParams.delete('root');
+    window.history.pushState({}, '', url.toString());
+    renderBreadcrumb();
+    renderTree();
+  }
+
+  // ── Click selection ─────────────────────────────────────────────────
+
+  async function selectClick(id) {
+    selectedId = id;
+
+    // Update URL
+    const url = new URL(window.location.href);
+    url.searchParams.set('click', id);
+    window.history.pushState({}, '', url.toString());
+
+    // Update tree highlight (re-render preserves selection via selectedId state)
+    renderTree();
+
+    // Load and render detail
+    await refreshDetail(id);
+  }
+
+  async function refreshDetail(id) {
+    const emptyEl = document.getElementById('detail-empty');
+    const contentEl = document.getElementById('detail-content');
+
+    let detail;
+    try {
+      detail = await api('GET', `/api/click/show?id=${encodeURIComponent(id)}`);
+    } catch (e) {
+      contentEl.innerHTML = `<div class="error-msg">Failed to load click: ${escHtml(e.message)}</div>`;
+      emptyEl.style.display = 'none';
+      contentEl.style.display = 'block';
+      return;
+    }
+
+    emptyEl.style.display = 'none';
+    contentEl.style.display = 'block';
+    contentEl.innerHTML = renderDetail(detail);
+    wireDetailEvents(contentEl, detail);
+
+    // Lazily fetch link target metadata (D16)
+    fetchLinkMetadata(detail);
+  }
+
+  // ── Detail pane rendering ───────────────────────────────────────────
+
+  function renderDetail(detail) {
+    const click = detail;
+    const isTerminal = click.status === 'concluded' || click.status === 'dropped';
+    let html = '';
+
+    // ── Header: goal + ID ──
+    html += `<div class="detail-section">`;
+    html += `<h2 class="detail-goal">${escHtml(click.goal)}</h2>`;
+    html += `<div class="detail-id-row">`;
+    html += `<code>${escHtml(click.id)}</code>`;
+    html += `<button class="node-btn" id="detail-copy-btn" data-id="${escAttr(click.id)}" title="Copy ID">📋</button>`;
+    html += `</div>`;
+    html += `</div>`;
+
+    // ── Details grid (D24) ──
+    html += `<div class="detail-section"><h4>Details</h4><dl class="detail-grid">`;
+    html += `<dt>Status</dt><dd>${statusBadge(click.status)}</dd>`;
+    if (click.parent) {
+      html += `<dt>Parent</dt><dd>`;
+      html += `<a class="link-target" data-click-id="${escAttr(click.parent.id)}" href="#">`;
+      html += `${escHtml(shortId(click.parent.id))}: ${escHtml(click.parent.goal)}`;
+      html += `</a> ${statusBadge(click.parent.status)}`;
+      html += `</dd>`;
+    }
+    html += `<dt>Created</dt><dd>${escHtml(fmtDate(click.createdAt))}</dd>`;
+    if (click.createdSessionId) {
+      html += `<dt>Session (created)</dt><dd><code>${escHtml(click.createdSessionId)}</code></dd>`;
+    }
+    if (click.resolvedAt) {
+      html += `<dt>Resolved</dt><dd>${escHtml(fmtDate(click.resolvedAt))}</dd>`;
+    }
+    if (click.resolvedSessionId) {
+      html += `<dt>Session (resolved)</dt><dd><code>${escHtml(click.resolvedSessionId)}</code></dd>`;
+    }
+    html += `</dl></div>`;
+
+    // ── Conclusion (terminal, expandable — D10/D24) ──
+    if (isTerminal && click.conclusion) {
+      html += `<div class="detail-section">`;
+      html += `<details>`;
+      html += `<summary><h4 style="display:inline;margin:0;font-size:0.7rem;text-transform:uppercase;letter-spacing:0.06em;opacity:0.5">Conclusion</h4></summary>`;
+      html += `<pre style="margin-top:0.5rem;white-space:pre-wrap;word-break:break-word;font-size:0.875rem;padding:0.6rem;background:var(--bg,#1a1b26);border-radius:4px;max-height:240px;overflow-y:auto">${escHtml(click.conclusion)}</pre>`;
+      html += `</details>`;
+      html += `</div>`;
+    }
+
+    // ── Lifecycle actions (detail pane only — D11) ──
+    if (!isTerminal) {
+      html += `<div class="detail-section"><h4>Actions</h4>`;
+      html += `<div class="action-buttons">`;
+      if (click.status === 'live') {
+        html += `<button class="btn" data-action="park" data-id="${escAttr(click.id)}">Park</button>`;
+      }
+      if (click.status === 'parked') {
+        html += `<button class="btn btn--primary" data-action="resume" data-id="${escAttr(click.id)}">Resume</button>`;
+      }
+      if (click.status === 'live' || click.status === 'parked') {
+        html += `<button class="btn btn--success" data-action="conclude-init" data-id="${escAttr(click.id)}">Conclude</button>`;
+        html += `<button class="btn btn--danger" data-action="drop-init" data-id="${escAttr(click.id)}">Drop</button>`;
+      }
+      html += `</div>`;
+      html += `<div id="confirm-area-${escAttr(click.id)}"></div>`;
+      html += `<div class="error-msg" id="action-error-${escAttr(click.id)}" style="display:none"></div>`;
+      html += `</div>`;
+    }
+
+    // ── Children (D22) ──
+    const childItems = click.children?.items ?? [];
+    if (childItems.length > 0) {
+      html += `<div class="detail-section"><h4>Children</h4>`;
+
+      // Status-count badge strip
+      const summary = click.children?.summary ?? {};
+      if (Object.keys(summary).length > 0) {
+        html += `<div style="margin-bottom:0.5rem;display:flex;gap:0.35rem;flex-wrap:wrap;align-items:center">`;
+        for (const [st, count] of Object.entries(summary)) {
+          html += `${statusBadge(st)}<span style="margin-right:0.25rem;font-size:0.8rem"> ${count}</span>`;
+        }
+        html += `</div>`;
+      }
+
+      // Children table: Status, Goal, ID — rows navigate to child detail (D22)
+      html += `<table class="data-table"><thead><tr>`;
+      html += `<th>Status</th><th>Goal</th><th>ID</th>`;
+      html += `</tr></thead><tbody>`;
+      for (const child of childItems) {
+        html += `<tr class="child-row" data-click-id="${escAttr(child.id)}">`;
+        html += `<td>${statusBadge(child.status)}</td>`;
+        html += `<td>${escHtml(child.goal)}</td>`;
+        html += `<td><code>${escHtml(shortId(child.id))}</code></td>`;
+        html += `</tr>`;
+      }
+      html += `</tbody></table></div>`;
+    }
+
+    // ── Links (D15/D16) ──
+    const outbound = click.links?.outbound ?? [];
+    const inbound = click.links?.inbound ?? [];
+    html += `<div class="detail-section" id="links-section-${escAttr(click.id)}"><h4>Links</h4>`;
+
+    if (outbound.length === 0 && inbound.length === 0) {
+      html += `<p style="font-size:0.875rem;opacity:0.5">No links.</p>`;
+    }
+
+    for (const l of outbound) {
+      html += renderLinkRow('→', l.targetId, l.linkType, l.sourceId, l.targetId, l.linkType, click.id);
+    }
+    for (const l of inbound) {
+      html += renderLinkRow('←', l.sourceId, l.linkType, l.sourceId, l.targetId, l.linkType, click.id);
+    }
+
+    // Add-link form (D14 — select dropdown for closed enum)
+    html += `<div class="add-link-form">`;
+    html += `<input type="text" id="link-target-${escAttr(click.id)}" placeholder="Target ID" style="min-width:130px">`;
+    html += `<select id="link-type-${escAttr(click.id)}">`;
+    html += `<option value="related">related</option>`;
+    html += `<option value="commissioned">commissioned</option>`;
+    html += `<option value="supersedes">supersedes</option>`;
+    html += `<option value="depends-on">depends-on</option>`;
+    html += `</select>`;
+    html += `<button class="btn btn--primary" data-action="addlink" data-id="${escAttr(click.id)}" style="padding:0.3rem 0.6rem;font-size:0.8rem">Add Link</button>`;
+    html += `</div>`;
+    html += `<div class="error-msg" id="link-error-${escAttr(click.id)}" style="display:none"></div>`;
+    html += `</div>`;
+
+    return html;
+  }
+
+  /**
+   * Render one link row.
+   * dir: '→' or '←'
+   * displayId: the ID to display (targetId for outbound, sourceId for inbound)
+   * linkType: type label
+   * sourceId / targetId / ltType: for the unlink button payload
+   * clickId: current click being viewed (for refresh after unlink)
+   */
+  function renderLinkRow(dir, displayId, linkType, sourceId, targetId, ltType, clickId) {
+    const type = linkTargetType(displayId);
+    const safeKey = displayId.replace(/[^a-z0-9]/gi, '_');
+    let targetHtml;
+    if (type === 'click' || type === 'writ') {
+      targetHtml = `<a class="link-target" data-link-target="${escAttr(displayId)}" href="#">${escHtml(shortId(displayId))}</a>`;
+    } else {
+      targetHtml = `<span class="link-meta">${escHtml(displayId)}</span>`;
+    }
+    return `<div class="link-row">
+      <span class="link-dir">${dir}</span>
+      ${targetHtml}
+      <span class="link-type-label">(${escHtml(linkType)})</span>
+      <span class="link-meta" id="lmeta-${escHtml(safeKey)}"></span>
+      <button class="btn btn--danger" style="padding:0.1rem 0.4rem;font-size:0.75rem;margin-left:auto"
+        data-action="unlink"
+        data-source="${escAttr(sourceId)}"
+        data-target="${escAttr(targetId)}"
+        data-ltype="${escAttr(ltType)}"
+        data-click-id="${escAttr(clickId)}">×</button>
+    </div>`;
+  }
+
+  // ── Lazy link metadata fetch (D16) ──────────────────────────────────
+
+  async function fetchLinkMetadata(detail) {
+    const outbound = detail.links?.outbound ?? [];
+    const inbound = detail.links?.inbound ?? [];
+
+    const targets = [
+      ...outbound.map(l => l.targetId),
+      ...inbound.map(l => l.sourceId),
+    ];
+
+    for (const id of targets) {
+      const key = id.replace(/[^a-z0-9]/gi, '_');
+      const metaEl = document.getElementById(`lmeta-${key}`);
+      if (!metaEl) continue;
+
+      if (id.startsWith('c-')) {
+        try {
+          const click = await api('GET', `/api/click/show?id=${encodeURIComponent(id)}`);
+          metaEl.textContent = `— ${click.goal}`;
+        } catch (_) { /* ignore */ }
+      } else if (id.startsWith('w-')) {
+        try {
+          const writ = await api('GET', `/api/writ/show?id=${encodeURIComponent(id)}`);
+          metaEl.textContent = `— ${writ.title}`;
+        } catch (_) { /* ignore */ }
+      }
+    }
+  }
+
+  // ── Wire detail pane events ─────────────────────────────────────────
+
+  function wireDetailEvents(container, detail) {
+    const id = detail.id;
+
+    // Copy ID button
+    const copyBtn = container.querySelector('#detail-copy-btn');
+    if (copyBtn) {
+      copyBtn.addEventListener('click', () => copyToClipboard(detail.id, copyBtn));
+    }
+
+    // Parent link — navigate to parent in detail pane
+    container.querySelectorAll('a[data-click-id]').forEach(a => {
+      a.addEventListener('click', e => {
+        e.preventDefault();
+        selectClick(a.dataset.clickId);
+      });
+    });
+
+    // Children table rows — select child
+    container.querySelectorAll('.child-row[data-click-id]').forEach(tr => {
+      tr.addEventListener('click', () => selectClick(tr.dataset.clickId));
+    });
+
+    // Link targets — prefix dispatch (D15)
+    container.querySelectorAll('a[data-link-target]').forEach(a => {
+      a.addEventListener('click', e => {
+        e.preventDefault();
+        const targetId = a.dataset.linkTarget;
+        const type = linkTargetType(targetId);
+        if (type === 'click') {
+          selectClick(targetId);
+        } else if (type === 'writ') {
+          window.location.href = `/pages/writs/?writ=${encodeURIComponent(targetId)}`;
+        }
+        // 'text' type: nothing (plain text, no click action)
+      });
+    });
+
+    // Action buttons
+    container.querySelectorAll('[data-action]').forEach(btn => {
+      btn.addEventListener('click', () => handleDetailAction(btn, detail));
+    });
+  }
+
+  // ── Detail action handlers ──────────────────────────────────────────
+
+  async function handleDetailAction(btn, detail) {
+    const action = btn.dataset.action;
+    const id = btn.dataset.id ?? detail.id;
+
+    if (action === 'park') {
+      await doLifecycle('/api/click/park', { id }, id, btn);
+    } else if (action === 'resume') {
+      await doLifecycle('/api/click/resume', { id }, id, btn);
+    } else if (action === 'conclude-init') {
+      showConfirm(id, 'conclude');
+    } else if (action === 'drop-init') {
+      showConfirm(id, 'drop');
+    } else if (action === 'unlink') {
+      await doUnlink(
+        btn.dataset.source,
+        btn.dataset.target,
+        btn.dataset.ltype,
+        btn,
+        btn.dataset.clickId ?? id,
+      );
+    } else if (action === 'addlink') {
+      const targetInput = document.getElementById(`link-target-${id}`);
+      const typeSelect  = document.getElementById(`link-type-${id}`);
+      const errEl       = document.getElementById(`link-error-${id}`);
+      await doAddLink(id, targetInput?.value.trim() ?? '', typeSelect?.value ?? '', btn, errEl, targetInput);
+    }
+  }
+
+  async function doLifecycle(path, body, clickId, btn) {
+    const orig = btn.textContent;
+    btn.disabled = true;
+    btn.textContent = '…';
+    const errEl = document.getElementById(`action-error-${clickId}`);
+    if (errEl) clearError(errEl);
+    try {
+      await api('POST', path, body);
+      await fullRefetch(clickId);
+    } catch (e) {
+      if (errEl) showError(errEl, e.message);
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  function showConfirm(id, action) {
+    const area = document.getElementById(`confirm-area-${id}`);
+    const errEl = document.getElementById(`action-error-${id}`);
+    if (!area) return;
+    if (errEl) clearError(errEl);
+
+    const isConclude = action === 'conclude';
+    const label = isConclude ? 'Conclusion (required)' : 'Drop reason (required)';
+    const confirmLabel = isConclude ? 'Confirm Conclude' : 'Confirm Drop';
+    const btnClass = isConclude ? 'btn--success' : 'btn--danger';
+
+    area.innerHTML = `
+      <div class="confirm-section">
+        <label>${label}</label>
+        <input type="text" id="confirm-text-${escAttr(id)}" placeholder="${label}">
+        <div class="confirm-actions">
+          <button class="btn ${btnClass}" id="confirm-btn-${escAttr(id)}" disabled>${confirmLabel}</button>
+          <button class="btn" id="confirm-cancel-${escAttr(id)}">Cancel</button>
+        </div>
+        <div class="error-msg" id="confirm-error-${escAttr(id)}" style="display:none"></div>
+      </div>`;
+
+    const textInput  = document.getElementById(`confirm-text-${id}`);
+    const confirmBtn = document.getElementById(`confirm-btn-${id}`);
+    const cancelBtn  = document.getElementById(`confirm-cancel-${id}`);
+    const confirmErr = document.getElementById(`confirm-error-${id}`);
+
+    textInput.addEventListener('input', () => {
+      confirmBtn.disabled = !textInput.value.trim();
+      clearError(confirmErr);
+    });
+
+    cancelBtn.addEventListener('click', () => { area.innerHTML = ''; });
+
+    confirmBtn.addEventListener('click', async () => {
+      const conclusion = textInput.value.trim();
+      if (!conclusion) return;
+      clearError(confirmErr);
+      confirmBtn.disabled = true;
+      confirmBtn.textContent = 'Working…';
+      try {
+        const endpoint = isConclude ? '/api/click/conclude' : '/api/click/drop';
+        await api('POST', endpoint, { id, conclusion });
+        await fullRefetch(id);
+      } catch (e) {
+        showError(confirmErr, e.message);
+        confirmBtn.disabled = false;
+        confirmBtn.textContent = confirmLabel;
+      }
+    });
+  }
+
+  async function doUnlink(sourceId, targetId, linkType, btn, clickId) {
+    const orig = btn.textContent;
+    btn.disabled = true;
+    try {
+      await api('POST', '/api/click/unlink', { sourceId, targetId, linkType });
+      await fullRefetch(clickId);
+    } catch (e) {
+      alert(`Unlink failed: ${e.message}`);
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  async function doAddLink(clickId, targetId, linkType, btn, errEl, targetInput) {
+    if (errEl) clearError(errEl);
+    if (!targetId || !linkType) {
+      if (errEl) showError(errEl, 'Target ID and link type are required.');
+      return;
+    }
+    const orig = btn.textContent;
+    btn.disabled = true;
+    btn.textContent = 'Linking…';
+    try {
+      await api('POST', '/api/click/link', { sourceId: clickId, targetId, linkType });
+      if (targetInput) targetInput.value = '';
+      await fullRefetch(clickId);
+    } catch (e) {
+      if (errEl) showError(errEl, e.message);
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  // ── Full refetch (D17) ──────────────────────────────────────────────
+
+  async function fullRefetch(keepSelectedId) {
+    const sid = keepSelectedId ?? selectedId;
+    await loadForest();
+    renderBreadcrumb();
+    renderTree();
+    if (sid) {
+      await refreshDetail(sid);
+    }
+  }
+
+  // ── Data loading ────────────────────────────────────────────────────
+
+  async function loadForest() {
+    try {
+      const data = await api('GET', '/api/click/tree?format=json');
+      forest = Array.isArray(data) ? data : [];
+
+      // Default D8: expand all nodes on first load;
+      // on subsequent loads, also expand any newly created nodes.
+      const ids = collectIds(forest);
+      if (expandedIds.size === 0) {
+        // First load: expand everything
+        expandedIds = ids;
+      } else {
+        // Subsequent loads: expand new nodes, preserve user collapse choices
+        for (const id of ids) {
+          if (!expandedIds.has(id)) expandedIds.add(id);
+        }
+      }
+    } catch (e) {
+      console.error('Failed to load click tree:', e);
+      forest = [];
+    }
+  }
+
+  // ── Status filter ────────────────────────────────────────────────────
+
+  function syncFilterButtons() {
+    const allActive = ALL_STATUSES.every(s => activeStatuses.has(s));
+    document.querySelectorAll('.filter-btn').forEach(btn => {
+      const s = btn.dataset.status;
+      if (s === 'all') {
+        btn.classList.toggle('active-filter', allActive);
+      } else {
+        btn.classList.toggle('active-filter', activeStatuses.has(s));
+      }
+    });
+  }
+
+  function toggleStatus(status) {
+    if (status === 'all') {
+      // Activate all
+      for (const s of ALL_STATUSES) activeStatuses.add(s);
+    } else {
+      const allActive = ALL_STATUSES.every(s => activeStatuses.has(s));
+      if (allActive) {
+        // Deselect all except the clicked one
+        activeStatuses = new Set([status]);
+      } else {
+        if (activeStatuses.has(status)) {
+          activeStatuses.delete(status);
+        } else {
+          activeStatuses.add(status);
+        }
+      }
+    }
+    syncFilterButtons();
+    renderTree();
+  }
+
+  // ── Create-click form ────────────────────────────────────────────────
+
+  function openCreateForm(prefillParentId) {
+    const section = document.getElementById('create-section');
+    section.classList.add('open');
+    if (prefillParentId) {
+      document.getElementById('create-parent-input').value = prefillParentId;
+    }
+    document.getElementById('create-goal-input').focus();
+  }
+
+  function closeCreateForm() {
+    const section = document.getElementById('create-section');
+    section.classList.remove('open');
+    document.getElementById('create-goal-input').value = '';
+    document.getElementById('create-parent-input').value = '';
+    clearError(document.getElementById('create-error'));
+  }
+
+  async function submitCreateForm() {
+    const goal     = document.getElementById('create-goal-input').value.trim();
+    const parentId = document.getElementById('create-parent-input').value.trim() || undefined;
+    const errEl    = document.getElementById('create-error');
+    clearError(errEl);
+
+    if (!goal) { showError(errEl, 'Goal is required.'); return; }
+
+    const btn = document.getElementById('create-submit-btn');
+    btn.disabled = true;
+    const orig = btn.textContent;
+    btn.textContent = 'Creating…';
+
+    try {
+      const payload = { goal, ...(parentId ? { parentId } : {}) };
+      const newClick = await api('POST', '/api/click/create', payload);
+      closeCreateForm();
+      await fullRefetch(newClick.id);
+      await selectClick(newClick.id);
+    } catch (e) {
+      showError(errEl, e.message);
+    } finally {
+      btn.disabled = false;
+      btn.textContent = orig;
+    }
+  }
+
+  // ── Tree interaction (event delegation) ────────────────────────────
+
+  document.getElementById('tree-root').addEventListener('click', e => {
+    const btn = e.target.closest('[data-action]');
+    if (btn) {
+      e.stopPropagation();
+      const action = btn.dataset.action;
+      const id = btn.dataset.id;
+      if (action === 'expand') {
+        if (expandedIds.has(id)) {
+          expandedIds.delete(id);
+        } else {
+          expandedIds.add(id);
+        }
+        renderTree();
+      } else if (action === 'copy') {
+        copyToClipboard(id, btn);
+      } else if (action === 'focus') {
+        setScopeRoot(id);
+      }
+      return;
+    }
+    const row = e.target.closest('.node-row[data-id]');
+    if (row) {
+      selectClick(row.dataset.id);
+    }
+  });
+
+  // ── Toolbar event wiring ────────────────────────────────────────────
+
+  document.getElementById('btn-new-click').addEventListener('click', () => {
+    const section = document.getElementById('create-section');
+    if (section.classList.contains('open')) {
+      closeCreateForm();
+    } else {
+      openCreateForm(null);
+    }
+  });
+
+  document.getElementById('btn-refresh').addEventListener('click', () => fullRefetch(null));
+  document.getElementById('create-submit-btn').addEventListener('click', submitCreateForm);
+  document.getElementById('create-cancel-btn').addEventListener('click', closeCreateForm);
+
+  document.getElementById('create-goal-input').addEventListener('keydown', e => {
+    if (e.key === 'Enter') submitCreateForm();
+  });
+
+  document.querySelectorAll('.filter-btn').forEach(btn => {
+    btn.addEventListener('click', () => toggleStatus(btn.dataset.status));
+  });
+
+  // ── Popstate (back/forward navigation) ─────────────────────────────
+
+  window.addEventListener('popstate', () => {
+    const params = new URLSearchParams(window.location.search);
+    scopeRootId = params.get('root') ?? null;
+    const newClickId = params.get('click') ?? null;
+    if (newClickId !== selectedId) {
+      selectedId = newClickId;
+    }
+    renderBreadcrumb();
+    renderTree();
+    if (selectedId) refreshDetail(selectedId);
+  });
+
+  // ── Init ─────────────────────────────────────────────────────────────
+
+  (async function init() {
+    const params = new URLSearchParams(window.location.search);
+    scopeRootId = params.get('root') ?? null;
+    const deepLinkClickId = params.get('click') ?? null;
+
+    await loadForest();
+    renderBreadcrumb();
+    renderTree();
+
+    // D19: auto-open detail pane for ?click=<id>
+    if (deepLinkClickId) {
+      selectedId = deepLinkClickId;
+      await selectClick(deepLinkClickId);
+    }
+  })();
+
+})();
+</script>
+</body>
+</html>
