@@ -0,0 +1,321 @@
+/**
+ * Reckoner public types.
+ *
+ * The Reckoner petition-scheduler — manages a kit-static registry of
+ * petitioner sources, exposes helper APIs for posting Reckoner-gated writs
+ * in the correct shape, and reads configuration from guild.json.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { WritDoc } from '@shardworks/clerk-apparatus';
+
+// ── Domain tags ─────────────────────────────────────────────────────────
+
+/**
+ * Domain tag values for `Priority.domain`. Multi-valued orthogonal
+ * classification — describes the kind of work, not its priority magnitude.
+ *
+ * Used by the Reckoner for filtering, patron-tunable weighting, and reporting.
+ */
+export type DomainTag =
+  | 'security'
+  | 'compliance'
+  | 'cost'
+  | 'feature'
+  | 'quality'
+  | 'infrastructure'
+  | 'documentation'
+  | 'research'
+  | 'ergonomics';
+
+// ── Priority ───────────────────────────────────────────────────────────
+
+/**
+ * Five-axis priority schema. Each axis is independent and the combination
+ * function that collapses them into a scheduling weight lives in the
+ * CDC-handler commission — not here.
+ *
+ * See: docs/architecture/petitioner-registration.md §3
+ */
+export type Priority = {
+  /**
+   * How does this petition relate to the product vision?
+   * Names a relationship type, not a magnitude.
+   */
+  visionRelation:
+    | 'vision-blocker'
+    | 'vision-violator'
+    | 'vision-advancer'
+    | 'vision-neutral';
+
+  /**
+   * If this petition is not acted on, how bad is the situation?
+   * Pure magnitude axis, independent of visionRelation.
+   */
+  severity: 'critical' | 'serious' | 'moderate' | 'minor';
+
+  /** What fraction of the system is affected? */
+  scope: 'whole-product' | 'major-area' | 'minor-area';
+
+  /**
+   * Temporal urgency — two genuinely independent sub-axes:
+   *   - `decay: true` — value degrades over time (drift sentinels, security exposure).
+   *   - `deadline` — an external commitment or pledged date.
+   */
+  time: {
+    decay: boolean;
+    /** ISO date string, or null when no deadline applies. */
+    deadline: string | null;
+  };
+
+  /**
+   * Multi-valued domain tag set. Orthogonal classification — NOT a priority
+   * axis. Describes the kind of work for filtering, weighting, and reporting.
+   */
+  domain: Array<DomainTag>;
+};
+
+/**
+ * Default priority values applied by `defaultPriority()` and by
+ * `reckoner.petition()` when fields are omitted.
+ *
+ * Defaults are deliberately permissive (lowest-pressure values on every
+ * dimension) so omission errs toward deference rather than urgency.
+ */
+export const DEFAULT_PRIORITY: Readonly<Priority> = Object.freeze({
+  visionRelation: 'vision-neutral' as const,
+  severity: 'minor' as const,
+  scope: 'minor-area' as const,
+  time: Object.freeze({ decay: false, deadline: null }),
+  domain: [] as DomainTag[],
+});
+
+/**
+ * Return a fully-populated `Priority` with defaults applied for any omitted
+ * fields. Passed a complete `Priority` the object is returned unchanged
+ * (structurally equivalent; values are not cloned).
+ *
+ * The helper is used by `reckoner.petition()` and is exported for callers
+ * that want to normalise a partial priority before persisting or comparing.
+ */
+export function defaultPriority(partial?: Partial<Priority>): Priority {
+  return {
+    visionRelation: partial?.visionRelation ?? DEFAULT_PRIORITY.visionRelation,
+    severity: partial?.severity ?? DEFAULT_PRIORITY.severity,
+    scope: partial?.scope ?? DEFAULT_PRIORITY.scope,
+    time: partial?.time ?? { decay: DEFAULT_PRIORITY.time.decay, deadline: DEFAULT_PRIORITY.time.deadline },
+    domain: partial?.domain ?? [...DEFAULT_PRIORITY.domain],
+  };
+}
+
+// ── Complexity ─────────────────────────────────────────────────────────
+
+/**
+ * Petitioner-side coarse cost estimate. Refined by the Astrolabe at plan
+ * time; this tier exists only for early-stage trade-offs before plans exist.
+ *
+ * Token ranges are calibration hints, **not contractual**. Petitioners are
+ * encouraged to omit rather than guess.
+ *
+ * See: docs/architecture/petitioner-registration.md §4
+ */
+export type ComplexityTier =
+  /** Clear path, minimal exploration. ~50K–200K tokens. */
+  | 'mechanical'
+  /** Clear scope, some exploration. ~200K–1M tokens. */
+  | 'bounded'
+  /** Design judgment required; multiple viable paths. ~1M–5M tokens. */
+  | 'exploratory'
+  /** Research, prototyping, or scope likely to grow. ~5M+ tokens. */
+  | 'open-ended';
+
+// ── Petition shape ─────────────────────────────────────────────────────
+
+/**
+ * The full `writ.ext['reckoner']` shape.
+ *
+ * A petition is not a separate entity from a writ — it is a writ in `new`
+ * phase carrying this ext sub-slot. The Reckoner inspects `ext['reckoner']`
+ * to decide whether to adopt responsibility for transitioning the writ.
+ *
+ * See: docs/architecture/petitioner-registration.md §2
+ */
+export interface ReckonerExt {
+  /**
+   * Required. Identifies the petitioner. Must match a registered petitioner
+   * descriptor when `enforceRegistration` is on.
+   */
+  source: string;
+
+  /** Required. Multi-dimensional priority. */
+  priority: Priority;
+
+  /**
+   * Optional petitioner-side coarse cost estimate. Refined by the Astrolabe
+   * at plan time.
+   */
+  complexity?: ComplexityTier;
+
+  /**
+   * Opaque petitioner-defined structured data. The Reckoner stores it but
+   * does not introspect; the rig's implementation engine reads it if needed.
+   */
+  payload?: unknown;
+
+  /**
+   * Additive non-priority metadata. Multi-instance discrimination
+   * (e.g. `'vision-keeper.io/vision-id': 'nexus'`), observability hints,
+   * diagnostic tags.
+   */
+  labels?: Record<string, string>;
+}
+
+// ── Petitioner registry ────────────────────────────────────────────────
+
+/**
+ * A single petitioner descriptor contributed via a kit's `petitioners` array.
+ *
+ * Kit authors populate `petitioners: [{ source, description }]` in their kit
+ * (or apparatus's `supportKit`). The Reckoner consumes the contribution at
+ * boot, builds the registry, and seals it at `phase:started`.
+ *
+ * Source ids must follow the grammar `{pluginId}.{kebab-suffix}` — the
+ * contributing plugin's derived id, a literal `.`, then a kebab-case suffix.
+ * Malformed ids hard-fail at startup.
+ *
+ * See: docs/architecture/petitioner-registration.md §5
+ */
+export interface PetitionerDescriptor {
+  /**
+   * Fully-qualified source id. Must be of the form `{pluginId}.{kebab-suffix}`:
+   * lowercase letters, digits, and single-hyphen separators; no leading or
+   * trailing hyphen on the suffix.
+   *
+   * Examples: `vision-keeper.snapshot`, `patron-bridge.commission`.
+   */
+  source: string;
+
+  /** Human-readable one-liner describing this petitioner source. */
+  description: string;
+}
+
+// ── API ────────────────────────────────────────────────────────────────
+
+/**
+ * Request shape for `reckoner.petition()`.
+ *
+ * Combines writ fields (type, title, body, codex, parentId?) and ext fields
+ * (source, priority, complexity?, payload?, labels?). Priority dimensions may
+ * be omitted — the helper applies defaults for any missing field.
+ *
+ * See: docs/architecture/petitioner-registration.md §1
+ */
+export interface PetitionRequest {
+  // ── Writ fields — passed through to clerk.post() ──────────────────
+  /** Writ type. Must be a registered writ type. */
+  type: string;
+  /** Short human-readable title describing the work. */
+  title: string;
+  /** Detail text. */
+  body: string;
+  /** Target codex name. */
+  codex: string;
+  /** Optional parent writ id. */
+  parentId?: string;
+
+  // ── ext.reckoner fields ────────────────────────────────────────────
+  /**
+   * Required. Identifies the petitioner. Validated against the registry;
+   * behaviour on unknown source controlled by `enforceRegistration` config.
+   */
+  source: string;
+  /**
+   * Priority dimensions. Any omitted dimension falls back to the default
+   * (vision-neutral / minor / minor-area / {decay: false, deadline: null} / []).
+   */
+  priority?: Partial<Priority>;
+  /** Optional coarse cost estimate. Omit when there is no basis to claim. */
+  complexity?: ComplexityTier;
+  /** Opaque petitioner-defined data — available to the rig engine after approval. */
+  payload?: unknown;
+  /** Additive non-priority metadata for discrimination and observability. */
+  labels?: Record<string, string>;
+}
+
+/**
+ * The Reckoner's runtime API — retrieved via
+ * `guild().apparatus<ReckonerApi>('reckoner')`.
+ *
+ * See: docs/architecture/petitioner-registration.md §1
+ */
+export interface ReckonerApi {
+  /**
+   * Post a writ in `new` phase with Reckoner ext set correctly.
+   *
+   * Validates the source against the registry (behaviour on unknown source
+   * governed by `enforceRegistration` config), applies defaults for any
+   * omitted priority dimensions, validates dimension values against the
+   * schema, calls `clerk.post()`, then writes `ext.reckoner` via
+   * `clerk.setWritExt()`.
+   *
+   * Returns the persisted `WritDoc` with `phase: 'new'` and
+   * `ext['reckoner']` populated.
+   *
+   * Equivalent in effect to calling `clerk.post()` with manual ext
+   * construction (Workflow 1 in the contract); this helper exists for type
+   * checking, default handling, and discoverability.
+   */
+  petition(request: PetitionRequest): Promise<WritDoc>;
+
+  /**
+   * Withdraw a held writ by transitioning it to `cancelled`.
+   *
+   * Thin wrapper around `clerk.transition(writId, 'cancelled', {resolution})`.
+   * No special source-check — the wrapper's purpose is ergonomic
+   * discoverability, not enforcement.
+   */
+  withdraw(writId: string, reason?: string): Promise<WritDoc>;
+}
+
+// ── Configuration ──────────────────────────────────────────────────────
+
+/**
+ * Reckoner apparatus configuration — lives under the `reckoner` key in guild.json.
+ *
+ * Both fields are permissive by default so development guilds work without
+ * explicit configuration. Production guilds that want hard guarantees about
+ * registered sources should set `enforceRegistration: true`.
+ *
+ * See: docs/architecture/petitioner-registration.md §6
+ */
+export interface ReckonerConfig {
+  /**
+   * When `true`: petitions whose `ext.reckoner.source` is not in the registry
+   * are declined (writ cancelled with a reason naming the unknown source).
+   *
+   * When `false` (default): a warning is logged and the writ proceeds.
+   */
+  enforceRegistration?: boolean;
+
+  /**
+   * Per-source disable list. Petitions from any source in this array are
+   * skipped by the Reckoner — left in `new` phase indefinitely. Defaults to
+   * an empty array.
+   *
+   * Skipping (rather than declining) preserves work across temporary
+   * disablings — the petitioner doesn't need to re-emit when the source is
+   * re-enabled.
+   */
+  disabledSources?: string[];
+}
+
+// ── GuildConfig augmentation ───────────────────────────────────────────
+
+// Augment GuildConfig so `guild().config('reckoner')` is typed without
+// requiring a manual type parameter at the call site.
+declare module '@shardworks/nexus-core' {
+  interface GuildConfig {
+    reckoner?: ReckonerConfig;
