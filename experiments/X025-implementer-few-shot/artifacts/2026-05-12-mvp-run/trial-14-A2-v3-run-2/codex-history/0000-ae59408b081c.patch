+/**
+ * @shardworks/reckoner-apparatus — The Reckoner petition-scheduler.
+ *
+ * Provides:
+ *   - Kit-static petitioner registry (`petitioners` contribution type).
+ *   - `guild.json` configuration parsing under the `reckoner` key.
+ *   - `defaultPriority()` helper — fills omitted priority dimensions with
+ *     contract defaults.
+ *   - `reckoner.petition(request)` helper — validates source, applies
+ *     defaults, posts writ via Clerk, writes `ext.reckoner`.
+ *   - `reckoner.withdraw(writId, reason?)` helper — thin wrapper around
+ *     `clerk.transition(writId, 'cancelled', ...)`.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import { createReckoner } from './reckoner.ts';
+
+export {
+  RECKONER_PLUGIN_ID,
+  createReckoner,
+  type PetitionerInfo,
+  type ReckonerInternalApi,
+} from './reckoner.ts';
+
+export {
+  DEFAULT_PRIORITY,
+  defaultPriority,
+  type ComplexityTier,
+  type DomainTag,
+  type PetitionRequest,
+  type PetitionerDescriptor,
+  type Priority,
+  type ReckonerApi,
+  type ReckonerConfig,
+  type ReckonerExt,
+} from './types.ts';
+
+export default createReckoner();
