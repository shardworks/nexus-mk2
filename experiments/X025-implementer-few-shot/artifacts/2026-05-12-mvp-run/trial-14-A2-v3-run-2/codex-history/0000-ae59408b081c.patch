+/**
+ * The Reckoner petition-scheduler apparatus.
+ *
+ * Contract surface for v0:
+ *
+ *   - Kit-static petitioner registry (consumes `petitioners` contributions).
+ *   - `guild.json` configuration parsing (`reckoner.enforceRegistration`,
+ *     `reckoner.disabledSources`).
+ *   - `defaultPriority()` helper — fills omitted priority dimensions with
+ *     contract defaults.
+ *   - `reckoner.petition(request)` helper — validates source, fills defaults,
+ *     calls `clerk.post()` then `clerk.setWritExt()`, returns WritDoc.
+ *   - `reckoner.withdraw(writId, reason?)` helper — thin wrapper around
+ *     `clerk.transition(writId, 'cancelled', {resolution})`.
+ *
+ * The CDC handler that watches held writs and decides their fate is a
+ * separate commission.
+ *
+ * See: docs/architecture/petitioner-registration.md
+ */
+
+import type { Plugin, StartupContext, KitEntry } from '@shardworks/nexus-core';
+import { guild } from '@shardworks/nexus-core';
+import type { ClerkApi, WritDoc } from '@shardworks/clerk-apparatus';
+
+import {
+  defaultPriority,
+  type ComplexityTier,
+  type DomainTag,
+  type PetitionRequest,
+  type PetitionerDescriptor,
+  type Priority,
+  type ReckonerApi,
+  type ReckonerConfig,
+  type ReckonerExt,
+} from './types.ts';
+
+// ── Constants ──────────────────────────────────────────────────────────
+
+/** Plugin id stamped on `writ.ext['reckoner']`. Matches the apparatus id. */
+export const RECKONER_PLUGIN_ID = 'reckoner';
+
+// ── Validation helpers ─────────────────────────────────────────────────
+
+/**
+ * Kebab-suffix grammar: lowercase letters, digits, and hyphens; must not
+ * start or end with a hyphen; must have at least one character.
+ *
+ * Matches Lattice trigger-types and Clerk link-kinds.
+ */
+const SOURCE_SUFFIX_RE = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
+
+/**
+ * Valid values for each Priority dimension. Used by `validatePriority` to
+ * detect mis-typed dimension values at petition() call time rather than
+ * letting them land silently in the writs book.
+ */
+const VALID_VISION_RELATIONS = new Set<string>([
+  'vision-blocker', 'vision-violator', 'vision-advancer', 'vision-neutral',
+]);
+const VALID_SEVERITIES = new Set<string>([
+  'critical', 'serious', 'moderate', 'minor',
+]);
+const VALID_SCOPES = new Set<string>([
+  'whole-product', 'major-area', 'minor-area',
+]);
+const VALID_DOMAIN_TAGS = new Set<string>([
+  'security', 'compliance', 'cost', 'feature', 'quality',
+  'infrastructure', 'documentation', 'research', 'ergonomics',
+]);
+const VALID_COMPLEXITY_TIERS = new Set<string>([
+  'mechanical', 'bounded', 'exploratory', 'open-ended',
+]);
+
+/**
+ * Validate a fully-populated `Priority` object against the schema.
+ * Throws with a descriptive message when any dimension value is not in its
+ * allowed set. Called by `petition()` after defaults have been applied.
+ */
+function validatePriority(priority: Priority): void {
+  if (!VALID_VISION_RELATIONS.has(priority.visionRelation)) {
+    throw new Error(
+      `[reckoner] petition: invalid priority.visionRelation "${priority.visionRelation}". ` +
+      `Allowed: ${[...VALID_VISION_RELATIONS].join(', ')}.`,
+    );
+  }
+  if (!VALID_SEVERITIES.has(priority.severity)) {
+    throw new Error(
+      `[reckoner] petition: invalid priority.severity "${priority.severity}". ` +
+      `Allowed: ${[...VALID_SEVERITIES].join(', ')}.`,
+    );
+  }
+  if (!VALID_SCOPES.has(priority.scope)) {
+    throw new Error(
+      `[reckoner] petition: invalid priority.scope "${priority.scope}". ` +
+      `Allowed: ${[...VALID_SCOPES].join(', ')}.`,
+    );
+  }
+  if (typeof priority.time.decay !== 'boolean') {
+    throw new Error(
+      `[reckoner] petition: priority.time.decay must be a boolean, got ${typeof priority.time.decay}.`,
+    );
+  }
+  if (priority.time.deadline !== null && typeof priority.time.deadline !== 'string') {
+    throw new Error(
+      `[reckoner] petition: priority.time.deadline must be a string or null.`,
+    );
+  }
+  for (const tag of priority.domain) {
+    if (!VALID_DOMAIN_TAGS.has(tag)) {
+      throw new Error(
+        `[reckoner] petition: invalid priority.domain tag "${tag}". ` +
+        `Allowed: ${[...VALID_DOMAIN_TAGS].join(', ')}.`,
+      );
+    }
+  }
+}
+
+/**
+ * Validate a source id against the `{pluginId}.{kebab-suffix}` grammar.
+ *
+ * @param pluginId - The contributing plugin id (prefix must match).
+ *   Pass an empty string to skip the prefix check (e.g. in unit tests
+ *   running without a real guild context).
+ * @param source   - The source id to validate.
+ *
+ * Throws with a descriptive message on any grammar violation.
+ */
+function validateSourceIdGrammar(pluginId: string, source: string): void {
+  const dotIdx = source.indexOf('.');
+  if (dotIdx <= 0 || dotIdx === source.length - 1) {
+    throw new Error(
+      `[reckoner] kit "${pluginId}" petitioners: source "${source}" must be of the form ` +
+      `"{pluginId}.{kebab-suffix}" — a non-empty prefix, a literal ".", and a non-empty kebab-case suffix.`,
+    );
+  }
+  const prefix = source.slice(0, dotIdx);
+  const suffix = source.slice(dotIdx + 1);
+
+  // Validate the prefix matches the contributing plugin id (where derivable).
+  if (pluginId.length > 0 && prefix !== pluginId) {
+    throw new Error(
+      `[reckoner] kit "${pluginId}" petitioners: source "${source}" has prefix "${prefix}" ` +
+      `but must match the contributing plugin id "${pluginId}".`,
+    );
+  }
+
+  // Validate the suffix is kebab-case. Reject any character outside the
+  // allowed set and any leading/trailing hyphens or consecutive hyphens.
+  if (!SOURCE_SUFFIX_RE.test(suffix)) {
+    throw new Error(
+      `[reckoner] kit "${pluginId}" petitioners: source "${source}" suffix "${suffix}" ` +
+      `must be kebab-case (lowercase letters and digits, single-hyphen separators, ` +
+      `not starting or ending with "-").`,
+    );
+  }
+}
+
+// ── Kit contribution processor ─────────────────────────────────────────
+
+/**
+ * Internal tracked entry per registered petitioner source.
+ */
+interface PetitionerEntry extends PetitionerDescriptor {
+  /** Plugin id that contributed this entry — used in collision errors. */
+  pluginId: string;
+}
+
+/**
+ * Process one `petitioners` KitEntry and populate `registry`.
+ *
+ * Validates every entry in the array for shape correctness, source-id
+ * grammar, and plugin-id prefix match. Detects duplicate source ids and
+ * throws naming both contributing plugin ids — mirrors the framework-wide
+ * collision policy applied to writ-types, rig-template-mappings, and engine
+ * designs.
+ *
+ * Throws on any validation failure (hard startup error).
+ */
+function processKitPetitioners(
+  kitEntry: KitEntry,
+  registry: Map<string, PetitionerEntry>,
+): void {
+  const pluginId = kitEntry.pluginId;
+  const raw = kitEntry.value;
+
+  if (!Array.isArray(raw)) {
+    throw new Error(
+      `[reckoner] kit "${pluginId}" petitioners: expected an array, got ${typeof raw}.`,
+    );
+  }
+
+  for (const item of raw) {
+    if (typeof item !== 'object' || item === null) {
+      throw new Error(
+        `[reckoner] kit "${pluginId}" petitioners: entry is not an object ` +
+        `(got ${item === null ? 'null' : typeof item}).`,
+      );
+    }
+    const rec = item as Record<string, unknown>;
+
+    const source = rec.source;
+    const description = rec.description;
+
+    if (typeof source !== 'string' || source.length === 0) {
+      throw new Error(
+        `[reckoner] kit "${pluginId}" petitioners: entry is missing a non-empty string "source" field.`,
+      );
+    }
+    if (typeof description !== 'string' || description.length === 0) {
+      throw new Error(
+        `[reckoner] kit "${pluginId}" petitioners: entry "${source}" is missing a non-empty string "description" field.`,
+      );
+    }
+
+    // Validate source-id grammar (hard startup error on malformed id).
+    validateSourceIdGrammar(pluginId, source);
+
+    // Collision check — duplicate source ids name both contributors.
+    const existing = registry.get(source);
+    if (existing) {
+      throw new Error(
+        `[reckoner] Duplicate petitioner source "${source}" — contributed by both ` +
+        `"${existing.pluginId}" and "${pluginId}". Each source id must be unique across all kits.`,
+      );
+    }
+
+    registry.set(source, { source, description, pluginId });
+  }
+}
+
+// ── Config resolver ────────────────────────────────────────────────────
+
+/**
+ * Normalised Reckoner config with all defaults applied.
+ * Resolved fresh on each operation so in-process config updates are visible
+ * without requiring a restart.
+ */
+interface NormalisedReckonerConfig {
+  enforceRegistration: boolean;
+  disabledSources: Set<string>;
+}
+
+function resolveConfig(): NormalisedReckonerConfig {
+  const raw: ReckonerConfig = guild().config<ReckonerConfig>('reckoner');
+  return {
+    enforceRegistration: raw.enforceRegistration ?? false,
+    disabledSources: new Set(raw.disabledSources ?? []),
+  };
+}
+
+// ── Plugin factory ─────────────────────────────────────────────────────
+
+/**
+ * Inspect a registered petitioner's descriptor.
+ */
+export interface PetitionerInfo extends PetitionerDescriptor {
+  /** Plugin id that contributed this petitioner. */
+  pluginId: string;
+}
+
+/**
+ * Extended Reckoner API including registry-inspection helpers used by tests
+ * and the upcoming CDC-handler commission.
+ *
+ * The `ReckonerApi` export in `types.ts` is the narrow public surface
+ * (petition + withdraw). This internal extension adds registry access.
+ */
+export interface ReckonerInternalApi extends ReckonerApi {
+  /**
+   * Return a snapshot of all registered petitioner descriptors.
+   * Empty before `start()` completes; sealed at `phase:started`.
+   */
+  listPetitioners(): PetitionerInfo[];
+
+  /**
+   * Return `true` when a source id is present in the registry.
+   * Useful for the CDC-handler commission's source-validation step.
+   */
+  isRegistered(source: string): boolean;
+}
+
+export function createReckoner(): Plugin {
+  // ── Registry ───────────────────────────────────────────────────────
+  //
+  // Kit-static: populated during start() from ctx.kits('petitioners'),
+  // sealed at `phase:started`. After sealing, the map is read-only.
+
+  const petitionerRegistry = new Map<string, PetitionerEntry>();
+  let registrySealed = false;
+
+  // ── API ────────────────────────────────────────────────────────────
+
+  const api: ReckonerInternalApi = {
+    // ── petition() ──────────────────────────────────────────────────
+
+    async petition(request: PetitionRequest): Promise<WritDoc> {
+      const config = resolveConfig();
+
+      // 1. Source check against the registry.
+      const isRegistered = petitionerRegistry.has(request.source);
+      if (!isRegistered) {
+        if (config.enforceRegistration) {
+          throw new Error(
+            `[reckoner] petition: source "${request.source}" is not registered in the petitioner registry. ` +
+            `enforceRegistration is on — unregistered sources are declined. ` +
+            `Declare the source in your kit's "petitioners" contribution before petitioning.`,
+          );
+        }
+        // enforceRegistration is off — warn and proceed.
+        console.warn(
+          `[reckoner] petition: source "${request.source}" is not in the petitioner registry ` +
+          `(enforceRegistration is off). Proceeding with writ creation.`,
+        );
+      }
+
+      // 2. Apply priority defaults for omitted dimensions.
+      const priority: Priority = defaultPriority(request.priority);
+
+      // 3. Validate dimension values against schema.
+      validatePriority(priority);
+
+      // 4. Validate complexity if supplied.
+      if (request.complexity !== undefined && !VALID_COMPLEXITY_TIERS.has(request.complexity)) {
+        throw new Error(
+          `[reckoner] petition: invalid complexity "${request.complexity}". ` +
+          `Allowed: ${[...VALID_COMPLEXITY_TIERS].join(', ')}.`,
+        );
+      }
+
+      // 5. Post the writ via Clerk.
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+      const writ = await clerk.post({
+        type: request.type,
+        title: request.title,
+        body: request.body,
+        codex: request.codex,
+        ...(request.parentId !== undefined ? { parentId: request.parentId } : {}),
+      });
+
+      // 6. Write ext.reckoner via the dedicated setter (transactional
+      //    read-modify-write — preserves sibling sub-slots).
+      const ext: ReckonerExt = {
+        source: request.source,
+        priority,
+        ...(request.complexity !== undefined ? { complexity: request.complexity } : {}),
+        ...(request.payload !== undefined ? { payload: request.payload } : {}),
+        ...(request.labels !== undefined ? { labels: request.labels } : {}),
+      };
+      const updated = await clerk.setWritExt(writ.id, RECKONER_PLUGIN_ID, ext);
+      return updated;
+    },
+
+    // ── withdraw() ──────────────────────────────────────────────────
+
+    async withdraw(writId: string, reason?: string): Promise<WritDoc> {
+      const clerk = guild().apparatus<ClerkApi>('clerk');
+      return clerk.transition(
+        writId,
+        'cancelled',
+        reason !== undefined ? { resolution: reason } : {},
+      );
+    },
+
+    // ── Registry introspection ───────────────────────────────────────
+
+    listPetitioners(): PetitionerInfo[] {
+      return [...petitionerRegistry.values()].map((e) => ({
+        source: e.source,
+        description: e.description,
+        pluginId: e.pluginId,
+      }));
+    },
+
+    isRegistered(source: string): boolean {
+      return petitionerRegistry.has(source);
+    },
+  };
+
+  // ── Plugin export ─────────────────────────────────────────────────
+
+  return {
+    apparatus: {
+      // Clerk is a hard dependency — petition() and withdraw() both call
+      // into ClerkApi. Stacks is not required by this commission; the CDC
+      // handler commission (which watches held writs) adds its own watcher.
+      requires: ['clerk'],
+      consumes: ['petitioners'],
+
+      provides: api,
+
+      async start(ctx: StartupContext): Promise<void> {
+        // ── Process kit petitioners ──────────────────────────────────
+        //
+        // Consume every `petitioners` contribution collected during the
+        // Wire phase. Duplicate or malformed entries throw here, blocking
+        // guild startup with a diagnostic message.
+        for (const entry of ctx.kits('petitioners')) {
+          processKitPetitioners(entry, petitionerRegistry);
+        }
+
+        // ── Seal registry at phase:started ───────────────────────────
+        //
+        // Per-plugin-load-cycle framing: seal fires once, after every
+        // apparatus's start() has completed. Kit contributions are
+        // Wire-phase-only, so nothing can be added after this point.
+        ctx.on('phase:started', () => {
+          registrySealed = true;
+        });
+      },
+    },
+  };
+}
+
