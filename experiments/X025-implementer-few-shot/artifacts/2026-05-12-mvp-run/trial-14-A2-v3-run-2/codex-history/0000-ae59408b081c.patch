+/**
+ * Reckoner apparatus — unit tests.
+ *
+ * Covers all behavioral cases from the commission spec:
+ *
+ *   Registry:
+ *   - Duplicate source → hard startup error naming both plugin ids.
+ *   - Malformed source id → hard startup error with grammar details.
+ *   - Source prefix mismatch → hard startup error.
+ *   - Valid registration → petitioner listed post-start.
+ *   - Registry sealed at phase:started.
+ *
+ *   petition():
+ *   - enforceRegistration: false (default) + unregistered source → warn,
+ *     writ created.
+ *   - enforceRegistration: true + unregistered source → throws, no writ.
+ *   - Partial priority → defaults applied for omitted dimensions.
+ *   - Full priority supplied → used as-is.
+ *   - Invalid priority dimension value → throws.
+ *   - Invalid complexity tier → throws.
+ *   - Resulting writ has phase 'new' and ext['reckoner'] populated.
+ *   - complexity, payload, labels are included in ext when supplied.
+ *   - complexity, payload, labels are absent from ext when not supplied.
+ *
+ *   withdraw():
+ *   - Transitions writ to 'cancelled' with the supplied reason.
+ *   - Works without a reason (no resolution set).
+ */
+
+import { describe, it, beforeEach, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild, generateId } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritDoc } from '@shardworks/clerk-apparatus';
+
+import { createReckoner, RECKONER_PLUGIN_ID } from './reckoner.ts';
+import { defaultPriority, DEFAULT_PRIORITY } from './types.ts';
+import type { ReckonerApi, ReckonerConfig, ReckonerExt } from './types.ts';
+
+// ── Test infrastructure ─────────────────────────────────────────────────
+
+const FRAMEWORK_KIT_FIELDS = new Set(['requires', 'recommends']);
+
+function buildKitEntries(kits: LoadedKit[]): KitEntry[] {
+  const entries: KitEntry[] = [];
+  for (const kit of kits) {
+    for (const [type, value] of Object.entries(kit.kit)) {
+      if (FRAMEWORK_KIT_FIELDS.has(type)) continue;
+      entries.push({ pluginId: kit.id, packageName: kit.packageName, type, value });
+    }
+  }
+  return entries;
+}
+
+/** Build a StartupContext that captures on() handlers and can fire them. */
+function buildCtx(entries: KitEntry[] = []): {
+  ctx: StartupContext;
+  fire(event: string): void;
+} {
+  const handlers = new Map<string, Array<() => void | Promise<void>>>();
+  const ctx: StartupContext = {
+    on(event: string, handler: (...args: unknown[]) => void | Promise<void>): void {
+      const list = handlers.get(event) ?? [];
+      list.push(handler as () => void | Promise<void>);
+      handlers.set(event, list);
+    },
+    kits(type: string): KitEntry[] {
+      return [...entries.filter((e) => e.type === type)];
+    },
+  };
+  function fire(event: string): void {
+    for (const handler of handlers.get(event) ?? []) {
+      handler();
+    }
+  }
+  return { ctx, fire };
+}
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+}
+
+async function buildFixture(options: {
+  kitEntries?: KitEntry[];
+  reckonerConfig?: ReckonerConfig;
+} = {}): Promise<Fixture> {
+  const backend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(backend);
+  const clerkPlugin = createClerk();
+  const reckonerPlugin = createReckoner();
+
+  if (!('apparatus' in stacksPlugin)) throw new Error('stacks must be apparatus');
+  if (!('apparatus' in clerkPlugin)) throw new Error('clerk must be apparatus');
+  if (!('apparatus' in reckonerPlugin)) throw new Error('reckoner must be apparatus');
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const reckonerConfigSection = options.reckonerConfig ?? {};
+  const guildConfig: GuildConfig = {
+    name: 'test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    reckoner: reckonerConfigSection,
+  };
+
+  const fakeGuild: Guild = {
+    home: '/tmp/test-guild',
+    apparatus<T>(name: string): T {
+      const api = apparatusMap.get(name);
+      if (!api) throw new Error(`Apparatus "${name}" not installed`);
+      return api as T;
+    },
+    config<T>(pluginId: string): T {
+      return ((guildConfig as unknown as Record<string, unknown>)[pluginId] ?? {}) as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return guildConfig;
+    },
+    kits(): LoadedKit[] { return []; },
+    apparatuses(): LoadedApparatus[] { return []; },
+    failedPlugins() { return []; },
+    startupWarnings() { return []; },
+  };
+
+  setGuild(fakeGuild);
+
+  // Ensure the books exist.
+  backend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    { indexes: ['phase', 'type', 'createdAt', 'parentId'] },
+  );
+  backend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    { indexes: ['sourceId', 'targetId'] },
+  );
+
+  // Start stacks
+  const { ctx: stacksCtx } = buildCtx();
+  stacksPlugin.apparatus.start(stacksCtx);
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // Start clerk
+  const { ctx: clerkCtx } = buildCtx();
+  await clerkPlugin.apparatus.start(clerkCtx);
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  // Start reckoner with kit entries
+  const { ctx: reckonerCtx, fire } = buildCtx(options.kitEntries ?? []);
+  await reckonerPlugin.apparatus.start(reckonerCtx);
+  fire('phase:started');
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  return { stacks, clerk, reckoner };
+}
+
+/**
+ * Build kit entries from a raw petitioners array contributed by a named plugin.
+ */
+function petitionerEntry(
+  pluginId: string,
+  petitioners: Array<{ source: string; description: string }>,
+): KitEntry {
+  return {
+    pluginId,
+    packageName: `@test/${pluginId}`,
+    type: 'petitioners',
+    value: petitioners,
+  };
+}
+
+// ── defaultPriority() helper tests ──────────────────────────────────────
+
+describe('defaultPriority()', () => {
+  it('returns all defaults when called with no argument', () => {
+    const p = defaultPriority();
+    assert.equal(p.visionRelation, 'vision-neutral');
+    assert.equal(p.severity, 'minor');
+    assert.equal(p.scope, 'minor-area');
+    assert.equal(p.time.decay, false);
+    assert.equal(p.time.deadline, null);
+    assert.deepEqual(p.domain, []);
+  });
+
+  it('returns all defaults when called with an empty partial', () => {
+    const p = defaultPriority({});
+    assert.equal(p.visionRelation, DEFAULT_PRIORITY.visionRelation);
+    assert.equal(p.severity, DEFAULT_PRIORITY.severity);
+    assert.equal(p.scope, DEFAULT_PRIORITY.scope);
+    assert.equal(p.time.decay, DEFAULT_PRIORITY.time.decay);
+    assert.equal(p.time.deadline, DEFAULT_PRIORITY.time.deadline);
+    assert.deepEqual(p.domain, []);
+  });
+
+  it('preserves supplied values and fills defaults for the rest', () => {
+    const p = defaultPriority({ visionRelation: 'vision-violator', severity: 'serious' });
+    assert.equal(p.visionRelation, 'vision-violator');
+    assert.equal(p.severity, 'serious');
+    assert.equal(p.scope, 'minor-area'); // default
+    assert.equal(p.time.decay, false);   // default
+  });
+
+  it('returns a fully-specified priority unchanged', () => {
+    const full = {
+      visionRelation: 'vision-blocker' as const,
+      severity: 'critical' as const,
+      scope: 'whole-product' as const,
+      time: { decay: true, deadline: '2026-06-01' },
+      domain: ['security' as const],
+    };
+    const p = defaultPriority(full);
+    assert.deepEqual(p, full);
+  });
+});
+
+// ── Registry — source id grammar validation ─────────────────────────────
+
+describe('Reckoner registry — source id grammar', () => {
+  afterEach(() => clearGuild());
+
+  it('accepts a well-formed source id matching the contributing plugin id', async () => {
+    const reckonerPlugin = createReckoner();
+    if (!('apparatus' in reckonerPlugin)) throw new Error('not apparatus');
+
+    // minimal guild needed for start()
+    const backend = new MemoryBackend();
+    const stacksPlugin = createStacksApparatus(backend);
+    const clerkPlugin = createClerk();
+    if (!('apparatus' in stacksPlugin)) throw new Error();
+    if (!('apparatus' in clerkPlugin)) throw new Error();
+    const apparatusMap = new Map<string, unknown>();
+    setGuild({
+      home: '/tmp/t',
+      apparatus<T>(n: string): T { return apparatusMap.get(n) as T; },
+      config<T>(): T { return {} as T; },
+      writeConfig() {},
+      guildConfig(): GuildConfig { return { name: 't', nexus: '0', plugins: [] }; },
+      kits() { return []; },
+      apparatuses() { return []; },
+      failedPlugins() { return []; },
+      startupWarnings() { return []; },
+    });
+    backend.ensureBook({ ownerId: 'clerk', book: 'writs' }, { indexes: ['phase', 'type', 'createdAt', 'parentId'] });
+    backend.ensureBook({ ownerId: 'clerk', book: 'links' }, { indexes: ['sourceId', 'targetId'] });
+    stacksPlugin.apparatus.start(buildCtx().ctx);
+    const stacks = stacksPlugin.apparatus.provides;
+    apparatusMap.set('stacks', stacks);
+    await clerkPlugin.apparatus.start(buildCtx().ctx);
+    apparatusMap.set('clerk', clerkPlugin.apparatus.provides);
+
+    const entry = petitionerEntry('vision-keeper', [
+      { source: 'vision-keeper.snapshot', description: 'test' },
+    ]);
+    const { ctx } = buildCtx([entry]);
+    // Should not throw
+    await reckonerPlugin.apparatus.start(ctx);
+  });
+
+  it('rejects a source id with no dot separator', async () => {
+    const reckonerPlugin = createReckoner();
+    if (!('apparatus' in reckonerPlugin)) throw new Error('not apparatus');
+
+    // Build a minimal fixture context for start() without kit entries.
+    const fix = await buildFixture();
+    // buildFixture already cleared the guild — set up fresh
+    clearGuild();
+    const entry = petitionerEntry('my-plugin', [
+      { source: 'nodot', description: 'bad' },
+    ]);
+    const reckonerPlugin2 = createReckoner();
+    if (!('apparatus' in reckonerPlugin2)) throw new Error();
+
+    // We need a guild to be set for start() to call guild().apparatus().
+    // Reuse a fresh minimal setup.
+    const backend = new MemoryBackend();
+    const stacksPlugin = createStacksApparatus(backend);
+    const clerkPlugin = createClerk();
+    if (!('apparatus' in stacksPlugin)) throw new Error();
+    if (!('apparatus' in clerkPlugin)) throw new Error();
+    const am = new Map<string, unknown>();
+    setGuild({
+      home: '/tmp/t2',
+      apparatus<T>(n: string): T { return am.get(n) as T; },
+      config<T>(): T { return {} as T; },
+      writeConfig() {},
+      guildConfig(): GuildConfig { return { name: 't', nexus: '0', plugins: [] }; },
+      kits() { return []; },
+      apparatuses() { return []; },
+      failedPlugins() { return []; },
+      startupWarnings() { return []; },
+    });
+    backend.ensureBook({ ownerId: 'clerk', book: 'writs' }, { indexes: ['phase', 'type', 'createdAt', 'parentId'] });
+    backend.ensureBook({ ownerId: 'clerk', book: 'links' }, { indexes: ['sourceId', 'targetId'] });
+    stacksPlugin.apparatus.start(buildCtx().ctx);
+    am.set('stacks', stacksPlugin.apparatus.provides);
+    await clerkPlugin.apparatus.start(buildCtx().ctx);
+    am.set('clerk', clerkPlugin.apparatus.provides);
+
+    const { ctx } = buildCtx([entry]);
+    await assert.rejects(
+      () => reckonerPlugin2.apparatus.start(ctx),
+      /must be of the form.*{pluginId}.*{kebab-suffix}/,
+    );
+  });
+
+  it('rejects a source id with an invalid suffix character', async () => {
+    const entry = petitionerEntry('my-plugin', [
+      { source: 'my-plugin.bad!suffix', description: 'bad' },
+    ]);
+    const reckonerPlugin = createReckoner();
+    if (!('apparatus' in reckonerPlugin)) throw new Error();
+    clearGuild();
+    const backend = new MemoryBackend();
+    const stacksPlugin = createStacksApparatus(backend);
+    const clerkPlugin = createClerk();
+    if (!('apparatus' in stacksPlugin)) throw new Error();
+    if (!('apparatus' in clerkPlugin)) throw new Error();
+    const am = new Map<string, unknown>();
+    setGuild({
+      home: '/tmp/t3',
+      apparatus<T>(n: string): T { return am.get(n) as T; },
+      config<T>(): T { return {} as T; },
+      writeConfig() {},
+      guildConfig(): GuildConfig { return { name: 't', nexus: '0', plugins: [] }; },
+      kits() { return []; },
+      apparatuses() { return []; },
+      failedPlugins() { return []; },
+      startupWarnings() { return []; },
+    });
+    backend.ensureBook({ ownerId: 'clerk', book: 'writs' }, { indexes: ['phase', 'type', 'createdAt', 'parentId'] });
+    backend.ensureBook({ ownerId: 'clerk', book: 'links' }, { indexes: ['sourceId', 'targetId'] });
+    stacksPlugin.apparatus.start(buildCtx().ctx);
+    am.set('stacks', stacksPlugin.apparatus.provides);
+    await clerkPlugin.apparatus.start(buildCtx().ctx);
+    am.set('clerk', clerkPlugin.apparatus.provides);
+
