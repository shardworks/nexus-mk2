+  // Sample now once at handler entry (D17 carry-over from the registry
+  // commission). The same Date is reused for every row id and
+  // `consideredAt` produced by this tick.
+  const now = new Date();
+  const tickEventId = event?.id;
+
+  // 2. Re-read + validate scheduler config. validateConfig throw =
+  //    fail-loud-skip the entire tick (no rows, no transitions).
