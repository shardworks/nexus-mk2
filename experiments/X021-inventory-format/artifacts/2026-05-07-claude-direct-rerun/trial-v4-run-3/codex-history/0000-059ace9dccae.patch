+++ b/packages/plugins/reckoner/src/reckoner-tick.test.ts
@@ -0,0 +1,710 @@
+/**
+ * Reckoner tick handler tests.
+ *
+ * Covers the behavioral matrix the originating brief enumerates,
+ * driven through the test-only `hooks.runTick(event?)` entry point:
+ *
+ *   1. empty-candidate ticks — no rows, no errors.
+ *   2. first tick after start picks up pre-existing held writs.
+ *   3. evaluate-throw isolation — the apparatus stays up; no rows
+ *      are written for any writ in the offending tick.
+ *   4. disabled-source mid-flight produces a `'declined'` row with
+ *      `declineReason: 'source_banned'` and the source name in
+ *      `remediationHint`, plus a transition to cancelled.
+ *   5. repeated-tick idempotency — re-running the tick at unchanged
+ *      `(writId, writUpdatedAt)` produces no second row.
+ *   6. type-aware target-phase resolution — the tick uses the writ-
+ *      type config to pick the active target. Tested with `mandate`
+ *      (target `'open'`) and a non-mandate type whose active state
+ *      is named differently.
+ *   7. withdrawal-mid-flight — a petitioner-initiated cancellation
+ *      drops the writ from the candidate set; no row.
+ *   8. defer outcome writes a `'deferred'` row with
+ *      `deferReason: 'other'` and the decision reason in `deferNote`,
+ *      and does not transition the writ.
+ *   9. pre-seal tick throws fail-loud (D8).
+ *
+ * The fixture mirrors the scaffolding in `reckoner.test.ts`: real
+ * Stacks + Clerk + Reckoner against MemoryBackend, with explicit
+ * book pre-creation. The tick relay is invoked directly via
+ * `hooks.runTick` so the assertions do not depend on a Clockworks
+ * daemon firing the standing order on the wall clock.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /**
+   * Re-fire `phase:started` against the registered handlers. The
+   * Reckoner's seal handler resolves the active scheduler.
+   */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  /**
+   * Additional `schedulers` kit contributions visible to the
+   * Reckoner's `start()`, on top of the built-in
+   * `reckoner.always-approve` instance the apparatus contributes.
+   */
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  config?: ReckonerConfig | undefined;
+  /** Optional writ types to register on the Clerk before start. */
+  writTypes?: WritTypeConfig[];
+  /**
+   * When set, callers can pre-seed writs into the writs book before
+   * the Reckoner's `start()` runs — used to exercise the
+   * "first tick picks up pre-existing writs" behavior.
+   */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+  /** When true, do not fire phase:started after start (pre-seal tests). */
+  skipPhaseStarted?: boolean;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the Clerk needs — Stacks' Wire phase would do
+  // this in production from the supportKit declarations.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  // Pre-create the Reckoner's reckonings book with the contract index
+  // set so the dedupe lookup hits indexed columns.
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  // Build a phase-started capable StartupContext per apparatus.
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler) {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  // ── Stacks ────────────────────────────────────────────────────────
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // ── Clerk ─────────────────────────────────────────────────────────
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  // Optional writ-type registration before the Reckoner starts so the
+  // type config is visible during the first tick.
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  // Optional pre-start seed (first-tick-picks-up-pre-existing-writ tests).
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  // ── Reckoner ──────────────────────────────────────────────────────
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  // Surface the Reckoner's own supportKit `schedulers` contribution
+  // (the built-in always-approve instance) plus any test-supplied
+  // schedulers.
+  const schedulerKitEntries: KitEntry[] = [
+    {
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    },
+    ...(opts.schedulerKits ?? []).map((entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    })),
+  ];
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+/**
+ * Compose a fully-typed scheduler instance from a partial; the
+ * non-overridden fields default to the always-approve shape so each
+ * test can replace exactly the surface it cares about.
+ */
+function makeScheduler(partial: Partial<Scheduler> & Pick<Scheduler, 'id'>): Scheduler {
+  return {
+    description: 'test scheduler',
+    async evaluate(): Promise<readonly SchedulerDecision[]> {
+      return [];
+    },
+    ...partial,
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+/** Minimal synthetic `clockworks.timer` event for tick-driven tests. */
+function makeTickEvent(id: string = 'e-test-tick'): GuildEvent {
+  return {
+    id,
+    name: 'clockworks.timer',
+    payload: {},
+    emitter: 'clockworks',
+    firedAt: new Date().toISOString(),
+  };
+}
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => clearGuild());
+
+  // ── 1: empty-candidate tick ──────────────────────────────────────
+
+  describe('empty-candidate tick', () => {
+    it('writes no rows and does not throw when no held writs exist', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+
+      // No petition has been posted; the tick reads zero candidates.
+      await fix.hooks.runTick(makeTickEvent());
+
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0, 'empty candidate set produces no rows');
+    });
+  });
+
+  // ── 2: first tick picks up pre-existing held writs ───────────────
+
+  describe('first tick after start', () => {
+    it('processes held writs that pre-date apparatus startup', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        async preStart({ clerk }) {
+          // Seed a held writ before the Reckoner starts.  Without a
+          // CDC handler the writ sits in `new` until the first tick
+          // runs.
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'tester.kind',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Pre-tick: writ remains held — no CDC runs evaluation now.
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      const writ = all[0]!;
+      assert.equal(writ.phase, 'new', 'pre-tick writ stays in new');
+
+      const tickId = 'e-first-tick';
+      await fix.hooks.runTick(makeTickEvent(tickId));
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open', 'first tick auto-approves the writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+      assert.equal(rows[0]!.tickEventId, tickId);
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ─────────────────────────────────
+
+  describe('evaluate-throw isolation', () => {
+    it('logs fail-loud and skips the entire tick — no rows, no transitions', async () => {
+      const scheduler: Scheduler = makeScheduler({
+        id: 'kit-a.bad-evaluate',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      });
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-evaluate' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick(makeTickEvent());
+      } finally {
+        console.warn = originalWarn;
+      }
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'writ untouched after evaluate throw');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0, 'no row written when evaluate throws');
+      assert.ok(
+        warnings.some((w) => /\[reckoner\] tick:/.test(w) && /evaluate threw/.test(w)),
+        `expected fail-loud log line; got: ${JSON.stringify(warnings)}`,
+      );
+    });
+  });
+
+  // ── 4: disabled-source mid-flight ───────────────────────────────
+
+  describe('disabled-source mid-flight', () => {
+    it('declines + cancels with declineReason: source_banned and source name in remediationHint', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        config: { disabledSources: ['tester.kind'] },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      // Suppress the tick's expected gate warnings (none expected
+      // for the happy path here, but keep the surface clean).
+      const originalWarn = console.warn;
+      console.warn = () => {};
+      try {
+        await fix.hooks.runTick(makeTickEvent());
+      } finally {
+        console.warn = originalWarn;
+      }
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'tester\.kind' is in reckoner\.disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'tester.kind');
+    });
+  });
+
+  // ── 5: repeated-tick idempotency ────────────────────────────────
+
+  describe('repeated-tick idempotency', () => {
+    it('no second row when the same (writId, writUpdatedAt) is re-considered', async () => {
+      // A scheduler that defers — the writ stays in `new` after
+      // tick 1 with one deferred row.  The tick's pre-evaluation
+      // dedupe lookup must filter this writ out of tick 2's
+      // candidate set so no second row is written.
+      const scheduler: Scheduler = makeScheduler({
+        id: 'kit-a.defer',
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          return input.candidates.map((w) => ({
+            writId: w.id,
+            outcome: 'defer' as const,
+            reason: 'capacity hold',
+          }));
+        },
+      });
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.defer' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      await fix.hooks.runTick(makeTickEvent('e-tick-1'));
+      const rowsAfter1 = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rowsAfter1.length, 1, 'first tick writes one deferred row');
+      assert.equal(rowsAfter1[0]!.outcome, 'deferred');
+
+      await fix.hooks.runTick(makeTickEvent('e-tick-2'));
+      const rowsAfter2 = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(
+        rowsAfter2.length,
+        1,
+        'second tick at unchanged writUpdatedAt writes no second row',
+      );
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'defer leaves writ in new');
+    });
+  });
+
+  // ── 6: type-aware target-phase resolution ────────────────────────
+
+  describe('target-phase resolution', () => {
+    it('picks `open` for mandate writs', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+      });
+
+      const writ = await fix.reckoner.petition({
