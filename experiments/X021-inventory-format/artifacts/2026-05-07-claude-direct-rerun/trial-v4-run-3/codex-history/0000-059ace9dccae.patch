+  }
+
+  // 7. Build SchedulerInput and call evaluate. Any throw fail-loud-
+  //    skips the entire tick (no rows for any writ in this fire).
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 8. Validate decisions. Filter-and-warn on stranger writIds (apply
+  //    only in-scope decisions); fail-loud-skip the whole tick on
+  //    multi-decision-per-writ (D9).
+  const candidateIds = new Set<string>(candidates.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any decision in this tick. Schedulers must emit at most one decision per candidate.`,
+      );
+      return;
+    }
+  }
+
+  // 9. Apply each decision. We iterate the candidate set so writs
+  //    without a decision are simply skipped (defer-equivalent —
+  //    no row, no transition).
+  for (const writ of candidates) {
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) continue;
+
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue; // defensive — gate ensured this above
+
+    if (
+      decision.outcome !== 'approve' &&
+      decision.outcome !== 'decline' &&
+      decision.outcome !== 'defer'
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+      );
+      continue;
+    }
+
+    if (decision.outcome === 'defer') {
+      // D3: defer rows mirror the decline-row shape, with deferReason
+      // 'other' + decision reason in deferNote. No transition.
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // approve.
+    let target: string;
+    try {
+      target = ctx.resolveActiveTargetPhase(writ);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+      );
+      continue;
+    }
+
+    try {
+      await ctx.clerk.transition(writ.id, target as WritPhase, {});
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+      );
+      continue;
+    }
+
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'accepted',
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+      );
+    }
+  }
+}
+
+/**
+ * Apply a gate-driven decline: idempotent dedupe lookup, transition
+ * to the writ's cancelled target, then write a Reckonings row. Used
+ * by both the disabled-source and the unregistered-strict gates.
+ *
+ * On dedupe hit, the function returns silently (no transition, no
+ * second row) so a tick that observes the same banned writ across
+ * fires writes one row total per `(writId, writUpdatedAt)`.
+ */
+async function applyDeclineGate(
+  ctx: TickContext,
+  params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    declineReason: NonNullable<ReckoningDoc['declineReason']>;
+    remediationHint: string;
+    resolution: string;
+    tickEventId?: string;
+  },
+): Promise<void> {
+  if (
+    await ctx.alreadyConsidered(
+      ctx.reckoningsBook,
+      params.writ.id,
+      params.writ.updatedAt,
+    )
+  ) {
+    return;
+  }
+  try {
+    await ctx.clerk.transition(
+      params.writ.id,
+      'cancelled' as WritPhase,
+      { resolution: params.resolution },
+    );
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${params.writ.id}" to cancelled (gate ${params.declineReason}): ${msg}`,
+    );
+    return;
+  }
+  const row = ctx.buildReckoningRow({
+    now: params.now,
+    writ: params.writ,
+    ext: params.ext,
+    outcome: 'declined',
+    declineReason: params.declineReason,
+    remediationHint: params.remediationHint,
+    ...(params.tickEventId !== undefined ? { tickEventId: params.tickEventId } : {}),
+  });
+  try {
+    await ctx.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${params.writ.id}" (gate ${params.declineReason}): ${msg}`,
+    );
+  }
+}
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. The factory takes a
+ * `() => TickContext` thunk so the apparatus's `start()` can wire
+ * the relay before the closure-scoped state (clerk, stacks,
+ * reckoningsBook, activeScheduler) has finished resolving — the
+ * thunk is only evaluated when the relay actually fires.
+ */
+export function createTickRelay(getCtx: () => TickContext): RelayDefinition {
+  return relay({
+    name: TICK_RELAY_NAME,
+    description:
+      'Periodic petition-evaluation tick. Reads every held writ ' +
+      'carrying ext.reckoner, applies source/disabled gates, then ' +
+      'runs the active scheduler against the surviving candidate set.',
+    handler: async (event, _context) => {
+      const ctx = getCtx();
+      await runTick(event, ctx);
+    },
+  });
+}
+
