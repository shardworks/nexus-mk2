+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // 3. Query held petitions through the same shape the registry
+  //    commission's catch-up scan used: a direct read of `clerk/writs`
+  //    filtered to `phase = 'new'` ordered by `createdAt asc`. The
+  //    explicit-phase query carries forward the apparatus's literal-
+  //    phase decision; the type-agnostic generalization is observed
+  //    and lifted as a separate concern.
+  const writsBook: ReadOnlyBook<WritDoc> = ctx.stacks.readBook<WritDoc>('clerk', 'writs');
