+/**
+ * `reckoner.tick` — periodic petition-evaluation relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` and triggered by the
+ * apparatus's own kit-contributed standing order at `@every 60s`. The
+ * tick is the **canonical and only** evaluation path — the Reckoner
+ * does not subscribe to CDC on `clerk/writs`. Each fire considers
+ * every currently-held petition through the configured scheduler in
+ * one batch.
+ *
+ * Per-fire sequence (the originating brief pins this exactly):
+ *
+ *   1. Resolve the apparatus-resolved active scheduler.
+ *      - Pre-seal (no scheduler resolved) is a fail-loud throw (D8);
+ *        production never trips it, tests get a deterministic signal.
+ *   2. Re-read `reckoner.schedulerConfig` from `guild.json` and run
+ *      the scheduler's optional `validateConfig` narrower. A throw
+ *      here is logged fail-loud and the tick is skipped (no rows).
+ *   3. Query held petitions — writs in `new` phase carrying
+ *      `ext.reckoner` — using the same shape today's catch-up scan
+ *      uses.
+ *   4. Apply source/disabled gates inline. A writ failing a gate
+ *      produces a `declined` row + a transition to its cancelled
+ *      target phase, and is removed from the candidate set:
+ *        - **Disabled-source** (D2): `declineReason: 'source_banned'`,
+ *          source name in `remediationHint`.
+ *        - **Unregistered + strict**: preserves the existing
+ *          `source_unregistered` reason and structured resolution
+ *          string the v0 path emitted.
+ *      Skip (no row, no transition) when ext is missing — the writ
+ *      is ineligible by gate, not refused.
+ *   5. Filter the surviving candidates against the `(writId,
+ *      writUpdatedAt)` dedupe lookup (D7). Already-considered writs
+ *      never reach the scheduler.
+ *   6. Empty-candidate early-return (D10): no rows, no errors, no
+ *      scheduler call.
+ *   7. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 capacity stub and call `evaluate` inside a
+ *      try/catch. A throw is logged and the entire tick is skipped
+ *      (no rows for any writ in this fire).
+ *   8. Validate decisions: filter-and-warn on stranger writIds (apply
+ *      only in-scope decisions); fail-loud-skip the **whole tick** on
+ *      any multi-decision-per-writ.
+ *   9. Apply each decision per outcome:
+ *        - `approve` → transition to active target via
+ *          `resolveActiveTargetPhase`; row carries `outcome: 'accepted'`.
+ *        - `decline` → transition to cancelled with the decision's
+ *          `reason` as resolution; row carries `outcome: 'declined'`,
+ *          `declineReason: 'other'`, reason in `remediationHint`.
+ *        - `defer` → no transition; row carries `outcome: 'deferred'`,
+ *          `deferReason: 'other'`, reason in `deferNote` (D3).
+ *      Each row stamps `tickEventId` from `event.id` when present
+ *      and omits it when absent (D6).
+ *
+ * The relay handler signature lives in
+ * `@shardworks/clockworks-apparatus`; the apparatus is a soft
+ * `recommends` of the Reckoner, so when Clockworks is not installed
+ * the kit-contributed relay simply never resolves and the tick never
+ * fires.
+ */
+
+import type { GuildEvent, RelayDefinition } from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+import type {
+  Book,
+  ReadOnlyBook,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/**
+ * Relay registration name. Dotted form (D1) — matches the apparatus's
+ * existing contributed-id grammar (scheduler ids, petitioner sources)
+ * and the originating brief's spelling verbatim.
+ */
+export const TICK_RELAY_NAME = 'reckoner.tick';
+
+/**
+ * Reckoner ext slot key. Mirrored locally rather than imported from
+ * `./reckoner.ts` to avoid a circular import — the constant is a
+ * single hardcoded literal (D11 in the registry commission); the
+ * apparatus and the tick share the same source-of-truth value.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * Dependency-injection context handed into the pure helper. The
+ * apparatus's `buildReckoner()` closure constructs one and passes it
+ * into the relay factory; unit tests construct a minimal one and
+ * drive the helper directly.
+ */
+export interface TickContext {
+  /** Clerk handle for `transition()` and writ-type lookup. */
+  clerk: ClerkApi;
+  /** Stacks handle for `readBook<WritDoc>('clerk', 'writs')`. */
+  stacks: StacksApi;
