+ */
+export interface BuildReckoningRowParams {
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  outcome: 'accepted' | 'declined' | 'deferred';
+  declineReason?: ReckoningDoc['declineReason'];
+  remediationHint?: string;
+  deferReason?: ReckoningDoc['deferReason'];
+  deferNote?: string;
+  weight?: number;
+  /**
+   * Triggering Clockworks event id stamped onto the resulting row
+   * when present. Omitted when the handler is driven directly with
+   * `null` (test-only `runTick` hook).
+   */
+  tickEventId?: string;
+}
+
+// ── Pure handler (testable without Clockworks) ──────────────────────
+
+/**
+ * The tick handler's pure body. Exported so unit tests can drive it
+ * with synthetic `GuildEvent`s (or `null`) against a hand-built
+ * `TickContext` without booting Clockworks's dispatcher / scheduler
+ * machinery.
+ *
+ * Throws when the active scheduler has not yet resolved (D8); every
+ * other failure mode (validateConfig throw, evaluate throw, multi-
+ * decision-per-writ) logs fail-loud and skips the tick without
+ * propagating the error to the dispatcher.
+ */
+export async function runTickWithContext(
+  event: GuildEvent | null,
+  ctx: TickContext,
+): Promise<void> {
+  const activeScheduler = ctx.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired',
+    );
+  }
+
+  // Sample `now` once per tick so every row produced by this fire
+  // shares one consideredAt moment.
+  const now = new Date();
+  const tickEventId = event?.id;
+
+  // Re-read + validate the scheduler config before paying the cost of
+  // the held-writ query. validateConfig throws fail-loud-skip the
+  // entire tick (D17) — no rows, no transitions.
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping this tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  const config = ctx.resolveConfig();
+
+  // Query held petitions. The query shape is the same one the prior
+  // catch-up scan used: `phase = 'new'` ordered by `createdAt` asc,
+  // then in-process-filtered to writs carrying the Reckoner ext slot
+  // and whose ext shape is at least minimally well-formed (non-empty
+  // source string). Iterating the writ-type registry for non-`new`
+  // initial phases is observed and lifted as a separate concern.
+  const writsBook: ReadOnlyBook<WritDoc> = ctx.stacks.readBook<WritDoc>(
+    'clerk',
+    'writs',
+  );
+  const heldRaw = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+
+  interface HeldEntry {
+    writ: WritDoc;
+    ext: ReckonerExt;
+  }
+  const held: HeldEntry[] = [];
+  for (const writ of heldRaw) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    held.push({ writ, ext });
+  }
+
+  // Empty candidate set after the initial query: D10's prescribed
+  // behavior — early-return without calling the scheduler. No rows,
+  // no errors.
+  if (held.length === 0) return;
+
+  // Apply source / disabled gates inline. Each gate-failing writ
+  // produces a decline row and skips the scheduler; surviving writs
+  // are passed to the dedupe stage.
+  interface CandidateEntry extends HeldEntry {
+    /** Whether this writ already has a row for its current writUpdatedAt. */
+    alreadyHasRow: boolean;
+  }
+  const surviving: CandidateEntry[] = [];
+
+  for (const entry of held) {
+    const { writ, ext } = entry;
+
+    // Disabled-source gate (D2): operator-set `disabledSources`. Same
+    // shape as the unregistered-strict decline row, but with the
+    // `source_banned` reason and the source name in remediationHint.
+    if (config.disabledSources.includes(ext.source)) {
+      if (await ctx.alreadyConsidered(ctx.reckoningsBook, writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is in reckoner.disabledSources.`;
+      try {
+        await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (disabled-source path): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source path): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unregistered-strict gate: the source is not in the kit-static
+    // registry and `enforceRegistration: true`. Same row shape as the
+    // pre-tick CDC handler used so consumers don't see a regression
+    // in the resolution-string format.
+    const isRegistered = ctx.isSourceRegistered(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      if (await ctx.alreadyConsidered(ctx.reckoningsBook, writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+      try {
+        await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (unregistered-strict path): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await ctx.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (unregistered-strict path): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Surviving — pass through to dedupe + scheduler.
+    surviving.push({ ...entry, alreadyHasRow: false });
+  }
+
+  // Pre-scheduler dedupe (D7): drop already-considered writs before
+  // building SchedulerInput so the scheduler never sees a candidate
+  // whose decision the row-write layer would silently discard.
+  const scheduled: HeldEntry[] = [];
+  for (const entry of surviving) {
+    const { writ } = entry;
+    const dup = await ctx.alreadyConsidered(
+      ctx.reckoningsBook,
+      writ.id,
+      writ.updatedAt,
+    );
+    if (dup) continue;
+    scheduled.push({ writ: entry.writ, ext: entry.ext });
+  }
+
+  if (scheduled.length === 0) return;
+
+  // Single SchedulerInput for the whole surviving set (per-tick batch
+  // semantics, replacing the per-writ candidate construction the CDC
+  // path used).
+  const candidateWrits = scheduled.map((e) => e.writ);
+
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates: candidateWrits,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping this tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping this tick.`,
+    );
+    return;
+  }
+
+  // Filter-and-warn on stranger writIds. Apply only in-scope
+  // decisions; the others are surfaced via console.warn and dropped.
+  const candidateIds = new Set<string>(candidateWrits.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  // Group by writId; fail-loud-skip the ENTIRE tick on any multi-
+  // decision-per-writ (D9). No rows for any writ in this tick.
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate. Skipping the entire tick.`,
+      );
+      return;
+    }
+  }
+
+  // Apply each decision in candidate order (the scheduler's ordering
+  // is already captured by the candidate array order; per-writ
+  // decisions follow that).
+  for (const entry of scheduled) {
+    const decision = grouped.get(entry.writ.id)?.[0];
+    if (!decision) continue;
+    await applyDecision({
+      ctx,
+      now,
+      writ: entry.writ,
+      ext: entry.ext,
+      decision,
+      activeSchedulerId: activeScheduler.id,
+      tickEventId,
+    });
+  }
+}
+
+interface ApplyDecisionParams {
+  ctx: TickContext;
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  decision: SchedulerDecision;
+  activeSchedulerId: string;
+  tickEventId: string | undefined;
+}
+
+async function applyDecision(params: ApplyDecisionParams): Promise<void> {
+  const { ctx, now, writ, ext, decision, activeSchedulerId, tickEventId } = params;
+
+  const tickStamp =
+    tickEventId !== undefined ? { tickEventId } : ({} as { tickEventId?: string });
+  const weightStamp =
+    decision.weight !== undefined ? { weight: decision.weight } : ({} as { weight?: number });
+
+  if (decision.outcome === 'defer') {
+    // No transition; write a deferred row with `deferReason: 'other'`
+    // and the decision's reason in `deferNote` (D3).
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'deferred',
+      deferReason: 'other',
+      deferNote: decision.reason,
+      ...weightStamp,
+      ...tickStamp,
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  if (decision.outcome === 'decline') {
+    const resolution = decision.reason;
+    try {
+      await ctx.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+      );
+      return;
+    }
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'declined',
+      declineReason: 'other',
+      remediationHint: decision.reason,
+      ...weightStamp,
+      ...tickStamp,
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  if (decision.outcome === 'approve') {
+    let target: string;
+    try {
+      target = ctx.resolveActiveTargetPhase(writ);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+      );
+      return;
+    }
+    try {
+      await ctx.clerk.transition(writ.id, target as WritPhase, {});
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+      );
+      return;
+    }
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'accepted',
+      ...weightStamp,
+      ...tickStamp,
+    });
+    try {
+      await ctx.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  // Unknown outcome — fail-loud log; do not apply.
+  // eslint-disable-next-line no-console
+  console.warn(
+    `[reckoner] tick: scheduler "${activeSchedulerId}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+  );
+}
+
+// ── Relay factory ───────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. Wired into
+ * `apparatus.supportKit.relays`; resolved by the Clockworks
+ * dispatcher when the kit-contributed standing order
+ * (`{ schedule: '@every 60s', run: 'reckoner.tick' }`) fires.
+ *
+ * The relay accepts a `resolveContext` thunk rather than a pre-built
+ * `TickContext` so the handler can lazily build the context on each
+ * fire. Lazy resolution is load-bearing: the Reckoner's apparatus
+ * factory wires the relay into `supportKit.relays` *before* `start()`
+ * resolves Clerk / Stacks / the active scheduler, so a context built
+ * eagerly at module-load would close over `undefined` handles. Each
+ * call to `resolveContext()` happens after the apparatus has booted,
+ * so the handles are populated by that point.
+ *
+ * Mirrors the structural shape the stdlib `summon-relay` uses for its
+ * Animator / Loom resolution — both lazily resolve dependencies that
+ * are not available at relay-construction time.
+ */
+export function createReckonerTickRelay(
+  resolveContext: () => TickContext,
+): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY_NAME,
+    description:
+      'Periodic Reckoner tick — evaluates every held petition through ' +
+      'the configured scheduler and applies the resulting decisions.',
+    handler: async (event) => {
+      const ctx = resolveContext();
+      await runTickWithContext(event, ctx);
+    },
+  });
+}
