+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'writ stays in new on evaluate throw');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0, 'no rows written on evaluate throw');
+      assert.ok(
+        warnings.some(
+          (w) =>
+            /\[reckoner\] tick: scheduler/.test(w) &&
+            /evaluate threw/.test(w),
+        ),
+        `expected fail-loud warning; got: ${JSON.stringify(warnings)}`,
+      );
+    });
+  });
+
+  // ── 4: disabled-source mid-flight decline+cancel ───────────────────
+
+  describe('disabled-source decline (D2)', () => {
+    it('writes a source_banned decline row and transitions to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        config: { disabledSources: ['tester.kind'] },
+      });
+
+      // Suppress the petition() helper's console output (none expected
+      // here, but defensive); we want the test output clean.
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+        priority: {
+          visionRelation: 'vision-violator',
+          severity: 'serious',
+        },
+      });
+
+      await fix.hooks.runTick(syntheticTickEvent('e-disabled-tick'));
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+      assert.match(
+        String(reread.resolution),
