+   * registry has not yet sealed. The tick handler throws fail-loud
+   * (D8) when this returns `undefined`.
+   */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Re-read the resolved Reckoner config block from `guild.json`. */
+  resolveConfig(): TickResolvedConfig;
+  /** Re-read the raw `reckoner.schedulerConfig` slot per call (D17). */
+  resolveSchedulerConfig(): unknown;
+  /**
