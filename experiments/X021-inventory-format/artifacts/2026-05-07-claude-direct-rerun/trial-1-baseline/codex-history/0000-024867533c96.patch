+/**
+ * `reckoner.tick` — periodic scheduler-evaluation relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` so every guild that
+ * installs Clockworks alongside the Reckoner gets a default standing
+ * order at `@every 60s` driving the active scheduler over every
+ * currently-held petition. The tick is the canonical evaluation
+ * surface: there is no CDC observer in this commission, and there is
+ * no operator-configurable cadence — the schedule is hard-coded in the
+ * `supportKit.standingOrders` contribution.
+ *
+ * Per-fire sequence (mirrors the order of operations described in the
+ * apparatus contract doc):
+ *
+ *   1. Resolve the active scheduler. Pre-seal ticks (the resolved
+ *      reference is `undefined`) throw fail-loud — the brief's #2
+ *      override; production never trips this, test fixtures get a
+ *      deterministic loud signal.
+ *   2. Re-read and validate `reckoner.schedulerConfig`. If
+ *      `validateConfig` throws, log fail-loud and skip the tick (no
+ *      rows, no transitions).
+ *   3. Query held petitions through the Clerk's writs book —
+ *      `phase = 'new'` ordered by `createdAt` ascending, filtered
+ *      in-process to those carrying `ext.reckoner`.
+ *   4. Apply source/disabled gates inline. For each writ failing the
+ *      disabled-source gate, write a `declined` Reckonings row
+ *      (`declineReason: 'source_banned'`) and transition the writ to
+ *      its cancelled target. For each writ failing the
+ *      unregistered-strict gate, write a `declined` Reckonings row
+ *      (`declineReason: 'source_unregistered'`) and transition.
+ *   5. Filter the surviving candidate set against the
+ *      `(writId, writUpdatedAt)` dedupe lookup so already-considered
+ *      writs never reach the scheduler.
+ *   6. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      for the surviving set and call `evaluate` once. On throw, log
+ *      fail-loud and skip the tick. On a non-array return, log and
+ *      skip. Stranger writIds are filter-and-warned; multi-decision-
+ *      per-writ fail-loud-skips the entire tick.
+ *   7. Apply each decision: `approve` → transition to active target +
+ *      `accepted` row; `decline` → transition to cancelled with the
+ *      decision's reason as resolution + `declined` row carrying
+ *      `declineReason: 'other'` and the reason in `remediationHint`;
+ *      `defer` → no transition + `deferred` row carrying
+ *      `deferReason: 'other'` and the reason in `deferNote`.
+ *
+ * `tickEventId` is stamped on every row when `event.id` is present;
+ * absent when the handler is driven directly with `null` (the test-
+ * only `runTick` hook).
+ *
+ * The relay handler closes over a context object built inside the
+ * apparatus factory's closure — same dependency-injection pattern the
+ * stdlib `summon-relay` uses with the Animator / Loom. The pure
+ * `runTickWithContext` helper is exported so unit tests can drive it
+ * without booting the Clockworks dispatcher.
+ *
+ * See: docs/architecture/apparatus/reckoner.md (Schedulers section),
+ * docs/architecture/reckonings-book.md (`tickEventId` semantics).
+ */
+
+import {
+  relay,
+  type GuildEvent,
+  type RelayDefinition,
+} from '@shardworks/clockworks-apparatus';
+
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+import type {
+  Book,
+  ReadOnlyBook,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+
+import type {
+  ReckoningDoc,
+  ReckonerExt,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+// ── Constants ───────────────────────────────────────────────────────
+
+/** Plugin id of the Reckoner — keys the `writ.ext['reckoner']` slot. */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/** The relay name registered with Clockworks (D1). */
+export const RECKONER_TICK_RELAY_NAME = 'reckoner.tick';
+
+// ── Dependency context ──────────────────────────────────────────────
+
+/**
+ * Concrete shape returned by the apparatus's config resolver.
+ * Mirrors the inner type defined in `reckoner.ts`; the tick handler
+ * reads both fields per fire so operator hot-edits land on the next
+ * tick without an apparatus restart.
+ */
+export interface TickResolvedConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Dependency-injection context supplied by `buildReckoner()` to the
+ * relay factory. Each field is the apparatus-side closure handle the
+ * tick needs to reach the registries / config / book / Clerk helpers
+ * the apparatus owns. Tests supply their own context to drive the
+ * pure handler against in-memory fixtures.
+ */
+export interface TickContext {
+  /** Resolved Clerk handle. */
+  clerk: ClerkApi;
+  /** Resolved Stacks handle — used to read the writs book. */
+  stacks: StacksApi;
+  /** The Reckonings book handle. */
+  reckoningsBook: Book<ReckoningDoc>;
+  /**
+   * `true` when `source` is currently in the kit-static petitioner
+   * registry (closure-scoped state inside the apparatus).
+   */
+  isSourceRegistered(source: string): boolean;
+  /**
