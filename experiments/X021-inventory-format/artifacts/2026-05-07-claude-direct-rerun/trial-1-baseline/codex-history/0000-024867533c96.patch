+   * `WritTypeConfig.allowedTransitions` and selecting the
+   * `classification: 'active'` candidate.
+   */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /**
+   * Persisted dedupe lookup against `(writId, writUpdatedAt)`. Returns
+   * `true` when the Reckonings book already carries a row for the
+   * exact triggering writ-version.
+   */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /**
