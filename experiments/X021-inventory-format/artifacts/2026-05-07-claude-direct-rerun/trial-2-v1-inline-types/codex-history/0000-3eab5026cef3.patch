index 0000000..478bb72
--- /dev/null
+++ b/packages/plugins/reckoner/src/tick.ts
@@ -0,0 +1,539 @@
+/**
+ * `reckoner.tick` — periodic tick relay.
+ *
+ * Wired into the Reckoner apparatus's `supportKit.relays` so every
+ * guild that installs the Clockworks alongside the Reckoner picks up
+ * the standing order:
+ *
+ *   { schedule: '@every 60s', run: 'reckoner.tick' }
+ *
+ * The relay replaces the older CDC-driven evaluation surface
+ * entirely. On each fire it:
+ *
+ *   1. Resolves the active scheduler. Throws fail-loud when the
+ *      scheduler reference has not yet been set (D8) — production
+ *      never trips this because the scheduler resolves at
+ *      `phase:started`, but tests asserting pre-seal behavior get a
+ *      deterministic loud signal.
+ *   2. Re-reads + validates the operator's
+ *      `reckoner.schedulerConfig` slice through the active
+ *      scheduler's `validateConfig` narrower. Throws inside the
+ *      narrower fail-loud-skip the entire tick (no rows, no
+ *      transitions).
+ *   3. Queries every held petition (writs in the literal `'new'`
+ *      phase carrying `ext.reckoner`) using the same find-by-phase
+ *      shape the prior catch-up scan used.
+ *   4. Applies the source / disabled gates inline. Disabled-source
+ *      writs produce a `declined` Reckonings row carrying
+ *      `declineReason: 'source_banned'` (D2) and the source name in
+ *      `remediationHint`, then transition to the cancelled target
+ *      phase. Unregistered-strict writs preserve the existing
+ *      `source_unregistered` decline shape from the prior CDC handler
+ *      byte-for-byte.
+ *   5. Filters surviving candidates against the `(writId,
+ *      writUpdatedAt)` dedupe lookup (D7) — already-considered writs
+ *      never reach the scheduler.
+ *   6. Builds one `SchedulerInput { candidates, capacity, now,
+ *      config }` for the whole batch and calls `evaluate` inside a
+ *      try/catch that fail-loud-skips on throw.
+ *   7. Validates decisions: filter-and-warn on stranger writIds;
+ *      fail-loud-skip the whole tick on any multi-decision-per-writ
+ *      (D9).
+ *   8. Applies each decision: approve → transition to the type's
+ *      active target via `resolveActiveTargetPhase`; decline →
+ *      transition to cancelled with the decision's reason recorded
+ *      as the resolution string, append a `declined` row carrying
+ *      `declineReason: 'other'` and the reason in `remediationHint`;
+ *      defer → no transition, append a `deferred` row carrying
+ *      `deferReason: 'other'` and the reason in `deferNote` (D3).
+ *      `tickEventId` is stamped from `event.id` when an event is
+ *      present and omitted when it is absent (D6).
+ *
+ * The handler-body helper (`runTick`) is exported for the
+ * apparatus's test hooks and the in-package tick test surface so
+ * unit tests can drive the body without booting the Clockworks
+ * dispatcher (D11).
+ */
+
+import type {
+  GuildEvent,
+  RelayDefinition,
+} from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  Book,
+  ReadOnlyBook,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/** Plugin id stamped on `writ.ext['reckoner']`. Mirrors the constant in `reckoner.ts`. */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/** Relay-registry name. Hardcoded literal — the constant is the contract. */
+export const RECKONER_TICK_RELAY = 'reckoner.tick';
+
+/**
+ * Resolved configuration block — the same shape the CDC-era
+ * `resolveConfig` returned. Re-read on each tick so operators can
+ * hot-edit the disabled list without restarting.
+ */
+interface ResolvedReckonerConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Dependency context the apparatus closure passes into the tick
+ * handler. Each field is a handle the closure already owns; bundling
+ * them here keeps the handler-body helper unit-testable without
+ * pulling the apparatus's closure-scoped state into the relay
+ * factory's argument list.
+ */
+export interface TickDeps {
+  /** Live Stacks handle — used for the held-petition find. */
+  stacks: StacksApi;
+  /** Clerk handle for `transition` and writ-type-config lookup. */
+  clerk: ClerkApi;
+  /** Writable handle on `reckoner/reckonings` for the row writes. */
+  reckoningsBook: Book<ReckoningDoc>;
+  /** Read-only handle on `clerk/writs` for the held-petition query. */
+  writsBook: ReadOnlyBook<WritDoc>;
+  /** True when `source` is registered with the kit-static petitioner registry. */
+  isSourceRegistered(source: string): boolean;
+  /** Active-scheduler accessor; returns `undefined` pre-seal. */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Re-read + validate the `reckoner` config block from `guild.json`. */
+  resolveConfig(): ResolvedReckonerConfig;
+  /** Re-read the raw `reckoner.schedulerConfig` value. */
+  resolveSchedulerConfig(): unknown;
+  /** Pick the type-aware active target phase for an approve transition. */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /** Persisted dedupe lookup against `(writId, writUpdatedAt)`. */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /** Build a Reckonings row from the in-flight consideration state. */
+  buildReckoningRow(params: BuildRowParams): ReckoningDoc;
+}
+
+/**
+ * Argument shape for `TickDeps.buildReckoningRow`. Mirrors the
+ * apparatus's internal builder — defer rows route their reason
+ * through `deferReason` + `deferNote` (D3), declines through
+ * `declineReason` + `remediationHint`.
+ */
+export interface BuildRowParams {
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  outcome: 'accepted' | 'declined' | 'deferred';
+  declineReason?: ReckoningDoc['declineReason'];
+  remediationHint?: string;
+  deferReason?: ReckoningDoc['deferReason'];
+  deferNote?: string;
+  weight?: number;
+  tickEventId?: string;
+}
+
+/**
+ * The pure handler body. Exported so the apparatus's test hook
+ * (`hooks.runTick`) can call it without booting Clockworks.
+ *
+ * The function is structured around a single early-return per
+ * failure mode and a clean per-writ outcome loop at the end. Every
+ * non-skip path writes at most one row per writ; the scheduler is
+ * called at most once per fire.
+ */
+export async function runTick(
+  event: GuildEvent | null,
+  deps: TickDeps,
+): Promise<void> {
+  // 1. Resolve the active scheduler. Pre-seal ticks throw (D8) —
+  //    production never trips this; tests use it to assert
+  //    activeScheduler-not-resolved fail-loud.
+  const activeScheduler = deps.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      `[reckoner] tick: activeScheduler not resolved — phase:started has not fired.`,
+    );
+  }
+
+  // Sample `now` once at handler entry so every row written within
+  // this tick shares a consistent `consideredAt` and id-seed.
+  const now = new Date();
+
+  const tickEventId = event?.id;
+
+  // 2. Query held petitions.
+  const heldRaw = await deps.writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+  const held = heldRaw.filter((w) => Boolean(w.ext?.[RECKONER_PLUGIN_ID]));
+
+  // 3. Empty candidate set → nothing to do (D10).
+  if (held.length === 0) return;
+
+  // 4. Source / disabled gates. Each gate applies inline so the
+  //    decision and the row write are colocated; surviving writs
+  //    flow to the dedupe + scheduler path.
+  const config = deps.resolveConfig();
+  const disabled = new Set(config.disabledSources);
+
+  const survivors: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const writ of held) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+
+    // Disabled-source decline (D2). Symmetric with the unregistered-
+    // strict path — produces a row + transition rather than a silent
+    // skip the way the CDC path used to. The decline reason is
+    // `source_banned`; the source name lands in `remediationHint`.
+    if (disabled.has(ext.source)) {
+      if (await deps.alreadyConsidered(deps.reckoningsBook, writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is in reckoner.disabledSources.`;
+      try {
+        await deps.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (disabled-source path): ${msg}`,
+        );
+        continue;
+      }
+      const row = deps.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await deps.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unregistered-strict decline. Preserves the CDC-era resolution
+    // string format and `declineReason: 'source_unregistered'` —
+    // operators relying on that grep should not see drift.
+    const isRegistered = deps.isSourceRegistered(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      if (await deps.alreadyConsidered(deps.reckoningsBook, writ.id, writ.updatedAt)) {
+        continue;
+      }
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+      try {
+        await deps.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (unregistered-strict path): ${msg}`,
+        );
+        continue;
+      }
+      const row = deps.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await deps.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (unregistered-strict decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    survivors.push({ writ, ext });
+  }
+
+  if (survivors.length === 0) return;
+
+  // 5. Pre-scheduler dedupe (D7). Already-considered writs never
+  //    reach the scheduler — keeping this above the evaluate call
+  //    means a stale CDC redelivery cannot make the scheduler emit
+  //    decisions the row-write layer would silently discard.
+  const fresh: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const candidate of survivors) {
+    const dup = await deps.alreadyConsidered(
+      deps.reckoningsBook,
+      candidate.writ.id,
+      candidate.writ.updatedAt,
+    );
+    if (dup) continue;
+    fresh.push(candidate);
+  }
+
+  if (fresh.length === 0) return;
+
+  // 6. Validate the operator-supplied `schedulerConfig` through the
+  //    active scheduler's narrower. Throws fail-loud-skip the tick
+  //    (no rows, no transitions).
+  const rawSchedulerConfig = deps.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // 7. Build the input batch and evaluate.
+  const candidateIds = new Set(fresh.map((c) => c.writ.id));
+
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates: fresh.map((c) => c.writ),
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 8. Filter-and-warn on stranger writIds; group by writId.
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+
+  // Multi-decision-per-writ → fail-loud-skip the entire tick (D9).
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any decision in this tick. Schedulers must emit at most one decision per candidate.`,
+      );
+      return;
+    }
+  }
+
+  // 9. Apply decisions. One row per writ considered; outcome-mapping
+  //    matches the apparatus contract document.
+  for (const candidate of fresh) {
+    const decision = grouped.get(candidate.writ.id)?.[0];
+    if (!decision) {
+      // No decision for this candidate — defer-equivalent in v0,
+      // no row, no transition. (The configured scheduler can still
+      // emit an explicit defer per candidate; this only fires when
+      // the scheduler simply omitted a candidate from its result.)
+      continue;
+    }
+
+    if (
+      decision.outcome !== 'approve' &&
+      decision.outcome !== 'decline' &&
+      decision.outcome !== 'defer'
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned an unknown outcome "${String(
+          (decision as { outcome?: unknown }).outcome,
+        )}" for writ "${candidate.writ.id}" — ignoring.`,
+      );
+      continue;
+    }
+
+    if (decision.outcome === 'defer') {
+      // D3: defer rows mirror the decline path's `'other'` mapping —
+      // `deferReason: 'other'` plus the decision reason in
+      // `deferNote`. No transition.
+      const row = deps.buildReckoningRow({
+        now,
+        writ: candidate.writ,
+        ext: candidate.ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await deps.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${candidate.writ.id}" (defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await deps.clerk.transition(candidate.writ.id, 'cancelled' as WritPhase, {
+          resolution,
+        });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${candidate.writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = deps.buildReckoningRow({
+        now,
+        writ: candidate.writ,
+        ext: candidate.ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await deps.reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${candidate.writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // approve.
+    let target: string;
+    try {
+      target = deps.resolveActiveTargetPhase(candidate.writ);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: writ "${candidate.writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+      );
+      continue;
+    }
+
+    try {
+      await deps.clerk.transition(candidate.writ.id, target as WritPhase, {});
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${candidate.writ.id}" to "${target}" (scheduler approve): ${msg}`,
+      );
+      continue;
+    }
+
+    const row = deps.buildReckoningRow({
+      now,
+      writ: candidate.writ,
+      ext: candidate.ext,
+      outcome: 'accepted',
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await deps.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${candidate.writ.id}" (scheduler approve): ${msg}`,
+      );
+    }
+  }
+}
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. Exported so the
+ * apparatus boot path can wire it into `supportKit.relays` and so
+ * unit tests can drive the relay directly.
+ */
+export function createTickRelay(deps: TickDeps): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY,
+    description:
+      'Reckoner periodic tick — evaluates every held petition through the active scheduler in one batch per fire.',
+    handler: async (event) => {
+      await runTick(event, deps);
+    },
+  });
+}
