@@ -0,0 +1,969 @@
+/**
+ * Reckoner tick-driven evaluation tests.
+ *
+ * Replaces the prior CDC handler test file. Every behavioral case
+ * the periodic-tick commission enumerates is exercised through
+ * `hooks.runTick(...)` — the in-package test surface that drives
+ * the relay handler's body without booting the Clockworks
+ * dispatcher.
+ *
+ * Behavioral matrix:
+ *
+ *   1. Empty-candidate tick — no rows, no errors.
+ *   2. First tick after start picks up pre-existing held petitions
+ *      (the catch-up replacement).
+ *   3. Pre-seal tick throws fail-loud (D8).
+ *   4. `evaluate` throw isolation — no rows written, apparatus stays up.
+ *   5. `validateConfig` throw isolation — same.
+ *   6. Disabled-source mid-flight produces a `source_banned` decline +
+ *      cancelled transition (D2).
+ *   7. Unregistered-strict mid-flight preserves the
+ *      `source_unregistered` resolution string format byte-for-byte.
+ *   8. Repeated-tick idempotency at unchanged `updatedAt` —
+ *      `(writId, writUpdatedAt)` dedupes.
+ *   9. Type-aware target-phase resolution (mandate vs. custom type).
+ *  10. Withdrawal-mid-flight — the writ leaves `new` before the
+ *      next tick, so the tick simply skips it.
+ *  11. Defer outcome writes a `'deferred'` row carrying
+ *      `deferReason: 'other'` and the decision reason in
+ *      `deferNote`; no transition (D3).
+ *  12. Multi-decision-per-writ fail-loud-skips the entire tick (D9).
+ *  13. Stranger writIds are filter-and-warn; the in-scope decision
+ *      still applies (D9).
+ *  14. tickEventId is stamped from `event.id` when present, omitted
+ *      otherwise (D6).
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /** Re-fire `phase:started` against registered handlers. */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  /** When true, do not include the built-in always-approve scheduler. */
+  omitDefaultScheduler?: boolean;
+  /** When true, do not fire `phase:started` after start (pre-seal tests). */
+  skipPhaseStarted?: boolean;
+  config?: ReckonerConfig | undefined;
+  writTypes?: WritTypeConfig[];
+  /** Pre-seed writs into the writs book before the Reckoner starts. */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the Clerk needs.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler): void {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  // ── Stacks ────────────────────────────────────────────────────────
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // ── Clerk ─────────────────────────────────────────────────────────
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  // ── Reckoner ──────────────────────────────────────────────────────
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [];
+  if (!opts.omitDefaultScheduler) {
+    schedulerKitEntries.push({
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    });
+  }
+  for (const entry of opts.schedulerKits ?? []) {
+    schedulerKitEntries.push({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    });
+  }
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+function syntheticEvent(id: string): {
+  id: string;
+  name: string;
+  payload: unknown;
+  emitter: string;
+  firedAt: string;
+} {
+  return {
+    id,
+    name: 'clockworks.timer',
+    payload: null,
+    emitter: 'clockworks',
+    firedAt: new Date().toISOString(),
+  };
+}
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner periodic tick', () => {
+  afterEach(() => {
+    clearGuild();
+  });
+
+  // ── 1: empty candidate set ─────────────────────────────────────────
+
+  describe('empty-candidate tick', () => {
+    it('writes no rows and throws no errors when no held writs exist', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+      // Nothing held — calling runTick should be a clean no-op.
+      await fix.hooks.runTick(syntheticEvent('e-empty'));
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0);
+    });
+  });
+
+  // ── 2: first tick picks up pre-existing held petitions ────────────
+
+  describe('first tick after start', () => {
+    it('approves a held petition that pre-existed the tick', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        async preStart({ clerk }) {
+          const w = await clerk.post({ title: 'pre-existing', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'tester.kind',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      const writ = all[0]!;
+      // No rows yet — phase:started fired but no tick has run.
+      const before = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(before.length, 0);
+      assert.equal((await fix.clerk.show(writ.id)).phase, 'new');
+
+      // Fire one tick.
+      await fix.hooks.runTick(syntheticEvent('e-tick-1'));
+
+      const after = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(after.length, 1);
+      assert.equal(after[0]!.outcome, 'accepted');
+      assert.equal(after[0]!.tickEventId, 'e-tick-1');
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open');
+    });
+  });
+
+  // ── 3: pre-seal tick throws fail-loud ──────────────────────────────
+
+  describe('pre-seal tick', () => {
+    it('throws fail-loud when activeScheduler is unresolved', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        skipPhaseStarted: true,
+      });
+      await assert.rejects(
+        () => fix.hooks.runTick(syntheticEvent('e-pre-seal')),
+        (err: Error) => {
+          assert.match(err.message, /\[reckoner\] tick: activeScheduler not resolved/);
+          return true;
+        },
+      );
+    });
+  });
+
+  // ── 4: evaluate throw isolation ────────────────────────────────────
+
+  describe('evaluate-throw isolation', () => {
+    it('logs fail-loud and writes no rows when evaluate throws', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.thrower',
+        description: 'always throws',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('boom');
+        },
+      };
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.thrower' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick(syntheticEvent('e-throw'));
+      } finally {
+        console.warn = originalWarn;
+      }
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0, 'evaluate throw must not write rows');
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'evaluate throw must not transition');
+      assert.ok(
+        warnings.some(
+          (w) => /\[reckoner\] tick: scheduler/.test(w) && /evaluate threw/.test(w),
+        ),
+        `expected fail-loud warning; got: ${JSON.stringify(warnings)}`,
+      );
+    });
+  });
+
+  // ── 5: validateConfig throw isolation ──────────────────────────────
+
+  describe('validateConfig-throw isolation', () => {
+    it('logs fail-loud and skips the tick on validateConfig throw', async () => {
+      const evaluateCalls: unknown[] = [];
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad-config',
+        description: 'broken config narrower',
+        validateConfig(): unknown {
+          throw new Error('bad config');
+        },
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          evaluateCalls.push(input);
+          return [];
+        },
+      };
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-config' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick(syntheticEvent('e-bad-config'));
+      } finally {
+        console.warn = originalWarn;
+      }
+
+      assert.equal(evaluateCalls.length, 0, 'evaluate must not run on validateConfig throw');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0);
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new');
+      assert.ok(
+        warnings.some(
+          (w) => /\[reckoner\] tick: scheduler/.test(w) && /validateConfig threw/.test(w),
+        ),
+        `expected fail-loud warning; got: ${JSON.stringify(warnings)}`,
+      );
+    });
+  });
+
+  // ── 6: disabled-source decline ─────────────────────────────────────
+
+  describe('disabled-source decline (D2)', () => {
+    it('writes a source_banned decline row and transitions to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        config: { disabledSources: ['tester.kind'] },
+      });
+
+      // Suppress the petition helper's expected warning when the source
+      // happens to also fail other gates downstream (it doesn't here,
+      // but the disabled-list is read at consideration time, not at
+      // petition time, so no warn is needed for the post itself).
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      await fix.hooks.runTick(syntheticEvent('e-disabled'));
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'tester\.kind' is in reckoner\.disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'tester.kind');
+      assert.equal(rows[0]!.tickEventId, 'e-disabled');
+    });
+  });
+
+  // ── 7: unregistered-strict decline (preserved shape) ──────────────
+
+  describe('unregistered-strict decline', () => {
+    it('preserves the source_unregistered resolution string format', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [],
+        config: { enforceRegistration: true },
+      });
+
+      // The petition helper itself rejects unregistered sources under
+      // strict registration; post + setWritExt directly so the held
+      // writ exists for the tick to find.
+      const writ = await fix.clerk.post({ title: 't', body: 'b' });
+      await fix.clerk.setWritExt(writ.id, 'reckoner', {
+        source: 'unknown.source',
+        priority: {
+          visionRelation: 'vision-neutral',
+          severity: 'minor',
+          scope: 'minor-area',
+          time: { decay: false, deadline: null },
+          domain: [],
+        },
+      });
+
+      await fix.hooks.runTick(syntheticEvent('e-unreg'));
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
