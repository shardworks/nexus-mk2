+      // the dedupe guard for the case where phase still happened to
+      // be `new`. Here the phase filter is sufficient; the assertion
+      // is that no second row appears.)
+      await fix.hooks.runTick(syntheticEvent('e-tick-B'));
+      const afterSecond = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
