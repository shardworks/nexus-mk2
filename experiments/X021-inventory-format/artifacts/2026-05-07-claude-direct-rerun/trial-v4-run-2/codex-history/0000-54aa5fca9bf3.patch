+ *      resolution string preserved from the per-call shape.
+ *   5. Filter the survivors against the `(writId, writUpdatedAt)`
+ *      dedupe lookup (D7) — rows already considered never reach the
+ *      scheduler.
+ *   6. Early-return on an empty candidate set (D10).
+ *   7. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 `capacity: {}` stub. Call `evaluate` inside a
+ *      try/catch. On throw, log fail-loud and skip the entire tick.
+ *   8. Validate decisions: filter-and-warn on stranger writIds (D9);
+ *      fail-loud-skip the entire tick on multi-decision-per-writ
+ *      (D9). Apply each decision per the outcome table — approve
+ *      transitions to the active target and writes an accepted row;
+ *      decline transitions to cancelled and writes a declined row
+ *      with `declineReason: 'other'`; defer leaves the writ in `new`
+ *      and writes a deferred row carrying `deferReason: 'other'` and
+ *      the decision's reason in `deferNote` (D3).
+ *   9. Stamp `tickEventId` on every row from the triggering event id
+ *      when present; omit when absent (D6).
+ *
+ * The body of the tick is intentionally extracted into the pure
+ * `runTick` helper so unit tests can drive it directly through a
+ * dependency context without booting Clockworks. The factory wrapper
+ * `createReckonerTickRelay` packages the helper into a
+ * `RelayDefinition` the apparatus's supportKit can hand the
+ * Clockworks. See `tick.test.ts` for the behavioral matrix.
+ */
+
+import type { GuildEvent, RelayDefinition } from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+import type { Book, ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/**
+ * Hardcoded relay name. Matches the apparatus's existing contributed-id
+ * grammar (`{pluginId}.{kebab-suffix}`). Operators referencing the
+ * relay from a custom standing order use this exact string in `run:`.
+ */
+export const RECKONER_TICK_RELAY_NAME = 'reckoner.tick';
+
+/**
+ * Hardcoded standing-order schedule. Operators cannot configure this
+ * cadence in v0 (a `reckoner.tickSchedule` knob is parked); the
+ * commission ships a single fixed-interval order through the kit
+ * contribution.
+ */
+export const RECKONER_TICK_SCHEDULE = '@every 60s';
+
+/** Plugin id used to read `writ.ext['reckoner']`. */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * Configuration block returned from the dependency context's
+ * config resolver (the `reckoner` block already validated against
+ * its top-level shape — `enforceRegistration` + `disabledSources`).
+ * Schedulers read `schedulerConfig` separately.
+ */
+export interface ResolvedReckonerConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Dependency context the tick handler closes over. The apparatus
+ * builds one of these inside `start()` and threads it into the relay
+ * factory; tests build one inside their fixture and call `runTick`
+ * directly.
+ *
+ * Every field is the closure-state shape from the existing apparatus
+ * — `clerk`, `stacks`, the resolved Reckonings book handle, the
+ * petitioner registry projection, the active scheduler accessor (so
+ * the pre-seal guard fires when start() has not finished), the
+ * config/scheduler-config resolvers, the type-aware target-phase
+ * resolver, the Reckoning row builder, and the dedupe lookup.
+ */
+export interface TickContext {
+  clerk: ClerkApi;
+  stacks: StacksApi;
+  reckoningsBook: Book<ReckoningDoc>;
+  /** Returns true when `source` is in the kit-static petitioner registry. */
+  isSourceRegistered: (source: string) => boolean;
+  /** Returns the resolved active scheduler, or `undefined` pre-seal. */
+  getActiveScheduler: () => Scheduler | undefined;
+  resolveConfig: () => ResolvedReckonerConfig;
+  resolveSchedulerConfig: () => unknown;
+  /** Walk the writ-type config and pick the active target phase (D5). */
+  resolveActiveTargetPhase: (writ: WritDoc) => string;
+  /**
+   * Persisted dedupe lookup — `true` when a Reckonings row already
+   * exists for this `(writId, writUpdatedAt)` pair. Same lookup the
+   * per-call CDC path used; reused verbatim.
+   */
+  alreadyConsidered: (writId: string, writUpdatedAt: string) => Promise<boolean>;
+  /**
+   * Build a Reckoning row from in-flight consideration state. The
+   * apparatus closure owns the row constructor so id/consideredAt
+   * stay consistent across decline/approve/defer paths.
+   */
+  buildReckoningRow: (params: BuildRowParams) => ReckoningDoc;
+}
+
+/**
+ * Argument shape for `TickContext.buildReckoningRow`. Mirrors the
+ * shape inside the apparatus closure; declared here as a public type
+ * so test fixtures can construct compatible context values without
+ * reaching into the apparatus internals.
+ */
+export interface BuildRowParams {
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  outcome: 'accepted' | 'declined' | 'deferred';
+  declineReason?: ReckoningDoc['declineReason'];
+  remediationHint?: string;
+  deferReason?: ReckoningDoc['deferReason'];
+  deferNote?: string;
+  /** Triggering Clockworks event id when present; omitted when absent (D6). */
+  tickEventId?: string;
+  /** Optional scheduler-emitted weight threaded onto the row. */
+  weight?: number;
+}
+
+/**
+ * Tick handler body — pure helper exercised by both the relay
+ * factory's `handler` and unit tests.
+ *
+ * Throws when `getActiveScheduler()` returns `undefined` (D8). All
+ * other failure modes are isolated and logged: validateConfig /
+ * evaluate throws, malformed decision lists, multi-decision-per-writ,
+ * and per-row write/transition errors all log a fail-loud line and
+ * skip the offending unit of work without crashing the tick.
+ *
+ * @param event   Triggering Clockworks event, or null when unit tests
+ *                drive the helper directly.
+ * @param context Closure-scoped dependency surface from the apparatus.
+ */
+export async function runTick(
+  event: GuildEvent | null,
+  context: TickContext,
+): Promise<void> {
+  // 1. Fail-loud pre-seal guard (D8). Production never trips this; the
+  //    standing-order schedule binds after phase:started fires. Test
+  //    fixtures use this throw as a deterministic loud signal instead
+  //    of the silent-skip behavior the per-call CDC path used.
+  const activeScheduler = context.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  const tickEventId = event?.id;
+  const now = new Date();
+
+  // 2. Re-read + validate scheduler config (D17/D18). Throw → fail-loud
+  //    log + skip the tick.
+  const rawSchedulerConfig = context.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // 3. Query held petitions. Same find-by-phase shape the previous
+  //    catch-up scan used; the type-agnostic generalization to
+  //    iterate Clerk's writ-type registry for non-`'new'` initial
+  //    phases is deferred (see brief: "Do not generalize the held-
+  //    writ query").
+  const writsBook: ReadOnlyBook<WritDoc> = context.stacks.readBook<WritDoc>(
+    'clerk',
+    'writs',
+  );
+  const heldRaw = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+
+  // Filter to writs carrying ext.reckoner — cheap pre-filter so writs
+  // that opted out (or never opted in) skip the gates entirely.
+  const held = heldRaw.filter((w) => Boolean(w.ext?.[RECKONER_PLUGIN_ID]));
+
+  // Read fresh config (re-read on every consumer call, D20).
+  const config = context.resolveConfig();
+
+  // 4. Apply source/disabled gates inline. Each failing writ produces
+  //    a `declined` row + transition; survivors continue to step 5.
+  const survivors: WritDoc[] = [];
+  for (const writ of held) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+
+    // Disabled-source decline (D2). Symmetric with the unregistered-
+    // strict path's resolution-string format; the row carries
+    // `declineReason: 'source_banned'` and the source name in
+    // `remediationHint`.
+    if (config.disabledSources.includes(ext.source)) {
+      await applyDeclineGate(context, {
+        writ,
+        ext,
+        now,
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        resolution:
+          `[reckoner] declined: source '${ext.source}' is in disabledSources.`,
+        tickEventId,
+        logScope: 'tick (disabled-source)',
+      });
+      continue;
+    }
+
+    // Unregistered-strict decline. The per-call shape's resolution-
+    // string and `declineReason: 'source_unregistered'` (with
+    // `remediationHint = source`) are preserved verbatim.
+    const isRegistered = context.isSourceRegistered(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      await applyDeclineGate(context, {
+        writ,
+        ext,
+        now,
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        resolution:
+          `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`,
+        tickEventId,
+        logScope: 'tick (unregistered-strict)',
+      });
+      continue;
+    }
+
+    survivors.push(writ);
+  }
+
+  // 5. Dedupe survivors against the persisted `(writId, writUpdatedAt)`
+  //    lookup before building SchedulerInput (D7). Already-considered
+  //    writs never reach the scheduler.
+  const candidates: WritDoc[] = [];
+  for (const writ of survivors) {
+    if (await context.alreadyConsidered(writ.id, writ.updatedAt)) continue;
+    candidates.push(writ);
+  }
+
+  // 6. Empty-candidate-set early return (D10). No scheduler call, no
+  //    rows, no errors.
+  if (candidates.length === 0) return;
+
+  // 7. Build SchedulerInput and call evaluate. v0 capacity stub stays
+  //    empty — the slot is reserved for future capacity-aware
+  //    schedulers.
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 8. Validate decisions: filter-and-warn on stranger writIds (D9);
+  //    fail-loud-skip the entire tick on any multi-decision-per-writ.
+  const candidateById = new Map<string, WritDoc>();
+  for (const writ of candidates) candidateById.set(writ.id, writ);
+
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateById.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate. Skipping the entire tick.`,
+      );
+      return;
+    }
+  }
+
+  // Apply each decision in candidate-order so test assertions stay
+  // deterministic.
+  for (const writ of candidates) {
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) continue; // No decision == defer-equivalent.
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue; // Defensive — gate already filtered these out.
+    await applyDecision(context, {
+      writ,
+      ext,
+      decision,
+      now,
+      tickEventId,
+      schedulerId: activeScheduler.id,
+    });
+  }
+}
+
+/**
+ * Internal helper: write a `declined` Reckonings row + transition to
+ * the cancelled target phase. Used by both source/disabled gate
+ * paths. Errors are caught and logged so one bad gate does not crash
+ * the tick.
+ */
+async function applyDeclineGate(
+  context: TickContext,
+  params: {
+    writ: WritDoc;
+    ext: ReckonerExt;
+    now: Date;
+    declineReason: NonNullable<ReckoningDoc['declineReason']>;
+    remediationHint: string;
+    resolution: string;
+    tickEventId: string | undefined;
+    logScope: string;
+  },
+): Promise<void> {
+  const { writ, ext, now, resolution, declineReason, remediationHint, tickEventId, logScope } =
+    params;
+
+  // Persisted dedupe — short-circuit if a row already exists for the
+  // exact (writId, writUpdatedAt). Mirrors the per-call CDC path.
+  if (await context.alreadyConsidered(writ.id, writ.updatedAt)) return;
+
+  try {
+    await context.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] ${logScope}: failed to transition writ "${writ.id}" to cancelled: ${msg}`,
+    );
+    return;
+  }
+
+  const row = context.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason,
+    remediationHint,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await context.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] ${logScope}: failed to persist Reckonings row for writ "${writ.id}": ${msg}`,
+    );
+  }
+}
+
+/**
+ * Internal helper: apply one `SchedulerDecision` to one held writ.
+ * Maps `approve`/`decline`/`defer` to the prescribed transition + row
+ * shapes per D2/D3 and the brief's per-fire sequence. Errors are
+ * caught and logged per-writ; one bad apply does not stop the tick
+ * from making progress on its siblings.
+ */
+async function applyDecision(
+  context: TickContext,
+  params: {
+    writ: WritDoc;
+    ext: ReckonerExt;
+    decision: SchedulerDecision;
+    now: Date;
+    tickEventId: string | undefined;
+    schedulerId: string;
+  },
+): Promise<void> {
+  const { writ, ext, decision, now, tickEventId, schedulerId } = params;
+
+  if (
+    decision.outcome !== 'approve' &&
+    decision.outcome !== 'decline' &&
+    decision.outcome !== 'defer'
+  ) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${schedulerId}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+    return;
+  }
+
+  if (decision.outcome === 'defer') {
+    // No transition. Write a `deferred` row carrying the decision's
+    // reason in `deferNote` (D3). Other defer-metadata fields stay
+    // absent — they require richer reason metadata than the
+    // SchedulerDecision shape declares.
+    const row = context.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'deferred',
+      deferReason: 'other',
+      deferNote: decision.reason,
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+    });
+    try {
+      await context.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick (scheduler defer): failed to persist Reckonings row for writ "${writ.id}": ${msg}`,
+      );
+    }
+    return;
+  }
+
+  if (decision.outcome === 'decline') {
+    const resolution = decision.reason;
+    try {
+      await context.clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick (scheduler decline): failed to transition writ "${writ.id}" to cancelled: ${msg}`,
+      );
+      return;
+    }
+    const row = context.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'declined',
+      declineReason: 'other',
+      remediationHint: decision.reason,
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+    });
+    try {
+      await context.reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick (scheduler decline): failed to persist Reckonings row for writ "${writ.id}": ${msg}`,
+      );
+    }
+    return;
+  }
+
+  // approve.
+  let target: string;
+  try {
+    target = context.resolveActiveTargetPhase(writ);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick (scheduler approve): writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+    );
+    return;
+  }
+
+  try {
+    await context.clerk.transition(writ.id, target as WritPhase, {});
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick (scheduler approve): failed to transition writ "${writ.id}" to "${target}": ${msg}`,
+    );
+    return;
+  }
+
+  const row = context.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'accepted',
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+    ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+  });
+  try {
+    await context.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick (scheduler approve): failed to persist Reckonings row for writ "${writ.id}": ${msg}`,
+    );
+  }
+}
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. The apparatus calls
+ * this from `start()` once the dependency context is available and
+ * passes the result through `apparatus.supportKit.relays`.
+ *
+ * Exported so the relay name and factory shape are testable, and so
+ * future commissions extending the tick (a dedicated CLI, an
+ * `nsg reckoner tick` operator surface) can grab the same factory
+ * without touching the apparatus body.
+ */
+export function createReckonerTickRelay(context: TickContext): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY_NAME,
+    description:
+      'Periodic Reckoner tick. Re-reads scheduler config, queries held petitions, applies the source/disabled gates, dedupes, and runs the active scheduler against the surviving candidate set.',
+    handler: async (event, _ctx) => {
+      await runTick(event, context);
+    },
+  });
+}
