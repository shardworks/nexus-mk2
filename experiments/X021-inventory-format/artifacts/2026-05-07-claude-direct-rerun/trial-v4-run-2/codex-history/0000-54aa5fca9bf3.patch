--- /dev/null
+++ b/packages/plugins/reckoner/src/reckoner-tick.test.ts
@@ -0,0 +1,829 @@
+/**
+ * Reckoner tick handler tests.
+ *
+ * The Reckoner's only evaluation entry is the periodic tick — every
+ * behavioral case is exercised through `hooks.runTick()`. The previous
+ * commission's per-writ-update CDC test file is replaced by this one;
+ * the per-tick batched semantics are the contract this file pins.
+ *
+ * Behavioral matrix (mirrors the brief's Acceptance Signal):
+ *
+ *   1. empty-candidate ticks — no rows, no errors;
+ *   2. first tick after start picks up pre-existing held writs;
+ *   3. evaluate-throw isolation — apparatus stays up, no rows written;
+ *   4. disabled-source mid-flight — decline + cancel + row;
+ *   5. repeated-tick idempotency at unchanged updatedAt;
+ *   6. type-aware target-phase resolution;
+ *   7. withdrawal-mid-flight — no row;
+ *   8. defer outcome writes a row with no transition;
+ *   9. pre-seal tick throws fail-loud;
+ *  10. unregistered-strict decline preserves the structured resolution;
+ *  11. tickEventId stamping (present and absent paths).
+ *
+ * Fixture mirrors the kit-registry tests in `reckoner.test.ts` — real
+ * Stacks + Clerk + Reckoner against `MemoryBackend`, with explicit
+ * book pre-creation. The tick handler is invoked through
+ * `hooks.runTick()` rather than booting the Clockworks dispatcher;
+ * the integration test exercises the full standing-order path.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritDoc, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /** Re-fire `phase:started` (sync handlers only — the tick model has no async seal work). */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  config?: ReckonerConfig | undefined;
+  /** Optional writ types to register on the Clerk before the Reckoner starts. */
+  writTypes?: WritTypeConfig[];
+  /** Optional pre-start seed — used to exercise pre-existing held writs. */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+  /** When true, do not fire phase:started after start (pre-seal tick tests). */
+  skipPhaseStarted?: boolean;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the Clerk needs — Stacks' Wire phase would do
+  // this in production from the supportKit declarations.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler) {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  // ── Stacks ────────────────────────────────────────────────────────
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // ── Clerk ─────────────────────────────────────────────────────────
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  // Register optional writ types before the Reckoner starts so the
+  // type config is visible during the first tick.
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  // Optional pre-start seed (pre-existing held petitions).
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  // ── Reckoner ──────────────────────────────────────────────────────
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  // Surface the Reckoner's own supportKit `schedulers` contribution
+  // (the built-in always-approve instance) plus any test-supplied
+  // schedulers. Arbor synthesises kit entries from each apparatus's
+  // supportKit in production; the test fixture mirrors that
+  // responsibility by hand.
+  const schedulerKitEntries: KitEntry[] = [
+    {
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    },
+    ...(opts.schedulerKits ?? []).map((entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    })),
+  ];
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  // Fire `phase:started` so the registry seals and the active scheduler
+  // resolves — the real Arbor lifecycle does this for us in production.
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+/** Build a stub `GuildEvent` so tests can assert tickEventId stamping. */
+function syntheticTickEvent(id = 'e-tick-test'): GuildEvent {
+  return {
+    id,
+    name: 'clockworks.timer',
+    payload: null,
+    emitter: 'clockworks',
+    firedAt: new Date().toISOString(),
+  };
+}
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => {
+    clearGuild();
+  });
+
+  // ── 1: empty-candidate tick ────────────────────────────────────────
+
+  describe('empty candidate set', () => {
+    it('writes no rows and surfaces no errors', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+      });
+      // No held petitions exist. A tick must short-circuit cleanly.
+      await fix.hooks.runTick(syntheticTickEvent());
+
+      const all = await fix.reckoningsBook.find({});
+      assert.equal(all.length, 0, 'empty-candidate tick writes no rows');
+    });
+  });
+
+  // ── 2: first tick picks up pre-existing held writs ─────────────────
+
+  describe('first tick after start', () => {
+    it('processes held writs that were created before the apparatus started', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        async preStart({ clerk }) {
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'tester.kind',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Before any tick fires, the writ stays in `new` (no CDC observer).
+      const before = await fix.clerk.list({ limit: 100 });
+      assert.equal(before.length, 1);
+      assert.equal(before[0]!.phase, 'new');
+      const rowsBefore = await fix.reckoningsBook.find({});
+      assert.equal(rowsBefore.length, 0, 'no rows pre-tick');
+
+      // Run the tick — the held writ flows through the always-approve
+      // scheduler and gets accepted.
+      await fix.hooks.runTick(syntheticTickEvent('e-pre-start-tick'));
+
+      const after = await fix.clerk.list({ limit: 100 });
+      assert.equal(after.length, 1);
+      assert.equal(after[0]!.phase, 'open', 'first tick auto-approves');
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+      assert.equal(rows[0]!.tickEventId, 'e-pre-start-tick');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ────────────────────────────────────
+
+  describe('evaluate throw', () => {
+    it('logs fail-loud and skips the tick — no rows, no transitions', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad-evaluate',
+        description: 'always throws',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-evaluate' },
+      });
+
+      // Petition then tick — the writ should remain in new and no row
+      // should land.
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick(syntheticTickEvent());
+      } finally {
+        console.warn = originalWarn;
+      }
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'writ untouched after evaluate throw');
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0, 'no rows after evaluate throw');
+      assert.ok(
+        warnings.some(
+          (w) => /\[reckoner\] scheduler:/.test(w) && /evaluate threw/.test(w),
+        ),
+        `expected fail-loud log line; got: ${JSON.stringify(warnings)}`,
+      );
+    });
+  });
+
+  // ── 4: disabled-source mid-flight decline + cancel ─────────────────
+
+  describe('disabled-source gate', () => {
+    it('writes a declined row with source_banned and transitions to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        config: {
+          disabledSources: ['tester.kind'],
+        },
+      });
+
+      // Stamp the held writ directly so the petition() helper does not
+      // emit a warning. Petition would also work — the gate runs in the
+      // tick handler regardless of how the writ got into `new`.
+      const writ = await fix.clerk.post({ title: 't', body: 'b' });
+      await fix.clerk.setWritExt(writ.id, 'reckoner', {
+        source: 'tester.kind',
+        priority: {
+          visionRelation: 'vision-neutral',
+          severity: 'minor',
+          scope: 'minor-area',
+          time: { decay: false, deadline: null },
+          domain: [],
+        },
+      });
+
+      await fix.hooks.runTick(syntheticTickEvent('e-banned-tick'));
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled', 'disabled source declines + cancels');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'tester\.kind' is in disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'tester.kind');
+      assert.equal(rows[0]!.tickEventId, 'e-banned-tick');
+    });
+  });
+
+  // ── 5: repeated-tick idempotency ───────────────────────────────────
+
+  describe('repeated-tick idempotency', () => {
+    it('produces exactly one row per (writId, writUpdatedAt) across multiple ticks', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        async preStart({ clerk }) {
+          const w = await clerk.post({ title: 't', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'tester.kind',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // First tick — held writ flows through. After acceptance, the
+      // writ's phase is no longer `new`, so a second tick simply does
+      // not see it as a candidate. Test the dedupe contract anyway by
+      // also synthesising a deferring scheduler later in this file.
+      await fix.hooks.runTick(syntheticTickEvent('e-tick-1'));
+      await fix.hooks.runTick(syntheticTickEvent('e-tick-2'));
+      await fix.hooks.runTick(syntheticTickEvent('e-tick-3'));
+
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      assert.equal(all[0]!.phase, 'open');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', all[0]!.id]],
+      });
+      assert.equal(rows.length, 1, 'exactly one row across repeated ticks');
+    });
+
+    it('a deferring scheduler running across two ticks at the same writUpdatedAt produces exactly one row', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.always-defer',
+        description: 'defers everything',
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          return input.candidates.map((w) => ({
+            writId: w.id,
+            outcome: 'defer' as const,
+            reason: 'capacity hold',
+          }));
