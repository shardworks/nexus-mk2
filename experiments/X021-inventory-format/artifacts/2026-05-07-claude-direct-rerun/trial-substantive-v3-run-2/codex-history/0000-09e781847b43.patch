+    // Unregistered-strict gate (existing path). Preserves the legacy
+    // resolution-string format byte-for-byte.
+    const isRegistered = deps.isSourceRegistered(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      await applyGateDecline({
+        deps,
+        clerk,
+        reckoningsBook,
+        writ,
+        ext,
+        now,
+        tickEventId,
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        resolution: unregisteredStrictResolution(ext.source),
+        gateName: 'unregistered-strict',
