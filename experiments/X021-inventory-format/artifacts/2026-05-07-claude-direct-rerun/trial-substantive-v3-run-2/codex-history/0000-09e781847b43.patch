+/**
+ * Reckoner tick-handler tests.
+ *
+ * Replaces the old `reckoner-cdc.test.ts` — the CDC subscription, the
+ * startup catch-up scan, and the per-writ-update consideration entry
+ * point are gone, so every behavioral case the originating brief
+ * enumerates is now exercised by driving the tick handler directly
+ * through `hooks.runTick(event?)`.
+ *
+ * Cases covered:
+ *
+ *   1. Empty-candidate tick — no rows, no errors.
+ *   2. First tick after start picks up pre-existing held writs (the
+ *      catch-up-scan replacement behavior).
+ *   3. `evaluate` throw — the tick is isolated; no rows written, no
+ *      transitions, the apparatus stays up.
+ *   4. Disabled-source mid-flight — produces a `declined` row carrying
+ *      `declineReason: 'source_banned'` and transitions the writ to
+ *      its cancelled target (D2).
+ *   5. Repeated-tick idempotency at unchanged `updatedAt` — the same
+ *      held writ ticked twice produces exactly one row.
+ *   6. Type-aware target-phase resolution — the tick uses the writ-
+ *      type config to pick the active state (mandate → `open`; a
+ *      custom non-mandate type → its registered active state).
+ *   7. Withdrawal-mid-flight — a held writ withdrawn before the tick
+ *      reaches it produces no Reckonings row.
+ *   8. Defer outcome writes a row with no transition; the row carries
+ *      `deferReason: 'other'` and the decision's reason in `deferNote`
+ *      (D3).
+ *   9. Pre-seal tick throws fail-loud (D8) with a diagnostic naming
+ *      `phase:started`.
+ *  10. Unregistered-strict decline path still applies inline at the
+ *      tick's source gate — the resolution string and row shape match
+ *      the legacy per-writ format byte-for-byte.
+ *  11. tickEventId stamping (D6) — when the relay is fired with a
+ *      synthetic `GuildEvent`, every row produced in the tick carries
+ *      the event id; when fired with `null`, the field is absent.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /**
+   * Re-fire `phase:started` against the registered handlers. The
+   * Reckoner's seal handler is synchronous in the tick model — there
+   * is no catch-up scan to await — but we keep the async signature so
+   * tests reading like the old fixture continue to compile.
+   */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  config?: ReckonerConfig | undefined;
+  writTypes?: WritTypeConfig[];
+  /**
+   * Optional pre-`start()` seed of writs into the writs book. Used
+   * to stage held petitions that pre-date apparatus startup so the
+   * first tick picks them up (the catch-up-scan replacement case).
+   */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+  /** Suppress the auto-fired `phase:started` so pre-seal tests can drive the tick. */
+  skipPhaseStarted?: boolean;
+  /** Suppress the auto-registration of the always-approve scheduler. */
+  omitDefaultScheduler?: boolean;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the apparatuses expect — Stacks' Wire phase
+  // would do this in production from the supportKit declarations.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler) {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  // Stacks
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  // Clerk
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  // Reckoner
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [];
+  if (!opts.omitDefaultScheduler) {
+    schedulerKitEntries.push({
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    });
+  }
+  for (const entry of opts.schedulerKits ?? []) {
+    schedulerKitEntries.push({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    });
+  }
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+/** Construct a synthetic `clockworks.timer` GuildEvent for tick-event-id stamping tests. */
+function makeTimerEvent(id: string): GuildEvent {
+  return {
+    id,
+    name: 'clockworks.timer',
+    payload: {},
+    emitter: 'framework',
+    firedAt: new Date().toISOString(),
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'vision-keeper',
+  value: [
+    { source: 'vision-keeper.snapshot', description: 'snapshots' },
+  ],
+};
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => {
+    clearGuild();
+  });
+
+  // ── 1: empty-candidate tick ────────────────────────────────────────
+
+  describe('empty candidate set', () => {
+    it('writes nothing and produces no errors when no held writs exist', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+      // No held writs; the tick should early-return after the find.
+      await fix.hooks.runTick();
+      const all = await fix.reckoningsBook.find({});
+      assert.equal(all.length, 0);
+    });
+  });
+
+  // ── 2: first tick after start picks up pre-existing held writs ─────
+
+  describe('first tick after start', () => {
+    it('processes held writs that pre-date apparatus startup', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        async preStart({ clerk }) {
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'vision-keeper.snapshot',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Drive the tick; the pre-existing held writ should now be
+      // approved and recorded.
+      await fix.hooks.runTick();
+
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      const writ = all[0]!;
+      assert.equal(writ.phase, 'open', 'tick auto-approves the writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── 3: evaluate throw isolation ────────────────────────────────────
+
+  describe('evaluate throw', () => {
+    it('logs fail-loud and skips the tick — no rows, no transitions', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad-evaluate',
+        description: 'throws on evaluate',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-evaluate' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick();
+      } finally {
+        console.warn = originalWarn;
+      }
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'evaluate-throw leaves writ in new');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0, 'no row when evaluate throws');
+      assert.ok(
+        warnings.some(
+          (w) => /\[reckoner\] scheduler:/.test(w) && /evaluate threw/.test(w),
+        ),
+        `expected evaluate-throw warning; got: ${JSON.stringify(warnings)}`,
+      );
+    });
+  });
+
+  // ── 4: disabled-source mid-flight decline+cancel ───────────────────
+
+  describe('disabled-source gate', () => {
+    it('declines + transitions to cancelled with declineReason source_banned (D2)', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        config: { disabledSources: ['vision-keeper.snapshot'] },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      // Sanity: petition() does not pre-emptively transition or write
+      // a row; the gate fires inside the tick.
+      const beforeTick = await fix.clerk.show(writ.id);
+      assert.equal(beforeTick.phase, 'new');
+
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'vision-keeper\.snapshot' is disabled by reckoner\.disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'vision-keeper.snapshot');
+      assert.equal(rows[0]!.source, 'vision-keeper.snapshot');
+    });
+  });
+
+  // ── 5: repeated-tick idempotency ───────────────────────────────────
+
+  describe('repeated tick idempotency', () => {
+    it('produces exactly one row across two ticks at unchanged updatedAt', async () => {
+      // Use a custom scheduler that defers so the writ stays in `new`
+      // across the second tick (an approve would transition it out and
+      // mask the dedupe path).
+      const scheduler: Scheduler = {
+        id: 'kit-a.defer',
+        description: 'defers every candidate',
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          return input.candidates.map((w) => ({
+            writId: w.id,
+            outcome: 'defer' as const,
+            reason: 'capacity hold',
+          }));
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.defer' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      await fix.hooks.runTick();
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1, 'second tick at unchanged updatedAt is a no-op');
+      assert.equal(rows[0]!.outcome, 'deferred');
+    });
+  });
+
+  // ── 6: type-aware target-phase resolution ──────────────────────────
+
+  describe('target-phase resolution', () => {
+    it('picks `open` for mandate writs', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+      });
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open');
+      assert.equal(reread.type, 'mandate');
+    });
+
+    it('picks the registered active state for a non-mandate type', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [
+          {
+            pluginId: 'tester',
+            value: [{ source: 'tester.kind', description: 'tester' }],
+          },
+        ],
+        writTypes: [
+          {
+            name: 'task',
+            states: [
+              {
+                name: 'new',
+                classification: 'initial',
+                allowedTransitions: ['running', 'cancelled'],
+              },
+              {
+                name: 'running',
+                classification: 'active',
+                allowedTransitions: ['done', 'cancelled'],
+              },
+              {
+                name: 'done',
+                classification: 'terminal',
+                attrs: ['success'],
+                allowedTransitions: [],
+              },
+              {
+                name: 'cancelled',
+                classification: 'terminal',
+                attrs: ['cancelled'],
+                allowedTransitions: [],
+              },
+            ],
+          },
+        ],
+      });
+
+      const writ = await fix.reckoner.petition({
+        type: 'task',
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.type, 'task');
+      assert.equal(
+        reread.phase,
+        'running',
+        'non-mandate type lands in its registered active state, not `open`',
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── 7: withdrawal-mid-flight ───────────────────────────────────────
+
+  describe('withdrawal mid-flight', () => {
+    it('produces no Reckonings row when the petitioner withdraws before the tick reaches the writ', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      // Withdraw before the tick fires. The writ leaves `new`, so
+      // the tick's held-petitions query never sees it.
+      await fix.reckoner.withdraw(writ.id, 'no longer relevant');
+
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0, 'withdrawn writs produce no row');
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+    });
+  });
+
+  // ── 8: defer outcome writes a row with no transition (D3) ──────────
+
+  describe('defer outcome', () => {
+    it('writes a deferred row with deferReason "other" and the decision reason in deferNote', async () => {
+      const reason = 'capacity hold';
+      const scheduler: Scheduler = {
+        id: 'kit-a.defer',
+        description: 'defers every candidate',
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          return input.candidates.map((w) => ({
+            writId: w.id,
+            outcome: 'defer' as const,
+            reason,
+          }));
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.defer' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new', 'defer leaves writ in new');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1, 'defer writes one Reckonings row');
+      assert.equal(rows[0]!.outcome, 'deferred');
+      assert.equal(rows[0]!.deferReason, 'other');
+      assert.equal(rows[0]!.deferNote, reason);
+      // No decline metadata leaked onto the deferred row.
+      assert.equal(rows[0]!.declineReason, undefined);
+      assert.equal(rows[0]!.remediationHint, undefined);
+    });
+  });
+
+  // ── 9: pre-seal tick fail-loud (D8) ────────────────────────────────
+
+  describe('pre-seal tick', () => {
+    it('throws fail-loud naming phase:started when activeScheduler is unresolved', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        skipPhaseStarted: true,
+      });
+      assert.equal(fix.hooks.getActiveSchedulerId(), undefined);
+      await assert.rejects(
+        () => fix.hooks.runTick(),
+        (err: Error) => {
+          assert.match(err.message, /\[reckoner\] tick: activeScheduler not resolved/);
+          assert.match(err.message, /phase:started has not fired/);
+          return true;
+        },
+      );
+    });
+  });
+
+  // ── 10: unregistered-strict decline path on the tick ───────────────
+
+  describe('unregistered-strict gate', () => {
+    it('declines unregistered sources with source_unregistered and a structured resolution', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [],
+        config: { enforceRegistration: true },
+      });
+
+      // The petition helper itself fail-loud rejects unregistered
+      // sources under strict registration; to drive the tick path,
+      // post the writ + ext via Clerk directly so the tick sees the
+      // held petition without going through the helper's gate.
+      const writ = await fix.clerk.post({ title: 't', body: 'b' });
