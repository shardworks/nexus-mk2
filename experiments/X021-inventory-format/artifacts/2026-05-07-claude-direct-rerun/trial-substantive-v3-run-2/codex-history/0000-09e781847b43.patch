+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // ── Decision validation ───────────────────────────────────────────
+  const candidateIds = new Set<string>(
+    candidateSet.map((entry) => entry.writ.id),
+  );
+
+  // Filter-and-warn on stranger writIds (D9 — apply only in-scope decisions).
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  // Group by writId; fail-loud-skip the entire tick on multi-decision per writ (D9).
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any decision in this tick. Schedulers must emit at most one decision per candidate.`,
+      );
+      return;
+    }
+  }
+
+  // ── Apply each decision ───────────────────────────────────────────
+  for (const entry of candidateSet) {
+    const decision = grouped.get(entry.writ.id)?.[0];
+    if (!decision) {
+      // No decision for this candidate — defer-equivalent absence.
+      // The brief specifies one row per writ considered; absence-of-
+      // decision is its own signal so we follow the per-call precedent
+      // (no row, no transition).
+      continue;
+    }
+    await applySchedulerDecision({
+      deps,
+      clerk,
+      reckoningsBook,
+      activeSchedulerId: activeScheduler.id,
+      writ: entry.writ,
+      ext: entry.ext,
+      decision,
+      now,
+      tickEventId,
+    });
+  }
+}
+
+// ── Helpers ─────────────────────────────────────────────────────────
+
+interface ApplyGateDeclineInputs {
+  deps: TickHandlerDeps;
+  clerk: ClerkApi;
+  reckoningsBook: Book<ReckoningDoc>;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  now: Date;
+  tickEventId: string | undefined;
+  declineReason: NonNullable<ReckoningDoc['declineReason']>;
+  remediationHint: string;
+  resolution: string;
+  gateName: string;
+}
+
+/**
+ * Drive the cancelled transition + write the matching decline row for
+ * a writ that failed a pre-scheduler gate. Logs and returns on
+ * transition / persistence errors so a single problem writ does not
+ * block sibling decisions in the same tick.
+ */
+async function applyGateDecline(inputs: ApplyGateDeclineInputs): Promise<void> {
+  const {
+    deps,
+    clerk,
+    reckoningsBook,
+    writ,
+    ext,
+    now,
+    tickEventId,
+    declineReason,
+    remediationHint,
+    resolution,
+    gateName,
+  } = inputs;
+
+  // Dedupe before paying the transition / write cost.
+  if (await deps.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+    return;
+  }
+
+  try {
+    await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (${gateName} gate): ${msg}`,
+    );
+    return;
+  }
+
+  const row = deps.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason,
+    remediationHint,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (${gateName} gate): ${msg}`,
+    );
+  }
+}
+
+interface ApplySchedulerDecisionInputs {
+  deps: TickHandlerDeps;
+  clerk: ClerkApi;
+  reckoningsBook: Book<ReckoningDoc>;
+  activeSchedulerId: string;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  decision: SchedulerDecision;
+  now: Date;
+  tickEventId: string | undefined;
+}
+
+/**
+ * Apply one decision: transition the writ (when the outcome calls for
+ * it) and append one Reckonings row. Outcome → row mapping mirrors
+ * D3 (deferred row carrying `deferReason: 'other'`) and the existing
+ * decline path (`declineReason: 'other'` + `remediationHint`).
+ */
+async function applySchedulerDecision(
+  inputs: ApplySchedulerDecisionInputs,
+): Promise<void> {
+  const {
+    deps,
+    clerk,
+    reckoningsBook,
+    activeSchedulerId,
+    writ,
+    ext,
+    decision,
+    now,
+    tickEventId,
+  } = inputs;
+
+  const outcome = decision.outcome;
+  if (outcome !== 'approve' && outcome !== 'decline' && outcome !== 'defer') {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeSchedulerId}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+    return;
+  }
+
+  if (outcome === 'defer') {
+    // No transition. D3: write a deferred row carrying
+    // `deferReason: 'other'` plus `deferNote` (the decision's reason).
+    const row = deps.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'deferred',
+      deferReason: 'other',
+      deferNote: decision.reason,
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  if (outcome === 'decline') {
+    const resolution = decision.reason;
+    try {
+      await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+      );
+      return;
+    }
+    const row = deps.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'declined',
+      declineReason: 'other',
+      remediationHint: decision.reason,
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  // approve.
+  let target: string;
+  try {
+    target = deps.resolveActiveTargetPhase(writ);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+    );
+    return;
+  }
+
+  try {
+    await clerk.transition(writ.id, target as WritPhase, {});
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+    );
+    return;
+  }
+
+  const row = deps.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'accepted',
+    ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+    );
+  }
+}
+
+// ── Relay factory ───────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. Exported so the
+ * apparatus boot path can wire it into `supportKit.relays`. Tests
+ * that drive the handler body directly do so via
+ * `runTickHandlerBody(deps, event)`.
+ */
+export function createReckonerTickRelay(deps: TickHandlerDeps): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY_NAME,
+    description:
+      'Walks every held petition (writs in their type initial phase ' +
+      'carrying ext.reckoner) and runs the configured scheduler in ' +
+      'one batch on each fire. Transitions and Reckonings rows are ' +
+      'applied per the resulting decisions.',
+    handler: async (event) => {
+      await runTickHandlerBody(deps, event);
+    },
+  });
+}
