+  const tickEventId = event?.id;
+
+  // ── Held-writs query ──────────────────────────────────────────────
+  //
+  // The brief explicitly carries forward the existing literal-phase
+  // shape (phase = 'new'). The type-agnostic generalization that would
+  // iterate Clerk's writ-type registry for non-`new` initial phases is
+  // observed and lifted as a separate concern.
