+  if (heldPetitions.length === 0) {
+    // D10: empty candidate set — write nothing, no errors. We deliberately
+    // return before paying the scheduler-config / `validateConfig` cost.
+    return;
+  }
+
+  const config = deps.resolveConfig();
+  const clerk = deps.getClerk();
+
+  // Sample `now` once at handler entry. Reused for every row's id seed
+  // and `consideredAt` so all rows produced by this tick share the same
+  // notional timestamp.
+  const now = new Date();
+
+  // ── Source / disabled gates ───────────────────────────────────────
+  //
+  // Inline pre-scheduler walk: each writ failing a gate is transitioned
+  // to its cancelled target and produces a Reckonings decline row. The
+  // gate failures never reach the scheduler — the candidate set handed
+  // to `evaluate` only contains writs that survived.
