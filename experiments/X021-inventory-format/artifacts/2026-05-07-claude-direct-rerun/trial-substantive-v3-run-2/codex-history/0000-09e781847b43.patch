+/**
+ * `reckoner.tick` — periodic Reckoner-evaluation relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` so every guild that
+ * installs both the Reckoner and Clockworks runs the same standing
+ * order:
+ *
+ *   { schedule: '@every 60s', run: 'reckoner.tick' }
+ *
+ * On every fire the handler walks every currently-held petition (writs
+ * in their type's initial phase carrying `ext.reckoner`), applies the
+ * source / disabled gates, dedupes against the Reckonings book, and
+ * hands the surviving candidate set to the configured scheduler in one
+ * batch. The scheduler returns one decision per writ; the handler
+ * applies each decision and appends one Reckonings row per writ
+ * considered.
+ *
+ * The CDC-driven per-writ evaluation surface that originally lived in
+ * `reckoner.ts` is replaced wholesale by this tick; the Reckoner now
+ * has exactly one evaluation entry point.
+ *
+ * Source-file layout follows the stdlib-relay pattern (sibling file
+ * exporting both a relay factory and a pure helper-body the in-package
+ * tests can drive without booting Clockworks). See `summon-relay.ts`
+ * (Clockworks) and `decline-relay.ts` (Vision-keeper).
+ *
+ * See: docs/architecture/apparatus/reckoner.md and
+ * docs/architecture/reckonings-book.md.
+ */
+
+import type { Book, ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+import type { ClerkApi, WritDoc, WritPhase } from '@shardworks/clerk-apparatus';
+import type { GuildEvent, RelayDefinition } from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  ReckonerExt,
+  ReckoningDoc,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/**
+ * The literal contract id of the relay. Any change here cascades into
+ * the kit-contributed standing order, the `tickEventId` payload
+ * shape, the doc set, and the audit greps in the Acceptance Signal —
+ * keep them aligned.
+ */
+export const RECKONER_TICK_RELAY_NAME = 'reckoner.tick';
+
+/**
+ * The plugin id stamped on `writ.ext['reckoner']`. Imported here as a
+ * literal so the tick handler stays decoupled from the apparatus
+ * factory's internal export surface.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * Resolved view of the `reckoner` block in `guild.json`. Mirrors the
+ * shape returned by the apparatus's `resolveConfig` helper — kept
+ * structural so the tick file does not need to import the closure-
+ * scoped resolver type.
+ */
+export interface ResolvedReckonerConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Argument shape for the row-construction helper threaded through the
+ * tick handler. Mirrors the apparatus's `buildReckoningRow` body so
+ * the tick can build accept / decline / defer rows uniformly.
+ */
+export interface BuildReckoningRowParams {
+  now: Date;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  outcome: 'accepted' | 'declined' | 'deferred';
+  declineReason?: ReckoningDoc['declineReason'];
+  remediationHint?: string;
+  deferReason?: ReckoningDoc['deferReason'];
+  deferNote?: string;
+  weight?: number;
+  /**
+   * Stamped from the triggering `clockworks.timer` event id when the
+   * tick was driven through Clockworks. Absent for direct test-hook
+   * invocations with a `null` event (D6).
+   */
+  tickEventId?: string;
+}
+
+/**
+ * Dependencies the tick handler reaches for at fire time. The
+ * Reckoner's `start()` populates this once and hands the same object to
+ * the relay factory; in-package tests construct it directly so they
+ * can drive the handler without booting Clockworks.
+ */
+export interface TickHandlerDeps {
+  /** Resolve the live Clerk handle. Throws if Clerk is not installed. */
+  getClerk(): ClerkApi;
+  /** Resolve the live Stacks handle, or `undefined` before `start()`. */
+  getStacks(): StacksApi | undefined;
+  /** Reckonings book handle, or `undefined` before `start()`. */
+  getReckoningsBook(): Book<ReckoningDoc> | undefined;
+  /**
+   * Active scheduler resolved at `phase:started`, or `undefined` when
+   * the seal handler has not yet fired. The tick fail-loud throws on
+   * `undefined` (D8) — production never trips it; test fixtures get a
+   * deterministic loud signal.
+   */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Returns `true` when the source is in the kit-static petitioner registry. */
+  isSourceRegistered(source: string): boolean;
+  /** Read-and-validate `guild().guildConfig().reckoner` (defaults applied). */
+  resolveConfig(): ResolvedReckonerConfig;
+  /** Read the live `reckoner.schedulerConfig` slot (returns `undefined` when absent). */
+  resolveSchedulerConfig(): unknown;
+  /** Compute the type-aware active target phase for `writ`. Throws on ambiguity. */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /** Returns `true` when a Reckonings row already exists for the (writId, writUpdatedAt) pair. */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /** Construct a Reckonings row from in-flight consideration state. */
+  buildReckoningRow(params: BuildReckoningRowParams): ReckoningDoc;
+}
+
+/**
+ * Unregistered-strict resolution-string template — matches the legacy
+ * per-writ shape verbatim so audit consumers parsing the resolution
+ * field do not have to discriminate between the two paths.
+ */
+function unregisteredStrictResolution(source: string): string {
+  return `[reckoner] declined: source '${source}' is not registered (enforceRegistration: true).`;
+}
+
+/**
+ * Disabled-source resolution-string template. Mirrors the
+ * unregistered-strict shape but names its own decline reason so an
+ * operator parsing the resolution field can discriminate the two
+ * decline paths without consulting the Reckonings row's
+ * `declineReason` field.
+ */
+function disabledSourceResolution(source: string): string {
+  return `[reckoner] declined: source '${source}' is disabled by reckoner.disabledSources.`;
+}
+
+/**
+ * The pure tick-handler body. Exported so the in-package tests can
+ * drive it directly without booting Clockworks; the relay factory in
+ * `createReckonerTickRelay` thinly wraps it.
+ *
+ * `event` is the triggering `GuildEvent` for tickEventId stamping
+ * (D6). Tests pass `null` to exercise the absent-event path.
+ *
+ * Per-fire sequence (matching the brief verbatim):
+ *
+ *   1. Resolve `activeScheduler`. Pre-seal calls fail-loud (D8) — the
+ *      apparatus's seal handler is the only path that resolves the
+ *      reference, so `undefined` here means a misordered tick.
+ *   2. Query held petitions. We use the same `find` shape today's
+ *      catch-up scan used (`phase = 'new'` literal, ordered by
+ *      `createdAt`) and filter to writs carrying `ext.reckoner`. The
+ *      brief defers the type-agnostic generalization to a future
+ *      observation (Out-of-radius drift section).
+ *   3. Apply source / disabled gates. Each writ failing the gate is
+ *      transitioned to its cancelled target with the matching
+ *      `declineReason` row, then dropped from the candidate set
+ *      before the scheduler is consulted.
+ *   4. Dedupe (D7) — drop writs whose `(writId, writUpdatedAt)` pair
+ *      is already in the Reckonings book.
+ *   5. Empty candidate-set short-circuit (D10) — nothing left to
+ *      evaluate; return without calling the scheduler.
+ *   6. Re-read + `validateConfig` the scheduler config; throws are
+ *      fail-loud-skip (no rows for any writ in this tick).
+ *   7. `evaluate` once across the whole candidate set. Throws are
+ *      fail-loud-skip.
+ *   8. Decision validation — filter-and-warn on stranger `writId`s
+ *      (D9); fail-loud-skip the entire tick on multi-decision per
+ *      writ (D9).
+ *   9. Apply each decision: approve → transition to active target +
+ *      accepted row; decline → transition to cancelled + declined
+ *      row carrying `declineReason: 'other'` and `remediationHint`;
+ *      defer → no transition + deferred row carrying
+ *      `deferReason: 'other'` and `deferNote` (D3).
+ *
+ * Failures inside per-writ application steps (a single transition or
+ * row write throwing) are caught and logged; the tick continues so a
+ * single problem writ does not block sibling decisions.
+ */
+export async function runTickHandlerBody(
+  deps: TickHandlerDeps,
+  event: GuildEvent | null,
+): Promise<void> {
+  const stacks = deps.getStacks();
+  const reckoningsBook = deps.getReckoningsBook();
+  if (!stacks || !reckoningsBook) {
+    // Pre-`start()` defensive guard. In production the relay never
+    // dispatches before the apparatus has primed its handles —
+    // standing-order dispatch starts after `phase:started`. This
+    // protects test fixtures that call `runTick` against a partially-
+    // built apparatus.
+    return;
+  }
+
+  const activeScheduler = deps.getActiveScheduler();
+  if (!activeScheduler) {
+    // D8: fail-loud throw. Production never trips this — `phase:started`
+    // resolves the active scheduler before the dispatcher starts firing
+    // standing orders. Tests that drive `runTick` pre-seal get a
+    // deterministic loud signal naming the missed step.
+    throw new Error(
+      `[reckoner] tick: activeScheduler not resolved — phase:started has not fired.`,
+    );
+  }
