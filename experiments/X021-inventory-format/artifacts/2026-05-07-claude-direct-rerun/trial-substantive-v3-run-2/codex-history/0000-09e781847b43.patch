+        clerk,
+        reckoningsBook,
+        writ,
+        ext,
+        now,
+        tickEventId,
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        resolution: disabledSourceResolution(ext.source),
+        gateName: 'disabled-source',
+      });
+      continue;
+    }
