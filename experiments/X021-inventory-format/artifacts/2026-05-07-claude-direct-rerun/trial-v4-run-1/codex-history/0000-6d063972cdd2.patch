index 0000000..b481609
--- /dev/null
+++ b/packages/plugins/reckoner/src/tick.ts
@@ -0,0 +1,563 @@
+/**
+ * `reckoner.tick` — periodic petition-evaluation relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` so any guild that
+ * installs the Reckoner alongside the Clockworks runs the standing
+ * order:
+ *
+ *   {
+ *     "schedule": "@every 60s",
+ *     "run": "reckoner.tick"
+ *   }
+ *
+ * Per-fire sequence:
+ *
+ *   1. Resolve the active scheduler from the apparatus's closed-over
+ *      registry. Throw fail-loud when unresolved (`phase:started` has
+ *      not run yet) — production never trips this; tests assert the
+ *      throw to lock down the ordering invariant.
+ *   2. Re-read `reckoner.schedulerConfig` and run
+ *      `Scheduler.validateConfig` if declared. A throw inside
+ *      `validateConfig` logs fail-loud and skips the tick (no rows,
+ *      no transitions).
+ *   3. Query held petitions — writs in `new` phase carrying
+ *      `ext.reckoner` — through the Stacks read-book the apparatus
+ *      already opens.
+ *   4. Apply source/disabled gates inline. Failing writs produce a
+ *      decline Reckonings row + transition to the type's cancelled
+ *      target; they do not reach the scheduler.
+ *   5. Filter the survivors against `(writId, writUpdatedAt)` dedupe
+ *      *before* building `SchedulerInput`, so already-considered
+ *      writs never reach the scheduler.
+ *   6. Build `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 capacity stub and call `evaluate` inside a
+ *      try/catch. A throw fail-loud-skips the entire tick (no rows
+ *      written for any candidate).
+ *   7. Validate decisions: filter-and-warn on stranger writIds,
+ *      fail-loud-skip the tick on multi-decision-per-writ.
+ *   8. Apply each decision (approve → active target, decline →
+ *      cancelled target, defer → no transition) and append one
+ *      Reckonings row per writ considered, stamping `tickEventId`
+ *      from the triggering `clockworks.timer` event id when the
+ *      relay was driven by Clockworks; omitting the field for
+ *      direct-invocation calls (e.g. unit tests handing a `null`
+ *      event).
+ *
+ * The handler body lives in `runTick`, which takes a dependency
+ * context the apparatus's `buildReckoner()` closure passes in. Tests
+ * drive `runTick` directly without booting the Clockworks; the
+ * `createTickRelay` factory is the production wiring used by
+ * `supportKit.relays`.
+ *
+ * See: `docs/architecture/apparatus/reckoner.md` (apparatus shape)
+ * and `docs/architecture/reckonings-book.md` §"Tick identity".
+ */
+
+import type {
+  GuildEvent,
+  RelayDefinition,
+} from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  Book,
+  ReadOnlyBook,
+} from '@shardworks/stacks-apparatus';
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+} from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckoningDoc,
+  ReckonerExt,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/** Public registration key. Operators name this in `run:`. */
+export const TICK_RELAY_NAME = 'reckoner.tick';
+
+/** Hardcoded schedule expression for the kit-contributed standing order. */
+export const TICK_RELAY_SCHEDULE = '@every 60s';
+
+/**
+ * Plugin id stamped on `writ.ext['reckoner']`. Must equal
+ * `RECKONER_PLUGIN_ID` in `reckoner.ts`. Duplicated here rather than
+ * imported to keep the tick module's import surface narrow.
+ */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+/**
+ * Resolved configuration the tick consumes for source / disabled gating.
+ * Mirrors the shape `resolveConfig()` in `reckoner.ts` returns.
+ */
+export interface TickResolvedConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Dependency-injection bundle for the tick handler. The apparatus's
+ * `buildReckoner()` closure constructs this and passes it into
+ * `createTickRelay()` (production) or `runTick()` (tests).
+ */
+export interface TickDeps {
+  /** The Clerk API used to drive transitions. */
+  clerk: () => ClerkApi;
+  /**
+   * Read-only handle to the Clerk writs book. Used to query held
+   * petitions per fire.
+   */
+  writsBook: () => ReadOnlyBook<WritDoc> | undefined;
+  /** Reckoner-owned writable book — the row destination per consideration. */
+  reckoningsBook: () => Book<ReckoningDoc> | undefined;
+  /**
+   * Lookup `(writId, writUpdatedAt)` dedupe identity. Returns true when
+   * a Reckonings row has already been written for the same triggering
+   * writ-version. Identical to the closure-local helper in
+   * `reckoner.ts`; reused by reference so the per-call dedupe path
+   * stays single-sourced.
+   */
+  alreadyConsidered: (writId: string, writUpdatedAt: string) => Promise<boolean>;
+  /** Source/disabled gating config. Re-read per call (D20). */
+  resolveConfig: () => TickResolvedConfig;
+  /** `reckoner.schedulerConfig` re-read per evaluation (D17). */
+  resolveSchedulerConfig: () => unknown;
+  /** Sealed source-registry test. */
+  isSourceRegistered: (source: string) => boolean;
+  /** Active scheduler accessor — `undefined` pre-seal. */
+  getActiveScheduler: () => Scheduler | undefined;
+  /** Type-aware target-phase resolution for an approve transition. */
+  resolveActiveTargetPhase: (writ: WritDoc) => string;
+  /**
+   * Build a Reckonings row from the consideration state. The apparatus
+   * keeps this helper closure-local so the row id seed and
+   * `consideredAt` are derived from the same `now` Date.
+   */
+  buildReckoningRow: (params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    outcome: 'accepted' | 'declined' | 'deferred';
+    declineReason?: ReckoningDoc['declineReason'];
+    deferReason?: ReckoningDoc['deferReason'];
+    remediationHint?: string;
+    deferNote?: string;
+    weight?: number;
+    tickEventId?: string;
+  }) => ReckoningDoc;
+}
+
+/**
+ * Run one tick of the Reckoner against the current set of held
+ * petitions.
+ *
+ * Pure helper — boot order, state, and lifecycle are owned by the
+ * apparatus's closure; the tick body sees only the dependency bundle
+ * and the triggering event (`null` for direct-invocation paths).
+ *
+ * @param event   The triggering Clockworks event, or `null` when the
+ *                handler is driven directly (tests, future programmatic
+ *                callers). Only `event.id` is read.
+ * @param deps    The dependency bundle from `buildReckoner()`.
+ * @throws        Fail-loud when `getActiveScheduler()` returns
+ *                `undefined` — the apparatus has not yet sealed.
+ *                Production never trips this; tests assert the throw
+ *                to verify the ordering invariant (D8).
+ */
+export async function runTick(
+  event: GuildEvent | null,
+  deps: TickDeps,
+): Promise<void> {
+  // ── 1. Active-scheduler resolution (D8) ─────────────────────────────
+  const activeScheduler = deps.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  // The reckonings book and the writs book come from the apparatus
+  // closure; both must be live by the time a tick fires (start() runs
+  // before phase:started). A missing handle is a defensive guard, not
+  // an expected runtime path.
+  const reckoningsBook = deps.reckoningsBook();
+  const writsBook = deps.writsBook();
+  if (!reckoningsBook || !writsBook) {
+    return;
+  }
+
+  // ── 2. schedulerConfig re-read + validateConfig narrow (D17/D18) ────
+  //
+  // Performed before the candidate query so a mis-configured
+  // schedulerConfig does not waste a writs-book scan. The narrow
+  // result is shared across every candidate in this fire — schedulers
+  // expect one validated value per evaluate call.
+  const rawSchedulerConfig = deps.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // ── 3. Held-petitions query ────────────────────────────────────────
+  //
+  // Literal-phase find by `phase = 'new'`, then in-process filter to
+  // writs carrying `ext.reckoner`. The query stays literal-phase (not
+  // type-walked) because the brief carries forward that constraint.
+  // Generalization is observed but out of scope.
+  const newWrits = await writsBook.find({
+    where: [['phase', '=', 'new']],
+    orderBy: ['createdAt', 'asc'],
+  });
+
+  const heldWrits: WritDoc[] = [];
+  for (const writ of newWrits) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+    heldWrits.push(writ);
+  }
+
+  // Sample `now` once at the call boundary (D33) so the row id seeds
+  // and `consideredAt` strings stay consistent within this tick.
+  const now = new Date();
+
+  // ── 4. Source / disabled gates ─────────────────────────────────────
+  //
+  // Inline so failing writs produce a decline row + cancelled-target
+  // transition without going through the scheduler. Each branch
+  // consults the dedupe lookup so a tick re-fire on the same writ
+  // version does not produce a duplicate row.
+  const config = deps.resolveConfig();
+  const tickEventId = event?.id;
+
+  const candidates: WritDoc[] = [];
+  for (const writ of heldWrits) {
+    const ext = writ.ext![RECKONER_PLUGIN_ID] as ReckonerExt;
+
+    // Disabled-source gate (D2) — write a decline row carrying
+    // `declineReason: 'source_banned'` and the source name in
+    // `remediationHint`, transition to the type's cancelled target.
+    if (config.disabledSources.includes(ext.source)) {
+      if (await deps.alreadyConsidered(writ.id, writ.updatedAt)) continue;
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is in reckoner.disabledSources.`;
+      try {
+        await deps.clerk().transition(writ.id, 'cancelled' as WritPhase, {
+          resolution,
+        });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (disabled-source decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = deps.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_banned',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // Unregistered-strict gate — preserves the resolution-string format
+    // from the prior CDC handler so any operator searching the journal
+    // for the legacy decline still finds it.
+    if (!deps.isSourceRegistered(ext.source) && config.enforceRegistration) {
+      if (await deps.alreadyConsidered(writ.id, writ.updatedAt)) continue;
+      const resolution =
+        `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+      try {
+        await deps.clerk().transition(writ.id, 'cancelled' as WritPhase, {
+          resolution,
+        });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (unregistered-strict decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = deps.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'source_unregistered',
+        remediationHint: ext.source,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (unregistered-strict decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    candidates.push(writ);
+  }
+
+  // ── 5. Pre-scheduler dedupe (D7) ───────────────────────────────────
+  //
+  // Filter against the (writId, writUpdatedAt) dedupe lookup before
+  // building SchedulerInput. Already-considered writs never reach the
+  // scheduler — pre-write dedupe would have the scheduler emit
+  // decisions the row-write layer silently discards, hiding drift.
+  const freshCandidates: WritDoc[] = [];
+  for (const writ of candidates) {
+    if (await deps.alreadyConsidered(writ.id, writ.updatedAt)) continue;
+    freshCandidates.push(writ);
+  }
+
+  // ── D10: empty-candidate early return ───────────────────────────────
+  if (freshCandidates.length === 0) {
+    return;
+  }
+
+  // ── 6. evaluate() ──────────────────────────────────────────────────
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates: freshCandidates,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] scheduler: "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // ── 7. Decision validation (D9) ────────────────────────────────────
+  const candidateIds = new Set<string>(freshCandidates.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof (decision as { writId?: unknown }).writId !== 'string' ||
+      (decision as { writId: string }).writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has((decision as SchedulerDecision).writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned a decision for writ "${(decision as SchedulerDecision).writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision as SchedulerDecision);
+  }
+
+  // Group by writId; fail-loud-skip the entire tick on multi-decision-per-writ.
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate. Skipping the entire tick.`,
+      );
+      return;
+    }
+  }
+
+  // ── 8. Apply decisions ─────────────────────────────────────────────
+  for (const writ of freshCandidates) {
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) {
+      // No decision for this candidate — defer-equivalent silence,
+      // no row, no transition.
+      continue;
+    }
+
+    const ext = writ.ext![RECKONER_PLUGIN_ID] as ReckonerExt;
+
+    // Sanity-check the outcome enum. An unknown value is logged and
+    // skipped per-writ (sibling decisions still apply).
+    if (
+      decision.outcome !== 'approve' &&
+      decision.outcome !== 'decline' &&
+      decision.outcome !== 'defer'
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] scheduler: "${activeScheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+      );
+      continue;
+    }
+
+    if (decision.outcome === 'defer') {
+      // No transition. Write a deferred row carrying deferReason
+      // 'other' + the decision's reason in deferNote (D3). Other
+      // defer-metadata fields stay absent.
+      const row = deps.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'deferred',
+        deferReason: 'other',
+        deferNote: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler defer): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      const resolution = decision.reason;
+      try {
+        await deps.clerk().transition(writ.id, 'cancelled' as WritPhase, {
+          resolution,
+        });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = deps.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: 'other',
+        remediationHint: decision.reason,
+        ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // approve.
+    let target: string;
+    try {
+      target = deps.resolveActiveTargetPhase(writ);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+      );
+      continue;
+    }
+
+    try {
+      await deps.clerk().transition(writ.id, target as WritPhase, {});
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+      );
+      continue;
+    }
+
+    const row = deps.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'accepted',
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+      );
+    }
+  }
+}
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. The apparatus boot
+ * path passes its dependency bundle in; production wiring places this
+ * on `apparatus.supportKit.relays`, and the kit-contributed standing
+ * order at `@every 60s` drives it.
+ */
+export function createTickRelay(deps: TickDeps): RelayDefinition {
+  return relay({
+    name: TICK_RELAY_NAME,
+    description:
+      'Reckoner periodic tick — evaluates every held petition through the configured scheduler in one batch per fire.',
+    handler: (event, _context) => runTick(event, deps),
+  });
+}
