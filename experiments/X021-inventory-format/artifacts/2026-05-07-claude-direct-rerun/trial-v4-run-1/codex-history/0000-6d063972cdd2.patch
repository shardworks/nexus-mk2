@@ -204,11 +204,13 @@ export interface PetitionerDescriptor {
 // ── Reckonings record ────────────────────────────────────────────────
 
 /**
- * Outcome enum for a Reckonings record. v0 of the CDC handler emits
- * only `'accepted'` (after a successful `new → active` transition) and
