+/**
+ * Reckoner tick handler tests.
+ *
+ * Covers the behavioral cases enumerated in the commission's
+ * Acceptance Signal — every case driven through `hooks.runTick()`:
+ *
+ *   1. empty-candidate ticks — no rows, no errors.
+ *   2. first tick after start — pre-existing held writs are picked up.
+ *   3. evaluate-throw isolation — apparatus stays up, no rows written.
+ *   4. disabled-source mid-flight — decline + cancel transition.
+ *   5. unregistered-strict mid-flight — decline + cancel transition.
+ *   6. registered-source approve path — accepted row + active transition.
+ *   7. repeated-tick idempotency at unchanged updatedAt — exactly one row.
+ *   8. type-aware target-phase resolution — non-mandate type transitions
+ *      to its registered active state.
+ *   9. withdrawal mid-flight — withdrawn writs do not produce rows.
+ *  10. defer outcome — writes a row carrying deferReason 'other' and
+ *      the decision's reason in deferNote; no transition.
+ *  11. pre-seal tick throws fail-loud (D8).
+ *  12. tickEventId is stamped from the triggering event id when present
+ *      and omitted when absent.
+ *
+ * The fixture mirrors the scaffolding in `reckoner.test.ts` — real
+ * Stacks + Clerk + Reckoner against MemoryBackend, with explicit
+ * book pre-creation.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /**
+   * Re-fire `phase:started` against the registered handlers. Awaits
+   * any async handlers.
+   */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  /** When true, do not include the built-in always-approve scheduler. */
+  omitDefaultScheduler?: boolean;
+  config?: ReckonerConfig | undefined;
+  /** Optional writ types to register on the Clerk before the Reckoner starts. */
+  writTypes?: WritTypeConfig[];
+  /** Pre-seed writs into the writs book before the Reckoner's start() runs. */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+  /** When true, do not fire phase:started after start (pre-seal tests). */
+  skipPhaseStarted?: boolean;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the Clerk needs.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler) {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [];
+  if (!opts.omitDefaultScheduler) {
+    schedulerKitEntries.push({
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    });
+  }
+  for (const entry of opts.schedulerKits ?? []) {
+    schedulerKitEntries.push({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    });
+  }
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+const VISION_KEEPER_PETITIONER = {
+  pluginId: 'vision-keeper',
+  value: [{ source: 'vision-keeper.snapshot', description: 'snapshots' }],
+};
+
+const SAMPLE_TICK_EVENT: GuildEvent = {
+  id: 'e-test-12345',
+  name: 'clockworks.timer',
+  payload: {},
+  emitter: 'framework',
+  firedAt: '2026-01-01T00:00:00.000Z',
+};
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => {
+    clearGuild();
+  });
+
+  // ── 1: empty-candidate ticks ───────────────────────────────────────
+
+  describe('empty candidate set', () => {
+    it('writes no rows and surfaces no errors when no held writs exist', async () => {
+      const fix = await buildFixture({ petitionerKits: [VISION_KEEPER_PETITIONER] });
+      await fix.hooks.runTick(null);
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0, 'empty candidate set must write nothing');
+    });
+  });
+
+  // ── 2: first tick picks up pre-existing held writs ─────────────────
+
+  describe('first tick after start', () => {
+    it('processes held writs that pre-date apparatus startup', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_PETITIONER],
+        async preStart({ clerk }) {
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'vision-keeper.snapshot',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Petition from preStart sat in `new` until the first tick.
+      const allBeforeTick = await fix.clerk.list({ limit: 100 });
+      assert.equal(allBeforeTick.length, 1);
+      assert.equal(allBeforeTick[0]!.phase, 'new', 'pre-existing writ stays in new until first tick');
+
+      await fix.hooks.runTick(SAMPLE_TICK_EVENT);
+
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      const writ = all[0]!;
+      assert.equal(writ.phase, 'open', 'first tick auto-approves the pre-existing held writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+      assert.equal(rows[0]!.tickEventId, SAMPLE_TICK_EVENT.id);
+
+      // Re-running the tick must not produce a second row — the writ's
+      // phase is no longer `new`, so it never enters the candidate set.
+      await fix.hooks.runTick(SAMPLE_TICK_EVENT);
+      const rowsAfter = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rowsAfter.length, 1, 'idempotent across repeated ticks');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ────────────────────────────────────
+
+  describe('evaluate throw', () => {
+    it('keeps the apparatus up; no rows written', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad-evaluate',
+        description: 'always throws',
+        async evaluate() {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-evaluate' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick(SAMPLE_TICK_EVENT);
+
+        const reread = await fix.clerk.show(writ.id);
+        assert.equal(reread.phase, 'new', 'writ stays in new on evaluate throw');
+        const rows = await fix.reckoningsBook.find({
+          where: [['writId', '=', writ.id]],
+        });
+        assert.equal(rows.length, 0);
+        assert.ok(
+          warnings.some(
+            (w) => /\[reckoner\] scheduler:/.test(w) && /evaluate threw/.test(w),
+          ),
+          `expected fail-loud warning; got: ${JSON.stringify(warnings)}`,
+        );
+      } finally {
+        console.warn = originalWarn;
+      }
+    });
+
+    it('keeps the apparatus up; subsequent ticks still work', async () => {
+      // After an evaluate throw on tick #1, the apparatus is still alive.
+      // Hot-edit the config to point to the always-approve scheduler and
+      // confirm tick #2 produces an approve row.
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad-evaluate',
+        description: 'always throws',
+        async evaluate() {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-evaluate' },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      console.warn = () => {};
+      try {
+        await fix.hooks.runTick(SAMPLE_TICK_EVENT);
+      } finally {
+        console.warn = originalWarn;
+      }
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new');
+    });
+  });
+
+  // ── 4: disabled-source mid-flight ──────────────────────────────────
+
+  describe('disabled-source decline', () => {
+    it('writes a declined row and transitions to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_PETITIONER],
+        config: { disabledSources: ['vision-keeper.snapshot'] },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      // Petition leaves the writ in `new`; the Reckoner does no work
+      // synchronously. The first tick observes the disabled gate.
+      const beforeTick = await fix.clerk.show(writ.id);
+      assert.equal(beforeTick.phase, 'new');
+
+      await fix.hooks.runTick(SAMPLE_TICK_EVENT);
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'vision-keeper\.snapshot' is in reckoner\.disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'vision-keeper.snapshot');
+      assert.equal(rows[0]!.tickEventId, SAMPLE_TICK_EVENT.id);
+    });
+  });
+
+  // ── 5: unregistered-strict mid-flight ──────────────────────────────
+
+  describe('unregistered-strict decline', () => {
