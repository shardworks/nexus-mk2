+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any. Schedulers must emit at most one decision per candidate.`,
+      );
+      return;
+    }
+  }
+
+  // 8. Apply each decision in candidate order. Per-writ failures are
+  //    swallowed so one corrupt decision does not stop the rest of
+  //    the tick.
+  for (const writ of survivingCandidates) {
+    const decision = grouped.get(writ.id)?.[0];
+    if (!decision) continue;
+
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+
+    if (decision.outcome === 'defer') {
+      await applyDeferOutcome({
+        context,
+        writ,
+        ext,
+        decision,
+        now,
+        tickEventId,
+        schedulerId: activeScheduler.id,
+      });
+      continue;
+    }
+
+    if (decision.outcome === 'decline') {
+      await applyDeclineOutcome({
+        context,
+        writ,
+        ext,
+        decision,
+        now,
+        tickEventId,
+        schedulerId: activeScheduler.id,
+      });
+      continue;
+    }
+
+    if (decision.outcome === 'approve') {
+      await applyApproveOutcome({
+        context,
+        writ,
+        ext,
+        decision,
+        now,
+        tickEventId,
+        schedulerId: activeScheduler.id,
+      });
+      continue;
+    }
