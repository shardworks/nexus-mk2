+/**
+ * The Reckoner tick — periodic batch evaluation entry point.
+ *
+ * This module owns the `reckoner.tick` relay: the canonical Reckoner
+ * evaluation surface. The Reckoner's apparatus contributes
+ *
+ *   - the `reckoner.tick` relay via `supportKit.relays`,
+ *   - a single standing order `{ schedule: '@every 60s', run: 'reckoner.tick' }`
+ *     via `supportKit.standingOrders`,
+ *
+ * so any guild that installs both the Reckoner and Clockworks gets a
+ * ticker firing every minute that walks every currently-held petition
+ * through the configured scheduler in one batch. Operators can append
+ * their own standing orders but cannot disable or override this one
+ * (the kit-contributed standing order has no `id` field — additive
+ * merge only).
+ *
+ * The CDC-driven per-writ-update model the Reckoner shipped before
+ * this commission is gone in its entirety. The tick is the only path
+ * driving scheduler evaluation.
+ *
+ * Per-fire sequence:
+ *
+ *   1. Resolve the active scheduler from the closure-scoped reference.
+ *      Throws fail-loud if it is unresolved (`phase:started` has not
+ *      fired) — production never trips it; test fixtures that drive
+ *      the tick pre-seal get a deterministic loud signal.
+ *   2. Re-read + validate `reckoner.schedulerConfig` (D17/D18). On a
+ *      `validateConfig` throw the entire tick is fail-loud-skipped —
+ *      no row, no transition for any writ.
+ *   3. Query the writs book for held petitions: writs in `'new'` phase
+ *      carrying `ext.reckoner`.
+ *   4. Apply the source/disabled gates inline. A writ failing a gate
+ *      produces a `declined` Reckonings row and a transition to its
+ *      type's cancelled target; the writ does not reach the
+ *      scheduler.
+ *   5. Filter the surviving candidates against the
+ *      `(writId, writUpdatedAt)` dedupe lookup before building
+ *      `SchedulerInput`. Already-considered writs never reach the
+ *      scheduler.
+ *   6. Build one `SchedulerInput { candidates, capacity, now, config }`
+ *      with the v0 capacity stub and call the scheduler's `evaluate`
+ *      inside a try/catch — a throw fail-loud-skips the entire tick.
+ *   7. Filter-and-warn on stranger writIds; fail-loud-skip the whole
+ *      tick on multi-decision-per-writ.
+ *   8. Apply each decision: approve → transition to active target;
+ *      decline → transition to cancelled with the decision's reason;
+ *      defer → no transition. Append one Reckonings row per writ
+ *      considered (defer rows carry `deferReason: 'other'` and the
+ *      decision's reason in `deferNote`).
+ *
+ * Design alignment:
+ *   - Mirrors the stdlib-relay pattern (`summon-relay.ts`,
+ *     `decline-relay.ts`): a sibling file exporting a relay factory
+ *     plus a pure handler-body helper for unit tests.
+ *   - The helper takes a `TickContext` dependency-injection object so
+ *     unit tests can drive the handler without booting Clockworks.
+ *
+ * See: docs/architecture/apparatus/reckoner.md (Schedulers section)
+ * and docs/architecture/reckonings-book.md (`tickEventId` rule).
+ */
+
+import type {
+  ClerkApi,
+  WritDoc,
+  WritPhase,
+  WritTypeConfig,
+} from '@shardworks/clerk-apparatus';
+import type {
+  ReadOnlyBook,
+  Book,
+  StacksApi,
+} from '@shardworks/stacks-apparatus';
+import type { GuildEvent, RelayDefinition } from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+
+import type {
+  ReckoningDoc,
+  ReckonerExt,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+// ── Constants ───────────────────────────────────────────────────────
+
+/**
+ * Kit-contributed relay name. Hardcoded literal — operators reference
+ * this string from `guild.json clockworks.standingOrders[].run` and
+ * the Reckoner's own kit-contributed standing order names it the same
+ * way. The relay name is intentionally dotted (matching contributed-id
+ * grammar elsewhere in the apparatus) — not hyphenated.
+ */
+export const RECKONER_TICK_RELAY = 'reckoner.tick';
+
+/** Plugin id stamped on `writ.ext['reckoner']`. */
+const RECKONER_PLUGIN_ID = 'reckoner';
+
+// ── Tick context ────────────────────────────────────────────────────
+
+/**
+ * Resolved Reckoner config slice the tick consumes. Mirrors
+ * `ResolvedReckonerConfig` in `reckoner.ts`.
+ */
+interface ResolvedConfig {
+  enforceRegistration: boolean;
+  disabledSources: string[];
+}
+
+/**
+ * Petitioner-registry presence lookup the tick consumes. The
+ * apparatus's internal registry carries more than presence (descriptor
+ * + contributing plugin id), but the tick path only needs the
+ * `.has(source)` check, so we narrow the type here.
+ */
+export interface RegistryPresence {
+  has(source: string): boolean;
+}
+
+/**
+ * Dependency-injection context the tick handler needs to do its work.
+ * The Reckoner's `buildReckoner()` closure constructs one of these and
+ * hands it to `createTickRelay` and `runTick`. Unit tests can build a
+ * minimal version directly to drive `runTick` without booting
+ * Clockworks.
+ */
+export interface TickContext {
+  /** Live Clerk handle. */
+  clerk: ClerkApi;
+  /** Live Stacks handle. */
+  stacks: StacksApi;
+  /** The Reckonings book the tick writes rows into. */
+  reckoningsBook: Book<ReckoningDoc>;
+  /** Petitioner-registry presence lookup. */
+  registry: RegistryPresence;
+  /** Closure-resolved active scheduler (undefined pre-seal). */
+  getActiveScheduler(): Scheduler | undefined;
+  /** Re-read + validated `reckoner` block (config defaults). */
+  resolveConfig(): ResolvedConfig;
+  /** Re-read raw `reckoner.schedulerConfig` slot. */
+  resolveSchedulerConfig(): unknown;
+  /** Type-aware active-target-phase resolution. */
+  resolveActiveTargetPhase(writ: WritDoc): string;
+  /** `(writId, writUpdatedAt)` dedupe lookup. */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /** Construct a Reckonings row from in-flight consideration state. */
+  buildReckoningRow(params: BuildReckoningRowParams): ReckoningDoc;
