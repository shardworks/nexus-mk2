+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" returned an unknown outcome "${String((decision as { outcome?: unknown }).outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+  }
+}
+
+// ── Gate decline appliers ───────────────────────────────────────────
+
+/**
+ * Apply a disabled-source decline. Writes a `declined` Reckonings row
+ * carrying `declineReason: 'source_banned'` and the source name in
+ * `remediationHint`, then transitions the writ to its type's cancelled
+ * target. Symmetric with the unregistered-strict decline path; uses
+ * its own resolution-string template (D2 forbids reusing the
+ * unregistered-strict helper if it required changing that format).
+ */
+async function applyDisabledSourceDecline(args: {
+  context: TickContext;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  now: Date;
+  tickEventId: string | undefined;
+}): Promise<void> {
+  const { context, writ, ext, now, tickEventId } = args;
+  // Dedupe before any side effect.
+  if (await context.alreadyConsidered(context.reckoningsBook, writ.id, writ.updatedAt)) {
+    return;
+  }
+  const cancelTarget = resolveCancelledTarget(context.clerk, writ);
+  if (!cancelTarget) return;
+  const resolution =
+    `[reckoner] declined: source '${ext.source}' is in disabledSources.`;
+  try {
+    await context.clerk.transition(writ.id, cancelTarget as WritPhase, { resolution });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to ${cancelTarget} (disabled-source decline): ${msg}`,
+    );
+    return;
+  }
+  const row = context.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason: 'source_banned',
+    remediationHint: ext.source,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await context.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (disabled-source decline): ${msg}`,
+    );
+  }
+}
+
+/**
+ * Apply an unregistered-strict decline. Mirrors the byte-for-byte
+ * resolution-string format the pre-tick CDC path used so a journal
+ * grep across pre- and post-tick rows still matches the same regex.
+ */
+async function applyUnregisteredStrictDecline(args: {
+  context: TickContext;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  now: Date;
+  tickEventId: string | undefined;
+}): Promise<void> {
+  const { context, writ, ext, now, tickEventId } = args;
+  if (await context.alreadyConsidered(context.reckoningsBook, writ.id, writ.updatedAt)) {
+    return;
+  }
+  const cancelTarget = resolveCancelledTarget(context.clerk, writ);
+  if (!cancelTarget) return;
+  const resolution =
+    `[reckoner] declined: source '${ext.source}' is not registered (enforceRegistration: true).`;
+  try {
+    await context.clerk.transition(writ.id, cancelTarget as WritPhase, { resolution });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to ${cancelTarget} (unregistered-strict decline): ${msg}`,
+    );
+    return;
+  }
+  const row = context.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason: 'source_unregistered',
+    remediationHint: ext.source,
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await context.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (unregistered-strict decline): ${msg}`,
+    );
+  }
+}
+
+// ── Decision appliers ───────────────────────────────────────────────
+
+async function applyApproveOutcome(args: {
+  context: TickContext;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  decision: SchedulerDecision;
+  now: Date;
+  tickEventId: string | undefined;
+  schedulerId: string;
+}): Promise<void> {
+  const { context, writ, ext, decision, now, tickEventId, schedulerId } = args;
+  let target: string;
+  try {
+    target = context.resolveActiveTargetPhase(writ);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+    );
+    return;
+  }
+
+  try {
+    await context.clerk.transition(writ.id, target as WritPhase, {});
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${schedulerId}" failed to transition writ "${writ.id}" to "${target}" (approve): ${msg}`,
+    );
+    return;
+  }
+
+  const row = context.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'accepted',
+    ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await context.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${schedulerId}" failed to persist Reckonings row for writ "${writ.id}" (approve): ${msg}`,
+    );
+  }
+}
+
+async function applyDeclineOutcome(args: {
+  context: TickContext;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  decision: SchedulerDecision;
+  now: Date;
+  tickEventId: string | undefined;
+  schedulerId: string;
+}): Promise<void> {
+  const { context, writ, ext, decision, now, tickEventId, schedulerId } = args;
+  const cancelTarget = resolveCancelledTarget(context.clerk, writ);
+  if (!cancelTarget) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" has no resolvable cancelled target — leaving in new (scheduler decline).`,
+    );
+    return;
+  }
+  try {
+    await context.clerk.transition(writ.id, cancelTarget as WritPhase, {
+      resolution: decision.reason,
+    });
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${schedulerId}" failed to transition writ "${writ.id}" to ${cancelTarget} (decline): ${msg}`,
+    );
+    return;
+  }
+
+  const row = context.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'declined',
+    declineReason: 'other',
+    remediationHint: decision.reason,
+    ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await context.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${schedulerId}" failed to persist Reckonings row for writ "${writ.id}" (decline): ${msg}`,
+    );
+  }
+}
+
+async function applyDeferOutcome(args: {
+  context: TickContext;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  decision: SchedulerDecision;
+  now: Date;
+  tickEventId: string | undefined;
+  schedulerId: string;
+}): Promise<void> {
+  const { context, writ, ext, decision, now, tickEventId, schedulerId } = args;
+  // Defer = no transition. Just write the row.
+  const row = context.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'deferred',
+    deferReason: 'other',
+    deferNote: decision.reason,
+    ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await context.reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${schedulerId}" failed to persist Reckonings row for writ "${writ.id}" (defer): ${msg}`,
+    );
+  }
+}
+
+// ── Helpers ─────────────────────────────────────────────────────────
+
+/**
+ * Resolve the writ-type's cancelled target phase. Walks the current
+ * state's `allowedTransitions` and picks the candidate classified as
+ * `terminal` carrying the `'cancelled'` attr. Defensive — returns
+ * `undefined` and logs when no resolvable target exists, so the
+ * tick's caller can skip the writ rather than throw.
+ */
+function resolveCancelledTarget(clerk: ClerkApi, writ: WritDoc): string | undefined {
+  const config: WritTypeConfig | undefined = clerk.getWritTypeConfig(writ.type);
+  if (!config) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" has type "${writ.type}" with no registered WritTypeConfig — cannot resolve cancelled target.`,
+    );
+    return undefined;
+  }
+  const currentState = config.states.find((s) => s.name === writ.phase);
+  if (!currentState) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" type "${writ.type}" has no declared state "${writ.phase}" — cannot resolve cancelled target.`,
+    );
+    return undefined;
+  }
+  const candidates: string[] = [];
+  for (const target of currentState.allowedTransitions) {
+    const targetState = config.states.find((s) => s.name === target);
+    if (!targetState) continue;
+    if (targetState.classification !== 'terminal') continue;
+    const attrs = targetState.attrs ?? [];
+    if (attrs.includes('cancelled')) {
+      candidates.push(target);
+    }
+  }
+  // Mandate's literal `'cancelled'` state is the canonical name; fall
+  // back to it for types that omit `attrs` but still name their
+  // terminal state `cancelled`.
+  if (candidates.length === 0) {
+    for (const target of currentState.allowedTransitions) {
+      if (target === 'cancelled') candidates.push(target);
+    }
+  }
+  if (candidates.length === 0) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" type "${writ.type}" current state "${writ.phase}" has no outbound transition to a cancelled state — cannot decline.`,
+    );
+    return undefined;
+  }
+  if (candidates.length > 1) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" type "${writ.type}" current state "${writ.phase}" has multiple cancelled candidates (${candidates.map((c) => `"${c}"`).join(', ')}) — picking "${candidates[0]}".`,
+    );
+  }
+  return candidates[0];
+}
+
