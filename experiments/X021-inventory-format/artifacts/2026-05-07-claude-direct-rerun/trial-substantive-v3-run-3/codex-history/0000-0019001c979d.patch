+    // Disabled-source decline.
+    if (config.disabledSources.includes(ext.source)) {
+      await applyDisabledSourceDecline({
+        context,
+        writ,
+        ext,
+        now,
+        tickEventId,
+      });
+      continue;
+    }
+
+    // Unregistered-strict decline.
+    const isRegistered = context.registry.has(ext.source);
+    if (!isRegistered && config.enforceRegistration) {
+      await applyUnregisteredStrictDecline({
+        context,
+        writ,
+        ext,
+        now,
+        tickEventId,
+      });
+      continue;
+    }
+
+    // 7. Dedupe BEFORE handing to scheduler (D7). Already-considered
+    //    writs never reach the scheduler.
+    if (await context.alreadyConsidered(context.reckoningsBook, writ.id, writ.updatedAt)) {
+      continue;
+    }
+
+    survivingCandidates.push(writ);
+  }
+
+  if (survivingCandidates.length === 0) return;
+
+  // 6. Build one SchedulerInput for the whole batch and evaluate.
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates: survivingCandidates,
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // 7. Validate decisions: filter-and-warn on stranger writIds (D9).
+  const candidateIdSet = new Set<string>(survivingCandidates.map((w) => w.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIdSet.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
