+ * writ (or, for whole-tick faults, the entire fire). The only
+ * fail-loud throw is the pre-seal guard (D8) — `activeScheduler`
+ * unresolved is a programming error in the test setup, not a runtime
+ * data fault.
+ */
+export async function runTick(
+  context: TickContext,
+  event: GuildEvent | null = null,
+): Promise<void> {
+  // 1. Active-scheduler guard (D8) — throw fail-loud.
+  const activeScheduler = context.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired',
+    );
+  }
