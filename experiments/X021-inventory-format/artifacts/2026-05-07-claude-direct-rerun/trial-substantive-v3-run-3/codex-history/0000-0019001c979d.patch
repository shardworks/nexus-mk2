+/**
+ * Reckoner tick handler tests.
+ *
+ * Replaces the pre-tick `reckoner-cdc.test.ts`. Every behavioral case
+ * the originating brief enumerates is exercised through the tick:
+ *
+ *   1. Empty-candidate ticks — no rows, no errors, no scheduler call.
+ *   2. First tick after start picking up pre-existing held writs.
+ *   3. Evaluate-throw isolation — the apparatus stays up; no rows
+ *      written; subsequent ticks succeed.
+ *   4. Disabled-source mid-flight produces a `declined` row carrying
+ *      `declineReason: 'source_banned'` plus the source name in
+ *      `remediationHint`, and transitions the writ to its cancelled
+ *      target.
+ *   5. Repeated-tick idempotency at unchanged `updatedAt`.
+ *   6. Type-aware target-phase resolution — `mandate` lands in `open`
+ *      via approve, plus a custom non-mandate type whose active
+ *      state is named differently.
+ *   7. Withdrawal-mid-flight — a writ cancelled before the tick is
+ *      no longer in `'new'` and so is filtered out of the candidate
+ *      query.
+ *   8. Defer outcome writes a row carrying `outcome: 'deferred'`,
+ *      `deferReason: 'other'`, and the decision's reason in
+ *      `deferNote`; no transition.
+ *   9. Pre-seal tick throws fail-loud (D8) — `activeScheduler`
+ *      unresolved.
+ *  10. Source/disabled gates run inline regardless of the scheduler's
+ *      decisions — the gate-failed writ never reaches `evaluate`.
+ *  11. Stranger writIds are filtered with a warning; the whole tick
+ *      is fail-loud-skipped on multi-decision-per-writ.
+ *  12. `validateConfig` throw fail-loud-skips the entire tick.
+ *  13. tickEventId is stamped on Reckonings rows when the synthetic
+ *      event carries an id, and omitted when the tick is driven with
+ *      `null`.
+ *
+ * The fixture mirrors the one in `reckoner.test.ts`: real Stacks +
+ * Clerk + Reckoner against `MemoryBackend`, with explicit book pre-
+ * creation and a phase-started capable StartupContext. The tick is
+ * driven through `hooks.runTick(event)` rather than booting
+ * Clockworks.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /**
+   * Re-fire `phase:started` against the registered handlers. Awaits
+   * any async handlers (the Reckoner's seal handler is sync but the
+   * fixture awaits anyway for symmetry with future commissions).
+   */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  config?: ReckonerConfig | undefined;
+  /**
+   * Optional writ types to register on the Clerk before the Reckoner
+   * starts.
+   */
+  writTypes?: WritTypeConfig[];
+  /**
+   * Optional pre-start seed (held-writ-pre-existed-at-boot tests).
+   */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+  /**
+   * When true, skip firing `phase:started` after start. Used for the
+   * pre-seal tick test that exercises the activeScheduler fail-loud
+   * guard.
+   */
+  skipPhaseStarted?: boolean;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler) {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [
+    {
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    },
+    ...(opts.schedulerKits ?? []).map((entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    })),
+  ];
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+/** Synthesise a clockworks.timer-shaped event id used by some tests. */
+function syntheticTimerEvent(id = 'e-test-tick'): GuildEvent {
+  return {
+    id,
+    name: 'clockworks.timer',
+    payload: null,
+    emitter: 'framework',
+    firedAt: new Date().toISOString(),
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => {
+    clearGuild();
+  });
+
+  // ── 1: empty candidate set ────────────────────────────────────────
+
+  describe('empty candidate set', () => {
+    it('writes no rows when no held petitions are present', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+      await fix.hooks.runTick(syntheticTimerEvent());
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0);
+    });
+  });
+
+  // ── 2: first tick picks up pre-existing held writs ────────────────
+
+  describe('first tick after start', () => {
+    it('processes held petitions seeded before apparatus start', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        async preStart({ clerk }) {
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'tester.kind',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      await fix.hooks.runTick(syntheticTimerEvent());
+
+      const all = await fix.clerk.list({ limit: 100 });
+      assert.equal(all.length, 1);
+      const writ = all[0]!;
+      assert.equal(writ.phase, 'open', 'first tick auto-approves the pre-existing writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+
+    it('post-petition tick approves a writ posted via the helper', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+      });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      // Before any tick, the writ stays in `new`.
+      const beforeTick = await fix.clerk.show(writ.id);
+      assert.equal(beforeTick.phase, 'new', 'no implicit dispatch on petition');
+
+      await fix.hooks.runTick(syntheticTimerEvent());
+
+      const afterTick = await fix.clerk.show(writ.id);
+      assert.equal(afterTick.phase, 'open');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ────────────────────────────────────
+
+  describe('evaluate throw', () => {
+    it('apparatus stays up, no rows written, subsequent ticks succeed', async () => {
+      let throwOnce = true;
+      const scheduler: Scheduler = {
+        id: 'kit-a.flaky',
+        description: 'throws once then approves',
+        async evaluate(input: SchedulerInput<unknown>): Promise<readonly SchedulerDecision[]> {
+          if (throwOnce) {
+            throwOnce = false;
+            throw new Error('first call throws');
+          }
+          return input.candidates.map((w) => ({
+            writId: w.id,
+            outcome: 'approve' as const,
+            reason: 'recovered',
+          }));
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.flaky' },
+      });
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick(syntheticTimerEvent());
+        // First tick was skipped — no row, writ untouched.
+        const reread = await fix.clerk.show(writ.id);
+        assert.equal(reread.phase, 'new');
+        const rows1 = await fix.reckoningsBook.find({
+          where: [['writId', '=', writ.id]],
+        });
+        assert.equal(rows1.length, 0);
+        assert.ok(
+          warnings.some(
+            (w) =>
+              /\[reckoner\] tick: scheduler/.test(w) && /evaluate threw/.test(w),
+          ),
+          `expected fail-loud log line; got: ${JSON.stringify(warnings)}`,
+        );
+
+        // Second tick recovers and approves.
+        await fix.hooks.runTick(syntheticTimerEvent('e-second'));
+        const reread2 = await fix.clerk.show(writ.id);
+        assert.equal(reread2.phase, 'open');
+        const rows2 = await fix.reckoningsBook.find({
+          where: [['writId', '=', writ.id]],
+        });
+        assert.equal(rows2.length, 1);
+        assert.equal(rows2[0]!.outcome, 'accepted');
+      } finally {
+        console.warn = originalWarn;
+      }
+    });
+  });
+
+  // ── 4: disabled-source mid-flight ──────────────────────────────────
+
+  describe('disabled-source decline', () => {
+    it('writes a declined row with source_banned and transitions to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        config: { disabledSources: ['tester.kind'] },
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      await fix.hooks.runTick(syntheticTimerEvent());
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled', 'disabled source declines on tick');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'tester\.kind' is in disabledSources\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'tester.kind');
+    });
+  });
+
+  // ── 5: repeated-tick idempotency at unchanged updatedAt ────────────
+
+  describe('repeated-tick idempotency', () => {
+    it('produces exactly one row across two ticks at unchanged updatedAt', async () => {
+      // A scheduler that returns approve every time — without dedupe
+      // this would produce a transition error on the second tick (and
+      // a duplicate row).
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+      // Tick 1 — auto-approves.
