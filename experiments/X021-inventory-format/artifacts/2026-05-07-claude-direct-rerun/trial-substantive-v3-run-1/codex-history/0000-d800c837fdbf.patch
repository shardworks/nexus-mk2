@@ -0,0 +1,918 @@
+/**
+ * Reckoner tick handler tests.
+ *
+ * The Reckoner's only path into scheduler evaluation is the
+ * periodic `reckoner.tick` relay, contributed via the apparatus's
+ * `supportKit.relays` and paired with a kit-contributed standing
+ * order at `@every 60s`. This file exercises every behavioral case
+ * the commission's Acceptance Signal enumerates, all driven through
+ * the `hooks.runTick(event?)` test entry point:
+ *
+ *   1. empty-candidate ticks — no rows, no errors, no scheduler call.
+ *   2. first tick after start picks up pre-existing held petitions.
+ *   3. evaluate-throw isolation — apparatus stays up, no rows for
+ *      any candidate in the throwing tick.
+ *   4. disabled-source mid-flight — produces a `'declined'` row
+ *      carrying `declineReason: 'source_banned'` and transitions the
+ *      writ to its cancelled target.
+ *   5. unregistered-strict decline — produces a `'declined'` row with
+ *      `declineReason: 'source_unregistered'` and a structured
+ *      resolution string.
+ *   6. registered-source approve — accepts the petition; the row
+ *      carries the lean projection.
+ *   7. repeated-tick idempotency — same writ, unchanged updatedAt,
+ *      one row total across two ticks.
+ *   8. type-aware target-phase resolution — non-mandate types land
+ *      in their declared active state.
+ *   9. withdrawal-mid-flight — the petitioner cancels the writ
+ *      before the tick reaches it; the tick produces no row because
+ *      the phase gate (writ.phase != 'new') skips it.
+ *  10. defer outcome — produces a `'deferred'` row carrying
+ *      `deferReason: 'other'` plus the decision's reason in
+ *      `deferNote`; no transition.
+ *  11. pre-seal tick fail-loud — the handler throws when
+ *      `phase:started` has not yet fired.
+ *
+ * The fixture mirrors the per-package scaffolding pattern used by
+ * `reckoner.test.ts` and `reckoner-scheduler.test.ts`: real Stacks +
+ * Clerk + Reckoner against `MemoryBackend`, with explicit book
+ * pre-creation. The tick relay handler is invoked through the
+ * `hooks.runTick` entry; the production path (via Clockworks
+ * dispatch) is exercised by the apparatus's integration test.
+ */
+
+import { describe, it, afterEach } from 'node:test';
+import assert from 'node:assert/strict';
+
+import { setGuild, clearGuild } from '@shardworks/nexus-core';
+import type {
+  Guild,
+  GuildConfig,
+  KitEntry,
+  LoadedApparatus,
+  LoadedKit,
+  StartupContext,
+} from '@shardworks/nexus-core';
+
+import { createStacksApparatus } from '@shardworks/stacks-apparatus';
+import { MemoryBackend } from '@shardworks/stacks-apparatus/testing';
+import type { ReadOnlyBook, StacksApi } from '@shardworks/stacks-apparatus';
+
+import { createClerk } from '@shardworks/clerk-apparatus';
+import type { ClerkApi, WritTypeConfig } from '@shardworks/clerk-apparatus';
+
+import type { GuildEvent } from '@shardworks/clockworks-apparatus';
+
+import { createReckonerWithHooks } from './reckoner.ts';
+import { alwaysApproveScheduler } from './schedulers/always-approve.ts';
+import type {
+  ReckoningDoc,
+  ReckonerApi,
+  ReckonerConfig,
+  Scheduler,
+  SchedulerDecision,
+  SchedulerInput,
+} from './types.ts';
+
+// ── Test harness ─────────────────────────────────────────────────────
+
+interface Fixture {
+  stacks: StacksApi;
+  clerk: ClerkApi;
+  reckoner: ReckonerApi;
+  hooks: ReturnType<typeof createReckonerWithHooks>['hooks'];
+  memBackend: MemoryBackend;
+  fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig };
+  reckoningsBook: ReadOnlyBook<ReckoningDoc>;
+  /**
+   * Re-fire `phase:started` against the registered handlers. Awaits
+   * any async handlers — the Reckoner's seal handler is sync today,
+   * but the helper stays async for parity with existing fixtures.
+   */
+  firePhaseStarted: () => Promise<void>;
+}
+
+function buildFakeGuild(
+  apparatusMap: Map<string, unknown>,
+  fakeGuildConfig: GuildConfig,
+): Guild {
+  return {
+    home: '/tmp/reckoner-tick-test-guild',
+    apparatus<T>(name: string): T {
+      const a = apparatusMap.get(name);
+      if (!a) throw new Error(`Apparatus "${name}" not installed`);
+      return a as T;
+    },
+    config<T>(_pluginId: string): T {
+      return {} as T;
+    },
+    writeConfig(): void {},
+    guildConfig(): GuildConfig {
+      return fakeGuildConfig;
+    },
+    kits(): LoadedKit[] {
+      return [];
+    },
+    apparatuses(): LoadedApparatus[] {
+      return [];
+    },
+    failedPlugins() {
+      return [];
+    },
+    startupWarnings(): string[] {
+      return [];
+    },
+  };
+}
+
+interface FixtureOptions {
+  petitionerKits?: Array<{ pluginId: string; value: unknown }>;
+  /**
+   * Additional `schedulers` kit contributions visible to the
+   * Reckoner's `start()`, on top of the built-in
+   * `reckoner.always-approve` instance the apparatus contributes
+   * from its own supportKit. Tests that need to exercise a non-
+   * default scheduler (decline / defer / weight / validateConfig)
+   * supply their scheduler here.
+   */
+  schedulerKits?: Array<{ pluginId: string; value: Scheduler[] }>;
+  config?: ReckonerConfig | undefined;
+  /**
+   * Optional writ types to register on the Clerk before the Reckoner
+   * starts. Used to test type-aware target-phase resolution against
+   * a non-mandate type.
+   */
+  writTypes?: WritTypeConfig[];
+  /**
+   * When set, callers can pre-seed writs into the writs book before
+   * the Reckoner's `start()` runs — used to exercise the first-tick-
+   * after-start case.
+   */
+  preStart?: (deps: { stacks: StacksApi; clerk: ClerkApi }) => Promise<void>;
+  /**
+   * When true, do not fire `phase:started` after start (pre-seal
+   * tick-throw test).
+   */
+  skipPhaseStarted?: boolean;
+}
+
+async function buildFixture(opts: FixtureOptions = {}): Promise<Fixture> {
+  const memBackend = new MemoryBackend();
+  const stacksPlugin = createStacksApparatus(memBackend);
+  const clerkPlugin = createClerk();
+  const built = createReckonerWithHooks();
+  const reckonerPlugin = built.plugin;
+
+  const apparatusMap = new Map<string, unknown>();
+
+  const fakeGuildConfig: GuildConfig & { reckoner?: ReckonerConfig } = {
+    name: 'reckoner-tick-test-guild',
+    nexus: '0.0.0',
+    plugins: [],
+    ...(opts.config !== undefined ? { reckoner: opts.config } : {}),
+  };
+
+  setGuild(buildFakeGuild(apparatusMap, fakeGuildConfig));
+
+  // Pre-create the books the Clerk needs — Stacks' Wire phase would do
+  // this in production from the supportKit declarations.
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'writs' },
+    {
+      indexes: [
+        'phase',
+        'type',
+        'createdAt',
+        'parentId',
+        ['phase', 'type'],
+        ['phase', 'createdAt'],
+        ['parentId', 'phase'],
+      ],
+    },
+  );
+  memBackend.ensureBook(
+    { ownerId: 'clerk', book: 'links' },
+    {
+      indexes: [
+        'sourceId',
+        'targetId',
+        'label',
+        ['sourceId', 'label'],
+        ['targetId', 'label'],
+      ],
+    },
+  );
+  // Pre-create the Reckoner's reckonings book with the contract
+  // index set so the handler's queries (and the dedupe lookup) hit
+  // indexed columns the same way they would in production.
+  memBackend.ensureBook(
+    { ownerId: 'reckoner', book: 'reckonings' },
+    {
+      indexes: [
+        'writId',
+        'consideredAt',
+        'outcome',
+        'source',
+        'visionRelation',
+        'severity',
+        'declineReason',
+        ['outcome', 'consideredAt'],
+        ['visionRelation', 'consideredAt'],
+        ['severity', 'consideredAt'],
+        ['writId', 'consideredAt'],
+      ],
+    },
+  );
+
+  const phaseStartedHandlers: Array<(...args: unknown[]) => void | Promise<void>> = [];
+  const firePhaseStarted = async (): Promise<void> => {
+    for (const handler of phaseStartedHandlers) {
+      await handler();
+    }
+  };
+
+  function buildCtx(kitEntries: KitEntry[]): StartupContext {
+    return {
+      on(event, handler): void {
+        if (event === 'phase:started') {
+          phaseStartedHandlers.push(handler);
+        }
+      },
+      kits(type: string): KitEntry[] {
+        return kitEntries.filter((e) => e.type === type);
+      },
+    };
+  }
+
+  await stacksPlugin.apparatus.start(buildCtx([]));
+  const stacks = stacksPlugin.apparatus.provides as StacksApi;
+  apparatusMap.set('stacks', stacks);
+
+  await clerkPlugin.apparatus.start(buildCtx([]));
+  const clerk = clerkPlugin.apparatus.provides as ClerkApi;
+  apparatusMap.set('clerk', clerk);
+
+  if (opts.writTypes) {
+    for (const config of opts.writTypes) {
+      clerk.registerWritType(config);
+    }
+  }
+
+  if (opts.preStart) {
+    await opts.preStart({ stacks, clerk });
+  }
+
+  const petitionerKitEntries: KitEntry[] = (opts.petitionerKits ?? []).map(
+    (entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'petitioners',
+      value: entry.value,
+    }),
+  );
+
+  const schedulerKitEntries: KitEntry[] = [
+    {
+      pluginId: 'reckoner',
+      packageName: '@shardworks/reckoner-apparatus',
+      type: 'schedulers',
+      value: [alwaysApproveScheduler],
+    },
+    ...(opts.schedulerKits ?? []).map((entry) => ({
+      pluginId: entry.pluginId,
+      packageName: `@test/${entry.pluginId}`,
+      type: 'schedulers',
+      value: entry.value,
+    })),
+  ];
+
+  await reckonerPlugin.apparatus.start(
+    buildCtx([...petitionerKitEntries, ...schedulerKitEntries]),
+  );
+  const reckoner = reckonerPlugin.apparatus.provides as ReckonerApi;
+  apparatusMap.set('reckoner', reckoner);
+
+  if (!opts.skipPhaseStarted) {
+    await firePhaseStarted();
+  }
+
+  return {
+    stacks,
+    clerk,
+    reckoner,
+    hooks: built.hooks,
+    memBackend,
+    fakeGuildConfig,
+    reckoningsBook: stacks.readBook<ReckoningDoc>('reckoner', 'reckonings'),
+    firePhaseStarted,
+  };
+}
+
+/**
+ * Synthetic Clockworks `clockworks.timer` event — what the
+ * dispatcher would hand the relay on a real fire. Used by the tests
+ * that need to assert `tickEventId` stamping on the resulting
+ * Reckonings row (D6).
+ */
+function fakeTickEvent(id = 'e-test-tick'): GuildEvent {
+  return {
+    id,
+    name: 'clockworks.timer',
+    payload: null,
+    emitter: 'clockworks',
+    firedAt: new Date().toISOString(),
+  };
+}
+
+const REGISTERED_PETITIONER = {
+  pluginId: 'tester',
+  value: [{ source: 'tester.kind', description: 'tester' }],
+};
+
+const VISION_KEEPER_PETITIONER = {
+  pluginId: 'vision-keeper',
+  value: [{ source: 'vision-keeper.snapshot', description: 'snapshots' }],
+};
+
+// ── Tests ────────────────────────────────────────────────────────────
+
+describe('Reckoner tick handler', () => {
+  afterEach(() => clearGuild());
+
+  // ── 1: empty-candidate tick ────────────────────────────────────────
+
+  describe('empty candidate set', () => {
+    it('writes nothing and returns cleanly when no held petitions exist', async () => {
+      const fix = await buildFixture({ petitionerKits: [REGISTERED_PETITIONER] });
+
+      // No writs in the book; no rows expected. The pure-no-op path
+      // also exercises the early-return after the held-writs query.
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({});
+      assert.equal(rows.length, 0, 'empty tick must produce no rows');
+    });
+  });
+
+  // ── 2: first-tick-after-start picks up pre-existing held writs ─────
+
+  describe('first tick after start', () => {
+    it('processes held writs that pre-date apparatus startup', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_PETITIONER],
+        async preStart({ clerk }) {
+          const w = await clerk.post({ title: 'pre-start', body: 'b' });
+          await clerk.setWritExt(w.id, 'reckoner', {
+            source: 'vision-keeper.snapshot',
+            priority: {
+              visionRelation: 'vision-neutral',
+              severity: 'minor',
+              scope: 'minor-area',
+              time: { decay: false, deadline: null },
+              domain: [],
+            },
+          });
+        },
+      });
+
+      // Before any tick, the writ remains in `new` (the tick relay
+      // is the only evaluation surface). Fire the first tick to
+      // drive it through the scheduler.
+      const allBefore = await fix.clerk.list({ limit: 100 });
+      assert.equal(allBefore.length, 1);
+      assert.equal(allBefore[0]!.phase, 'new');
+
+      await fix.hooks.runTick();
+
+      const allAfter = await fix.clerk.list({ limit: 100 });
+      assert.equal(allAfter.length, 1);
+      const writ = allAfter[0]!;
+      assert.equal(writ.phase, 'open', 'first tick auto-approves the held writ');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'accepted');
+    });
+  });
+
+  // ── 3: evaluate-throw isolation ─────────────────────────────────────
+
+  describe('evaluate throw isolation', () => {
+    it('writes no rows when the scheduler throws — apparatus stays up', async () => {
+      const scheduler: Scheduler = {
+        id: 'kit-a.bad-evaluate',
+        description: 'always throws',
+        async evaluate(): Promise<readonly SchedulerDecision[]> {
+          throw new Error('evaluate deliberately threw');
+        },
+      };
+
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        schedulerKits: [{ pluginId: 'kit-a', value: [scheduler] }],
+        config: { scheduler: 'kit-a.bad-evaluate' },
+      });
+
+      // Post a writ and then fire the tick. evaluate throws → no
+      // rows for the candidate.
+      const writ = await fix.reckoner.petition({
+        source: 'tester.kind',
+        title: 't',
+        body: 'b',
+      });
+
+      const originalWarn = console.warn;
+      const warnings: string[] = [];
+      console.warn = (msg: unknown) => {
+        warnings.push(String(msg));
+      };
+      try {
+        await fix.hooks.runTick();
+      } finally {
+        console.warn = originalWarn;
+      }
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'new');
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 0);
+      assert.ok(
+        warnings.some(
+          (w) => /\[reckoner\] tick:/.test(w) && /evaluate threw/.test(w),
+        ),
+        `expected fail-loud log line; got: ${JSON.stringify(warnings)}`,
+      );
+    });
+  });
+
+  // ── 4: disabled-source mid-flight ──────────────────────────────────
+
+  describe('disabled-source decline', () => {
+    it('emits a source_banned decline row and transitions the writ to cancelled', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_PETITIONER],
+        config: { disabledSources: ['vision-keeper.snapshot'] },
+      });
+
+      // Petition, then disable the source mid-flight by editing the
+      // config (the resolver re-reads on every tick — D20). Equivalent
+      // to seeding the config with the source already banned: the
+      // writ lands in `new` and the next tick declines it.
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      // The writ stays in new before the tick fires.
+      const before = await fix.clerk.show(writ.id);
+      assert.equal(before.phase, 'new');
+
+      await fix.hooks.runTick();
+
+      const after = await fix.clerk.show(writ.id);
+      assert.equal(after.phase, 'cancelled');
+      assert.match(
+        String(after.resolution),
+        /\[reckoner\] declined: source 'vision-keeper\.snapshot' is in reckoner\.disabledSources \(operator action\)\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_banned');
+      assert.equal(rows[0]!.remediationHint, 'vision-keeper.snapshot');
+    });
+  });
+
+  // ── 5: unregistered-strict decline ─────────────────────────────────
+
+  describe('enforceRegistration: true', () => {
+    it('declines unregistered sources with source_unregistered and a structured resolution', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [],
+        config: { enforceRegistration: true },
+      });
+
+      // The petition helper itself fail-loud rejects unregistered
+      // sources under strict registration; to drive the tick decline
+      // path, post the writ + ext via Clerk so the held writ exists
+      // without going through the helper's gate.
+      const writ = await fix.clerk.post({ title: 't', body: 'b' });
+      await fix.clerk.setWritExt(writ.id, 'reckoner', {
+        source: 'unknown.source',
+        priority: {
+          visionRelation: 'vision-neutral',
+          severity: 'minor',
+          scope: 'minor-area',
+          time: { decay: false, deadline: null },
+          domain: [],
+        },
+      });
+
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'cancelled');
+      assert.match(
+        String(reread.resolution),
+        /\[reckoner\] declined: source 'unknown\.source' is not registered \(enforceRegistration: true\)\./,
+      );
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.outcome, 'declined');
+      assert.equal(rows[0]!.declineReason, 'source_unregistered');
+      assert.equal(rows[0]!.remediationHint, 'unknown.source');
+      assert.equal(rows[0]!.source, 'unknown.source');
+    });
+  });
+
+  // ── 6: registered-source approve ──────────────────────────────────
+
+  describe('registered-source approve', () => {
+    it('approves and writes a lean Reckonings row', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_PETITIONER],
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+        priority: {
+          visionRelation: 'vision-violator',
+          severity: 'serious',
+        },
+      });
+
+      await fix.hooks.runTick();
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open');
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      const row = rows[0]!;
+      assert.equal(row.outcome, 'accepted');
+      assert.equal(row.source, 'vision-keeper.snapshot');
+      assert.equal(row.visionRelation, 'vision-violator');
+      assert.equal(row.severity, 'serious');
+      assert.equal(typeof row.consideredAt, 'string');
+      assert.equal(typeof row.writUpdatedAt, 'string');
+      assert.ok(row.id.startsWith('rk-'));
+      // No reason metadata on accepted rows.
+      assert.equal(row.declineReason, undefined);
+      assert.equal(row.deferReason, undefined);
+      // No tickEventId because the test fixture passed `null`.
+      assert.equal(row.tickEventId, undefined);
+    });
+
+    it('stamps tickEventId from a populated triggering event id', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_PETITIONER],
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      await fix.hooks.runTick(fakeTickEvent('e-tick-42'));
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1);
+      assert.equal(rows[0]!.tickEventId, 'e-tick-42');
+    });
+  });
+
+  // ── 7: repeated-tick idempotency ───────────────────────────────────
+
+  describe('repeated-tick idempotency', () => {
+    it('produces exactly one row across two ticks at unchanged updatedAt', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_PETITIONER],
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+
+      await fix.hooks.runTick();
+      await fix.hooks.runTick();
+
+      const rows = await fix.reckoningsBook.find({
+        where: [['writId', '=', writ.id]],
+      });
+      assert.equal(rows.length, 1, 'second tick must dedupe');
+
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open');
+    });
+  });
+
+  // ── 8: type-aware target-phase resolution ──────────────────────────
+
+  describe('target-phase resolution', () => {
+    it('picks `open` for mandate writs', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [VISION_KEEPER_PETITIONER],
+      });
+
+      const writ = await fix.reckoner.petition({
+        source: 'vision-keeper.snapshot',
+        title: 't',
+        body: 'b',
+      });
+      await fix.hooks.runTick();
+      const reread = await fix.clerk.show(writ.id);
+      assert.equal(reread.phase, 'open');
+      assert.equal(reread.type, 'mandate');
+    });
+
+    it('picks the registered active state for a non-mandate type', async () => {
+      const fix = await buildFixture({
+        petitionerKits: [REGISTERED_PETITIONER],
+        writTypes: [
+          {
+            name: 'task',
+            states: [
+              {
+                name: 'new',
+                classification: 'initial',
+                allowedTransitions: ['running', 'cancelled'],
+              },
+              {
+                name: 'running',
+                classification: 'active',
+                allowedTransitions: ['done', 'cancelled'],
+              },
+              {
+                name: 'done',
+                classification: 'terminal',
+                attrs: ['success'],
+                allowedTransitions: [],
+              },
+              {
+                name: 'cancelled',
