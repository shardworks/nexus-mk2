+} from '@shardworks/clerk-apparatus';
+
+import type {
+  ReckoningDoc,
+  ReckonerExt,
+  Scheduler,
+  SchedulerDecision,
+} from './types.ts';
+
+/**
+ * Public name the apparatus registers the tick under and the
+ * kit-contributed standing order targets in its `run:` field. The
+ * dotted form (`reckoner.tick`) matches the apparatus's existing
+ * contributed-id grammar and the originating brief's verbatim
+ * spelling.
+ */
+export const RECKONER_TICK_RELAY_NAME = 'reckoner.tick';
+
+/**
+ * Schedule cadence for the kit-contributed standing order. Hard-
+ * coded `@every 60s`; no operator-configurable knob in this
+ * commission — see the brief's "What NOT To Do" list.
+ */
+export const RECKONER_TICK_SCHEDULE = '@every 60s';
+
