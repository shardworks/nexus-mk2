+   * the candidate set is handed to the scheduler (D7).
+   */
+  alreadyConsidered(
+    book: Book<ReckoningDoc>,
+    writId: string,
+    writUpdatedAt: string,
+  ): Promise<boolean>;
+  /**
+   * Build a Reckonings row from the in-flight consideration state.
+   * Defer-row construction follows the same template as the decline
+   * path (D3), swapping the reason fields.
+   */
+  buildReckoningRow(params: {
+    now: Date;
+    writ: WritDoc;
+    ext: ReckonerExt;
+    outcome: 'accepted' | 'declined' | 'deferred';
+    declineReason?: ReckoningDoc['declineReason'];
+    deferReason?: ReckoningDoc['deferReason'];
+    deferNote?: string;
+    remediationHint?: string;
+    weight?: number;
+    tickEventId?: string;
+  }): ReckoningDoc;
+  /**
+   * Read held petitions out of `clerk/writs`. Mirrors the catch-up
+   * scan shape the apparatus used pre-tick: a direct find against
+   * `phase: 'new'` because Clerk's `list({ phase })` applies an
+   * implicit `type = 'mandate'` filter when phase is supplied
+   * without type. Returns the raw candidate set; the handler applies
+   * the `ext.reckoner` filter and the source/disabled gates.
+   */
+  queryHeldPetitions(): Promise<readonly WritDoc[]>;
+}
+
+// ── Pure handler body ────────────────────────────────────────────────
+
+/**
+ * Pure tick handler body. Exported so unit tests can drive it
+ * directly with a synthetic event id (or `null`) without booting
+ * Clockworks. The relay factory below wraps this with the standard
+ * `relay()` plumbing.
+ */
+export async function runTick(
+  ctx: TickContext,
+  event: GuildEvent | null,
+): Promise<void> {
+  // ── 1. Pre-seal guard (D8) ────────────────────────────────────────
+  const activeScheduler = ctx.getActiveScheduler();
+  if (!activeScheduler) {
+    throw new Error(
+      '[reckoner] tick: activeScheduler not resolved — phase:started has not fired.',
+    );
+  }
+
+  const reckoningsBook = ctx.getReckoningsBook();
+  if (!reckoningsBook) {
+    // Phase ordering safety: the book handle is set inside the
+    // closure's start(). If a tick fires before that completes, we
+    // silently no-op; the next tick (post-Wire) will pick up.
+    return;
+  }
+
+  const clerk = ctx.getClerk();
+
+  // Sample `now` once per tick (D17). Reused for the row id seed and
+  // every consideration's consideredAt within this fire.
+  const now = new Date();
+
+  // tickEventId is present iff a triggering Clockworks timer event id
+  // was supplied (D6). Test paths driving the handler with `null`
+  // omit the field entirely.
+  const tickEventId = event?.id;
+
+  // ── 2. Re-read + validate scheduler config (D17/D18) ─────────────
+  const rawSchedulerConfig = ctx.resolveSchedulerConfig();
+  let validatedConfig: unknown = rawSchedulerConfig;
+  if (typeof activeScheduler.validateConfig === 'function') {
+    try {
+      validatedConfig = activeScheduler.validateConfig(rawSchedulerConfig);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" validateConfig threw — skipping tick. ${msg}`,
+      );
+      return;
+    }
+  }
+
+  // ── 3. Query held petitions ──────────────────────────────────────
+  const candidates = await ctx.queryHeldPetitions();
+  const config = ctx.resolveConfig();
+
+  // ── 4. Source / disabled gates (inline, pre-scheduler) ───────────
+  const survivors: Array<{ writ: WritDoc; ext: ReckonerExt }> = [];
+  for (const writ of candidates) {
+    const ext = writ.ext?.[RECKONER_PLUGIN_ID] as ReckonerExt | undefined;
+    if (!ext) continue;
+    if (typeof ext.source !== 'string' || ext.source.length === 0) continue;
+
+    const gate = evaluateSourceGate(ext.source, config, ctx.isSourceRegistered);
+    if (gate.kind === 'declined') {
+      // Idempotency lookup before writing the decline row — a tick
+      // re-firing after a partial earlier dispatch must not double-
+      // write.
+      if (await ctx.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+        continue;
+      }
+      try {
+        await clerk.transition(writ.id, 'cancelled' as WritPhase, {
+          resolution: gate.resolution,
+        });
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (source-gate decline): ${msg}`,
+        );
+        continue;
+      }
+      const row = ctx.buildReckoningRow({
+        now,
+        writ,
+        ext,
+        outcome: 'declined',
+        declineReason: gate.declineReason,
+        remediationHint: gate.remediationHint,
+        ...(tickEventId !== undefined ? { tickEventId } : {}),
+      });
+      try {
+        await reckoningsBook.put(row);
+      } catch (err) {
+        const msg = err instanceof Error ? err.message : String(err);
+        // eslint-disable-next-line no-console
+        console.warn(
+          `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (source-gate decline): ${msg}`,
+        );
+      }
+      continue;
+    }
+
+    // ── 5. Dedupe before SchedulerInput (D7) ────────────────────────
+    if (await ctx.alreadyConsidered(reckoningsBook, writ.id, writ.updatedAt)) {
+      continue;
+    }
+
+    survivors.push({ writ, ext });
+  }
+
+  // ── 6. Empty candidate set → early return (D10) ──────────────────
+  if (survivors.length === 0) {
+    return;
+  }
+
+  // ── 7. Evaluate ──────────────────────────────────────────────────
+  let decisions: readonly SchedulerDecision[];
+  try {
+    const result = await activeScheduler.evaluate({
+      candidates: survivors.map((s) => s.writ),
+      capacity: {},
+      now,
+      config: validatedConfig,
+    });
+    decisions = result;
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate threw — skipping tick. ${msg}`,
+    );
+    return;
+  }
+
+  if (!Array.isArray(decisions)) {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${activeScheduler.id}" evaluate did not return an array — skipping tick.`,
+    );
+    return;
+  }
+
+  // ── 8. Decision validation (D9) ──────────────────────────────────
+  const candidateIds = new Set<string>(survivors.map((s) => s.writ.id));
+  const inScope: SchedulerDecision[] = [];
+  for (const decision of decisions) {
+    if (
+      decision === null ||
+      typeof decision !== 'object' ||
+      typeof decision.writId !== 'string' ||
+      decision.writId.length === 0
+    ) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a malformed decision (missing writId) — ignoring.`,
+      );
+      continue;
+    }
+    if (!candidateIds.has(decision.writId)) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned a decision for writ "${decision.writId}" which was not in the candidate set — ignoring.`,
+      );
+      continue;
+    }
+    inScope.push(decision);
+  }
+
+  const grouped = new Map<string, SchedulerDecision[]>();
+  for (const decision of inScope) {
+    const list = grouped.get(decision.writId) ?? [];
+    list.push(decision);
+    grouped.set(decision.writId, list);
+  }
+  for (const [writId, list] of grouped) {
+    if (list.length > 1) {
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: scheduler "${activeScheduler.id}" returned ${list.length} decisions for writ "${writId}" — refusing to apply any decisions in this tick. Schedulers must emit at most one decision per candidate.`,
+      );
+      return;
+    }
+  }
+
+  // ── 9. Apply decisions ───────────────────────────────────────────
+  for (const survivor of survivors) {
+    const decision = grouped.get(survivor.writ.id)?.[0];
+    if (!decision) {
+      // No decision for this candidate — defer-equivalent silence.
+      // Per D3 a real `defer` outcome writes a row; a missing
+      // decision (scheduler chose not to weigh in) writes nothing.
+      continue;
+    }
+    await applyDecision({
+      ctx,
+      reckoningsBook,
+      clerk,
+      now,
+      tickEventId,
+      writ: survivor.writ,
+      ext: survivor.ext,
+      decision,
+      schedulerId: activeScheduler.id,
+    });
+  }
+}
+
+// ── Source / disabled gate evaluation ────────────────────────────────
+
+/**
+ * Decide whether a writ clears the source / disabled / unregistered-
+ * strict gates before reaching the scheduler. Pulled out of `runTick`
+ * so the gate semantics are visible side-by-side and tests can
+ * exercise the policy mapping without the surrounding I/O.
+ *
+ * Symmetric decline rows are emitted for two failure modes (D2):
+ *
+ *   - **`source_banned`** — the operator added the source to
+ *     `reckoner.disabledSources`. The remediation hint carries the
+ *     source name; the resolution string names the operator action
+ *     so a finder-by-grep on `clerk/writs.resolution` lands at the
+ *     guild config drift.
+ *   - **`source_unregistered`** — the source is not in the kit-static
+ *     petitioner registry and `enforceRegistration: true`. Preserves
+ *     the existing resolution-string format byte-for-byte; the
+ *     decline path matches the per-call CDC flow that this tick
+ *     replaces.
+ */
+function evaluateSourceGate(
+  source: string,
+  config: { enforceRegistration: boolean; disabledSources: string[] },
+  isSourceRegistered: (source: string) => boolean,
+): GateOutcome {
+  if (config.disabledSources.includes(source)) {
+    return {
+      kind: 'declined',
+      declineReason: 'source_banned',
+      remediationHint: source,
+      resolution:
+        `[reckoner] declined: source '${source}' is in reckoner.disabledSources (operator action).`,
+    };
+  }
+  if (!isSourceRegistered(source) && config.enforceRegistration) {
+    return {
+      kind: 'declined',
+      declineReason: 'source_unregistered',
+      remediationHint: source,
+      resolution:
+        `[reckoner] declined: source '${source}' is not registered (enforceRegistration: true).`,
+    };
+  }
+  return { kind: 'kept' };
+}
+
+// ── Decision application ─────────────────────────────────────────────
+
+interface ApplyDecisionInputs {
+  ctx: TickContext;
+  reckoningsBook: Book<ReckoningDoc>;
+  clerk: ClerkApi;
+  now: Date;
+  tickEventId: string | undefined;
+  writ: WritDoc;
+  ext: ReckonerExt;
+  decision: SchedulerDecision;
+  schedulerId: string;
+}
+
+/**
+ * Apply a single scheduler decision: drive the transition (when the
+ * outcome calls for one) and append the corresponding Reckonings row.
+ * Each persistence step is wrapped in its own try/catch so a single
+ * failed write does not abort the rest of the tick.
+ */
+async function applyDecision(inputs: ApplyDecisionInputs): Promise<void> {
+  const { ctx, reckoningsBook, clerk, now, tickEventId, writ, ext, decision, schedulerId } =
+    inputs;
+
+  const outcome = decision.outcome;
+  if (outcome !== 'approve' && outcome !== 'decline' && outcome !== 'defer') {
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: scheduler "${schedulerId}" returned an unknown outcome "${String(outcome)}" for writ "${writ.id}" — ignoring.`,
+    );
+    return;
+  }
+
+  if (outcome === 'defer') {
+    // No transition — the writ stays in `new`. Per D3 the row carries
+    // `deferReason: 'other'` plus the decision's `reason` in
+    // `deferNote`. Other defer-metadata fields (deferUntil,
+    // deferSignal, deferCount, …) wait for a real consumer.
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'deferred',
+      deferReason: 'other',
+      deferNote: decision.reason,
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (defer): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  if (outcome === 'decline') {
+    const resolution = decision.reason;
+    try {
+      await clerk.transition(writ.id, 'cancelled' as WritPhase, { resolution });
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to transition writ "${writ.id}" to cancelled (scheduler decline): ${msg}`,
+      );
+      return;
+    }
+    const row = ctx.buildReckoningRow({
+      now,
+      writ,
+      ext,
+      outcome: 'declined',
+      declineReason: 'other',
+      remediationHint: decision.reason,
+      ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+      ...(tickEventId !== undefined ? { tickEventId } : {}),
+    });
+    try {
+      await reckoningsBook.put(row);
+    } catch (err) {
+      const msg = err instanceof Error ? err.message : String(err);
+      // eslint-disable-next-line no-console
+      console.warn(
+        `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler decline): ${msg}`,
+      );
+    }
+    return;
+  }
+
+  // approve.
+  let target: string;
+  try {
+    target = ctx.resolveActiveTargetPhase(writ);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: writ "${writ.id}" has no resolvable active target — leaving in new. ${msg}`,
+    );
+    return;
+  }
+
+  try {
+    await clerk.transition(writ.id, target as WritPhase, {});
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to transition writ "${writ.id}" to "${target}" (scheduler approve): ${msg}`,
+    );
+    return;
+  }
+
+  const row = ctx.buildReckoningRow({
+    now,
+    writ,
+    ext,
+    outcome: 'accepted',
+    ...(decision.weight !== undefined ? { weight: decision.weight } : {}),
+    ...(tickEventId !== undefined ? { tickEventId } : {}),
+  });
+  try {
+    await reckoningsBook.put(row);
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    // eslint-disable-next-line no-console
+    console.warn(
+      `[reckoner] tick: failed to persist Reckonings row for writ "${writ.id}" (scheduler approve): ${msg}`,
+    );
+  }
+}
+
+// ── Relay factory ────────────────────────────────────────────────────
+
+/**
+ * Build the `reckoner.tick` `RelayDefinition`. Exported so the
+ * apparatus boot path can wire it into `supportKit.relays` and so
+ * unit tests can drive the relay directly without booting Clockworks.
+ */
+export function createTickRelay(ctx: TickContext): RelayDefinition {
+  return relay({
+    name: RECKONER_TICK_RELAY_NAME,
+    description:
+      'Periodic Reckoner tick — evaluates every held petition through ' +
+      'the configured scheduler in one batch.',
+    handler: async (event) => {
+      await runTick(ctx, event);
+    },
+  });
+}
