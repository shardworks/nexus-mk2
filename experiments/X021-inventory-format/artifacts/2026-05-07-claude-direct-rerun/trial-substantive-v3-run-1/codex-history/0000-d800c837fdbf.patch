+/**
+ * `reckoner.tick` — periodic scheduler-evaluation relay.
+ *
+ * Wired into the apparatus's `supportKit.relays` and paired with a kit-
+ * contributed standing order at `@every 60s` so every guild that
+ * installs the Reckoner alongside the Clockworks evaluates its held
+ * petitions through the configured scheduler once per minute. The
+ * standing order has no `id` field per the additive-merge contract;
+ * operators can append their own standing orders but cannot disable
+ * or override this one.
+ *
+ * On fire the handler:
+ *
+ *   1. Throws fail-loud when `activeScheduler` has not yet resolved
+ *      (D8). Production never trips this — the apparatus's
+ *      `phase:started` handler runs before the daemon's first
+ *      schedule pass; test fixtures that omit phase:started get a
+ *      deterministic loud signal naming the absent contract.
+ *   2. Re-reads and validates `reckoner.schedulerConfig` per fire
+ *      (D17). A `validateConfig` throw is logged fail-loud and the
+ *      tick is skipped — no rows, no transitions.
+ *   3. Queries held petitions using the same find-by-phase shape
+ *      today's evaluation surface uses, then filters to writs
+ *      carrying `ext.reckoner`.
+ *   4. Applies the disabled-source / unregistered-strict source
+ *      gates inline. A failing writ produces a `declined` Reckonings
+ *      row and a transition to its cancelled target phase before the
+ *      candidate set is handed to the scheduler.
+ *   5. Filters the surviving candidates against the
+ *      `(writId, writUpdatedAt)` dedupe lookup (D7) — already-
+ *      considered writs never reach the scheduler.
+ *   6. Early-returns when the candidate set is empty (D10) — no
+ *      rows, no errors, no scheduler call.
+ *   7. Builds one `SchedulerInput { candidates, capacity, now,
+ *      config }` for the whole survivors set (the v0 capacity stub
+ *      stays empty) and calls `evaluate` inside a try/catch. A throw
+ *      logs fail-loud and skips the entire tick.
+ *   8. Filters-and-warns on stranger `writId`s (D9). Fail-loud-skips
+ *      the entire tick on multi-decision-per-writ.
+ *   9. Applies each decision: approve → transition to active target
+ *      via `resolveActiveTargetPhase`; decline → transition to
+ *      cancelled with the decision's reason; defer → no transition.
+ *      One Reckonings row per writ considered, stamped with
+ *      `tickEventId` from the triggering `clockworks.timer` event id
+ *      when present (D6) and absent otherwise.
+ *
+ * Source-file layout follows the stdlib-relay precedent
+ * (`packages/plugins/clockworks/src/summon-relay.ts`,
+ * `packages/plugins/vision-keeper/src/decline-relay.ts`): the relay
+ * factory and a pure handler-body helper live in this sibling file
+ * alongside the apparatus core. The pure helper accepts a dependency-
+ * injection context the closure constructs and passes in, so unit
+ * tests can drive the handler directly without booting Clockworks.
+ *
+ * See: docs/architecture/apparatus/reckoner.md
+ *      docs/architecture/reckonings-book.md
+ */
+
+import type { GuildEvent, RelayDefinition } from '@shardworks/clockworks-apparatus';
+import { relay } from '@shardworks/clockworks-apparatus';
+import type { Book } from '@shardworks/stacks-apparatus';
+import type {
+  ClerkApi,
