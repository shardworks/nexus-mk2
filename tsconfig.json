{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "verbatimModuleSyntax": true,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "#*": ["./src/*"]
    }
  },
  "include": ["src"]
}
