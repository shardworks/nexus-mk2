  },
  "devDependencies": {
    "@types/node": "25.5.0"
  },
  "files": [
    "dist",
    "nexus-engine.json"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
