{
  "name": "@shardworks/engine-mcp-server",
  "version": "0.1.6",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/shardworks/nexus-mk2",
    "directory": "packages/engine-mcp-server"
  },
  "description": "MCP server engine — serves guild implements as MCP tools for anima sessions",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
