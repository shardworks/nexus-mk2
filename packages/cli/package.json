{
  "name": "@shardworks/nexus",
  "version": "0.1.8",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/shardworks/nexus-mk2",
    "directory": "packages/cli"
  },
  "description": "Nexus Mk 2.1 — CLI for the guild system",
  "type": "module",
  "bin": {
    "nexus": "./src/cli.ts",
    "nsg": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./commands/*": "./src/commands/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "cli": "node --disable-warning=ExperimentalWarning --experimental-transform-types src/cli.ts",
    "test": "node --disable-warning=ExperimentalWarning --experimental-transform-types --test 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shardworks/nexus-core": "workspace:*",
    "@shardworks/engine-ledger-migrate": "workspace:*",
    "@shardworks/engine-manifest": "workspace:*",
    "@shardworks/implement-dispatch": "workspace:*",
    "@shardworks/implement-install-tool": "workspace:*",
    "@shardworks/implement-instantiate": "workspace:*",
    "@shardworks/implement-nexus-version": "workspace:*",
    "@shardworks/implement-remove-tool": "workspace:*",
    "@shardworks/engine-mcp-server": "workspace:*",
    "@shardworks/engine-worktree-setup": "workspace:*",
    "better-sqlite3": "12.8.0",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "14.0.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.5.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./commands/*": {
        "types": "./dist/commands/*.d.ts",
        "import": "./dist/commands/*.js"
      }
    },
    "bin": {
      "nexus": "./dist/cli.js",
      "nsg": "./dist/cli.js"
    }
  }
}
